<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LMS Nội Bộ Doanh Nghiệp</title>
  <!-- Google Fonts: Inter — load sớm để không bị FOUT -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
  <link rel="stylesheet" href="/css/style.css?v=1.5">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <!-- Strip gradient-text khỏi heading ngay khi DOM load — không chờ stylesheet -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('h1, h2, h3').forEach(function (el) {
        var s = el.style;
        if (s.webkitTextFillColor === 'transparent' || s.getPropertyValue('-webkit-text-fill-color') === 'transparent') {
          s.background = 'none';
          s.webkitBackgroundClip = 'unset';
          s.webkitTextFillColor = '';
          el.style.removeProperty('-webkit-text-fill-color');
          el.style.removeProperty('-webkit-background-clip');
          el.style.removeProperty('background');
        }
      });
    });
  </script>
  <style>
    /* Real-time Notification Center Styles */
    .notification-wrapper {
      transition: all 0.3s ease;
    }
    .sidebar-collapsed .notification-wrapper {
      padding: 0.5rem !important;
      display: flex;
      justify-content: center;
    }
    .sidebar-collapsed .notification-wrapper #notification-bell-btn {
      width: 40px !important;
      height: 40px !important;
      padding: 0 !important;
      justify-content: center !important;
      position: relative;
    }
    .sidebar-collapsed .notification-wrapper .nav-text {
      display: none;
    }
    .sidebar-collapsed .notification-wrapper #notification-badge {
      position: absolute;
      top: 4px;
      right: 4px;
      width: 14px;
      height: 14px;
      font-size: 0.6rem;
    }
    .sidebar-collapsed .notification-wrapper #notification-dropdown {
      left: 5rem !important;
      bottom: 1rem !important;
      width: 260px !important;
    }
  </style>
</head>

<body>
  <script>
    if (localStorage.getItem('main-sidebar-collapsed') === 'true') {
      document.body.classList.add('sidebar-collapsed');
    }
  </script>

  <% if (user && user.isImpersonating) { %>
    <!-- Banner cảnh báo chế độ giả lập tài khoản nhân viên -->
    <div class="impersonation-banner">
      <div>
        <i class="fa-solid fa-triangle-exclamation"></i>
        <span>Bạn đang đóng vai tài khoản của nhân viên <strong>
            <%= user.username %>
          </strong> (Tài khoản gốc của bạn: <strong>
            <%= user.originalUsername %>
          </strong>)</span>
      </div>
      <a href="/auth/impersonate/stop">
        <i class="fa-solid fa-arrow-right-from-bracket"></i> Thoát giả lập
      </a>
    </div>
    <% } %>

      <div class="app-container">
        <!-- Sidebar mờ kính bên trái -->
        <aside class="sidebar">
          <!-- Nút thu nhỏ/mở rộng sidebar -->
          <button class="sidebar-toggle-btn" id="sidebar-toggle-btn" onclick="toggleMainSidebar()" title="Thu gọn/Mở rộng menu">
            <i class="fa-solid fa-angle-left"></i>
          </button>

          <div class="logo-container">
            <i class="fa-solid fa-graduation-cap fa-2x" style="color: #6366f1;"></i>
            <span class="logo-text">CompanyLMS</span>
          </div>

          <nav style="flex-grow: 1;">
            <ul class="nav-list">
              <% if (user) { %>
                <% const perms=user.permissions || []; const studentPermissions=['PATH_VIEW', 'COURSE_ENROLL_REQUEST'
                  , 'HISTORY_VIEW' , 'PROGRESS_TRACK' ]; const hasStudentAccess=perms.some(p=>
                  studentPermissions.includes(p));
                  %>

                  <!-- ===== TRANG CHỦ TỔNG QUAN ===== -->
                  <li class="nav-item">
                    <a href="/dashboard"><i class="fa-solid fa-chart-simple"></i> <span>Trang chủ</span></a>
                  </li>

                  <!-- ===== NHÓM: HỌC VIÊN ===== -->
                  <% if (hasStudentAccess) { %>
                    <li class="nav-section-label">
                      <span>Học tập</span>
                    </li>


                        <% if (perms.includes('COURSE_ENROLL_REQUEST')) { %>
                          <li class="nav-item">
                            <a href="/courses"><i class="fa-solid fa-book"></i> <span>Kho khóa học</span></a>
                          </li>
                          <% } %>

                            <% if (perms.includes('PROGRESS_TRACK')) { %>
                              <li class="nav-item">
                                <a href="/my-deadlines"><i class="fa-solid fa-calendar-days"></i> <span>Lịch học & Deadline</span></a>
                              </li>
                              <% } %>
                                <!-- Bài kiểm tra doanh nghiệp (hiển thị cho học viên) -->
                                <li class="nav-item">
                                  <a href="/assessments"><i class="fa-solid fa-clipboard-list"></i> <span>Bài Kiểm Tra</span></a>
                                </li>
                                <% } %>

                                  <!-- ===== NHÓM: TRƯỞNG PHÒNG ===== -->
                                  <% if (user.isManager) { %>
                                    <li class="nav-section-label" style="margin-top: 0.75rem;">
                                      <span><i class="fa-solid fa-user-tie"
                                          style="margin-right: 0.4rem; opacity: 0.6; font-size: 0.65rem;"></i>Quản lý nhóm</span>
                                    </li>
                                    <li class="nav-item">
                                      <a href="/my-groups"><i class="fa-solid fa-users-viewfinder"></i> <span>Nhóm của tôi</span></a>
                                    </li>
                                    <% } %>

                                      <% 
                                        // Nhóm quyền: Nội dung & Đào tạo
                                        const hasContentAccess = perms.includes('COURSE_VIEW') ||
                                          perms.includes('QUIZ_BANK_VIEW') || 
                                          perms.includes('LESSON_CREATE') ||
                                          perms.includes('LESSON_MANAGE') || 
                                          perms.includes('QUIZ_GRADE') ||
                                          perms.includes('ENROLL_APPROVE') ||
                                          perms.includes('ENROLL_ASSIGN'); 

                                        // Nhóm quyền: Nhân sự & Tổ chức
                                        const hasHRAccess = perms.includes('USER_VIEW') || 
                                          perms.includes('USER_MANAGE') ||
                                          perms.includes('DEPARTMENT_MANAGE'); 

                                        // Nhóm quyền: Phân tích & Báo cáo
                                        const hasAnalyticsAccess = perms.includes('REPORT_VIEW') ||
                                          perms.includes('REPORT_EXPORT'); 

                                        // Nhóm quyền: Hệ thống & Bảo mật
                                        const hasSystemAccess = perms.includes('ROLE_MANAGE') ||
                                          perms.includes('AUDIT_LOG_VIEW'); 

                                        // Kiểm tra xem tài khoản có bất kỳ quyền quản trị/quản lý nào hay không
                                        const hasAnyAdminAccess = hasContentAccess || hasHRAccess || hasAnalyticsAccess || hasSystemAccess; 

                                        // Quyền truy cập tổng quan trang quản lý (tính toán dựa trên việc sở hữu ít nhất một quyền quản trị)
                                        const hasGeneralAdminAccess = hasAnyAdminAccess; 
                                      %>

                                        <% if (hasGeneralAdminAccess) { %>
                                          <!-- ===== DASHBOARD QUẢN TRỊ ===== -->
                                          <li class="nav-divider"></li>
                                          <% } %>

                                            <!-- ===== NHÓM: NỘI DUNG & ĐÀO TẠO ===== -->
                                            <% if (hasContentAccess) { %>
                                              <li class="nav-section-label" style="margin-top: 0.75rem;">
                                                <span><i class="fa-solid fa-graduation-cap"
                                                    style="margin-right: 0.4rem; opacity: 0.6; font-size: 0.65rem;"></i>Nội dung & Đào tạo</span>
                                              </li>

                                              <% if (perms.includes('COURSE_VIEW')) { %>
                                                <li class="nav-item">
                                                  <a href="/course-management"><i class="fa-solid fa-folder-open"></i> <span>Quản lý khóa học</span></a>
                                                </li>
                                                <% } %>

                                                  <% if (perms.includes('LESSON_CREATE') ||
                                                    perms.includes('LESSON_MANAGE')) { %>
                                                    <li class="nav-item">
                                                      <a href="/lessons"><i class="fa-solid fa-file-video"></i> <span>Bài học & Nội dung</span></a>
                                                    </li>
                                                    <% } %>

                                                      <% if (perms.includes('QUIZ_BANK_VIEW')) { %>
                                                        <li class="nav-item">
                                                          <a href="/admin/assessments"><i
                                                              class="fa-solid fa-clipboard-check"></i> <span>Kiểm tra Doanh nghiệp</span></a>
                                                        </li>
                                                        <% } %>

                                                          <% if (perms.includes('QUIZ_GRADE')) { %>
                                                            <li class="nav-item">
                                                              <a href="/grade"><i
                                                                  class="fa-solid fa-graduation-cap"></i> <span>Kết quả thi</span></a>
                                                            </li>
                                                            <% } %>



                                                                  <% if (perms.includes('ENROLL_APPROVE')) { %>
                                                                    <li class="nav-item">
                                                                      <a href="/approvals"><i
                                                                          class="fa-solid fa-user-check"></i> <span>Duyệt đăng ký</span></a>
                                                                    </li>
                                                                    <% } %>
                                                                      <% } %>

                                                                        <!-- ===== NHÓM: NHÂN SỰ & PHÒNG BAN ===== -->
                                                                        <% if (hasHRAccess) { %>
                                                                          <li class="nav-section-label"
                                                                            style="margin-top: 0.75rem;">
                                                                            <span><i class="fa-solid fa-people-group"
                                                                                style="margin-right: 0.4rem; opacity: 0.6; font-size: 0.65rem;"></i>Nhân sự & Tổ chức</span>
                                                                          </li>

                                                                          <% if (perms.includes('USER_VIEW') ||
                                                                            perms.includes('USER_MANAGE')) { %>
                                                                            <li class="nav-item">
                                                                              <a href="/users"><i
                                                                                  class="fa-solid fa-users-gear"></i> <span>Quản lý nhân sự</span></a>
                                                                            </li>
                                                                            <% } %>

                                                                              <% if
                                                                                (perms.includes('DEPARTMENT_MANAGE')) {
                                                                                %>
                                                                                <li class="nav-item">
                                                                                  <a href="/departments"><i
                                                                                      class="fa-solid fa-building"></i> <span>Phòng ban</span></a>
                                                                                </li>
                                                                                <% } %>
                                                                                  <% } %>



                                                                                                <!-- ===== NHÓM: HỆ THỐNG & BẢO MẬT ===== -->
                                                                                                <% if (hasSystemAccess)
                                                                                                  { %>
                                                                                                  <li
                                                                                                    class="nav-section-label"
                                                                                                    style="margin-top: 0.75rem;">
                                                                                                    <span><i
                                                                                                        class="fa-solid fa-server"
                                                                                                        style="margin-right: 0.4rem; opacity: 0.6; font-size: 0.65rem;"></i>Hệ thống & Bảo mật</span>
                                                                                                  </li>

                                                                                                  <% if
                                                                                                    (perms.includes('ROLE_MANAGE'))
                                                                                                    { %>
                                                                                                    <li
                                                                                                      class="nav-item">
                                                                                                      <a
                                                                                                        href="/permissions"><i
                                                                                                          class="fa-solid fa-shield-halved"></i> <span>Cấu hình phân quyền</span></a>
                                                                                                    </li>
                                                                                                    <% } %>

                                                                                                      <% if
                                                                                                        (perms.includes('AUDIT_LOG_VIEW'))
                                                                                                        { %>
                                                                                                        <li
                                                                                                          class="nav-item">
                                                                                                          <a
                                                                                                            href="/audit"><i
                                                                                                              class="fa-solid fa-clock-rotate-left"></i> <span>Nhật ký hệ thống</span></a>
                                                                                                        </li>
                                                                                                        <% } %>


                                                                                                          <% } %>

                                                                                                            <!-- ===== FOOTER: CÀI ĐẶT ===== -->
                                                                                                            <li
                                                                                                              class="nav-divider"
                                                                                                              style="margin-top: 1rem;">
                                                                                                            </li>
                                                                                                            <li
                                                                                                              class="nav-item">
                                                                                                              <a
                                                                                                                href="/settings"><i
                                                                                                                  class="fa-solid fa-gear"></i> <span>Cài đặt tài khoản</span></a>
                                                                                                            </li>

                                                                                                            <% } else {
                                                                                                              %>
                                                                                                              <li
                                                                                                                class="nav-item">
                                                                                                                <a
                                                                                                                  href="/auth/login"><i
                                                                                                                    class="fa-solid fa-right-to-bracket"></i> <span>Đăng nhập</span></a>
                                                                                                              </li>
                                                                                                              <li
                                                                                                                class="nav-item">
                                                                                                                <a
                                                                                                                  href="/auth/register"><i
                                                                                                                    class="fa-solid fa-user-plus"></i> <span>Đăng ký nhân viên</span></a>
                                                                                                              </li>
                                                                                                              <% } %>
            </ul>
          </nav>

          <% if (user) { %>
            <!-- Khối thông báo thời gian thực -->
            <div class="notification-wrapper" style="padding: 0.5rem 1rem; border-top: 1px solid var(--border-light); position: relative; margin-bottom: 0.5rem;">
              <button id="notification-bell-btn" style="background: none; border: none; color: var(--text-muted); cursor: pointer; display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 0.5rem; border-radius: 8px; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.05)'; this.style.color='#fff';" onmouseout="this.style.background='none'; this.style.color='var(--text-muted)';">
                <span style="font-size: 0.85rem; font-weight: 500; display: inline-flex; align-items: center; gap: 0.6rem;">
                  <i class="fa-solid fa-bell"></i> <span class="nav-text">Thông báo</span>
                </span>
                <span id="notification-badge" class="badge-count" style="display: none; background: #ef4444; color: white; border-radius: 50%; font-size: 0.7rem; width: 16px; height: 16px; align-items: center; justify-content: center; font-weight: bold;">0</span>
              </button>
              
              <!-- Dropdown chứa danh sách thông báo -->
              <div id="notification-dropdown" class="glass-card" style="display: none; position: absolute; bottom: 100%; left: 1rem; right: 1rem; margin-bottom: 0.5rem; width: 280px; max-height: 350px; overflow-y: auto; z-index: 3100; padding: 0.75rem; border-color: var(--border-glow); background: rgba(15, 23, 42, 0.98); box-shadow: 0 10px 40px rgba(0,0,0,0.5);">
                <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
                  <span style="font-size: 0.85rem; font-weight: 700; color: var(--text-main);">Thông báo</span>
                  <button onclick="clearNotifications(event)" style="background: none; border: none; color: #ef4444; font-size: 0.7rem; cursor: pointer;">Xóa hết</button>
                </div>
                <div id="notification-list" class="custom-scroll" style="display: flex; flex-direction: column; gap: 0.4rem; max-height: 250px; overflow-y: auto;">
                  <!-- Javascript tự động render danh sách thông báo tại đây -->
                </div>
              </div>
            </div>

            <!-- Card thông tin cá nhân tích hợp Đăng xuất ở dưới cùng Sidebar -->
            <div class="sb-profile-card">
              <div class="sb-avatar">
                <%= user.username.charAt(0).toUpperCase() %>
              </div>
              <div class="sb-profile-meta">
                <span class="sb-profile-name" title="<%= user.username %>">
                  <%= user.username %>
                </span>
                <span class="sb-profile-role" title="<%= user.roleName %>">
                  <%= user.roleName %>
                </span>
              </div>
              <a href="/auth/logout" class="sb-logout-btn" title="Đăng xuất">
                <i class="fa-solid fa-arrow-right-from-bracket"></i>
              </a>
            </div>
            <% } %>

              <script>
                // Hàm toggle trạng thái đóng/mở sidebar lưu vào localStorage
                function toggleMainSidebar() {
                  const isCollapsed = document.body.classList.toggle('sidebar-collapsed');
                  localStorage.setItem('main-sidebar-collapsed', isCollapsed ? 'true' : 'false');
                }

                document.addEventListener('DOMContentLoaded', () => {
                  // 1. Tự động xác định link active dựa trên URL hiện tại
                  const currentPath = window.location.pathname;
                  const navLinks = document.querySelectorAll('.nav-item a');

                  let activeLink = null;
                  let maxMatchLen = -1;

                  navLinks.forEach(link => {
                    const href = link.getAttribute('href');
                    if (href) {
                      if (currentPath === href) {
                        activeLink = link;
                        maxMatchLen = href.length;
                      } else if (href !== '/dashboard' && href !== '/management' && currentPath.startsWith(href) && href.length > maxMatchLen) {
                        activeLink = link;
                        maxMatchLen = href.length;
                      }
                    }
                  });

                  if (activeLink) {
                    navLinks.forEach(link => link.parentElement.classList.remove('active'));
                    activeLink.parentElement.classList.add('active');
                  }

                  // 2. Giữ nguyên vị trí cuộn của Sidebar tránh bị reset khi tải lại trang
                  const sidebar = document.querySelector('.sidebar nav');
                  if (sidebar) {
                    // Khôi phục vị trí cuộn
                    const savedScroll = localStorage.getItem('sidebar-scroll-position');
                    if (savedScroll) {
                      sidebar.scrollTop = parseInt(savedScroll, 10);
                    }

                    // Lưu vị trí cuộn khi người dùng cuộn sidebar
                    sidebar.addEventListener('scroll', () => {
                      localStorage.setItem('sidebar-scroll-position', sidebar.scrollTop);
                    });

                    // Lưu trước khi unload trang để chắc chắn vị trí cuối cùng được ghi nhận
                    window.addEventListener('beforeunload', () => {
                      localStorage.setItem('sidebar-scroll-position', sidebar.scrollTop);
                    });
                  }
                });
              </script>
        </aside>


        <main class="main-content">