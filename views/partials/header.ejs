<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LMS Nội Bộ Doanh Nghiệp</title>
  <link rel="stylesheet" href="/css/style.css">
  <!-- Thêm font awesome để dùng icon đơn giản -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

  <% if (user && user.isImpersonating) { %>
    <!-- Banner cảnh báo chế độ giả lập tài khoản nhân viên -->
    <div class="impersonation-banner">
      <div>
        <i class="fa-solid fa-triangle-exclamation"></i>
        <span>Bạn đang đóng vai tài khoản của nhân viên <strong><%= user.username %></strong> (Tài khoản gốc của bạn: <strong><%= user.originalUsername %></strong>)</span>
      </div>
      <a href="/auth/impersonate/stop">
        <i class="fa-solid fa-arrow-right-from-bracket"></i> Thoát giả lập
      </a>
    </div>
  <% } %>

  <div class="app-container">
    <!-- Sidebar mờ kính bên trái -->
    <aside class="sidebar">
      <div class="logo-container">
        <i class="fa-solid fa-graduation-cap fa-2x" style="color: #6366f1;"></i>
        <span class="logo-text">CompanyLMS</span>
      </div>

      <% if (user) { %>
        <!-- Card thông tin cá nhân ở đầu Sidebar giống mockup -->
        <div class="user-profile-card" style="padding: 0.85rem 1rem; margin: 0 1rem 1rem 1rem; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-light); border-radius: 12px; display: flex; flex-direction: column; gap: 0.4rem;">
          <div style="font-weight: 700; color: #f1f5f9; display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem;">
            <i class="fa-solid fa-user-astronaut" style="color: #818cf8; font-size: 0.95rem;"></i>
            <span><%= user.username %></span>
          </div>
          <div style="font-size: 0.75rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.5rem;">
            <i class="fa-solid fa-tag" style="color: #fb7185; font-size: 0.8rem;"></i>
            <span><%= user.roleName %></span>
          </div>
        </div>
      <% } %>

      <nav style="flex-grow: 1;">
        <ul class="nav-list">
          <% if (user) { %>
            <%
            const perms = user.permissions || [];
            %>

            <!-- ===== NHÓM: HỌC VIÊN ===== -->
            <li class="nav-section-label">
              <span>Học tập</span>
            </li>

            <li class="nav-item">
              <a href="/dashboard"><i class="fa-solid fa-chart-simple"></i> Trang chủ (Dashboard)</a>
            </li>

            <% if (perms.includes('PATH_VIEW')) { %>
              <li class="nav-item">
                <a href="/my-paths"><i class="fa-solid fa-route"></i> Lộ trình của tôi</a>
              </li>
            <% } %>
            <% if (perms.includes('COURSE_ENROLL_REQUEST')) { %>
              <li class="nav-item">
                <a href="/courses"><i class="fa-solid fa-book"></i> Kho khóa học</a>
              </li>
            <% } %>
            <% if (perms.includes('HISTORY_VIEW')) { %>
              <li class="nav-item">
                <a href="/my-history"><i class="fa-solid fa-award"></i> Lịch sử & Thành tựu</a>
              </li>
            <% } %>
            <% if (perms.includes('PROGRESS_TRACK')) { %>
              <li class="nav-item">
                <a href="/my-deadlines"><i class="fa-solid fa-calendar-days"></i> Lịch học & Deadline</a>
              </li>
            <% } %>

            <%
            // Nhóm: Nội dung & Đào tạo
            const hasContentAccess = perms.includes('COURSE_VIEW') || perms.includes('QUIZ_BANK_VIEW') || perms.includes('LESSON_CREATE') || perms.includes('LESSON_MANAGE') || perms.includes('QUIZ_GRADE') || perms.includes('PATH_MANAGE') || perms.includes('ENROLL_APPROVE') || perms.includes('ENROLL_ASSIGN');
            
            // Nhóm: Nhân sự
            const hasHRAccess = perms.includes('USER_VIEW') || perms.includes('USER_MANAGE') || perms.includes('DEPARTMENT_MANAGE');
            
            // Nhóm: Phân tích
            const hasAnalyticsAccess = perms.includes('REPORT_VIEW') || perms.includes('REPORT_EXPORT');
            
            // Nhóm: Hệ thống
            const hasSystemAccess = perms.includes('ROLE_MANAGE') || perms.includes('AUDIT_LOG_VIEW');
            
            // Có bất kỳ quyền quản trị nào không?
            const hasAnyAdminAccess = hasContentAccess || hasHRAccess || hasAnalyticsAccess || hasSystemAccess;

            // Quyền truy cập trang quản trị tổng quan (được tính động dựa trên việc có bất kỳ quyền quản lý nào)
            const hasGeneralAdminAccess = hasAnyAdminAccess;
            %>

            <% if (hasGeneralAdminAccess) { %>
              <!-- ===== DASHBOARD QUẢN TRỊ ===== -->
              <li class="nav-divider"></li>
              <li class="nav-section-label">
                <span>Quản trị L&D</span>
              </li>
              <li class="nav-item">
                <a href="/management"><i class="fa-solid fa-gauge-high"></i> Bảng điều khiển</a>
              </li>
            <% } %>

            <!-- ===== NHÓM: NỘI DUNG & ĐÀO TẠO ===== -->
            <% if (hasContentAccess) { %>
              <li class="nav-section-label" style="margin-top: 0.75rem;">
                <span><i class="fa-solid fa-graduation-cap" style="margin-right: 0.4rem; opacity: 0.6; font-size: 0.65rem;"></i>Nội dung & Đào tạo</span>
              </li>

              <% if (perms.includes('COURSE_VIEW')) { %>
                <li class="nav-item">
                  <a href="/course-management"><i class="fa-solid fa-folder-open"></i> Quản lý khóa học</a>
                </li>
              <% } %>

              <% if (perms.includes('LESSON_CREATE') || perms.includes('LESSON_MANAGE')) { %>
                <li class="nav-item">
                  <a href="/lessons"><i class="fa-solid fa-file-video"></i> Bài học & Nội dung</a>
                </li>
              <% } %>

              <% if (perms.includes('QUIZ_BANK_VIEW')) { %>
                <li class="nav-item">
                  <a href="/quiz-management"><i class="fa-solid fa-circle-question"></i> Đề thi & Câu hỏi</a>
                </li>
              <% } %>

              <% if (perms.includes('QUIZ_GRADE')) { %>
                <li class="nav-item">
                  <a href="/grade"><i class="fa-solid fa-star-half-stroke"></i> Chấm điểm</a>
                </li>
              <% } %>

              <% if (perms.includes('PATH_MANAGE')) { %>
                <li class="nav-item">
                  <a href="/paths"><i class="fa-solid fa-route"></i> Lộ trình đào tạo</a>
                </li>
              <% } %>

              <% if (perms.includes('ENROLL_APPROVE')) { %>
                <li class="nav-item">
                  <a href="/approvals"><i class="fa-solid fa-user-check"></i> Duyệt đăng ký</a>
                </li>
              <% } %>
            <% } %>

            <!-- ===== NHÓM: NHÂN SỰ & PHÒNG BAN ===== -->
            <% if (hasHRAccess) { %>
              <li class="nav-section-label" style="margin-top: 0.75rem;">
                <span><i class="fa-solid fa-people-group" style="margin-right: 0.4rem; opacity: 0.6; font-size: 0.65rem;"></i>Nhân sự & Tổ chức</span>
              </li>

              <% if (perms.includes('USER_VIEW') || perms.includes('USER_MANAGE')) { %>
                <li class="nav-item">
                  <a href="/users"><i class="fa-solid fa-users-gear"></i> Quản lý nhân sự</a>
                </li>
              <% } %>

              <% if (perms.includes('DEPARTMENT_MANAGE')) { %>
                <li class="nav-item">
                  <a href="/departments"><i class="fa-solid fa-building"></i> Phòng ban</a>
                </li>
              <% } %>
            <% } %>

            <!-- ===== NHÓM: PHÂN TÍCH & BÁO CÁO ===== -->
            <% if (hasAnalyticsAccess) { %>
              <li class="nav-section-label" style="margin-top: 0.75rem;">
                <span><i class="fa-solid fa-chart-simple" style="margin-right: 0.4rem; opacity: 0.6; font-size: 0.65rem;"></i>Phân tích & Báo cáo</span>
              </li>

              <% if (perms.includes('REPORT_VIEW')) { %>
                <li class="nav-item">
                  <a href="/reports"><i class="fa-solid fa-chart-pie"></i> Báo cáo thống kê</a>
                </li>
              <% } %>

              <% if (perms.includes('REPORT_EXPORT')) { %>
                <li class="nav-item">
                  <a href="/reports/raw"><i class="fa-solid fa-file-export"></i> Xuất dữ liệu thô</a>
                </li>
              <% } %>
            <% } %>

            <!-- ===== NHÓM: HỆ THỐNG & BẢO MẬT ===== -->
            <% if (hasSystemAccess) { %>
              <li class="nav-section-label" style="margin-top: 0.75rem;">
                <span><i class="fa-solid fa-server" style="margin-right: 0.4rem; opacity: 0.6; font-size: 0.65rem;"></i>Hệ thống & Bảo mật</span>
              </li>

              <% if (perms.includes('ROLE_MANAGE')) { %>
                <li class="nav-item">
                  <a href="/permissions"><i class="fa-solid fa-shield-halved"></i> Cấu hình phân quyền</a>
                </li>
              <% } %>

              <% if (perms.includes('AUDIT_LOG_VIEW')) { %>
                <li class="nav-item">
                  <a href="/audit"><i class="fa-solid fa-clock-rotate-left"></i> Nhật ký hệ thống</a>
                </li>
              <% } %>

              <% if (perms.includes('ROLE_MANAGE')) { %>
                <li class="nav-item">
                  <a href="/experiments"><i class="fa-solid fa-flask"></i> Thực nghiệm AI</a>
                </li>
              <% } %>
            <% } %>

            <!-- ===== FOOTER: CÀI ĐẶT & ĐĂNG XUẤT ===== -->
            <li class="nav-divider" style="margin-top: 1rem;"></li>
            <li class="nav-item">
              <a href="/settings"><i class="fa-solid fa-gear"></i> Cài đặt tài khoản</a>
            </li>
            <li class="nav-item">
              <a href="/auth/logout" class="nav-logout"><i class="fa-solid fa-arrow-right-from-bracket"></i> Đăng xuất</a>
            </li>

          <% } else { %>
            <li class="nav-item">
              <a href="/auth/login"><i class="fa-solid fa-right-to-bracket"></i> Đăng nhập</a>
            </li>
            <li class="nav-item">
              <a href="/auth/register"><i class="fa-solid fa-user-plus"></i> Đăng ký nhân viên</a>
            </li>
          <% } %>
        </ul>
      </nav>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          // 1. Tự động xác định link active dựa trên URL hiện tại
          const currentPath = window.location.pathname;
          const navLinks = document.querySelectorAll('.nav-item a');
          
          let activeLink = null;
          let maxMatchLen = -1;
          
          navLinks.forEach(link => {
            const href = link.getAttribute('href');
            if (href) {
              if (currentPath === href) {
                activeLink = link;
                maxMatchLen = href.length;
              } else if (href !== '/dashboard' && href !== '/management' && currentPath.startsWith(href) && href.length > maxMatchLen) {
                activeLink = link;
                maxMatchLen = href.length;
              }
            }
          });
          
          if (activeLink) {
            navLinks.forEach(link => link.parentElement.classList.remove('active'));
            activeLink.parentElement.classList.add('active');
          }

          // 2. Giữ nguyên vị trí cuộn của Sidebar tránh bị reset khi tải lại trang
          const sidebar = document.querySelector('.sidebar nav');
          if (sidebar) {
            // Khôi phục vị trí cuộn
            const savedScroll = localStorage.getItem('sidebar-scroll-position');
            if (savedScroll) {
              sidebar.scrollTop = parseInt(savedScroll, 10);
            }

            // Lưu vị trí cuộn khi người dùng cuộn sidebar
            sidebar.addEventListener('scroll', () => {
              localStorage.setItem('sidebar-scroll-position', sidebar.scrollTop);
            });

            // Lưu trước khi unload trang để chắc chắn vị trí cuối cùng được ghi nhận
            window.addEventListener('beforeunload', () => {
              localStorage.setItem('sidebar-scroll-position', sidebar.scrollTop);
            });
          }
        });
      </script>
    </aside>

    <!-- Thẻ bắt đầu của nội dung chính -->
    <main class="main-content">
      <!-- Universal Topbar -->
      <div class="top-bar" style="display: flex; justify-content: flex-end; align-items: center; padding: 0.75rem 1.5rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border-light); background: rgba(30, 41, 59, 0.4); backdrop-filter: blur(12px); border-radius: 12px; gap: 1rem;">
        <div style="flex-grow: 1; display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--text-muted);">
          <i class="fa-solid fa-clock"></i> <span>Hệ thống LMS Nội bộ Doanh nghiệp</span>
        </div>
        
        <% if (user) { %>
          <!-- Bell Notification Center -->
          <div class="notification-bell-container" style="position: relative;">
            <button id="notification-bell-btn" class="btn btn-secondary" style="padding: 0; border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; position: relative; background: rgba(255,255,255,0.03); border: 1px solid var(--border-light); cursor: pointer; transition: all 0.3s;">
              <i class="fa-solid fa-bell" style="font-size: 1.1rem; color: var(--text-accent);"></i>
              <span id="notification-badge" style="display: none; position: absolute; top: -2px; right: -2px; background: #ef4444; color: white; border-radius: 50%; font-size: 0.65rem; width: 18px; height: 18px; display: flex; align-items: center; justify-content: center; font-weight: 700; border: 2px solid var(--navy-dark);">0</span>
            </button>
            <div id="notification-dropdown" class="glass-card" style="display: none; position: absolute; top: 48px; right: 0; width: 320px; z-index: 2100; box-shadow: 0 10px 40px rgba(0,0,0,0.6); padding: 1rem; border-color: var(--border-glow); background: #0f172a;">
              <h4 style="font-size: 0.9rem; margin-top: 0; margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 0.5rem; font-weight: 700;">
                <span>Thông báo mới nhất</span>
                <span onclick="clearNotifications(event)" style="color: var(--text-muted); font-size: 0.75rem; cursor: pointer; font-weight: 600;">Xóa tất cả</span>
              </h4>
              <div id="notification-list" style="display: flex; flex-direction: column; gap: 0.6rem; max-height: 280px; overflow-y: auto;">
                <p style="color: var(--text-muted); font-size: 0.8rem; text-align: center; padding: 1rem 0; margin: 0;">Không có thông báo mới</p>
              </div>
            </div>
          </div>
        <% } %>
      </div>
