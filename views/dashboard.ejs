        </h2>

        <div class="glass-card" style="padding: 1.5rem; overflow-x: auto; border-radius: 16px;">
          <% if (recentLogs.length === 0) { %>
            <div style="text-align: center; color: var(--text-muted); padding: 2rem;">Chưa có lịch sử hoạt động ghi nhận.</div>
          <% } else { %>
            <table class="custom-table" style="margin-top: 0; font-size: 0.85rem; width: 100%;">
              <thead>
                <tr>
                  <th style="width: 110px;">Thời gian</th>
                  <th style="width: 120px;">Nhân sự</th>
                  <th style="width: 180px;">Hành động</th>
                  <th>Chi tiết</th>
                </tr>
              </thead>
              <tbody>
                <% recentLogs.forEach(log => { %>
                  <tr>
                    <td style="color: var(--text-muted); white-space: nowrap;"><%= new Date(log.created_at).toLocaleTimeString('vi-VN') %></td>
                    <td><strong><%= log.username || 'Hệ thống' %></strong></td>
                    <td>
                      <% 
                        let badgeStyle = "background: rgba(79, 70, 229, 0.08); color: var(--text-accent); border: 1px solid rgba(79, 70, 229, 0.16);";
                        if (log.action.includes('SUCCESS') || log.action === 'USER_LOGIN' || log.action.includes('APPROVED')) {
                          badgeStyle = "background: rgba(16, 185, 129, 0.08); color: #059669; border: 1px solid rgba(16, 185, 129, 0.18);";
                        } else if (log.action.includes('REQUESTED') || log.action.includes('FAIL') || log.action.includes('REJECTED')) {
                          badgeStyle = "background: rgba(239, 68, 68, 0.08); color: #dc2626; border: 1px solid rgba(239, 68, 68, 0.18);";
                        } else if (log.action === 'USER_LOGOUT') {
                          badgeStyle = "background: rgba(100, 116, 139, 0.08); color: #64748b; border: 1px solid rgba(100, 116, 139, 0.18);";
                        }
                      %>
                      <span style="<%= badgeStyle %> padding: 0.25rem 0.55rem; border-radius: 6px; font-size: 0.74rem; font-weight: 600; display: inline-block;">
                        <%= dashboardActionLabels[log.action] || log.action %>
                      </span>
                    </td>
                    <td>
                      <div style="max-width: 420px; line-height: 1.4; word-break: break-word;">
                        <%- formatDashboardAuditDetails(log.details) %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
  <% } %>
</div>
<% } %>

