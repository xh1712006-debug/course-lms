        const subtext = isPendingEmpty ? 'Đã duyệt hết yêu cầu' : 'Yêu cầu cần duyệt gấp';
        const icon = isPendingEmpty ? 'fa-solid fa-circle-check' : 'fa-solid fa-clock';
      %>
      <div class="kpi-card-modern">
        <div class="kpi-icon-container <%= colorClass %>">
          <i class="<%= icon %>"></i>
        </div>
