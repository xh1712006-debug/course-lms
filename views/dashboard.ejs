                        let badgeStyle = "background: rgba(99, 102, 241, 0.15); color: var(--text-accent); border: 1px solid rgba(99, 102, 241, 0.3); font-weight: 600;";
                        if (log.action.includes('SUCCESS') || log.action === 'USER_LOGIN') {
                          badgeStyle = "background: rgba(13, 148, 136, 0.12); color: #0d9488; border: 1px solid rgba(13, 148, 136, 0.25); font-weight: 600;";
                        } else if (log.action.includes('REQUESTED') || log.action.includes('FAIL')) {
                          badgeStyle = "background: rgba(234, 88, 12, 0.12); color: #ea580c; border: 1px solid rgba(234, 88, 12, 0.25); font-weight: 600;";
                        } else if (log.action === 'USER_LOGOUT') {
                          badgeStyle = "background: rgba(100, 116, 139, 0.12); color: #64748b; border: 1px solid rgba(100, 116, 139, 0.25); font-weight: 600;";
                        }
                      %>
                      <span style="<%= badgeStyle %> padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.75rem;">
                        <%= actionLabels[log.action] || log.action %>
                      </span>
                    </td>
                    <td style="max-width: 300px; color: var(--text-main); font-size: 0.82rem; word-break: break-word; white-space: normal;"><%- formatAuditDetails(log.details) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
  <% } %>
</div>
<% } %>

<% if (!hasStudentAccess && !hasAdminAccess) { %>
  <!-- Giao diện trống thân thiện nếu không được phân quyền -->
  <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; margin-top: 2rem;" class="dashboard-main-grid-override">
    
    <!-- Cột trái: Thông báo và chi tiết trạng thái tài khoản -->
    <div class="glass-card" style="padding: 3rem 2.5rem; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; gap: 1.5rem; border-left: 5px solid var(--text-accent);">
      <div style="background: rgba(13, 148, 136, 0.08); padding: 1rem; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center;">
        <i class="fa-solid fa-user-shield fa-3x" style="color: var(--text-accent);"></i>
      </div>
      
      <div>
        <h3 style="font-size: 1.8rem; font-weight: 800; color: var(--text-main); margin: 0;">Trang chủ chưa được thiết lập</h3>
        <p style="color: var(--text-muted); margin-top: 0.5rem; font-size: 1rem; line-height: 1.6; max-width: 600px;">
          Tài khoản của bạn đã đăng nhập thành công vào hệ thống. Tuy nhiên, vai trò hiện tại chưa được gán quyền hạn hiển thị bất kỳ phân hệ nào trên Dashboard.
        </p>
      </div>

      <div style="width: 100%; border-top: 1px solid var(--border-light); padding-top: 1.5rem;">
        <div style="display: grid; grid-template-columns: auto 1fr; gap: 1rem 2rem; font-size: 0.95rem;">
          <span style="color: var(--text-muted); font-weight: 600;">Vai trò của bạn:</span>
          <span style="font-weight: 700; color: var(--text-main);"><%= user.roleName %></span>
          
          <span style="color: var(--text-muted); font-weight: 600;">Danh sách quyền:</span>
          <div>
            <% if (user.permissions && user.permissions.length > 0) { %>
              <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.2rem;">
                <% user.permissions.forEach(perm => { %>
                  <span style="background: rgba(100, 116, 139, 0.08); color: var(--text-muted); border: 1px solid var(--border-light); padding: 0.2rem 0.5rem; border-radius: 6px; font-family: monospace; font-size: 0.75rem;">
                    <%= perm %>
                  </span>
                <% }) %>
              </div>
            <% } else { %>
              <span style="color: #ea580c; font-style: italic; font-weight: 500;">
                <i class="fa-solid fa-triangle-exclamation" style="margin-right: 0.25rem;"></i> Chưa được gán quyền hạn nào
              </span>
            <% } %>
          </div>
        </div>
      </div>

      <% if (user.permissions && user.permissions.includes('ROLE_MANAGE')) { %>
        <div style="margin-top: 1rem; background: rgba(99, 102, 241, 0.05); border: 1px dashed rgba(99, 102, 241, 0.3); padding: 1.25rem; border-radius: 12px; width: 100%;">
          <h4 style="margin: 0 0 0.5rem 0; color: #4f46e5; font-size: 0.95rem; font-weight: 700;">
            <i class="fa-solid fa-lock-open" style="margin-right: 0.4rem;"></i> Hướng dẫn dành cho Quản trị viên
          </h4>
          <p style="margin: 0 0 1rem 0; font-size: 0.85rem; color: var(--text-muted); line-height: 1.5;">
            Vì bạn có quyền <strong>ROLE_MANAGE</strong>, bạn có thể truy cập trực tiếp vào ma trận phân quyền để gán các đặc quyền phù hợp cho vai trò <strong><%= user.roleName %></strong>.
          </p>
          <a href="/permissions" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; padding: 0.6rem 1.2rem;">
            <i class="fa-solid fa-shield-halved"></i> Cấu hình quyền RBAC ngay
          </a>
        </div>
      <% } %>
    </div>

    <!-- Cột phải: Giải thích cơ chế Dashboard thích ứng động -->
    <div class="glass-card" style="padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem;">
      <h4 style="font-size: 1.1rem; font-weight: 700; color: var(--text-main); margin: 0; display: flex; align-items: center; gap: 0.5rem;">
        <i class="fa-solid fa-circle-info" style="color: #6366f1;"></i> Hướng dẫn kích hoạt
