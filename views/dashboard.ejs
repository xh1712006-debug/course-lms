          <div class="kpi-title" style="margin:0;">Chờ duyệt học</div>
          <div class="kpi-value" style="color:<%= textColor %>; font-size:1.8rem;"><%= stats.pendingApprovals %></div>
          <div class="kpi-card-subtext"><%= subtext %></div>
        </div>
      </div>
    <% } %>
  </div>


  <% 
