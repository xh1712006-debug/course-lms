          'assessment_id': 'Mã bài kiểm tra',
          'question_id': 'Mã câu hỏi'
        };

        const dashboardDetailValues = {
          'user_settings_change': 'Thay đổi cài đặt tài khoản',
          'active': 'Đang hoạt động',
          'disabled': 'Vô hiệu hóa',
          'approved': 'Đã duyệt',
          'rejected': 'Từ chối',
          'pending': 'Đang chờ duyệt',
          'true': 'Đúng / Có / Đạt',
          'false': 'Sai / Không / Không đạt',
          'null': 'Không có',
          'published': 'Xuất bản',
          'draft': 'Bản nháp',
          'user': 'Nhân sự',
          'department': 'Phòng ban'
        };

        function formatDashboardAuditDetails(details) {
          if (!details) {
            return '<span style="color:#94a3b8; font-style:italic;">Không có chi tiết</span>';
          }
          
          let parsedDetails = details;
          if (typeof details === 'string') {
            try {
              parsedDetails = JSON.parse(details);
            } catch (e) {
              return details;
            }
          }
          
          if (!parsedDetails || typeof parsedDetails !== 'object' || Object.keys(parsedDetails).length === 0) {
            return '<span style="color:#94a3b8; font-style:italic;">Không có chi tiết</span>';
          }
          
          return Object.entries(parsedDetails).map(([key, val]) => {
            const label = dashboardDetailKeys[key] || key;
            let displayVal = val;
            
            if (val === true) {
              displayVal = 'Có';
            } else if (val === false) {
              displayVal = 'Không';
            } else if (val === null || val === undefined) {
              displayVal = 'Rỗng';
            } else if (Array.isArray(val)) {
              displayVal = val.join(', ');
            } else {
              displayVal = dashboardDetailValues[val] !== undefined ? dashboardDetailValues[val] : val;
            }
            
            return `<span class="chip-badge gray" style="margin-right: 0.25rem; margin-bottom: 0.25rem;"><strong>${label}</strong>: ${displayVal}</span>`;
          }).join(' ');
        }
