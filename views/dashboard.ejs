        <h2 style="font-size: 1.4rem; margin-bottom: 1.25rem; color: var(--text-main);"><i class="fa-solid fa-bolt" style="color: #ea580c;"></i> Thao tác nhanh</h2>
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem; padding: 1.5rem;">
          <% if (user.permissions.includes('COURSE_CREATE')) { %>
            <a href="/course-management" class="btn btn-primary" style="justify-content: flex-start; padding: 0.85rem 1rem;">
              <i class="fa-solid fa-plus"></i> Tạo khóa học mới
            </a>
          <% } %>
          
          <% if (user.permissions.includes('USER_MANAGE')) { %>
            <a href="/users" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.85rem 1rem;">
              <i class="fa-solid fa-user-plus"></i> Quản lý & giao khóa học
            </a>
          <% } %>

          <% if (user.permissions.includes('ROLE_MANAGE')) { %>
            <a href="/permissions" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.85rem 1rem;">
              <i class="fa-solid fa-shield-halved"></i> Cấu hình Phân quyền & Matrix
            </a>
          <% } %>

          <% if (user.permissions.includes('REPORT_VIEW')) { %>
            <a href="/reports" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.85rem 1rem;">
              <i class="fa-solid fa-chart-pie"></i> Xem báo cáo thống kê Excel
            </a>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- Xem nhật ký vết (Audit Logs) gần đây -->
    <% if (hasAuditLog) { %>
      <div>
        <h2 style="font-size: 1.4rem; margin-bottom: 1.25rem; display: flex; align-items: center; justify-content: space-between; color: var(--text-main);">
          <span><i class="fa-solid fa-clock-rotate-left" style="color: #4f46e5;"></i> Nhật ký hoạt động gần đây</span>
          <a href="/audit" style="font-size: 0.8rem; color: var(--text-accent);">Xem tất cả <i class="fa-solid fa-arrow-right"></i></a>
        </h2>

        <div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
          <% if (recentLogs.length === 0) { %>
            <div style="text-align: center; color: var(--text-muted); padding: 2rem;">Chưa có lịch sử hoạt động ghi nhận.</div>
          <% } else { %>
            <%
              const actionLabels = {
                'USER_LOGIN': 'Đăng nhập',
                'USER_LOGOUT': 'Đăng xuất',
                'PASSWORD_RESET_REQUESTED': 'Yêu cầu OTP quên mật khẩu',
                'PASSWORD_RESET_SUCCESS': 'Đặt lại mật khẩu thành công',
                'USER_CREATE': 'Tạo tài khoản nhân viên',
                'USER_PROFILE_UPDATE': 'Cập nhật tài khoản',
                'ROLE_CREATE': 'Tạo vai trò mới',
                'ROLE_DELETE': 'Xóa vai trò',
                'ROLE_PERMISSIONS_UPDATE': 'Cập nhật phân quyền',
                'ROLE_PERMISSION_TOGGLE': 'Thay đổi phân quyền nhanh',
                'COURSE_CREATE': 'Tạo khóa học mới',
                'COURSE_UPDATE': 'Cập nhật khóa học',
                'COURSE_DELETE': 'Xóa khóa học',
                'COURSE_PUBLISH': 'Thay đổi trạng thái khóa học',
                'LESSON_CREATE': 'Thêm bài giảng',
                'LESSON_UPDATE': 'Sửa bài giảng',
                'LESSON_DELETE': 'Xóa bài giảng',
                'PATH_CREATE': 'Tạo lộ trình đào tạo',
                'DEPARTMENT_CREATE': 'Tạo phòng ban mới',
                'DEPARTMENT_DELETE': 'Xóa phòng ban',
                'DEPARTMENT_UPDATE': 'Cập nhật phòng ban',
                'ENROLLMENT_APPROVED': 'Phê duyệt đăng ký khóa học',
                'ENROLLMENT_REJECTED': 'Từ chối đăng ký khóa học',
                'USER_IMPERSONATE_START': 'Bắt đầu đóng vai',
                'USER_IMPERSONATE_END': 'Thoát đóng vai',
                'RUN_EXPERIMENT_SUCCESS': 'Huấn luyện AI thành công',
                'RUN_EXPERIMENT_FAILED': 'Huấn luyện AI thất bại',
                'AI_SUMMARIZE_LESSON': 'AI tóm tắt bài giảng',
                'AI_CHAT_ASSISTANT': 'Trò chuyện với trợ lý AI',
                'AI_GENERATE_QUICK_QUIZ': 'AI sinh đề trắc nghiệm nhanh',
                'AI_GENERATE_QUIZ_TO_BANK': 'AI lưu trắc nghiệm vào DB',
                'COURSE_ASSIGN_USER': 'Giao khóa học cho nhân sự',
                'COURSE_ASSIGN_DEPARTMENT': 'Giao khóa học cho phòng ban',
                'QUIZ_SETTING_UPDATE': 'Cập nhật cài đặt đề thi',
                'QUIZ_GRADE': 'Chấm điểm đề thi',
                'QUIZ_SUBMIT': 'Nộp bài thi trắc nghiệm',
                'PATH_ASSIGN_BULK': 'Giao lộ trình hàng loạt',
                'ENROLL_REQUEST': 'Yêu cầu đăng ký khóa học',
                'ENROLL_DIRECT': 'Vào học trực tiếp'
              };

              const detailKeys = {
                'reason': 'Lý do',
                'role_id': 'Mã vai trò',
                'role_name': 'Tên vai trò',
                'permission': 'Quyền hạn',
                'is_assigned': 'Gán quyền',
                'lesson_id': 'Mã bài học',
                'lesson_title': 'Tên bài học',
                'course_id': 'Mã khóa học',
                'course_title': 'Tên khóa học',
                'user_id': 'Mã nhân viên',
                'target_user_id': 'Mã nhân viên mục tiêu',
                'new_user_id': 'Mã nhân viên mới',
                'username': 'Tên tài khoản',
                'email': 'Email',
                'status': 'Trạng thái',
                'name': 'Tên phòng ban',
                'parent_id': 'Mã phòng ban cha',
                'department_id': 'Mã phòng ban',
                'enrollment_id': 'Mã đăng ký',
                'experiment_id': 'Mã thực nghiệm',
                'accuracy': 'Độ chính xác',
                'loss': 'Độ hao hụt (Loss)',
                'message_length': 'Độ dài tin nhắn',
                'questions_count': 'Số lượng câu hỏi',
                'count': 'Số lượng',
                'title': 'Tiêu đề',
                'has_essay': 'Có câu tự luận',
                'score': 'Điểm số',
                'is_passed': 'Kết quả đạt',
                'submission_id': 'Mã bài nộp',
                'path_id': 'Mã lộ trình',
                'courses': 'Mã các khóa học',
                'users': 'Số nhân sự nhận',
                'target_username': 'Tài khoản bị đóng vai',
                'original_user_id': 'Mã người quản trị',
                'original_username': 'Tài khoản quản trị',
                'error': 'Lỗi chi tiết',
                'permissions': 'Danh sách quyền'
              };

              const detailValues = {
                'user_settings_change': 'Thay đổi cài đặt tài khoản',
                'active': 'Đang hoạt động',
                'disabled': 'Vô hiệu hóa',
                'approved': 'Đã duyệt',
                'rejected': 'Từ chối',
                'pending': 'Đang chờ duyệt',
                'true': 'Đúng / Có / Đạt',
                'false': 'Sai / Không / Không đạt',
                'null': 'Không có',
                'published': 'Xuất bản',
                'draft': 'Bản nháp',
                
                // Ánh xạ tên quyền hạn (Permissions Mapping)
                'COURSE_VIEW': 'Xem khóa học',
                'COURSE_CREATE': 'Tạo khóa học',
                'COURSE_UPDATE': 'Cập nhật khóa học',
                'COURSE_DELETE': 'Xóa khóa học',
                'COURSE_PUBLISH': 'Xuất bản khóa học',
                'LESSON_CREATE': 'Tạo bài học',
                'CONTENT_UPLOAD': 'Tải lên học liệu (video/file)',
                'LESSON_MANAGE': 'Quản lý bài giảng',
                'QUIZ_BANK_VIEW': 'Xem ngân hàng câu hỏi',
                'QUIZ_BANK_MANAGE': 'Quản lý ngân hàng câu hỏi',
