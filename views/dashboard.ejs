        function formatDashboardAuditDetails(details) {
          if (!details) {
            return '<span style="color:#94a3b8; font-style:italic;">Không có chi tiết</span>';
          }
          
          let parsedDetails = details;
          if (typeof details === 'string') {
            try {
              parsedDetails = JSON.parse(details);
            } catch (e) {
              return details;
            }
          }
          
          if (!parsedDetails || typeof parsedDetails !== 'object' || Object.keys(parsedDetails).length === 0) {
            return '<span style="color:#94a3b8; font-style:italic;">Không có chi tiết</span>';
          }
          
          return Object.entries(parsedDetails).map(([key, val]) => {
            const label = dashboardDetailKeys[key] || key;
            let displayVal = val;
            
            if (val === true) {
              displayVal = 'Có';
            } else if (val === false) {
              displayVal = 'Không';
            } else if (val === null || val === undefined) {
              displayVal = 'Rỗng';
            } else if (Array.isArray(val)) {
              displayVal = val.join(', ');
            } else {
              displayVal = dashboardDetailValues[val] !== undefined ? dashboardDetailValues[val] : val;
            }
            
            return `<span style="display:inline-block; background:#f1f5f9; border:1px solid #e2e8f0; padding:0.1rem 0.35rem; border-radius:5px; margin:0.1rem 0.15rem 0.1rem 0; font-size:0.75rem; color:#475569;"><strong>${label}</strong>: ${displayVal}</span>`;
          }).join(' ');
        }
