                'USER_DISABLE': 'Vô hiệu hóa tài khoản',
                'DEPARTMENT_MANAGE': 'Quản lý phòng ban',
                'REPORT_VIEW': 'Xem báo cáo thống kê',
                'REPORT_EXPORT': 'Xuất dữ liệu báo cáo',
                'ROLE_MANAGE': 'Quản lý vai trò & phân quyền',
                'USER_IMPERSONATE': 'Đóng vai người dùng',
                'AUDIT_LOG_VIEW': 'Xem nhật ký hệ thống',
                'PATH_VIEW': 'Xem lộ trình học cá nhân',
                'COURSE_ENROLL_REQUEST': 'Yêu cầu tham gia khóa học',
                'HISTORY_VIEW': 'Xem lịch sử học tập',
                'PROGRESS_TRACK': 'Theo dõi tiến độ học tập'
              };

              function formatAuditDetails(details) {
                if (!details) {
                  return '<span style="font-style: italic; opacity: 0.7;">Không có chi tiết</span>';
                }
                
                let parsedDetails = details;
                if (typeof details === 'string') {
                  try {
                    parsedDetails = JSON.parse(details);
                  } catch (e) {
                    return details;
                  }
                }
                
                if (!parsedDetails || typeof parsedDetails !== 'object' || Object.keys(parsedDetails).length === 0) {
                  return '<span style="font-style: italic; opacity: 0.7;">Không có chi tiết</span>';
                }
                
                return Object.entries(parsedDetails).map(([key, val]) => {
                  const label = detailKeys[key] || key;
                  let displayVal = val;
                  
                  if (val === true) {
                    displayVal = 'Có';
                  } else if (val === false) {
                    displayVal = 'Không';
                  } else if (val === null || val === undefined) {
                    displayVal = 'Rỗng';
                  } else if (Array.isArray(val)) {
                    displayVal = val.map(item => detailValues[item] || item).join(', ');
                  } else {
                    displayVal = detailValues[val] !== undefined ? detailValues[val] : val;
                  }
                  
                  return `<strong>${label}</strong>: ${displayVal}`;
                }).join(', ');
              }
            %>
            <table class="custom-table" style="margin-top: 0; font-size: 0.85rem;">
