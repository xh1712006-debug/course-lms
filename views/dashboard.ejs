                'PATH_MANAGE': 'Quản lý lộ trình học',
                'ENROLL_ASSIGN': 'Giao khóa học',
                'ENROLL_APPROVE': 'Phê duyệt đăng ký',
                'USER_VIEW': 'Xem danh sách nhân viên',
