        </h2>

        <div class="glass-card" style="padding: 1.5rem; border-radius: 12px; max-height: 480px; overflow-y: auto;">
          <% if (recentLogs.length === 0) { %>
            <div style="text-align: center; color: var(--text-muted); padding: 2rem;">Chưa có lịch sử hoạt động ghi nhận.</div>
          <% } else { %>
            <div class="timeline-list">
              <% recentLogs.forEach(log => { %>
                <%
                  let iconClass = 'fa-solid fa-circle-info';
                  let iconColor = '#475569';
                  let badgeType = 'gray';

                  if (log.action.includes('USER_LOGIN')) {
                    iconClass = 'fa-solid fa-right-to-bracket';
                    iconColor = '#10b981';
                    badgeType = 'green';
                  } else if (log.action.includes('USER_LOGOUT')) {
                    iconClass = 'fa-solid fa-right-from-bracket';
                    iconColor = '#64748b';
                    badgeType = 'gray';
                  } else if (log.action.includes('CREATE') || log.action.includes('ADD')) {
                    iconClass = 'fa-solid fa-circle-plus';
                    iconColor = '#3b82f6';
                    badgeType = 'blue';
                  } else if (log.action.includes('DELETE') || log.action.includes('REJECTED')) {
                    iconClass = 'fa-solid fa-circle-xmark';
                    iconColor = '#ef4444';
                    badgeType = 'red';
                  } else if (log.action.includes('APPROVED') || log.action.includes('SUCCESS')) {
                    iconClass = 'fa-solid fa-circle-check';
                    iconColor = '#10b981';
                    badgeType = 'green';
                  } else if (log.action.includes('GRADE') || log.action.includes('SUBMIT')) {
                    iconClass = 'fa-solid fa-square-poll-vertical';
                    iconColor = '#8b5cf6';
                    badgeType = 'purple';
                  } else if (log.action.includes('ASSIGN')) {
                    iconClass = 'fa-solid fa-route';
                    iconColor = '#f59e0b';
                    badgeType = 'amber';
                  }
                %>
                <div class="timeline-item">
                  <div class="timeline-time">
                    <%= new Date(log.created_at).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %>
                  </div>
                  <div class="timeline-icon-box" style="background: rgba(71, 85, 105, 0.05); color: <%= iconColor %>;">
                    <i class="<%= iconClass %>"></i>
                  </div>
                  <div class="timeline-body">
                    <div class="timeline-title">
                      <span class="timeline-user"><%= log.username || 'Hệ thống' %></span>
                      <span class="chip-badge <%= badgeType %>" style="margin-left:0.35rem; font-size:0.68rem; padding: 0.1rem 0.35rem;">
                        <%= dashboardActionLabels[log.action] || log.action %>
                      </span>
                    </div>
                    <div class="timeline-details" style="margin-top: 0.25rem;">
                      <%- formatDashboardAuditDetails(log.details) %>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
  <% } %>
</div>
<% } %>

