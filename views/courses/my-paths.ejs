        if      (pnl.includes('backend') || pnl.includes('node'))                          pIcon = 'fa-server';
        else if (pnl.includes('devops') || pnl.includes('docker') || pnl.includes('cloud')) pIcon = 'fa-terminal';
        else if (pnl.includes('frontend') || pnl.includes('react'))                        pIcon = 'fa-code';
