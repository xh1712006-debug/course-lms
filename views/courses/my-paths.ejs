<script>
  /* ── Tab switching ── */
  const TAB_COLORS = {
    'my-courses': '#6366f1',
    'mandatory':  '#dc2626',
    'elective':   '#0d9488'
  };

  function mpSwitchTab(id) {
    document.querySelectorAll('.mp-tab-pane').forEach(p => p.style.display = 'none');
    document.getElementById('tab-' + id).style.display = 'block';

    document.querySelectorAll('.mp-tab-btn').forEach(b => {
      b.classList.remove('active');
      b.querySelector('.mp-tab-count').style.background = '#f1f5f9';
      b.querySelector('.mp-tab-count').style.color = 'var(--text-muted)';
    });

    const btn = document.getElementById('tab-btn-' + id);
    btn.classList.add('active');
    const color = TAB_COLORS[id];
    btn.style.color = color;
    btn.style.borderBottomColor = color;

    const countEl = btn.querySelector('.mp-tab-count');
    const lightBg = { 'my-courses': '#e0e7ff', mandatory: '#fee2e2', elective: '#ccfbf1' };
    countEl.style.background = lightBg[id];
    countEl.style.color = color;
  }

  /* ── Course filter ── */
  function mpFilter(val, el) {
    document.querySelectorAll('.mp-pill').forEach(p => p.classList.remove('active'));
    el.classList.add('active');

    const items = document.querySelectorAll('#mp-course-grid .filter-item');
    let visible = 0;
    items.forEach(item => {
      const type = item.dataset.type;
      const done = item.dataset.completed === 'true';
      const show = val === 'all' || (val === 'mandatory' && type === 'mandatory')
                || (val === 'elective' && type === 'elective')
                || (val === 'completed' && done);
      item.style.display = show ? 'flex' : 'none';
      if (show) visible++;
    });

    const noRes = document.getElementById('mp-no-filter');
    const grid  = document.getElementById('mp-course-grid');
    if (noRes && grid) {
      noRes.style.display  = visible === 0 ? 'block' : 'none';
      grid.style.display   = visible === 0 ? 'none'  : 'grid';
    }
  }

  /* ── Timeline toggle ── */
  function mpToggleTimeline(id) {
    const wrap = document.getElementById('mp-timeline-' + id);
    const btn  = document.getElementById('mp-toggle-' + id);
    if (!wrap || !btn) return;

    const isOpen = wrap.classList.toggle('open');
    const chevron = btn.querySelector('i');
    chevron.className = isOpen ? 'fa-solid fa-chevron-up' : 'fa-solid fa-chevron-down';
    btn.querySelector('span').textContent = isOpen ? 'Thu gọn lộ trình' : 'Xem chi tiết lộ trình';

    if (isOpen) {
      setTimeout(() => wrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
    }
  }

  /* ── Pin elective path ── */
  document.addEventListener('DOMContentLoaded', () => {
    let pinned = JSON.parse(localStorage.getItem('mp-pinned') || '[]');

    document.querySelectorAll('.elective-card[data-path-id]').forEach(card => {
      const pid = parseInt(card.dataset.pathId);
      const btn = card.querySelector('.mp-pin-btn');
      if (pinned.includes(pid) && btn) applyPin(btn, true);
    });

    updatePinnedCount();
  });

  function mpTogglePin(pathId, btn) {
    let pinned = JSON.parse(localStorage.getItem('mp-pinned') || '[]');
    pathId = parseInt(pathId);
    const isPinned = pinned.includes(pathId);

    if (isPinned) {
      pinned = pinned.filter(id => id !== pathId);
      applyPin(btn, false);
    } else {
      pinned.push(pathId);
      applyPin(btn, true);
    }

    localStorage.setItem('mp-pinned', JSON.stringify(pinned));
    updatePinnedCount();
  }

  function applyPin(btn, state) {
    if (state) {
      btn.classList.add('pinned');
      btn.innerHTML = '<i class="fa-solid fa-star" style="color:#fbbf24"></i> Đang theo đuổi';
    } else {
      btn.classList.remove('pinned');
      btn.innerHTML = '<i class="fa-regular fa-star"></i> Theo đuổi';
    }
  }

  function updatePinnedCount() {
    const pinned = JSON.parse(localStorage.getItem('mp-pinned') || '[]');
    const el = document.getElementById('mp-pinned-count');
    if (el) el.textContent = pinned.length;
  }
</script>

