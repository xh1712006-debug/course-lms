<!-- ══════════════════════════════════════════ -->
<!-- TAB 2: LỘ TRÌNH BẮT BUỘC                  -->
<!-- ══════════════════════════════════════════ -->
<div id="tab-mandatory" class="mp-tab-pane" style="display:<%= defaultTab === 'mandatory' ? 'block' : 'none' %>">

  <!-- Stats -->
  <div class="mp-stats">
    <div class="mp-stat">
      <div class="mp-stat-icon red"><i class="fa-solid fa-route"></i></div>
      <div>
        <span class="mp-stat-val"><%= mandatoryPaths.length %></span>
        <span class="mp-stat-label">Lộ trình được gán</span>
      </div>
    </div>
    <div class="mp-stat">
      <div class="mp-stat-icon amber"><i class="fa-solid fa-percent"></i></div>
      <div>
        <span class="mp-stat-val">
          <%= mandatoryPaths.length > 0
            ? Math.round(mandatoryPaths.reduce((a,p) => a + p.progress, 0) / mandatoryPaths.length)
            : 0 %>%
        </span>
        <span class="mp-stat-label">Tiến độ trung bình</span>
      </div>
    </div>
    <div class="mp-stat">
      <div class="mp-stat-icon green"><i class="fa-solid fa-trophy"></i></div>
      <div>
        <span class="mp-stat-val"><%= mandatoryPaths.filter(p => p.progress === 100).length %></span>
        <span class="mp-stat-label">Đã hoàn thành</span>
      </div>
    </div>
  </div>

  <% if (mandatoryPaths.length === 0) { %>
    <div class="mp-empty">
      <div class="mp-empty-icon"><i class="fa-solid fa-shield-halved"></i></div>
      <h3>Bạn chưa có lộ trình bắt buộc nào</h3>
      <p>Liên hệ bộ phận HR nếu bạn cần được gán lộ trình đào tạo.</p>
    </div>
  <% } else { %>
    <% mandatoryPaths.forEach(path => { %>
      <%
        let pIcon = 'fa-route';
