      <div class="mp-path-card mandatory-card" data-path-id="<%= path.id %>">

        <div class="mp-path-head">
          <div class="mp-path-head-left">
            <div class="mp-path-icon red"><i class="fa-solid <%= pIcon %>"></i></div>
            <div>
              <h2 class="mp-path-name">
                <%= path.name %>
                <span class="mp-path-badge mandatory"><i class="fa-solid fa-thumbtack"></i> Bắt buộc</span>
              </h2>
              <p class="mp-path-desc"><%= path.description %></p>
            </div>
          </div>
          <div class="mp-path-right">
            <div class="mp-path-pct"><%= path.progress %>%</div>
