<%- include('../partials/header') %>

<style>
  /* ── Page header ── */
  .mp-header {
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 1.75rem;
  }
  .mp-title {
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 0.3rem;
    letter-spacing: -0.3px;
  }
  .mp-sub {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* ── Tab navigation ── */
  .mp-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--border-light);
    margin-bottom: 1.75rem;
    overflow-x: auto;
  }
  .mp-tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.18s, border-color 0.18s;
    white-space: nowrap;
  }
  .mp-tab-btn:hover { color: var(--text-main); }
  .mp-tab-btn.active {
    color: #6366f1;
    border-bottom-color: #6366f1;
  }
  .mp-tab-btn.active.red  { color: #dc2626; border-bottom-color: #dc2626; }
  .mp-tab-btn.active.teal { color: #0d9488; border-bottom-color: #0d9488; }
  .mp-tab-count {
    font-size: 0.72rem;
    font-weight: 700;
    background: #f1f5f9;
    color: var(--text-muted);
    padding: 0.1rem 0.45rem;
    border-radius: 20px;
    transition: background 0.18s, color 0.18s;
  }
  .mp-tab-btn.active .mp-tab-count {
    background: #e0e7ff;
    color: #6366f1;
  }
  .mp-tab-btn.active.red .mp-tab-count  { background: #fee2e2; color: #dc2626; }
  .mp-tab-btn.active.teal .mp-tab-count { background: #ccfbf1; color: #0d9488; }

  /* ── Stats strip (shared) ── */
  .mp-stats {
    display: flex;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    margin-bottom: 1.75rem;
  }
  .mp-stat {
    flex: 1;
    padding: 0.9rem 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    border-right: 1px solid var(--border-light);
  }
  .mp-stat:last-child { border-right: none; }
  .mp-stat-icon {
    width: 34px; height: 34px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem;
    flex-shrink: 0;
  }
  .mp-stat-icon.indigo { background: #eff6ff; color: #6366f1; }
  .mp-stat-icon.green  { background: #f0fdf4; color: #22c55e; }
  .mp-stat-icon.amber  { background: #fffbeb; color: #f59e0b; }
  .mp-stat-icon.red    { background: #fff1f2; color: #ef4444; }
  .mp-stat-icon.teal   { background: #f0fdfa; color: #0d9488; }
  .mp-stat-val   { font-size: 1.15rem; font-weight: 700; color: var(--text-main); display: block; line-height: 1; }
  .mp-stat-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.15rem; display: block; }

  /* ── Filter pills ── */
  .mp-filters {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .mp-pill {
    padding: 0.32rem 0.8rem;
    border: 1px solid var(--border-light);
    border-radius: 20px;
    background: #fff;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.18s;
  }
  .mp-pill:hover { border-color: #6366f1; color: #6366f1; }
  .mp-pill.active { background: #6366f1; border-color: #6366f1; color: #fff; }

  /* ── My-course cards grid ── */
  .mp-course-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.1rem;
  }
  .mp-course-card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 14px;
    padding: 1.1rem 1.1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    transition: box-shadow 0.2s, transform 0.2s;
    overflow: hidden;
  }
  .mp-course-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.07);
    transform: translateY(-2px);
  }
  .mp-course-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.65rem;
  }
  .mp-course-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .mp-type-tag {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.18rem 0.5rem;
    border-radius: 5px;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }
  .mp-type-tag.mandatory { background: #fff1f2; color: #dc2626; border: 1px solid #fecdd3; }
  .mp-type-tag.elective  { background: #f0fdfa; color: #0d9488; border: 1px solid #99f6e4; }
  .mp-course-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 0.35rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .mp-course-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0 0 0.85rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .mp-progress-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
  }
  .mp-progress-bar-wrap {
    height: 5px;
    background: #f1f5f9;
    border-radius: 99px;
    overflow: hidden;
    margin-bottom: 0.85rem;
  }
  .mp-progress-fill {
    height: 100%;
    border-radius: 99px;
    background: #22c55e;
    transition: width 0.4s ease;
  }
  .mp-card-foot {
    border-top: 1px solid var(--border-light);
    padding: 0.65rem 0;
    display: flex;
    justify-content: flex-end;
  }

  /* ── Path cards ── */
  .mp-path-card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 14px;
    margin-bottom: 1.1rem;
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .mp-path-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
  .mp-path-card.mandatory-card { border-left: 4px solid #ef4444; }
  .mp-path-card.elective-card  { border-left: 4px solid #0d9488; }
  .mp-path-head {
    padding: 1.1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .mp-path-head-left {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
    flex: 1;
    min-width: 0;
  }
  .mp-path-icon {
    width: 42px; height: 42px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.05rem;
    flex-shrink: 0;
  }
  .mp-path-icon.red  { background: #fff1f2; color: #ef4444; }
  .mp-path-icon.teal { background: #f0fdfa; color: #0d9488; }
  .mp-path-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .mp-path-badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }
  .mp-path-badge.mandatory { background: #fff1f2; color: #dc2626; }
  .mp-path-badge.elective  { background: #f0fdfa; color: #0d9488; }
  .mp-path-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .mp-path-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    flex-shrink: 0;
  }
  .mp-path-pct {
    font-size: 1.35rem;
    font-weight: 800;
    color: #22c55e;
    line-height: 1;
  }
  .mp-path-pct-label { font-size: 0.72rem; color: var(--text-muted); }

  /* Pin button */
  .mp-pin-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border-light);
    border-radius: 7px;
    background: #fff;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.18s;
  }
  .mp-pin-btn:hover { border-color: #fbbf24; color: #d97706; }
  .mp-pin-btn.pinned { background: #fffbeb; color: #d97706; border-color: #fcd34d; }

  /* Path meta strip */
  .mp-path-meta {
    padding: 0.6rem 1.25rem;
    background: #f8fafc;
    border-top: 1px solid var(--border-light);
    display: flex;
    gap: 1.5rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    align-items: center;
  }
  .mp-path-meta span { display: inline-flex; align-items: center; gap: 0.3rem; }
  .mp-skill-tag {
    font-size: 0.68rem;
    font-weight: 600;
    background: #f1f5f9;
    color: #475569;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    border: 1px solid #e2e8f0;
  }

  /* Progress bar in path */
  .mp-path-progress {
    padding: 0 1.25rem;
    margin: 0.65rem 0;
  }
  .mp-path-progress-bar {
    height: 5px;
    background: #f1f5f9;
    border-radius: 99px;
    overflow: hidden;
  }
  .mp-path-progress-fill {
    height: 100%;
    border-radius: 99px;
    transition: width 0.5s ease;
  }
  .fill-red  { background: linear-gradient(90deg, #ef4444, #22c55e); }
  .fill-teal { background: linear-gradient(90deg, #0d9488, #22c55e); }

  /* Toggle roadmap button */
  .mp-toggle-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.6rem;
    background: none;
    border: none;
    border-top: 1px solid var(--border-light);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    transition: background 0.18s, color 0.18s;
  }
  .mp-toggle-btn:hover { background: #f8fafc; color: var(--text-main); }

  /* Timeline wrapper */
  .mp-timeline-wrap {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .mp-timeline-wrap.open {
    max-height: 1400px;
  }
  .mp-timeline-inner {
    padding: 0.75rem 1.25rem 1rem;
    border-top: 1px dashed var(--border-light);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    position: relative;
  }
  /* Vertical connector line */
  .mp-timeline-inner::before {
    content: '';
    position: absolute;
    left: calc(1.25rem + 10px);
    top: 1.25rem;
    bottom: 1rem;
    width: 1px;
    background: var(--border-light);
    z-index: 0;
  }

  /* Timeline node */
  .mp-node {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 0.9rem;
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    position: relative;
    z-index: 1;
    transition: border-color 0.18s, box-shadow 0.18s;
  }
  .mp-node:hover { border-color: #c7d2fe; box-shadow: 0 2px 8px rgba(99,102,241,0.05); }
  .mp-node.not-enrolled { background: #fafafa; border-style: dashed; }
  .mp-node-dot {
    width: 22px; height: 22px;
    border-radius: 50%;
    border: 2px solid #cbd5e1;
    background: #fff;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 700;
    color: #64748b;
    z-index: 2;
  }
  .mp-node-dot.done    { border-color: #22c55e; color: #22c55e; }
  .mp-node-dot.active  { border-color: #6366f1; color: #6366f1; }
  .mp-node-dot.pending { border-color: #f59e0b; color: #f59e0b; }
  .mp-node-body { flex: 1; min-width: 0; }
  .mp-node-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-main);
    margin: 0 0 0.15rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .mp-node-title .n-tag {
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.08rem 0.35rem;
    border-radius: 3px;
  }
  .n-tag.basic    { background: #dcfce7; color: #15803d; }
  .n-tag.mid      { background: #e0e7ff; color: #4f46e5; }
  .n-tag.advanced { background: #ffe4e6; color: #b91c1c; }
  .n-tag.learning { background: rgba(99,102,241,0.08); color: #6366f1; border: 1px solid rgba(99,102,241,0.15); }
  .n-tag.pending  { background: rgba(245,158,11,0.08); color: #d97706; border: 1px solid rgba(245,158,11,0.15); }
  .n-tag.locked   { background: #f1f5f9; color: #94a3b8; border: 1px solid #e2e8f0; }
  .mp-node-desc { font-size: 0.75rem; color: var(--text-muted); margin: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
  .mp-node-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .mp-node-hours { font-size: 0.72rem; color: var(--text-muted); white-space: nowrap; }

  /* Shared buttons */
  .mp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.8rem;
    border-radius: 7px;
    font-size: 0.75rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.18s;
  }
  .mp-btn-primary { background: #6366f1; color: #fff; }
  .mp-btn-primary:hover { background: #4f46e5; }
  .mp-btn-outline { background: #f1f5f9; color: var(--text-main); }
  .mp-btn-outline:hover { background: #e2e8f0; }
  .mp-btn-disabled { background: #f1f5f9; color: #94a3b8; pointer-events: none; }

  /* ── Empty state ── */
  .mp-empty {
    text-align: center;
    padding: 3.5rem 2rem;
    border: 1px dashed var(--border-light);
    border-radius: 14px;
    background: #fafafa;
  }
  .mp-empty-icon { font-size: 1.75rem; color: var(--text-muted); opacity: 0.3; margin-bottom: 0.75rem; }
  .mp-empty h3 { font-size: 0.95rem; color: var(--text-main); margin: 0 0 0.35rem; }
  .mp-empty p  { font-size: 0.82rem; color: var(--text-muted); margin: 0 0 1rem; }

  @media (max-width: 640px) {
    .mp-stats { flex-direction: column; }
    .mp-stat  { border-right: none; border-bottom: 1px solid var(--border-light); }
    .mp-stat:last-child { border-bottom: none; }
    .mp-course-grid { grid-template-columns: 1fr; }
    .mp-path-head { flex-direction: column; }
    .mp-path-right { flex-direction: row; align-items: center; }
  }
</style>

<!-- ── Page header ── -->
<div class="mp-header">
  <h1 class="mp-title">Lộ Trình Học Tập Của Tôi</h1>
  <p class="mp-sub">Theo dõi các lộ trình đào tạo và danh sách khóa học của bạn trong tổ chức.</p>
</div>

<!-- ── Tab navigation ── -->
<% const defaultTab = (myCourses.length > 0) ? 'my-courses' : (electivePaths.length > 0 ? 'elective' : 'mandatory'); %>
<div class="mp-tabs" id="mp-tab-nav">
  <button id="tab-btn-my-courses"
    class="mp-tab-btn <%= defaultTab === 'my-courses' ? 'active' : '' %>"
    onclick="mpSwitchTab('my-courses')">
    <i class="fa-solid fa-graduation-cap"></i>
    Khóa học của tôi
    <span class="mp-tab-count"><%= myCourses.length %></span>
  </button>
  <button id="tab-btn-mandatory"
    class="mp-tab-btn red <%= defaultTab === 'mandatory' ? 'active red' : '' %>"
    onclick="mpSwitchTab('mandatory')">
    <i class="fa-solid fa-thumbtack"></i>
    Lộ trình bắt buộc
    <span class="mp-tab-count"><%= mandatoryPaths.length %></span>
  </button>
  <button id="tab-btn-elective"
    class="mp-tab-btn teal <%= defaultTab === 'elective' ? 'active teal' : '' %>"
    onclick="mpSwitchTab('elective')">
    <i class="fa-solid fa-compass"></i>
    Lộ trình tự chọn
    <span class="mp-tab-count"><%= electivePaths.length %></span>
  </button>
</div>

<!-- ══════════════════════════════════════════ -->
<!-- TAB 1: KHÓA HỌC CỦA TÔI                  -->
<!-- ══════════════════════════════════════════ -->
<div id="tab-my-courses" class="mp-tab-pane" style="display:<%= defaultTab === 'my-courses' ? 'block' : 'none' %>">

  <!-- Stats -->
  <div class="mp-stats">
    <div class="mp-stat">
      <div class="mp-stat-icon indigo"><i class="fa-solid fa-layer-group"></i></div>
      <div>
        <span class="mp-stat-val"><%= myCourses.length %></span>
        <span class="mp-stat-label">Khóa đã đăng ký</span>
      </div>
    </div>
    <div class="mp-stat">
      <div class="mp-stat-icon amber"><i class="fa-solid fa-spinner"></i></div>
      <div>
        <span class="mp-stat-val"><%= myCourses.filter(c => c.progress > 0 && c.progress < 100).length %></span>
        <span class="mp-stat-label">Đang tiến hành</span>
      </div>
    </div>
    <div class="mp-stat">
      <div class="mp-stat-icon green"><i class="fa-solid fa-circle-check"></i></div>
      <div>
        <span class="mp-stat-val"><%= myCourses.filter(c => c.progress === 100).length %></span>
        <span class="mp-stat-label">Đã hoàn thành</span>
      </div>
    </div>
  </div>

  <!-- Filter pills -->
  <div class="mp-filters">
    <button class="mp-pill active" onclick="mpFilter('all', this)">Tất cả</button>
    <button class="mp-pill" onclick="mpFilter('mandatory', this)">Bắt buộc</button>
    <button class="mp-pill" onclick="mpFilter('elective', this)">Tự chọn</button>
    <button class="mp-pill" onclick="mpFilter('completed', this)">Đã hoàn thành</button>
  </div>

  <% if (myCourses.length === 0) { %>
    <div class="mp-empty">
      <div class="mp-empty-icon"><i class="fa-solid fa-book-open-reader"></i></div>
      <h3>Bạn chưa đăng ký khóa học nào</h3>
      <p>Khám phá kho khóa học để bắt đầu hành trình học tập.</p>
      <a href="/courses" class="mp-btn mp-btn-primary">
        <i class="fa-solid fa-book"></i> Đến Kho Khóa Học
      </a>
    </div>
  <% } else { %>
    <div class="mp-course-grid" id="mp-course-grid">
      <% myCourses.forEach(c => { %>
        <%
          let cIcon = 'fa-book';
          let cIconBg = 'rgba(99,102,241,0.1)';
          let cIconColor = '#6366f1';
          const tl = c.title.toLowerCase();
          if      (tl.includes('aws') || tl.includes('cloud'))                            { cIcon='fa-cloud';          cIconBg='rgba(2,132,199,0.1)';   cIconColor='#0284c7'; }
          else if (tl.includes('docker') || tl.includes('devops') || tl.includes('ci/cd')){ cIcon='fa-terminal';       cIconBg='rgba(234,88,12,0.1)';   cIconColor='#ea580c'; }
          else if (tl.includes('react') || tl.includes('frontend') || tl.includes('vue')) { cIcon='fa-code';           cIconBg='rgba(6,182,212,0.1)';   cIconColor='#06b6d4'; }
          else if (tl.includes('node') || tl.includes('backend'))                         { cIcon='fa-server';         cIconBg='rgba(99,102,241,0.1)';  cIconColor='#6366f1'; }
          else if (tl.includes('git') || tl.includes('github'))                           { cIcon='fa-brands fa-github';cIconBg='rgba(15,23,42,0.08)';  cIconColor='#0f172a'; }
          else if (tl.includes('scrum') || tl.includes('agile'))                          { cIcon='fa-people-group';   cIconBg='rgba(16,185,129,0.1)'; cIconColor='#10b981'; }
          else if (tl.includes('machine') || tl.includes('ai') || tl.includes('trí tuệ')){ cIcon='fa-brain';           cIconBg='rgba(139,92,246,0.1)'; cIconColor='#8b5cf6'; }
          else if (tl.includes('giao tiếp') || tl.includes('kỹ năng'))                   { cIcon='fa-comments';        cIconBg='rgba(236,72,153,0.1)'; cIconColor='#ec4899'; }
