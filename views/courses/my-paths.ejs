          <div class="mp-timeline-inner">
            <% path.courses.forEach((c, idx) => { %>
              <%
                let diffTag = 'mid', diffText = 'Trung cấp';
                const ctl = c.title.toLowerCase();
                if (ctl.includes('cơ bản') || ctl.includes('nhập môn') || ctl.includes('scrum') || ctl.includes('agile')) { diffTag='basic'; diffText='Cơ bản'; }
                else if (ctl.includes('chuyên sâu') || ctl.includes('devops') || ctl.includes('aws') || ctl.includes('ci/cd')) { diffTag='advanced'; diffText='Nâng cao'; }
                const hrs = 8 + idx * 6 + (c.title.length % 5);
              %>
              <div class="mp-node <%= !c.isEnrolled ? 'not-enrolled' : '' %>">
                <div class="mp-node-dot <%= c.isEnrolled && c.progress === 100 ? 'done' : c.isEnrolled ? 'active' : c.isPending ? 'pending' : '' %>">
                  <% if (c.isEnrolled && c.progress === 100) { %><i class="fa-solid fa-check"></i>
                  <% } else if (c.isEnrolled) { %><i class="fa-solid fa-play" style="margin-left:1px"></i>
                  <% } else if (c.isPending) { %><i class="fa-solid fa-hourglass-start"></i>
                  <% } else { %><%= idx + 1 %>
                  <% } %>
                </div>
                <div class="mp-node-body">
                  <div class="mp-node-title">
                    <%= c.title %>
                    <span class="n-tag <%= diffTag %>"><%= diffText %></span>
                    <% if (c.isEnrolled) { %><span class="n-tag learning">Đang học (<%= c.progress %>%)</span>
                    <% } else if (c.isPending) { %><span class="n-tag pending">Chờ duyệt</span>
                    <% } else { %><span class="n-tag locked">Chưa học</span>
                    <% } %>
                  </div>
                  <p class="mp-node-desc"><%= c.description %></p>
                </div>
                <div class="mp-node-right">
                  <span class="mp-node-hours"><i class="fa-regular fa-clock"></i> <%= hrs %>h</span>
