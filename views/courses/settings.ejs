<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 1.55rem; font-weight: 700; color: var(--text-main);">
    Cài Đặt Tài Khoản
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">
    Quản lý thông tin cá nhân và thay đổi mật khẩu đăng nhập hệ thống LMS.
  </p>
</div>

<!-- Thông báo thành công / lỗi -->
<% if (success) { %>
  <div class="alert-banner alert-success" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); color: #10b981; display: flex; align-items: center; gap: 0.75rem;">
    <i class="fa-solid fa-circle-check"></i>
    <span><%= success %></span>
  </div>
<% } %>
<% if (error) { %>
  <div class="alert-banner alert-error" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #f87171; display: flex; align-items: center; gap: 0.75rem;">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span><%= error %></span>
  </div>
<% } %>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start;">
  
  <!-- Hồ sơ người dùng -->
  <div class="glass-card" style="padding: 2rem;">
    <h2 style="font-size: 1.3rem; font-weight: 700; color: #f1f5f9; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
      <i class="fa-solid fa-user-gear" style="color: #6366f1;"></i> Thông tin tài khoản
    </h2>
    
    <div style="display: flex; flex-direction: column; gap: 1.25rem;">
      <div style="display: flex; align-items: center; gap: 1.25rem; border-bottom: 1px solid var(--border-light); padding-bottom: 1.25rem;">
        <div style="width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(139,92,246,0.2)); border: 1px solid rgba(99,102,241,0.3); display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: #818cf8; font-weight: 800;">
          <%= userDetails.username.charAt(0).toUpperCase() %>
        </div>
        <div>
          <h3 style="font-size: 1.2rem; font-weight: 700; margin: 0; color: #f8fafc;"><%= userDetails.username %></h3>
          <span style="font-size: 0.8rem; color: var(--text-muted);"><%= userDetails.email %></span>
        </div>
      </div>
      
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div>
          <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; display: block;">Vai trò hiện tại</span>
          <strong style="color: #f1f5f9; font-size: 0.95rem; display: block; margin-top: 0.2rem;"><%= userDetails.role_name %></strong>
        </div>
        <div>
          <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; display: block;">Phòng ban</span>
          <strong style="color: #f1f5f9; font-size: 0.95rem; display: block; margin-top: 0.2rem;"><%= userDetails.department_name || 'Chưa chỉ định' %></strong>
        </div>
        <div>
          <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; display: block;">Trạng thái hoạt động</span>
          <strong style="color: #10b981; font-size: 0.95rem; display: block; margin-top: 0.2rem;">
            <i class="fa-solid fa-circle-check" style="margin-right: 0.2rem;"></i> Đang hoạt động
          </strong>
        </div>
        <div>
          <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; display: block;">Ngày tham gia</span>
          <strong style="color: #cbd5e1; font-size: 0.95rem; display: block; margin-top: 0.2rem;">
            <%= new Date(userDetails.created_at).toLocaleDateString('vi-VN') %>
          </strong>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Thay đổi mật khẩu -->
  <div class="glass-card" style="padding: 2rem;">
    <h2 style="font-size: 1.3rem; font-weight: 700; color: #f1f5f9; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
      <i class="fa-solid fa-lock" style="color: #a78bfa;"></i> Bảo mật & Đổi mật khẩu
    </h2>
    
    <form action="/settings/change-password" method="POST">
      <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        
        <div>
          <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;" for="oldPassword">
            Mật khẩu hiện tại
          </label>
          <input 
            type="password" 
            name="oldPassword" 
            id="oldPassword"
            placeholder="Nhập mật khẩu hiện tại"
            required
            style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none;"
          >
        </div>
        
        <div>
          <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;" for="newPassword">
            Mật khẩu mới
          </label>
          <input 
            type="password" 
            name="newPassword" 
            id="newPassword"
            placeholder="Nhập mật khẩu mới (từ 6 ký tự trở lên)"
            required
            style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none;"
          >
        </div>
        
        <div>
          <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;" for="confirmPassword">
            Xác nhận mật khẩu mới
          </label>
          <input 
            type="password" 
            name="confirmPassword" 
            id="confirmPassword"
            placeholder="Nhập lại mật khẩu mới"
            required
            style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none;"
          >
        </div>
        
        <button type="submit" class="btn btn-primary" style="padding: 0.85rem; font-size: 0.95rem; margin-top: 0.5rem;">
          <i class="fa-solid fa-key"></i> Xác nhận đổi mật khẩu
        </button>
        
      </div>
    </form>
  </div>

</div>

<script>
  // Tự động ẩn alert sau 5 giây
  setTimeout(() => {
    document.querySelectorAll('.alert-banner').forEach(el => {
      el.style.transition = 'opacity 0.5s';
      el.style.opacity = '0';
      setTimeout(() => el.remove(), 500);
    });
  }, 5000);
</script>

<%- include('../partials/footer') %>
