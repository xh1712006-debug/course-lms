<%- include('../partials/header') %>

<div style="margin-bottom: 1rem;">
  <a href="/courses/<%= courseId %>" style="font-size: 0.9rem; font-weight: 500; color: var(--text-muted);">
    <i class="fa-solid fa-chevron-left" style="font-size: 0.8rem; margin-right: 0.25rem;"></i> Quay lại danh mục khóa học
  </a>
  <h1 style="font-size: 1.8rem; font-weight: 800; margin-top: 0.5rem;"><%= lesson.title %></h1>
</div>

<div class="learning-layout">
  
  <!-- Cột bên trái: Bài giảng & Thảo luận -->
  <div>
    <!-- MOCK VIDEO PLAYER -->
    <div class="video-container">
      <video id="lesson-video" controls poster="/images/video_poster.svg">
        <source src="<%= lesson.video_url %>" type="video/mp4">
        Trình duyệt của bạn không hỗ trợ định dạng video.
      </video>
    </div>

    <!-- TABS KHU VỰC BÀI GIẢNG -->
    <div class="lesson-details">
      <div class="lesson-tab-nav">
        <button class="tab-btn active" onclick="switchTab(event, 'tab-content')">
          <i class="fa-solid fa-file-invoice"></i> Tài liệu bài học
        </button>
        <button class="tab-btn" onclick="switchTab(event, 'tab-discussion')">
          <i class="fa-solid fa-comments"></i> Thảo luận trực tuyến
        </button>
      </div>

      <!-- Tab Nội dung chi tiết bài học -->
      <div id="tab-content" class="tab-pane active glass-card" style="padding: 1.5rem;">
        <div style="white-space: pre-line; font-size: 0.95rem; color: #cbd5e1;">
          <%= lesson.content %>
        </div>
        
        <% if (lesson.attachment_url) { %>
          <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border-light); display: flex; align-items: center; justify-content: space-between;">
            <span style="font-size: 0.85rem; color: var(--text-muted);"><i class="fa-solid fa-paperclip"></i> Tài liệu đính kèm: Slide & PDF bài học</span>
            <a href="<%= lesson.attachment_url %>" class="btn btn-secondary" style="padding: 0.4rem 1rem; font-size: 0.8rem;" download>
              <i class="fa-solid fa-download"></i> Tải tài liệu
            </a>
          </div>
        <% } %>
      </div>

      <!-- Tab Thảo luận trực tuyến (WebSocket Chat) -->
      <div id="tab-discussion" class="tab-pane">
        <div class="chat-container">
          <div class="chat-messages" id="chat-messages-container">
            <% comments.forEach(c => { %>
              <div class="chat-msg">
                <div class="chat-msg-sender"><%= c.username %></div>
                <div class="chat-msg-text" style="font-size: 0.9rem;"><%= c.content %></div>
              </div>
            <% }) %>
          </div>
          
          <form id="comment-form" class="chat-input-area" onsubmit="handleSendComment(event)">
            <input type="hidden" id="lesson-id-field" value="<%= lesson.id %>">
            <input type="text" id="comment-input-field" class="chat-input" placeholder="Viết câu hỏi hoặc chia sẻ thảo luận tại đây..." required>
            <button type="submit" class="btn btn-primary" style="padding: 0.5rem 1.25rem;">
              Gửi <i class="fa-solid fa-paper-plane" style="font-size: 0.8rem;"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Cột bên phải: Danh mục bài & Trợ lý học tập AI -->
  <div style="display: flex; flex-direction: column; gap: 1.5rem;">
    
    <!-- Danh sách các bài giảng khác -->
    <div class="glass-card" style="padding: 1.25rem;">
      <h3 style="font-size: 1.1rem; margin-bottom: 1rem;"><i class="fa-solid fa-list-check" style="color: #6366f1;"></i> Danh sách bài học</h3>
      <div class="lesson-list-sidebar">
        <% lessons.forEach((l, idx) => { 
          const isLocked = idx > 0 && enrollment.progress < Math.round((idx / lessons.length) * 100);
        %>
          <% if (isLocked) { %>
            <div class="lesson-list-item locked" style="opacity: 0.5; cursor: not-allowed; display: flex; justify-content: space-between; align-items: center;" title="Bài học này đang bị khóa. Vui lòng hoàn thành các bài học trước.">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-weight: 700; font-size: 0.85rem; color: var(--text-muted);">#<%= idx + 1 %></span>
                <span style="font-size: 0.85rem; font-weight: 500; color: var(--text-muted); display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;"><%= l.title %></span>
              </div>
              <i class="fa-solid fa-lock" style="color: var(--text-muted); font-size: 0.85rem;"></i>
            </div>
          <% } else { %>
            <a href="/courses/<%= courseId %>/lessons/<%= l.id %>" class="lesson-list-item <%= l.id === lesson.id ? 'active' : '' %>">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-weight: 700; font-size: 0.85rem; color: var(--text-accent);">#<%= idx + 1 %></span>
                <span style="font-size: 0.85rem; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;"><%= l.title %></span>
              </div>
              <% if (idx < currentIdx) { %>
                <i class="fa-solid fa-circle-check" style="color: #10b981; font-size: 0.85rem;"></i>
              <% } else if (l.id === lesson.id) { %>
                <i class="fa-solid fa-circle-play" style="color: #6366f1; font-size: 0.85rem;"></i>
              <% } else { %>
                <i class="fa-solid fa-circle" style="color: var(--text-muted); font-size: 0.75rem;"></i>
              <% } %>
            </a>
          <% } %>
        <% }) %>
      </div>
      
      <!-- Cấp đề thi cuối khóa -->
      <% if (quiz) { %>
        <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border-light);">
          <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem; display: flex; justify-content: space-between;">
            <span>Tiến trình hoàn thành:</span>
            <strong><%= enrollment.progress %>%</strong>
          </div>
          <div class="progress-container" style="margin-bottom: 1rem;">
            <div class="progress-bar" style="width: <%= enrollment.progress %>%;"></div>
          </div>
          <!-- Học viên có thể thi khi đã đạt 80% tiến trình hoặc thi tự do tùy thuộc vai trò -->
          <button class="btn btn-secondary" onclick="openFinalQuizModal()" style="width: 100%; font-size: 0.85rem; background: var(--secondary-gradient); color: #fff; box-shadow: 0 4px 10px rgba(6, 182, 212, 0.3);">
            <i class="fa-solid fa-award"></i> Làm bài thi kiểm tra
          </button>
        </div>
      <% } %>
    </div>

    <!-- TRỢ LÝ AI HỌC TẬP THÔNG MINH (GEMINI INTEGRATION) -->
    <div class="glass-card ai-panel" style="padding: 1.5rem;">
      <div class="ai-header">
        <div class="ai-title">
          <i class="fa-solid fa-wand-magic-sparkles" style="color: #8b5cf6;"></i>
          <span>Trợ lý Học tập AI</span>
        </div>
        <button class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;" onclick="handleAiSummarize()">
          Tóm tắt bài học
        </button>
      </div>

      <div class="ai-body">
        <!-- AI chat box hiển thị phản hồi -->
        <div class="ai-chat-box" id="ai-chat-box">
          <div class="ai-msg assistant">
            Chào bạn! Tôi là Trợ lý AI. Bạn cần tôi giải thích thêm gì về bài học này hay làm bài trắc nghiệm nhanh không?
          </div>
        </div>

        <div style="display: flex; gap: 0.5rem; align-items: center;">
          <input type="text" id="ai-chat-input" placeholder="Hỏi AI..." style="padding: 0.4rem 0.75rem; font-size: 0.85rem;">
          <button class="btn btn-primary" onclick="handleAiSendChat()" style="padding: 0.4rem 0.75rem; font-size: 0.85rem;">
            Hỏi <i class="fa-solid fa-magnifying-glass-chart" style="font-size: 0.75rem;"></i>
          </button>
        </div>

        <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
          <button class="btn btn-secondary" style="flex: 1; font-size: 0.75rem; padding: 0.4rem;" onclick="handleAiGenerateQuiz()">
            <i class="fa-solid fa-circle-question" style="color: #06b6d4;"></i> Sinh trắc nghiệm nhanh
          </button>
          
          <% if (user.permissions.includes('QUIZ_BANK_MANAGE') && quiz) { %>
            <!-- Phím tắt sinh câu hỏi trực tiếp đưa vào ngân hàng đề thi -->
            <button class="btn btn-secondary" style="flex: 1; font-size: 0.75rem; padding: 0.4rem; border-color: rgba(139, 92, 246, 0.4);" onclick="handleAiGenerateToDb('<%= quiz.id %>')">
              <i class="fa-solid fa-database" style="color: #8b5cf6;"></i> Thêm trắc nghiệm vào DB
            </button>
          <% } %>
        </div>
      </div>
    </div>

    <!-- KHU VỰC HIỂN THỊ CÂU HỎI TRẮC NGHIỆM AI TẠO NHANH -->
    <div id="ai-quick-quiz-area" style="display: none;"></div>

  </div>
</div>

<!-- MODAL BÀI THI CUỐI KHÓA (CHỨC NĂNG THI TỰ ĐỘNG THỰC TẾ) -->
<div id="final-quiz-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; max-width: 90%; max-height: 80vh; overflow-y: auto; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
  <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 1rem; margin-bottom: 1.5rem;">
    <h3 id="modal-quiz-title" style="font-size: 1.3rem;">Bài kiểm tra cuối khóa</h3>
    <button class="btn btn-secondary" onclick="closeFinalQuizModal()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <div id="modal-quiz-questions">
    <p style="color: var(--text-muted);">Đang tải câu hỏi thi từ hệ thống...</p>
  </div>
  <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1.5rem; border-top: 1px solid var(--border-light); padding-top: 1rem;">
    <button class="btn btn-secondary" onclick="closeFinalQuizModal()">Hủy bỏ</button>
    <button class="btn btn-primary" onclick="submitFinalQuiz()">Nộp bài kiểm tra</button>
  </div>
</div>
<!-- Lớp phủ tối modal -->
<div id="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 999;" onclick="closeFinalQuizModal()"></div>

<script>
  // Chuyển đổi tab xem nội dung / Thảo luận
  function switchTab(evt, tabId) {
    const tabPanes = document.querySelectorAll('.tab-pane');
    tabPanes.forEach(pane => pane.classList.remove('active'));
    
    const tabButtons = document.querySelectorAll('.tab-btn');
    tabButtons.forEach(btn => btn.classList.remove('active'));
    
    document.getElementById(tabId).classList.add('active');
    evt.currentTarget.classList.add('active');
  }

  // Tự động mở khóa và chuyển bài khi video kết thúc
  document.addEventListener('DOMContentLoaded', () => {
    const video = document.getElementById('lesson-video');
    if (video) {
      video.onended = function() {
        const currentIdx = parseInt('<%= currentIdx %>');
        const totalLessons = parseInt('<%= lessons.length %>');
        if (currentIdx + 1 < totalLessons) {
          alert('Chúc mừng bạn đã hoàn thành bài học! Hệ thống sẽ tự động chuyển sang bài giảng tiếp theo.');
          // Tìm link bài tiếp theo trong sidebar để chuyển trang
          const links = document.querySelectorAll('.lesson-list-sidebar a');
          // Lọc ra các a tag vì có các div.locked xen kẽ
          if (links && links.length > 0) {
            // Tìm a tag kế tiếp
            let nextLink = null;
            links.forEach(link => {
              if (link.href.includes('/lessons/')) {
                const parts = link.href.split('/');
                const id = parseInt(parts[parts.length - 1]);
                if (id !== parseInt('<%= lesson.id %>') && !nextLink) {
                  // Lấy bài học đầu tiên có ID khác bài hiện tại và ở vị trí sau
                  const nextLessonId = parseInt('<%= lessons[currentIdx + 1].id %>');
                  if (id === nextLessonId) {
                    nextLink = link;
                  }
                }
              }
            });
            if (nextLink) {
              window.location.href = nextLink.href;
              return;
            }
          }
          window.location.reload();
        } else {
          alert('Chúc mừng bạn đã học xong toàn bộ bài giảng của khóa học này! Hãy tiến hành làm bài kiểm tra cuối khóa.');
          window.location.reload();
        }
      };
    }
  });
</script>
<!-- Nạp JS Xử lý trợ lý AI -->
<script src="/js/ai-assistant.js"></script>

<%- include('../partials/footer') %>
