<%- include('../partials/header') %>

<!-- CDN Libraries for Markdown Parsing & Syntax Highlighting -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/styles/github-dark.css">
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/highlight.min.js"></script>

<!-- Các thư viện CDN hỗ trợ hiển thị công thức Toán học (KaTeX) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css">
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js"></script>

<style>
  .markdown-body h1, .markdown-body h2, .markdown-body h3, .markdown-body h4 {
    color: var(--text-normal, #f8fafc);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }
  .markdown-body h1 { font-size: 1.6rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem; }
  .markdown-body h2 { font-size: 1.35rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.25rem; }
  .markdown-body h3 { font-size: 1.15rem; }
  
  .markdown-body p {
    margin-bottom: 1rem;
    line-height: 1.7;
    color: #cbd5e1;
  }
  
  .markdown-body ul, .markdown-body ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .markdown-body li {
    margin-bottom: 0.35rem;
    line-height: 1.6;
  }
  
  .markdown-body code {
    background: rgba(244, 63, 94, 0.15);
    color: #fb7185;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: 'Fira Code', 'Courier New', Courier, monospace;
    font-size: 0.85rem;
  }
  
  .markdown-body pre {
    background: #0f172a !important;
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 8px;
    padding: 1rem;
    margin: 1.25rem 0;
    overflow-x: auto;
    position: relative;
  }
  
  .markdown-body pre code {
    background: transparent !important;
    color: #e2e8f0 !important;
    padding: 0 !important;
    font-size: 0.9rem;
    line-height: 1.5;
    display: block;
  }

  .code-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #94a3b8;
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .code-copy-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
  }
</style>

<div style="margin-bottom: 1rem;">
  <a href="/courses/<%= courseId %>" style="font-size: 0.9rem; font-weight: 500; color: var(--text-muted);">
    <i class="fa-solid fa-chevron-left" style="font-size: 0.8rem; margin-right: 0.25rem;"></i> Quay lại danh mục khóa học
  </a>
  <h1 style="font-size: 1.8rem; font-weight: 800; margin-top: 0.5rem;"><%= lesson.title %></h1>
</div>

<div class="learning-layout">
  
  <!-- Cột bên trái: Bài giảng & Thảo luận -->
  <div>
    <% if (lesson.is_quiz) { %>
      <!-- GIAO DIỆN BÀI KIỂM TRA TRẮC NGHIỆM AI -->
      <div class="glass-card" style="padding: 2rem; margin-bottom: 1.5rem; border-color: var(--border-glow); background: rgba(15, 23, 42, 0.35);">
        <h2 style="font-size: 1.4rem; font-weight: 700; margin-bottom: 1rem; color: #fbbf24; display: flex; align-items: center; gap: 0.5rem;">
          <i class="fa-solid fa-circle-question"></i> Bài kiểm tra trắc nghiệm kiến thức
        </h2>
        <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); padding-bottom: 0.75rem;">
          Dựa trên nội dung các bài học trước, AI đã tự động thiết kế bộ câu hỏi trắc nghiệm gồm 10 câu để kiểm tra độ hiểu bài của bạn.
          <br>
          <strong style="color: #fb7185;"><i class="fa-solid fa-triangle-exclamation"></i> Yêu cầu bắt buộc:</strong> Bạn phải đạt điểm tuyệt đối <strong>100/100 (Trả lời đúng 10/10 câu)</strong> để mở khóa bài tiếp theo.
        </p>

        <% if (isQuizPassed) { %>
          <!-- Màn hình đã vượt qua -->
          <div style="text-align: center; padding: 2rem 1rem;">
            <div style="background: rgba(16, 185, 129, 0.1); border: 1px solid #10b981; border-radius: 50%; width: 80px; height: 80px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);">
              <i class="fa-solid fa-check fa-3x" style="color: #10b981;"></i>
            </div>
            <h3 style="font-size: 1.3rem; font-weight: 700; color: #10b981; margin-bottom: 0.5rem;">Đã Hoàn Thành Xuất Sắc!</h3>
            <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 2rem;">Bạn đã trả lời đúng 100% câu hỏi và vượt qua bài kiểm tra này thành công.</p>
            
            <% if (nextLessonId) { %>
              <a href="/courses/<%= courseId %>/lessons/<%= nextLessonId %>" class="btn btn-primary" style="padding: 0.8rem 2.5rem; font-size: 0.95rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none;">
                Học bài tiếp theo <i class="fa-solid fa-arrow-right"></i>
              </a>
            <% } else { %>
              <a href="/courses/<%= courseId %>" class="btn btn-primary" style="padding: 0.8rem 2.5rem; font-size: 0.95rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem; background: var(--primary-gradient); border: none;">
                Hoàn thành khóa học <i class="fa-solid fa-graduation-cap"></i>
              </a>
            <% } %>
          </div>
        <% } else { %>
          <!-- Màn hình làm bài thi -->
          <form id="lesson-quiz-form" onsubmit="submitLessonQuiz(event)">
            <input type="hidden" id="lesson-quiz-id" value="<%= lessonQuiz.id %>">
            <input type="hidden" id="lesson-id-field" value="<%= lesson.id %>">
            
            <div class="quiz-questions-list">
              <% lessonQuestions.forEach((q, qIdx) => { %>
                <div style="margin-bottom: 2rem; padding: 1.25rem; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border-light); border-radius: 12px; transition: border-color 0.2s;">
                  <p style="font-weight: 600; margin-bottom: 1rem; font-size: 0.95rem; line-height: 1.5; color: var(--text-main);">
                    <span style="color: #6366f1; font-weight: 800; margin-right: 0.25rem;">Câu <%= qIdx + 1 %>:</span> <%= q.question_text %>
                  </p>
                  
                  <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <% q.options.forEach((opt) => { %>
                      <label style="display: flex; align-items: center; gap: 0.75rem; background: rgba(255, 255, 255, 0.01); padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border-light); cursor: pointer; transition: all 0.2s;" class="quiz-option-label" onclick="highlightSelectedOption(this)">
                        <input type="radio" name="q-<%= q.id %>" value="<%= opt %>" required style="accent-color: #6366f1;">
                        <span style="font-size: 0.88rem; color: var(--text-normal);"><%= opt %></span>
                      </label>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>

            <div id="quiz-result-alert" style="display: none; margin-top: 1.5rem; padding: 1rem; border-radius: 8px; font-weight: 500; font-size: 0.9rem;"></div>

            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2rem; border-top: 1px solid var(--border-light); padding-top: 1.5rem;" id="quiz-actions-container">
              <button type="submit" class="btn btn-primary" id="btn-submit-lesson-quiz" style="padding: 0.8rem 2.5rem; font-size: 0.95rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem; background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%); border: none;">
                <i class="fa-solid fa-paper-plane"></i> Nộp bài kiểm tra
              </button>
            </div>
          </form>
        <% } %>
      </div>
    <% } else { %>
      <!-- MOCK VIDEO PLAYER (Chỉ hiển thị nếu bài học có Video) -->
      <% if (lesson.video_url && lesson.video_url.trim() !== '') { 
        // Hàm helper kiểm tra và trích xuất URL embed YouTube
        let ytEmbedUrl = null;
        const ytRegExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=|shorts\/)([^#\&\?]*).*/;
        const ytMatch = lesson.video_url.match(ytRegExp);
        if (ytMatch && ytMatch[2].length === 11) {
          ytEmbedUrl = `https://www.youtube.com/embed/${ytMatch[2]}?autoplay=0&rel=0`;
        }
      %>
        <div class="video-container" style="margin-bottom: 1.5rem;">
          <% if (ytEmbedUrl) { %>
            <iframe src="<%= ytEmbedUrl %>" title="YouTube video player" style="width: 100%; height: 100%; border: none;" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
          <% } else { %>
            <video id="lesson-video" controls poster="/images/video_poster.svg">
              <source src="<%= lesson.video_url %>" type="video/mp4">
              Trình duyệt của bạn không hỗ trợ định dạng video.
            </video>
          <% } %>
        </div>
      <% } %>

      <!-- TABS KHU VỰC BÀI GIẢNG -->
      <div class="lesson-details">
        <% 
          const hasContent = (lesson.content && lesson.content.trim() !== '') || (lesson.attachment_url && lesson.attachment_url.trim() !== '');
        %>
        <div class="lesson-tab-nav">
          <% if (hasContent) { %>
            <button class="tab-btn active" onclick="switchTab(event, 'tab-content')">
              <i class="fa-solid fa-file-invoice"></i> Tài liệu bài học
            </button>
            <button class="tab-btn" onclick="switchTab(event, 'tab-discussion')">
              <i class="fa-solid fa-comments"></i> Thảo luận trực tuyến
            </button>
          <% } else { %>
            <button class="tab-btn active" onclick="switchTab(event, 'tab-discussion')" style="width: 100%; border-radius: 8px;">
              <i class="fa-solid fa-comments"></i> Thảo luận trực tuyến
            </button>
          <% } %>
        </div>

        <!-- Tab Nội dung chi tiết bài học -->
        <% if (hasContent) { %>
          <div id="tab-content" class="tab-pane active glass-card" style="padding: 1.5rem;">
            <% if (lesson.content && lesson.content.trim() !== '') { %>
              <div id="raw-markdown-content" style="display: none;"><%= lesson.content %></div>
              <div id="rendered-markdown-content" class="markdown-body"></div>
            <% } %>
            
            <% if (lesson.attachment_url && lesson.attachment_url.trim() !== '') { %>
              <div class="attachment-viewer" style="<%= (lesson.content && lesson.content.trim() !== '') ? 'margin-top: 1.5rem;' : '' %>">
                <% if (lesson.attachment_url.toLowerCase().endsWith('.pdf')) { %>
                  <iframe src="<%= lesson.attachment_url %>#toolbar=0&navpanes=0&view=FitH" style="width: 100%; height: 750px; border: none; border-radius: 8px; background: #fff;" title="Tài liệu bài học"></iframe>
                <% } else if (['.png', '.jpg', '.jpeg', '.gif', '.svg', '.webp'].some(ext => lesson.attachment_url.toLowerCase().endsWith(ext))) { %>
                  <div style="text-align: center; background: rgba(0,0,0,0.1); padding: 0.5rem; border-radius: 8px; border: 1px solid var(--border-light);">
                    <img src="<%= lesson.attachment_url %>" style="max-width: 100%; max-height: 500px; border-radius: 4px;" alt="Tài liệu bài học">
                  </div>
                <% } else { %>
                  <div class="glass-card" style="padding: 1.5rem; text-align: center; border-color: rgba(255,255,255,0.05); background: rgba(255,255,255,0.01);">
                    <i class="fa-solid fa-file-zipper" style="font-size: 2.5rem; color: var(--text-muted); margin-bottom: 0.75rem;"></i>
                    <p style="margin: 0; font-size: 0.9rem; font-weight: 500;">Tài liệu đính kèm bài học</p>
                    <p style="margin: 0.25rem 0 1rem; font-size: 0.75rem; color: var(--text-muted);">Định dạng này không hỗ trợ xem trực tuyến. Vui lòng tải về máy để học tập.</p>
                    <a href="<%= lesson.attachment_url %>" class="btn btn-primary" style="padding: 0.5rem 1.5rem; font-size: 0.85rem;" download>
                      <i class="fa-solid fa-download"></i> Tải xuống tài liệu (<%= lesson.attachment_url.split('.').pop().toUpperCase() %>)
                    </a>
                  </div>
                <% } %>
              </div>
            <% } %>
          </div>
        <% } %>

        <!-- Tab Thảo luận trực tuyến (WebSocket Chat) -->
        <div id="tab-discussion" class="tab-pane <%= !hasContent ? 'active' : '' %>">
          <div class="chat-container">
            <div class="chat-messages" id="chat-messages-container">
              <% comments.forEach(c => { %>
                <div class="chat-msg">
                  <div class="chat-msg-sender"><%= c.username %></div>
                  <div class="chat-msg-text" style="font-size: 0.9rem;"><%= c.content %></div>
                </div>
              <% }) %>
            </div>
            
            <form id="comment-form" class="chat-input-area" onsubmit="handleSendComment(event)">
              <input type="hidden" id="lesson-id-field" value="<%= lesson.id %>">
              <input type="text" id="comment-input-field" class="chat-input" placeholder="Viết câu hỏi hoặc chia sẻ thảo luận tại đây..." required>
              <button type="submit" class="btn btn-primary" style="padding: 0.5rem 1.25rem;">
                Gửi <i class="fa-solid fa-paper-plane" style="font-size: 0.8rem;"></i>
              </button>
            </form>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Cột bên phải: Danh mục bài & Trợ lý học tập AI -->
  <div style="display: flex; flex-direction: column; gap: 1.5rem;">
    
    <!-- Danh sách các bài giảng khác -->
    <div class="glass-card" style="padding: 1.25rem;">
      <h3 style="font-size: 1.1rem; margin-bottom: 1rem;"><i class="fa-solid fa-list-check" style="color: #6366f1;"></i> Danh sách bài học</h3>
      <div class="lesson-list-sidebar">
        <% lessons.forEach((l, idx) => { 
          const isLocked = idx > 0 && enrollment.progress < Math.round((idx / lessons.length) * 100);
        %>
          <% if (isLocked) { %>
            <div class="lesson-list-item locked" style="opacity: 0.5; cursor: not-allowed; display: flex; justify-content: space-between; align-items: center;" title="Bài học này đang bị khóa. Vui lòng hoàn thành các bài học trước.">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-weight: 700; font-size: 0.85rem; color: var(--text-muted);">#<%= idx + 1 %></span>
                <span style="font-size: 0.85rem; font-weight: 500; color: var(--text-muted); display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;"><%= l.title %></span>
              </div>
              <i class="fa-solid fa-lock" style="color: var(--text-muted); font-size: 0.85rem;"></i>
            </div>
          <% } else { %>
            <a href="/courses/<%= courseId %>/lessons/<%= l.id %>" class="lesson-list-item <%= l.id === lesson.id ? 'active' : '' %>">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-weight: 700; font-size: 0.85rem; color: var(--text-accent);">#<%= idx + 1 %></span>
                <span style="font-size: 0.85rem; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;"><%= l.title %></span>
              </div>
              <% if (idx < currentIdx) { %>
                <i class="fa-solid fa-circle-check" style="color: #10b981; font-size: 0.85rem;"></i>
              <% } else if (l.id === lesson.id) { %>
                <i class="fa-solid fa-circle-play" style="color: #6366f1; font-size: 0.85rem;"></i>
              <% } else { %>
                <i class="fa-solid fa-circle" style="color: var(--text-muted); font-size: 0.75rem;"></i>
              <% } %>
            </a>
          <% } %>
        <% }) %>
      </div>
      
      <!-- Cấp đề thi cuối khóa -->
      <% if (quiz) { %>
        <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border-light);">
          <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.5rem; display: flex; justify-content: space-between;">
            <span>Tiến trình hoàn thành:</span>
            <strong><%= enrollment.progress %>%</strong>
          </div>
          <div class="progress-container" style="margin-bottom: 1rem;">
            <div class="progress-bar" style="width: <%= enrollment.progress %>%;"></div>
          </div>
          <!-- Học viên có thể thi khi đã đạt 80% tiến trình hoặc thi tự do tùy thuộc vai trò -->
          <button class="btn btn-secondary" onclick="openFinalQuizModal()" style="width: 100%; font-size: 0.85rem; background: var(--secondary-gradient); color: #fff; box-shadow: 0 4px 10px rgba(6, 182, 212, 0.3);">
            <i class="fa-solid fa-award"></i> Làm bài thi kiểm tra
          </button>
        </div>
      <% } %>
    </div>

    <!-- TRỢ LÝ AI HỌC TẬP THÔNG MINH (GEMINI INTEGRATION) -->
    <% if (!lesson.is_quiz) { %>
      <div class="glass-card ai-panel" style="padding: 1.5rem;">
        <div class="ai-header">
          <div class="ai-title">
            <i class="fa-solid fa-wand-magic-sparkles" style="color: #8b5cf6;"></i>
            <span>Trợ lý Học tập AI</span>
          </div>
          <button class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;" onclick="handleAiSummarize()">
            Tóm tắt bài học
          </button>
        </div>

        <div class="ai-body">
          <!-- AI chat box hiển thị phản hồi -->
          <div class="ai-chat-box" id="ai-chat-box">
            <div class="ai-msg assistant">
              Chào bạn! Tôi là Trợ lý AI. Bạn cần tôi giải thích thêm gì về bài học này hay làm bài trắc nghiệm nhanh không?
            </div>
          </div>

          <div style="display: flex; gap: 0.5rem; align-items: center;">
            <input type="text" id="ai-chat-input" placeholder="Hỏi AI..." style="padding: 0.4rem 0.75rem; font-size: 0.85rem;">
            <button class="btn btn-primary" onclick="handleAiSendChat()" style="padding: 0.4rem 0.75rem; font-size: 0.85rem;">
              Hỏi <i class="fa-solid fa-magnifying-glass-chart" style="font-size: 0.75rem;"></i>
            </button>
          </div>

          <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
            <button class="btn btn-secondary" style="flex: 1; font-size: 0.75rem; padding: 0.4rem;" onclick="handleAiGenerateQuiz()">
              <i class="fa-solid fa-circle-question" style="color: #06b6d4;"></i> Sinh trắc nghiệm nhanh
            </button>
            
            <% if (user.permissions.includes('QUIZ_BANK_MANAGE') && quiz) { %>
              <!-- Phím tắt sinh câu hỏi trực tiếp đưa vào ngân hàng đề thi -->
              <button class="btn btn-secondary" style="flex: 1; font-size: 0.75rem; padding: 0.4rem; border-color: rgba(139, 92, 246, 0.4);" onclick="handleAiGenerateToDb('<%= quiz.id %>')">
                <i class="fa-solid fa-database" style="color: #8b5cf6;"></i> Thêm trắc nghiệm vào DB
              </button>
            <% } %>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="glass-card" style="padding: 1.5rem; text-align: center; color: var(--text-muted); font-size: 0.85rem; background: rgba(15, 23, 42, 0.2);">
        <i class="fa-solid fa-lock" style="font-size: 1.5rem; color: #fbbf24; margin-bottom: 0.5rem; display: block;"></i>
        Trợ lý AI đang tạm khóa trong quá trình thực hiện bài kiểm tra.
      </div>
    <% } %>

    <!-- KHU VỰC HIỂN THỊ CÂU HỎI TRẮC NGHIỆM AI TẠO NHANH -->
    <div id="ai-quick-quiz-area" style="display: none;"></div>

  </div>
</div>

<!-- MODAL BÀI THI CUỐI KHÓA (CHỨC NĂNG THI TỰ ĐỘNG THỰC TẾ) -->
<div id="final-quiz-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; max-width: 90%; max-height: 80vh; overflow-y: auto; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
  <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 1rem; margin-bottom: 1.5rem;">
    <h3 id="modal-quiz-title" style="font-size: 1.3rem;">Bài kiểm tra cuối khóa</h3>
    <button class="btn btn-secondary" onclick="closeFinalQuizModal()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <div id="modal-quiz-questions">
    <p style="color: var(--text-muted);">Đang tải câu hỏi thi từ hệ thống...</p>
  </div>
  <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1.5rem; border-top: 1px solid var(--border-light); padding-top: 1rem;">
    <button class="btn btn-secondary" onclick="closeFinalQuizModal()">Hủy bỏ</button>
    <button class="btn btn-primary" onclick="submitFinalQuiz()">Nộp bài kiểm tra</button>
  </div>
</div>
<!-- Lớp phủ tối modal -->
<div id="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 999;" onclick="closeFinalQuizModal()"></div>

<%
  let nextLessonId = null;
  if (currentIdx + 1 < lessons.length) {
    nextLessonId = lessons[currentIdx + 1].id;
  }
%>
<script>
  // Định nghĩa các phần mở rộng cho Marked để hỗ trợ toán học KaTeX trước khi parse Markdown
  if (typeof marked !== 'undefined') {
    const blockMath = {
      name: 'blockMath',
      level: 'block',
      start(src) { return src.indexOf('$$'); },
      tokenizer(src, tokens) {
        const match = src.match(/^\$\$([\s\S]+?)\$\$/);
        if (match) {
          return {
            type: 'blockMath',
            raw: match[0],
            text: match[1].trim()
          };
        }
      },
      renderer(token) {
        try {
          // Chuẩn hóa: loại bỏ khoảng trắng sau dấu gạch chéo ngược (ví dụ \ Delta -> \Delta)
          const cleanText = token.text.replace(/\\ +([a-zA-Z]+)/g, '\\$1');
          return `<div class="katex-block">${katex.renderToString(cleanText, { displayMode: true, throwOnError: false })}</div>`;
        } catch (err) {
          return `<div class="katex-block-error">${token.raw}</div>`;
        }
      }
    };

    const inlineMath = {
      name: 'inlineMath',
      level: 'inline',
      start(src) { return src.indexOf('$'); },
      tokenizer(src, tokens) {
        const match = src.match(/^\$([^$\n]+?)\$/);
        if (match) {
          return {
            type: 'inlineMath',
            raw: match[0],
            text: match[1]
          };
        }
      },
      renderer(token) {
        try {
          // Chuẩn hóa: loại bỏ khoảng trắng sau dấu gạch chéo ngược (ví dụ \ Delta -> \Delta)
          const cleanText = token.text.replace(/\\ +([a-zA-Z]+)/g, '\\$1');
          return katex.renderToString(cleanText, { displayMode: false, throwOnError: false });
        } catch (err) {
          return token.raw;
        }
      }
    };

    marked.use({
      extensions: [blockMath, inlineMath]
    });
  }

  // Hàm bổ trợ kết xuất công thức toán học KaTeX trong một phần tử chỉ định
  function renderMath(element) {
    if (typeof renderMathInElement !== 'undefined' && element) {
      renderMathInElement(element, {
        delimiters: [
          {left: '$$', right: '$$', display: true},
          {left: '$', right: '$', display: false},
          {left: '\\(', right: '\\)', display: false},
          {left: '\\[', right: '\\]', display: true}
        ],
        throwOnError: false
      });
    }
  }

  // Chuyển đổi tab xem nội dung / Thảo luận
  function switchTab(evt, tabId) {
    const tabPanes = document.querySelectorAll('.tab-pane');
    tabPanes.forEach(pane => pane.classList.remove('active'));
    
    const tabButtons = document.querySelectorAll('.tab-btn');
    tabButtons.forEach(btn => btn.classList.remove('active'));
    
    document.getElementById(tabId).classList.add('active');
    evt.currentTarget.classList.add('active');
  }

  // Tự động mở khóa và chuyển bài khi video kết thúc
  document.addEventListener('DOMContentLoaded', () => {
    // Render Markdown bài học
    const rawMarkdownEl = document.getElementById('raw-markdown-content');
    const renderedMarkdownEl = document.getElementById('rendered-markdown-content');
    if (rawMarkdownEl && renderedMarkdownEl) {
      const rawText = rawMarkdownEl.textContent || rawMarkdownEl.innerText;
      if (typeof marked !== 'undefined') {
        marked.use({
          renderer: {
            code(code, infostring) {
              const lang = (infostring || '').match(/\S*/)[0];
              const validLang = typeof hljs !== 'undefined' && hljs.getLanguage(lang) ? lang : 'plaintext';
              const highlighted = typeof hljs !== 'undefined' 
                ? hljs.highlight(code, { language: validLang }).value 
                : code;
              return `<pre><code class="hljs language-${validLang}">${highlighted}</code></pre>`;
            }
          }
        });
        renderedMarkdownEl.innerHTML = marked.parse(rawText);
        
        // Kết xuất công thức toán học trong nội dung tài liệu!
        renderMath(renderedMarkdownEl);
        
        renderedMarkdownEl.querySelectorAll('pre').forEach((pre) => {
          pre.style.position = 'relative';
          const codeBlock = pre.querySelector('code');
          if (codeBlock) {
            const btn = document.createElement('button');
            btn.className = 'code-copy-btn';
            btn.innerHTML = '<i class="fa-regular fa-copy"></i> Copy';
            btn.onclick = () => {
              navigator.clipboard.writeText(codeBlock.innerText).then(() => {
                btn.innerHTML = '<i class="fa-solid fa-check" style="color: #10b981;"></i> Copied!';
                setTimeout(() => {
                  btn.innerHTML = '<i class="fa-regular fa-copy"></i> Copy';
                }, 2000);
              });
            };
            pre.appendChild(btn);
          }
        });
      } else {
        renderedMarkdownEl.innerText = rawText;
      }
    }

    const video = document.getElementById('lesson-video');
    if (video) {
      video.onended = function() {
        const currentIdx = parseInt('<%= currentIdx %>');
        const totalLessons = parseInt('<%= lessons.length %>');
        if (currentIdx + 1 < totalLessons) {
          alert('Chúc mừng bạn đã hoàn thành bài học! Hệ thống sẽ tự động chuyển sang bài giảng tiếp theo.');
          // Tìm link bài tiếp theo trong sidebar để chuyển trang
          const links = document.querySelectorAll('.lesson-list-sidebar a');
          // Lọc ra các a tag vì có các div.locked xen kẽ
          if (links && links.length > 0) {
            // Tìm a tag kế tiếp
            let nextLink = null;
            links.forEach(link => {
              if (link.href.includes('/lessons/')) {
                const parts = link.href.split('/');
                const id = parseInt(parts[parts.length - 1]);
                if (id !== parseInt('<%= lesson.id %>') && !nextLink) {
                  // Lấy bài học đầu tiên có ID khác bài hiện tại và ở vị trí sau
                  const nextLessonId = <%= nextLessonId !== null ? nextLessonId : 'null' %>;
                  if (id === nextLessonId) {
                    nextLink = link;
                  }
                }
              }
            });
            if (nextLink) {
              window.location.href = nextLink.href;
              return;
            }
          }
          window.location.reload();
        } else {
          alert('Chúc mừng bạn đã học xong toàn bộ bài giảng của khóa học này! Hãy tiến hành làm bài kiểm tra cuối khóa.');
          window.location.reload();
        }
      };
    }
  });
</script>
<!-- Nạp JS Xử lý trợ lý AI -->
<script src="/js/ai-assistant.js"></script>

