<%- include('../partials/header') %>

<%
// Helper to choose path icons
function getPathIcon(name) {
  const lower = name.toLowerCase();
  if (lower.includes('backend') || lower.includes('node') || lower.includes('java')) return 'fa-server';
  if (lower.includes('frontend') || lower.includes('react') || lower.includes('vue') || lower.includes('javascript')) return 'fa-code';
  if (lower.includes('devops') || lower.includes('cloud') || lower.includes('aws')) return 'fa-terminal';
  if (lower.includes('ai') || lower.includes('machine') || lower.includes('brain') || lower.includes('data')) return 'fa-brain';
  return 'fa-route';
}
%>

<style>
  /* ── Course Detail Container ── */
  .cd-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.5rem 0 2.5rem;
  }

  /* ── Premium Hero Card ── */
  .cd-hero-card {
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 20px;
    padding: 2.25rem;
    box-shadow: var(--shadow-card);
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-bottom: 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .cd-hero-card::before {
    content: '';
    position: absolute;
    top: -50px;
    left: -50px;
    width: 150px;
    height: 150px;
    background: rgba(79, 70, 229, 0.02);
    border-radius: 50%;
    filter: blur(30px);
    pointer-events: none;
  }

  .cd-img-wrapper {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 16/10;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    border: 1px solid var(--border-light);
    background: #f8fafc;
    flex-shrink: 0;
  }
  .cd-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .cd-hero-card:hover .cd-img-wrapper img {
    transform: scale(1.02);
  }

  .cd-badge-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.85rem;
  }
  .cd-badge {
    font-size: 0.68rem;
    font-weight: 800;
    padding: 0.22rem 0.65rem;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .cd-badge.published {
    background: rgba(79, 70, 229, 0.08);
    color: var(--text-accent);
    border: 1px solid rgba(79, 70, 229, 0.15);
  }
  .cd-badge.type-open {
    background: rgba(13, 148, 136, 0.08);
    color: #0f766e;
    border: 1px solid rgba(13, 148, 136, 0.15);
  }
  .cd-badge.type-restricted {
    background: rgba(245, 158, 11, 0.08);
    color: #b45309;
    border: 1px solid rgba(245, 158, 11, 0.15);
  }

  .cd-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -0.5px;
    line-height: 1.35;
    margin: 0 0 0.75rem 0;
  }
  .cd-desc {
    color: var(--text-muted);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
  }

  /* ── Enrollment Strip ── */
  .cd-enrollment-bar {
    background: #f8fafc;
    border: 1px solid var(--border-light);
    border-radius: 14px;
    padding: 1.1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .cd-status-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .cd-status-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
  }
  .cd-status-icon.pending { background: #fffbeb; color: #d97706; }
  .cd-status-icon.approved { background: #f0fdf4; color: #16a34a; }
  .cd-status-icon.none { background: #f1f5f9; color: #64748b; }
  .cd-status-icon.rejected { background: #fef2f2; color: #dc2626; }

  .cd-status-title {
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--text-main);
  }
  .cd-status-sub {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 0.1rem;
  }

  .cd-progress-wrapper {
    flex-grow: 1;
    min-width: 150px;
    max-width: 250px;
    margin-left: auto;
  }
  .cd-progress-lbl {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
  }
  .cd-progress-track {
    height: 6px;
    background: #e2e8f0;
    border-radius: 99px;
    overflow: hidden;
  }
  .cd-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #10b981, #34d399);
    border-radius: 99px;
  }

  .cd-btn-action {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.6rem 1.25rem;
    font-size: 0.82rem;
    font-weight: 700;
    border-radius: 9px;
    border: none;
    cursor: pointer;
    transition: var(--transition-smooth);
    text-decoration: none;
  }
  .cd-btn-action.primary {
    background: var(--primary-gradient);
    color: #ffffff !important;
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.15);
  }
  .cd-btn-action.primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(79, 70, 229, 0.25);
  }
  .cd-btn-action.teal {
    background: var(--secondary-gradient);
    color: #ffffff !important;
    box-shadow: 0 4px 12px rgba(13, 148, 136, 0.15);
  }
  .cd-btn-action.teal:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(13, 148, 136, 0.25);
  }
  .cd-btn-action.amber {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: #ffffff !important;
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.15);
  }
  .cd-btn-action.amber:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(245, 158, 11, 0.25);
  }
  .cd-btn-action.outline {
    background: #ffffff;
    border: 1px solid #cbd5e1;
    color: var(--text-main);
  }
  .cd-btn-action.outline:hover {
    background: #f8fafc;
    border-color: #94a3b8;
  }

  /* ── Bố cục chia hai cột chính (Grid Layout) ── */
  /* Sử dụng minmax(0, 1fr) cho cột trái để cho phép cột thu nhỏ linh hoạt
     dưới kích thước nội dung mặc định của nó, ngăn chặn việc đẩy cột phải tràn ra ngoài. */
  .cd-columns {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 350px;
    gap: 2.25rem;
    align-items: start;
  }

  @media (max-width: 992px) {
    .cd-hero-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .cd-columns {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ── Danh sách bài giảng cột trái ── */
  .cd-section-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cd-section-title i {
    color: #4f46e5;
  }

  .cd-curriculum-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  /* Khung thẻ bài giảng */
  .cd-lesson-card {
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: var(--transition-smooth);
  }
  .cd-lesson-card:hover {
    border-color: #cbd5e1;
    box-shadow: var(--shadow-hover);
    transform: translateX(3px);
  }
  .cd-lesson-card.locked {
    background: #f8fafc;
    opacity: 0.7;
    cursor: not-allowed;
  }
  
  /* Phần thông tin bài giảng bên trái trong flexbox
     Thêm flex-grow và flex-shrink để chiếm không gian tối đa nhưng co rút được
     khi cần thiết mà không phá vỡ cấu trúc flexbox. */
  .cd-lesson-left {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
    flex-grow: 1;
    flex-shrink: 1;
  }
  .cd-lesson-num {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(79, 70, 229, 0.05);
    color: #4f46e5;
    font-size: 0.85rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cd-lesson-card.locked .cd-lesson-num {
    background: #e2e8f0;
    color: #94a3b8;
  }
  
  /* Tiêu đề bài giảng
     Loại bỏ white-space: nowrap để tiêu đề tự xuống dòng khi chật hẹp,
     tránh việc giãn rộng thẻ làm vỡ khung hình ngang. */
  .cd-lesson-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0;
    white-space: normal;
    word-break: break-word;
    line-height: 1.4;
  }
  
  /* Mô tả ngắn bài giảng
     Sử dụng line-clamp để giới hạn tối đa 2 dòng văn bản nhằm giữ khung đều,
     loại bỏ nowrap để cho phép ngắt dòng tự động. */
  .cd-lesson-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    white-space: normal;
    word-break: break-word;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.5;
  }

  /* ── Right Column Sidebar Blocks ── */
  .cd-sidebar-block {
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
    margin-bottom: 1.5rem;
  }
  .cd-sidebar-title {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 1rem 0;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-bottom: 1px solid #f1f5f9;
    padding-bottom: 0.75rem;
  }
  .cd-sidebar-title i {
    color: var(--text-accent);
  }

  /* Assessment specifications */
  .cd-quiz-rules {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .cd-quiz-rules li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cd-quiz-rules i {
    color: #4f46e5;
    width: 16px;
    font-size: 0.85rem;
  }

  /* Associated Learning Paths List */
  .cd-associated-paths-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cd-path-link-card {
    background: #f8fafc;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: var(--transition-smooth);
  }
  .cd-path-link-card:hover {
    border-color: #cbd5e1;
    background: #ffffff;
    box-shadow: var(--shadow-card);
    transform: translateY(-1.5px);
  }
  .cd-path-card-icon-box {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    background: #ffffff;
    border: 1px solid var(--border-light);
    color: #4f46e5;
    flex-shrink: 0;
  }
  .cd-path-card-info {
    flex-grow: 1;
    min-width: 0;
  }
  .cd-path-card-name {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 0.15rem 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cd-path-card-step {
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .cd-path-card-chevron {
    color: var(--text-muted);
    font-size: 0.75rem;
    opacity: 0.6;
    transition: transform 0.2s ease;
  }
  .cd-path-link-card:hover .cd-path-card-chevron {
    transform: translateX(2px);
    color: #4f46e5;
    opacity: 1;
  }
</style>

<div class="cd-wrapper">
  <!-- Back Button -->
  <div style="margin-bottom: 1.25rem;">
    <a href="/courses" class="cd-btn-action outline" style="padding: 0.45rem 1rem; border-radius: 8px; font-size: 0.82rem; text-decoration: none;">
      <i class="fa-solid fa-arrow-left" style="margin-right: 0.35rem;"></i> Quay lại
    </a>
  </div>

  <!-- Course Intro Hero Section -->
  <div class="cd-hero-card">
    <div class="cd-img-wrapper">
      <img src="<%= course.image_url %>" onerror="this.onerror=null; this.src='/images/default_course.svg';" alt="<%= course.title %>">
    </div>

    <div style="min-width: 0;">
      <!-- Badges -->
      <div class="cd-badge-row">
        <span class="cd-badge published">
          <i class="fa-solid fa-circle-check"></i> Đã xuất bản
        </span>
        <% if (course.enrollment_type === 'restricted') { %>
          <span class="cd-badge type-restricted"><i class="fa-solid fa-user-lock"></i> HR phê duyệt</span>
        <% } else { %>
          <span class="cd-badge type-open"><i class="fa-solid fa-globe"></i> Tự do đăng ký</span>
        <% } %>
      </div>

      <h1 class="cd-title"><%= course.title %></h1>
      <p class="cd-desc"><%= course.description %></p>

      <!-- Enrollment Bar -->
      <div class="cd-enrollment-bar">
        <% if (enrollment) { %>
          <% if (enrollment.status === 'pending') { %>
            <div class="cd-status-info">
              <div class="cd-status-icon pending"><i class="fa-solid fa-circle-notch fa-spin"></i></div>
              <div>
                <div class="cd-status-title" style="color: #b45309;">Đang chờ HR duyệt</div>
                <div class="cd-status-sub">Yêu cầu tham gia lớp đang được xem xét.</div>
              </div>
            </div>
            <a href="/dashboard" class="cd-btn-action outline">
              <i class="fa-solid fa-house"></i> Về trang chủ
            </a>
          <% } else if (enrollment.status === 'rejected') { %>
            <div class="cd-status-info">
              <div class="cd-status-icon rejected"><i class="fa-solid fa-circle-xmark"></i></div>
              <div>
                <div class="cd-status-title" style="color: #dc2626;">Yêu cầu bị từ chối</div>
                <div class="cd-status-sub">Vui lòng trao đổi với phòng HR hoặc Admin để đăng ký lại.</div>
              </div>
            </div>
            <a href="/courses/<%= course.id %>/enroll" class="cd-btn-action primary">
              <i class="fa-solid fa-rotate"></i> Đăng ký lại
            </a>
          <% } else { %>
            <div class="cd-status-info">
              <div class="cd-status-icon approved"><i class="fa-solid fa-circle-check"></i></div>
              <div>
                <div class="cd-status-title" style="color: #16a34a;">Đã đăng ký lớp học</div>
                <div class="cd-status-sub">Chào mừng học viên trở lại!</div>
              </div>
            </div>

            <div class="cd-progress-wrapper">
              <div class="cd-progress-lbl">
                <span>Tiến độ hiện tại</span>
                <span><%= enrollment.progress %>%</span>
              </div>
              <div class="cd-progress-track">
                <div class="cd-progress-fill" style="width: <%= enrollment.progress %>%;"></div>
              </div>
            </div>

            <a href="/courses/<%= course.id %>/lessons/<%= lessons.length > 0 ? lessons[0].id : 1 %>" class="cd-btn-action teal">
              <i class="fa-solid fa-circle-play"></i> Vào học ngay
            </a>
          <% } %>
        <% } else { %>
          <% if (course.enrollment_type === 'restricted') { %>
            <div class="cd-status-info">
              <div class="cd-status-icon none"><i class="fa-solid fa-shield-halved"></i></div>
              <div>
                <div class="cd-status-title">Khóa học nội bộ giới hạn</div>
                <div class="cd-status-sub">Vui lòng gửi yêu cầu duyệt tới phòng HR để bắt đầu.</div>
              </div>
            </div>
            <a href="/courses/<%= course.id %>/enroll" class="cd-btn-action amber">
              <i class="fa-solid fa-paper-plane"></i> Gửi yêu cầu duyệt
            </a>
          <% } else { %>
            <div class="cd-status-info">
              <div class="cd-status-icon none"><i class="fa-solid fa-globe"></i></div>
              <div>
                <div class="cd-status-title">Khóa học mở tự do</div>
                <div class="cd-status-sub">Học viên có thể ghi danh và vào học ngay lập tức.</div>
              </div>
            </div>
            <a href="/courses/<%= course.id %>/enroll" class="cd-btn-action primary">
              <i class="fa-solid fa-user-plus"></i> Đăng ký học ngay
            </a>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Workspace columns -->
  <div class="cd-columns">
    
    <!-- LEFT: Lessons Index List -->
    <main>
      <h2 class="cd-section-title">
        <i class="fa-solid fa-list-check"></i> Giáo trình & Nội dung chi tiết bài học
      </h2>

      <style>
        details > summary { list-style: none; }
        details > summary::-webkit-details-marker { display: none; }
        details[open] > summary .toggle-icon { transform: rotate(180deg); }
        details > summary:hover { background: #f1f5f9 !important; }
        details .cd-lesson-card:last-child { border-bottom: none !important; }
      </style>

      <div class="cd-curriculum-list">
        <% if (!chapters || chapters.length === 0 || (chapters.length === 1 && chapters[0].lessons && chapters[0].lessons.length === 0)) { %>
          <div class="glass-card" style="padding: 3rem 2rem; text-align: center; border-style: dashed;">
            <i class="fa-solid fa-folder-open fa-2x" style="color: var(--text-muted); margin-bottom: 0.75rem; opacity: 0.4;"></i>
            <p style="color: var(--text-muted); font-size: 0.88rem; margin: 0;">
              Chưa có bài học nào được đăng tải cho khóa học này.
            </p>
          </div>
        <% } else { %>
          <% const isUnlocked = enrollment && enrollment.status === 'approved'; %>
          <% let globalLessonIndex = 1; %>
          <% chapters.forEach((chapter, chapIdx) => { %>
            <% if (chapter.lessons && chapter.lessons.length > 0 || (chapter.title && chapter.title !== 'Bài học khác')) { %>
              <details class="cd-chapter-group" style="margin-bottom: 1rem; background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.02);">
                <summary style="font-size: 1.05rem; font-weight: 700; color: var(--text-main); padding: 1rem 1.25rem; background: #f8fafc; cursor: pointer; display: flex; align-items: center; user-select: none; transition: background 0.2s;">
                  <i class="fa-solid fa-folder-open" style="color: #6366f1; margin-right: 0.75rem; font-size: 1.1rem;"></i>
                  <span style="flex: 1;"><%= chapter.title || 'Chương học' %></span>
                  <span style="font-size: 0.8rem; font-weight: 500; color: var(--text-muted); background: #e2e8f0; padding: 0.15rem 0.6rem; border-radius: 20px; margin-right: 0.75rem;">
                    <%= chapter.lessons ? chapter.lessons.length : 0 %> bài học
                  </span>
                  <i class="fa-solid fa-chevron-down toggle-icon" style="color: var(--text-muted); font-size: 0.85rem; transition: transform 0.3s;"></i>
                </summary>
                
                <div class="cd-chapter-lessons" style="display: flex; flex-direction: column; gap: 0; padding: 0;">
                  <% if (chapter.lessons && chapter.lessons.length > 0) { %>
                    <% chapter.lessons.forEach((lesson, index) => { %>
                      <div class="cd-lesson-card <%= !isUnlocked ? 'locked' : '' %>" style="margin-bottom: 0; border-radius: 0; border: none; border-bottom: 1px solid #f1f5f9; padding: 1rem 1.25rem; box-shadow: none;">
                        <div class="cd-lesson-left">
                          <span class="cd-lesson-num" style="background: rgba(99, 102, 241, 0.1); color: #4f46e5;">#<%= globalLessonIndex++ %></span>
                          <div style="min-width: 0;">
                            <h4 class="cd-lesson-title"><%= lesson.title %></h4>
                            <p class="cd-lesson-desc">
                              <% if (lesson.is_quiz) { %>
                                <span style="color: #d97706; font-weight: 700;"><i class="fa-solid fa-circle-question"></i> Bài kiểm tra trắc nghiệm</span>
                              <% } else { %>
                                <%= lesson.content || 'Không có mô tả chi tiết cho bài giảng này.' %>
                              <% } %>
                            </p>
                          </div>
                        </div>

                        <div>
                          <% if (isUnlocked) { %>
                            <a href="/courses/<%= course.id %>/lessons/<%= lesson.id %>" class="cd-btn-action outline" style="padding: 0.4rem 0.85rem; font-size: 0.75rem;">
                              Vào xem <i class="fa-solid fa-chevron-right" style="font-size: 0.65rem;"></i>
                            </a>
                          <% } else { %>
                            <i class="fa-solid fa-lock" style="color: var(--text-muted); font-size: 0.88rem; padding-right: 0.5rem;" title="Đăng ký học để mở khóa bài học này"></i>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <div style="padding: 1.5rem; text-align: center;">
                      <p style="color: var(--text-muted); font-size: 0.85rem; font-style: italic; margin: 0;">Chưa có bài học nào trong thư mục này.</p>
                    </div>
                  <% } %>
                </div>
              </details>
            <% } %>
          <% }) %>
        <% } %>
      </div>
    </main>

    <!-- RIGHT: Sidebar Cards (Quiz specs & Associated Paths) -->
    <aside>
      <!-- Final Assessment Card -->
      <div class="cd-sidebar-block">
        <h3 class="cd-sidebar-title"><i class="fa-solid fa-award"></i> Đánh giá cuối khóa</h3>
        <% if (!quiz) { %>
          <div style="text-align: center; padding: 0.5rem 0;">
            <i class="fa-solid fa-circle-info" style="color: var(--text-muted); opacity: 0.5; font-size: 1.5rem; margin-bottom: 0.4rem; display: block;"></i>
            <p style="color: var(--text-muted); font-size: 0.78rem; margin: 0; line-height: 1.4;">Khóa học này chưa thiết lập bài kiểm tra trắc nghiệm cuối khóa.</p>
          </div>
        <% } else { %>
          <h4 style="font-weight: 700; font-size: 0.9rem; color: var(--text-main); margin-bottom: 0.75rem;"><%= quiz.title %></h4>
          <ul class="cd-quiz-rules">
            <li>
              <i class="fa-solid fa-clock"></i>
              <span>Thời gian giới hạn: <strong><%= quiz.duration_minutes %> phút</strong></span>
            </li>
            <li>
              <i class="fa-solid fa-circle-check"></i>
              <span>Loại hình: <strong>Trắc nghiệm tự động</strong></span>
            </li>
            <li>
              <i class="fa-solid fa-trophy"></i>
              <span>Điểm đạt tối thiểu: <strong><%= quiz.passing_score %>/100</strong></span>
            </li>
          </ul>

          <% if (isUnlocked) { %>
            <a href="/courses/<%= course.id %>/lessons/<%= lessons.length > 0 ? lessons[0].id : 1 %>" class="cd-btn-action primary" style="width: 100%; justify-content: center; font-size: 0.8rem; padding: 0.55rem;">
              <i class="fa-solid fa-graduation-cap"></i> Vào học để mở thi
            </a>
          <% } else { %>
            <button class="cd-btn-action outline" style="width: 100%; justify-content: center; font-size: 0.8rem; padding: 0.55rem; cursor: not-allowed; opacity: 0.6;" disabled>
              <i class="fa-solid fa-lock"></i> Đăng ký để mở thi
            </button>
          <% } %>
        <% } %>
      </div>


    </aside>

  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Tự động thu nhỏ menu sidebar khi vào trang chi tiết khóa học
    if (!document.body.classList.contains('sidebar-collapsed')) {
      document.body.classList.add('sidebar-collapsed');
      localStorage.setItem('main-sidebar-collapsed', 'true');
    }
  });
</script>

<%- include('../partials/footer') %>
