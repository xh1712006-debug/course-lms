<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
    <a href="/dashboard" style="color: var(--text-muted); text-decoration:none; font-size: 0.85rem; display:flex; align-items:center; gap:0.4rem; transition: color 0.15s;" onmouseover="this.style.color='var(--text-accent)'" onmouseout="this.style.color='var(--text-muted)'">
      <i class="fa-solid fa-chevron-left"></i> Bảng điều khiển
    </a>
  </div>
  <h1 style="font-size: 2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
    Bài Kiểm Tra Của Tôi
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">Danh sách các bài kiểm tra năng lực được giao từ công ty.</p>
</div>

<% if (assessments.length === 0) { %>
  <div class="glass-card" style="text-align: center; padding: 5rem 2rem; color: var(--text-muted);">
    <i class="fa-solid fa-clipboard-check" style="font-size: 4rem; color: #374151; margin-bottom: 1.5rem; display: block;"></i>
    <h3 style="color: #6b7280; margin-bottom: 0.5rem;">Chưa có bài kiểm tra nào</h3>
    <p style="font-size: 0.9rem;">Bộ phận L&D chưa giao bài kiểm tra cho bạn. Hãy tiếp tục học các khóa học!</p>
    <a href="/courses" class="btn btn-primary" style="margin-top: 1.5rem; display: inline-block;">
      <i class="fa-solid fa-graduation-cap" style="margin-right: 0.5rem;"></i> Xem Khóa Học
    </a>
  </div>
<% } else { %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem;">
    <% assessments.forEach(a => {
      const isSubmitted = !!a.submission_id;
      const isNotStarted = a.start_time && new Date(a.start_time) > new Date() && !isSubmitted;
      const isExpired = a.deadline && new Date(a.deadline) < new Date() && !isSubmitted;
    %>
    <div class="glass-card" style="padding: 1.75rem; display: flex; flex-direction: column; gap: 1rem; position: relative; overflow: hidden;
      <%= isSubmitted ? 'border-color: rgba(16,185,129,0.3);' : isNotStarted ? 'border-color: rgba(156,163,175,0.3); opacity:0.85;' : isExpired ? 'border-color: rgba(239,68,68,0.3); opacity:0.75;' : 'border-color: var(--border-glow);' %>">

      <!-- Badge trạng thái -->
      <div style="position: absolute; top: 1rem; right: 1rem;">
        <% if (isSubmitted) { %>
          <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(52,211,153,0.3);;">
            <i class="fa-solid fa-check-circle"></i> Đã nộp
          </span>
        <% } else if (isNotStarted) { %>
          <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; background: rgba(156,163,175,0.15); color: #9ca3af; border: 1px solid rgba(156,163,175,0.3);">
            <i class="fa-solid fa-lock"></i> Chưa mở
          </span>
        <% } else if (isExpired) { %>
          <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; background: rgba(239,68,68,0.12); color: #fca5a5; border: 1px solid rgba(239,68,68,0.3);">
            <i class="fa-solid fa-clock-rotate-left"></i> Hết hạn
          </span>
        <% } else { %>
          <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3);">
            <i class="fa-solid fa-circle-dot"></i> Chờ làm bài
          </span>
        <% } %>
      </div>

      <!-- Icon & Tiêu đề -->
      <div style="display: flex; align-items: flex-start; gap: 1rem; padding-right: 4rem;">
        <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, rgba(99,102,241,0.2), rgba(139,92,246,0.2)); border: 1px solid rgba(99,102,241,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
          <i class="fa-solid fa-file-pen" style="color: #8b5cf6; font-size: 1.1rem;"></i>
        </div>
        <div>
          <h3 style="font-size: 1rem; font-weight: 700; margin: 0 0 0.3rem; line-height: 1.3;"><%= a.title %></h3>
          <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;">Tạo bởi: <%= a.creator_name || 'L&D Team' %></p>
        </div>
      </div>

      <!-- Thống kê -->
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem;">
        <div style="text-align: center; padding: 0.6rem; background: rgba(255,255,255,0.03); border-radius: 8px; border: 1px solid var(--border-light);">
          <div style="font-size: 1.1rem; font-weight: 800; color: #a5b4fc;"><%= a.question_count %></div>
          <div style="font-size: 0.7rem; color: var(--text-muted);">câu hỏi</div>
        </div>
        <div style="text-align: center; padding: 0.6rem; background: rgba(255,255,255,0.03); border-radius: 8px; border: 1px solid var(--border-light);">
          <div style="font-size: 1.1rem; font-weight: 800; color: #6ee7b7;"><%= a.duration_minutes %></div>
          <div style="font-size: 0.7rem; color: var(--text-muted);">phút</div>
        </div>
        <div style="text-align: center; padding: 0.6rem; background: rgba(255,255,255,0.03); border-radius: 8px; border: 1px solid var(--border-light);">
          <div style="font-size: 1.1rem; font-weight: 800; color: #fbbf24;"><%= a.passing_score %>%</div>
          <div style="font-size: 0.7rem; color: var(--text-muted);">điểm đạt</div>
        </div>
      </div>

      <!-- Thời gian mở và hạn nộp -->
      <div style="display: flex; flex-direction: column; gap: 0.3rem;">
        <% if (a.start_time) { %>
        <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: <%= isNotStarted ? '#a5b4fc' : 'var(--text-muted)' %>;">
          <i class="fa-regular fa-calendar-check"></i>
          Thời gian mở: <strong><%= new Date(a.start_time).toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></strong>
        </div>
        <% } %>
        <% if (a.deadline) { %>
        <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: <%= isExpired ? '#fca5a5' : 'var(--text-muted)' %>;">
          <i class="fa-regular fa-calendar-xmark"></i>
          Hạn nộp: <strong><%= new Date(a.deadline).toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></strong>
        </div>
        <% } %>
      </div>

      <!-- Kết quả nếu đã làm -->
      <% if (isSubmitted) { %>
      <div style="padding: 0.75rem 1rem; background: <%= parseFloat(a.score) >= a.passing_score ? 'rgba(16,185,129,0.1)' : 'rgba(239,68,68,0.1)' %>; border-radius: 8px; border: 1px solid <%= parseFloat(a.score) >= a.passing_score ? 'rgba(52,211,153,0.3)' : 'rgba(239,68,68,0.3)' %>; display: flex; align-items: center; justify-content: space-between;">
        <div>
          <div style="font-size: 0.78rem; color: var(--text-muted);">Kết quả của bạn</div>
          <div style="font-size: 1.3rem; font-weight: 800; color: <%= parseFloat(a.score) >= a.passing_score ? '#34d399' : '#f87171' %>;">
            <%= parseFloat(a.score).toFixed(1) %>%
            <span style="font-size: 0.8rem; font-weight: 600;">— <%= a.is_passed ? '✅ Đạt' : '❌ Chưa đạt' %></span>
          </div>
        </div>
        <i class="fa-solid fa-<%= a.is_passed ? 'trophy' : 'circle-xmark' %>" style="font-size: 1.5rem; color: <%= a.is_passed ? '#fbbf24' : '#f87171' %>;"></i>
      </div>
      <% } %>

      <!-- Nút hành động -->
      <div style="margin-top: auto;">
        <% if (isSubmitted) { %>
          <a href="/assessments/<%= a.id %>/result" class="btn btn-primary" style="width: 100%; display: block; text-align: center; text-decoration: none; padding: 0.7rem;">
            <i class="fa-solid fa-chart-bar" style="margin-right: 0.4rem;"></i> Xem Kết Quả Chi Tiết
          </a>
        <% } else if (isNotStarted) { %>
          <button class="btn" disabled style="width: 100%; opacity: 0.6; cursor: not-allowed; background: var(--border-light); color: var(--text-muted); border: 1px solid var(--border-light); padding: 0.7rem;">
            <i class="fa-solid fa-lock" style="margin-right: 0.4rem;"></i> Chưa đến giờ làm bài
          </button>
        <% } else if (isExpired) { %>
          <button class="btn" disabled style="width: 100%; opacity: 0.5; cursor: not-allowed;">
            <i class="fa-solid fa-lock" style="margin-right: 0.4rem;"></i> Bài kiểm tra đã hết hạn
          </button>
        <% } else { %>
          <a href="/assessments/<%= a.id %>/take" class="btn btn-primary" style="width: 100%; display: block; text-align: center; text-decoration: none; padding: 0.7rem;"
            onclick="return confirm('Bạn sắp bắt đầu bài kiểm tra này. Sau khi bắt đầu, bộ đếm thời gian sẽ chạy. Bạn có sẵn sàng không?')">
            <i class="fa-solid fa-play" style="margin-right: 0.4rem;"></i> Bắt Đầu Làm Bài
          </a>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
