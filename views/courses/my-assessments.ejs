<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
    <a href="/dashboard" style="color: var(--text-muted); text-decoration:none; font-size: 0.85rem; display:flex; align-items:center; gap:0.4rem; transition: color 0.15s;" onmouseover="this.style.color='var(--text-accent)'" onmouseout="this.style.color='var(--text-muted)'">
      <i class="fa-solid fa-chevron-left"></i> Bảng điều khiển
    </a>
  </div>
  <h1 style="font-size: 2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
    Bài Kiểm Tra Của Tôi
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">Danh sách các bài kiểm tra năng lực được giao từ công ty.</p>
</div>

<% if (assessments.length === 0) { %>
  <div class="glass-card" style="text-align: center; padding: 5rem 2rem; color: var(--text-muted);">
    <i class="fa-solid fa-clipboard-check" style="font-size: 4rem; color: #374151; margin-bottom: 1.5rem; display: block;"></i>
    <h3 style="color: #6b7280; margin-bottom: 0.5rem;">Chưa có bài kiểm tra nào</h3>
    <p style="font-size: 0.9rem;">Bộ phận L&D chưa giao bài kiểm tra cho bạn. Hãy tiếp tục học các khóa học!</p>
    <a href="/courses" class="btn btn-primary" style="margin-top: 1.5rem; display: inline-block;">
      <i class="fa-solid fa-graduation-cap" style="margin-right: 0.5rem;"></i> Xem Khóa Học
    </a>
  </div>
<% } else { %>
  <%
    const ongoing = assessments.filter(a => !a.submission_id);
    const completed = assessments.filter(a => !!a.submission_id);
  %>

  <style>
    .assessment-tabs {
      display: flex;
      gap: 1rem;
      border-bottom: 1px solid var(--border-light);
      margin-bottom: 1.5rem;
      padding-bottom: 0.25rem;
    }
    .assessment-tab-btn {
      background: none;
      border: none;
      padding: 0.75rem 1.25rem;
      font-family: var(--font-title);
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--text-muted);
      cursor: pointer;
      position: relative;
      transition: var(--transition-smooth);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      border-radius: 8px 8px 0 0;
    }
    .assessment-tab-btn:hover {
      color: var(--text-accent);
      background: rgba(79, 70, 229, 0.04);
    }
    .assessment-tab-btn.active {
      color: var(--text-accent);
    }
    .assessment-tab-btn.active::after {
      content: '';
      position: absolute;
      bottom: -5px;
      left: 0;
      width: 100%;
      height: 3px;
      background: var(--primary-gradient);
      border-radius: 3px;
    }
    .tab-badge {
      font-size: 0.75rem;
      font-weight: 600;
      padding: 0.15rem 0.5rem;
      border-radius: 20px;
      color: #fff;
      transition: var(--transition-smooth);
    }
    .tab-badge.ongoing {
      background: var(--alert-gradient);
    }
    .tab-badge.completed {
      background: var(--secondary-gradient);
    }
    
    .assessment-card {
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: relative;
      overflow: hidden;
      background: var(--bg-card);
      border: 1px solid var(--border-light);
      border-radius: 16px;
      box-shadow: var(--shadow-card);
      transition: var(--transition-smooth);
    }
    .assessment-card:hover {
      transform: translateY(-3px);
      border-color: var(--border-glow);
      box-shadow: var(--shadow-hover);
    }
  </style>

  <!-- Tabs Navigation -->
  <div class="assessment-tabs">
    <button class="assessment-tab-btn active" id="ongoing-btn" onclick="switchAssessmentTab('ongoing')">
      <i class="fa-solid fa-hourglass-half"></i> Đang tiến hành
      <span class="tab-badge ongoing"><%= ongoing.length %></span>
    </button>
    <button class="assessment-tab-btn" id="completed-btn" onclick="switchAssessmentTab('completed')">
      <i class="fa-solid fa-circle-check"></i> Đã hoàn thành
      <span class="tab-badge completed"><%= completed.length %></span>
    </button>
  </div>

  <!-- Tab Content: Ongoing -->
  <div id="ongoing-tab" class="assessment-tab-content">
    <% if (ongoing.length === 0) { %>
      <div style="text-align: center; padding: 3rem 1rem;">
        <i class="fa-solid fa-circle-check fa-3x" style="color: #10b981; margin-bottom: 1rem;"></i>
        <h3 style="color: var(--text-main); margin-bottom: 0.5rem; font-weight: 700; font-size: 1.1rem;">Không có bài kiểm tra nào cần làm</h3>
        <p style="color: var(--text-muted); font-size: 0.95rem;">Tuyệt vời! Bạn đã hoàn thành tất cả các bài kiểm tra được giao.</p>
      </div>
    <% } else { %>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem;">
        <% ongoing.forEach(a => {
          const isNotStarted = a.start_time && new Date(a.start_time) > new Date();
          const isExpired = a.deadline && new Date(a.deadline) < new Date();
        %>
          <div class="assessment-card" style="<%= isNotStarted ? 'border-color: rgba(156,163,175,0.3); opacity:0.85;' : isExpired ? 'border-color: rgba(239,68,68,0.3); opacity:0.75;' : '' %>">
            <!-- Badge trạng thái -->
            <div style="position: absolute; top: 1.25rem; right: 1.25rem;">
              <% if (isNotStarted) { %>
                <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; background: rgba(156,163,175,0.15); color: var(--text-muted); border: 1px solid rgba(156,163,175,0.3);">
                  <i class="fa-solid fa-lock"></i> Chưa mở
                </span>
              <% } else if (isExpired) { %>
                <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; background: rgba(239,68,68,0.12); color: #ef4444; border: 1px solid rgba(239,68,68,0.3);">
                  <i class="fa-solid fa-clock-rotate-left"></i> Hết hạn
                </span>
              <% } else { %>
                <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; background: rgba(245,158,11,0.15); color: #d97706; border: 1px solid rgba(251,191,36,0.3);">
                  <i class="fa-solid fa-circle-dot"></i> Chờ làm bài
                </span>
              <% } %>
            </div>

            <!-- Icon & Tiêu đề -->
            <div style="display: flex; align-items: flex-start; gap: 1rem; padding-right: 5rem;">
              <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(139,92,246,0.1)); border: 1px solid rgba(99,102,241,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <i class="fa-solid fa-file-pen" style="color: #6366f1; font-size: 1.1rem;"></i>
              </div>
              <div>
                <h3 style="font-size: 1.05rem; font-weight: 700; margin: 0 0 0.3rem; line-height: 1.3; color: var(--text-main);"><%= a.title %></h3>
                <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;">Tạo bởi: <strong><%= a.creator_name || 'L&D Team' %></strong></p>
              </div>
            </div>

            <!-- Thống kê -->
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-top: 0.25rem;">
              <div style="text-align: center; padding: 0.6rem; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border-light);">
                <div style="font-size: 1.1rem; font-weight: 800; color: #4f46e5;"><%= a.question_count %></div>
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">câu hỏi</div>
              </div>
              <div style="text-align: center; padding: 0.6rem; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border-light);">
                <div style="font-size: 1.1rem; font-weight: 800; color: #0d9488;"><%= a.duration_minutes %></div>
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">phút</div>
              </div>
              <div style="text-align: center; padding: 0.6rem; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border-light);">
                <div style="font-size: 1.1rem; font-weight: 800; color: #d97706;"><%= a.passing_score %>%</div>
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">điểm đạt</div>
              </div>
            </div>

            <!-- Thời gian mở và hạn nộp -->
            <div style="display: flex; flex-direction: column; gap: 0.3rem; margin-top: 0.25rem;">
              <% if (a.start_time) { %>
                <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: <%= isNotStarted ? '#4f46e5' : 'var(--text-muted)' %>;">
                  <i class="fa-regular fa-calendar-check"></i>
                  Thời gian mở: <strong><%= new Date(a.start_time).toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></strong>
                </div>
              <% } %>
              <% if (a.deadline) { %>
                <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: <%= isExpired ? '#ef4444' : 'var(--text-muted)' %>;">
                  <i class="fa-regular fa-calendar-xmark"></i>
                  Hạn nộp: <strong><%= new Date(a.deadline).toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></strong>
                </div>
              <% } %>
            </div>

            <!-- Nút hành động -->
            <div style="margin-top: auto; padding-top: 0.5rem;">
              <% if (isNotStarted) { %>
                <button class="btn" disabled style="width: 100%; opacity: 0.6; cursor: not-allowed; background: #cbd5e1; color: #64748b; border: 1px solid #cbd5e1; padding: 0.7rem;">
                  <i class="fa-solid fa-lock" style="margin-right: 0.4rem;"></i> Chưa đến giờ làm bài
                </button>
              <% } else if (isExpired) { %>
                <button class="btn" disabled style="width: 100%; opacity: 0.5; cursor: not-allowed; background: #f8fafc; border: 1px solid var(--border-light); color: var(--text-muted); padding: 0.7rem;">
                  <i class="fa-solid fa-lock" style="margin-right: 0.4rem;"></i> Bài kiểm tra đã hết hạn
                </button>
              <% } else { %>
                <a href="/assessments/<%= a.id %>/take" class="btn btn-primary" style="width: 100%; display: block; text-align: center; text-decoration: none; padding: 0.7rem;"
                  onclick="return confirm('Bạn sắp bắt đầu bài kiểm tra này. Sau khi bắt đầu, bộ đếm thời gian sẽ chạy. Bạn có sẵn sàng không?')">
                  <i class="fa-solid fa-play" style="margin-right: 0.4rem;"></i> Bắt Đầu Làm Bài
                </a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Tab Content: Completed -->
  <div id="completed-tab" class="assessment-tab-content" style="display: none;">
    <% if (completed.length === 0) { %>
      <div style="text-align: center; padding: 3rem 1rem;">
        <i class="fa-solid fa-circle-exclamation fa-3x" style="color: #cbd5e1; margin-bottom: 1rem; display: block;"></i>
        <h3 style="color: var(--text-main); margin-bottom: 0.5rem; font-weight: 700; font-size: 1.1rem;">Chưa hoàn thành bài kiểm tra nào</h3>
        <p style="color: var(--text-muted); font-size: 0.95rem;">Hãy hoàn thành các bài thi được giao ở tab "Đang tiến hành".</p>
      </div>
    <% } else { %>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem;">
        <% completed.forEach(a => { %>
          <div class="assessment-card" style="border-color: rgba(16,185,129,0.3);">
            <!-- Badge trạng thái -->
            <div style="position: absolute; top: 1.25rem; right: 1.25rem;">
              <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid rgba(16,185,129,0.2);">
                <i class="fa-solid fa-check-circle"></i> Đã nộp
              </span>
            </div>

            <!-- Icon & Tiêu đề -->
            <div style="display: flex; align-items: flex-start; gap: 1rem; padding-right: 5rem;">
              <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(20,184,166,0.1)); border: 1px solid rgba(16,185,129,0.2); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <i class="fa-solid fa-clipboard-check" style="color: #10b981; font-size: 1.1rem;"></i>
              </div>
              <div>
                <h3 style="font-size: 1.05rem; font-weight: 700; margin: 0 0 0.3rem; line-height: 1.3; color: var(--text-main);"><%= a.title %></h3>
                <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;">Tạo bởi: <strong><%= a.creator_name || 'L&D Team' %></strong></p>
              </div>
            </div>

            <!-- Thống kê -->
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-top: 0.25rem;">
              <div style="text-align: center; padding: 0.6rem; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border-light);">
                <div style="font-size: 1.1rem; font-weight: 800; color: #4f46e5;"><%= a.question_count %></div>
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">câu hỏi</div>
              </div>
              <div style="text-align: center; padding: 0.6rem; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border-light);">
                <div style="font-size: 1.1rem; font-weight: 800; color: #0d9488;"><%= a.duration_minutes %></div>
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">phút</div>
              </div>
              <div style="text-align: center; padding: 0.6rem; background: #f8fafc; border-radius: 8px; border: 1px solid var(--border-light);">
                <div style="font-size: 1.1rem; font-weight: 800; color: #d97706;"><%= a.passing_score %>%</div>
                <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 500;">điểm đạt</div>
              </div>
            </div>

            <!-- Kết quả làm bài -->
            <div style="padding: 0.75rem 1rem; background: <%= parseFloat(a.score) >= a.passing_score ? 'rgba(16,185,129,0.06)' : 'rgba(239,68,68,0.06)' %>; border-radius: 8px; border: 1px solid <%= parseFloat(a.score) >= a.passing_score ? 'rgba(16,185,129,0.15)' : 'rgba(239,68,68,0.15)' %>; display: flex; align-items: center; justify-content: space-between; margin-top: 0.25rem;">
              <div>
                <div style="font-size: 0.78rem; color: var(--text-muted); font-weight: 500;">Kết quả của bạn</div>
                <div style="font-size: 1.25rem; font-weight: 800; color: <%= parseFloat(a.score) >= a.passing_score ? '#10b981' : '#ef4444' %>;">
                  <%= parseFloat(a.score).toFixed(1) %>%
                  <span style="font-size: 0.8rem; font-weight: 600;">— <%= a.is_passed ? '✅ Đạt' : '❌ Chưa đạt' %></span>
                </div>
              </div>
              <i class="fa-solid fa-<%= a.is_passed ? 'trophy' : 'circle-xmark' %>" style="font-size: 1.4rem; color: <%= a.is_passed ? '#fbbf24' : '#ef4444' %>;"></i>
            </div>

            <!-- Nút hành động -->
            <div style="margin-top: auto; padding-top: 0.5rem;">
              <a href="/assessments/<%= a.id %>/result" class="btn btn-primary" style="width: 100%; display: block; text-align: center; text-decoration: none; padding: 0.7rem;">
                <i class="fa-solid fa-chart-bar" style="margin-right: 0.4rem;"></i> Xem Kết Quả Chi Tiết
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
<% } %>

<script>
  function switchAssessmentTab(tabName) {
    document.querySelectorAll('.assessment-tab-content').forEach(el => {
      el.style.display = 'none';
    });
    document.querySelectorAll('.assessment-tab-btn').forEach(btn => {
      btn.classList.remove('active');
    });
    
    document.getElementById(tabName + '-tab').style.display = 'block';
    document.getElementById(tabName + '-btn').classList.add('active');
  }
</script>

<%- include('../partials/footer') %>
