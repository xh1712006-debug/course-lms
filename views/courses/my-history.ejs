<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 1.55rem; font-weight: 700; color: var(--text-main);">
    Lịch Sử & Thành Tựu
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">
    Xem lại kết quả thi và lời phê của giảng viên về các bài thi của bạn.
  </p>
</div>

<div style="display: grid; grid-template-columns: minmax(0, 1fr); gap: 2rem; align-items: start;">
  
  <!-- Cột trái: Lịch sử thi -->
  <div class="glass-card" style="padding: 2rem;">
    <h2 style="font-size: 1.3rem; font-weight: 700; color: var(--text-main); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
      <i class="fa-solid fa-clock-rotate-left" style="color: #8b5cf6;"></i> Nhật ký thi và kiểm tra
    </h2>
    
    <% if (submissions.length === 0) { %>
      <div style="text-align: center; padding: 3rem 1rem;">
        <i class="fa-solid fa-square-poll-vertical fa-3x" style="color: var(--text-muted); margin-bottom: 1rem;"></i>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Bạn chưa thực hiện bài thi cuối khóa nào.</p>
      </div>
    <% } else { %>
      <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        <% submissions.forEach(sub => { %>
          <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-light); border-radius: 12px; padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap;">
              <div>
                <h4 style="font-size: 1.05rem; font-weight: 700; margin: 0; color: var(--text-main);"><%= sub.quiz_title %></h4>
                <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0.25rem 0 0 0;">
                  Khóa học: <strong><%= sub.course_title %></strong>
                </p>
                <span style="font-size: 0.75rem; color: var(--text-muted);">
                  Thời gian nộp: <%= new Date(sub.created_at).toLocaleString('vi-VN') %>
                </span>
              </div>
              
              <div style="text-align: right; flex-shrink: 0;">
                <% if (sub.score === null || typeof sub.score === 'undefined') { %>
                  <span class="btn" style="padding: 0.3rem 0.75rem; font-size: 0.75rem; cursor: default; background: rgba(245,158,11,0.1); color: #f59e0b; border: 1px solid #f59e0b; display: inline-flex; align-items: center; gap: 0.25rem;">
                    <i class="fa-solid fa-spinner fa-spin"></i> Chờ chấm điểm
                  </span>
                <% } else { %>
                  <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem;">
                    <span style="font-size: 1.4rem; font-weight: 800; <%= sub.is_passed ? 'color: #10b981;' : 'color: #f87171;' %>">
                      <%= sub.score %> / 100
                    </span>
                    <span style="font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 6px; <%= sub.is_passed ? 'background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid #10b981;' : 'background: rgba(239,68,68,0.1); color: #f87171; border: 1px solid #ef4444;' %>">
                      <%= sub.is_passed ? 'ĐẠT YÊU CẦU' : 'CHƯA ĐẠT' %>
                    </span>
                  </div>
                <% } %>
              </div>
            </div>
            
            <% if (sub.grade_feedback) { %>
              <div style="padding: 0.75rem 1rem; background: rgba(139, 92, 246, 0.05); border-left: 3px solid #8b5cf6; border-radius: 6px; font-size: 0.85rem; color: var(--text-muted);">
                <div style="font-weight: 700; color: #a78bfa; margin-bottom: 0.25rem; display: flex; align-items: center; gap: 0.3rem;">
                  <i class="fa-solid fa-comment-dots"></i> Nhận xét từ giảng viên:
                </div>
                <span style="font-style: italic;">"<%= sub.grade_feedback %>"</span>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
