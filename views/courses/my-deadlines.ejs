<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 1.55rem; font-weight: 700; color: var(--text-main);">
    Lịch Học & Deadline
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">
    Theo dõi thời hạn và lịch trình học tập bắt buộc để đảm bảo hoàn thành KPI đào tạo doanh nghiệp.
  </p>
</div>

<style>
  .deadline-tabs {
    display: flex;
    gap: 1rem;
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 1.5rem;
    padding-bottom: 0.25rem;
  }
  .deadline-tab-btn {
    background: none;
    border: none;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text-muted);
    cursor: pointer;
    position: relative;
    transition: var(--transition-smooth);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 8px 8px 0 0;
  }
  .deadline-tab-btn:hover {
    color: var(--text-accent);
    background: rgba(79, 70, 229, 0.04);
  }
  .deadline-tab-btn.active {
    color: var(--text-accent);
  }
  .deadline-tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--primary-gradient);
    border-radius: 3px;
  }
  .tab-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    color: #fff;
    transition: var(--transition-smooth);
  }
  .tab-badge.incomplete {
    background: var(--alert-gradient);
  }
  .tab-badge.completed {
    background: var(--secondary-gradient);
  }
  
  .deadline-item-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    transition: var(--transition-smooth);
  }
  .deadline-item-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-glow);
    box-shadow: var(--shadow-hover);
    background: rgba(255, 255, 255, 0.98);
  }
</style>

<div class="glass-card" style="padding: 2rem;">
  <h2 style="font-size: 1.3rem; font-weight: 700; color: var(--text-main); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
    <i class="fa-solid fa-calendar-check" style="color: #ef4444;"></i> Lịch trình hoàn thành bắt buộc
  </h2>

  <% if (deadlines.length === 0) { %>
    <div style="text-align: center; padding: 4rem 1rem;">
      <i class="fa-solid fa-calendar-xmark fa-3x" style="color: var(--text-muted); margin-bottom: 1rem;"></i>
      <p style="color: var(--text-muted); font-size: 0.9rem;">Bạn chưa đăng ký hoặc chưa được giao khóa học bắt buộc nào.</p>
      <a href="/courses" class="btn btn-primary" style="margin-top: 1rem;">Đăng ký khóa học ngay</a>
    </div>
  <% } else { %>
    <%
      const incomplete = deadlines.filter(item => item.progress < 100);
      const completed = deadlines.filter(item => item.progress === 100);
    %>

    <!-- Tabs Navigation -->
    <div class="deadline-tabs">
      <button class="deadline-tab-btn active" id="incomplete-btn" onclick="switchDeadlineTab('incomplete')">
        <i class="fa-solid fa-hourglass-half"></i> Chưa hoàn thành
        <span class="tab-badge incomplete"><%= incomplete.length %></span>
      </button>
      <button class="deadline-tab-btn" id="completed-btn" onclick="switchDeadlineTab('completed')">
        <i class="fa-solid fa-circle-check"></i> Đã hoàn thành
        <span class="tab-badge completed"><%= completed.length %></span>
      </button>
    </div>

    <!-- Tab content: Incomplete -->
    <div id="incomplete-tab" class="deadline-tab-content">
      <% if (incomplete.length === 0) { %>
        <div style="text-align: center; padding: 3rem 1rem;">
          <i class="fa-solid fa-circle-check fa-3x" style="color: #10b981; margin-bottom: 1rem;"></i>
          <p style="color: var(--text-muted); font-size: 0.95rem; font-weight: 600;">Tuyệt vời! Bạn đã hoàn thành tất cả các khóa học hiện tại.</p>
        </div>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <% incomplete.forEach(item => { %>
            <div class="deadline-item-card" style="
              <% if (item.status === 'overdue') { %> border-left: 4px solid #ef4444; <% } %>
              <% if (item.status === 'warning') { %> border-left: 4px solid #f59e0b; <% } %>
              <% if (item.status === 'active') { %> border-left: 4px solid #3b82f6; <% } %>
              <% if (item.status === 'unlimited') { %> border-left: 4px solid #0d9488; <% } %>
            ">
              <!-- Thông tin khóa học -->
              <div style="display: flex; align-items: center; gap: 1rem; flex: 2; min-width: 250px;">
                <img src="<%= item.image_url %>" alt="<%= item.title %>" style="width: 70px; height: 50px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-light); flex-shrink: 0;">
                <div>
                  <h4 style="font-size: 1.05rem; font-weight: 700; margin: 0; color: var(--text-main);"><%= item.title %></h4>
                  <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0.25rem 0 0 0;">
                    Thể loại: <strong><%= item.is_assigned ? 'HR Chỉ định bắt buộc' : 'Đăng ký tự nguyện' %></strong>
                  </p>
                </div>
              </div>

              <!-- Tiến độ -->
              <div style="flex: 1; min-width: 150px;">
                <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem;">
                  <span>Tiến độ:</span>
                  <span style="font-weight: 700; color: #10b981;"><%= item.progress %>%</span>
                </div>
                <div class="progress-container" style="height: 6px;">
                  <div class="progress-bar" style="width: <%= item.progress %>%;"></div>
                </div>
              </div>

              <!-- Mốc Deadline và Số ngày còn lại -->
              <div style="flex: 1; min-width: 180px; text-align: left;">
                <div style="font-size: 0.8rem; color: var(--text-muted);">Hạn chót hoàn thành:</div>
                <div style="font-size: 0.95rem; font-weight: 700; color: var(--text-main); margin-top: 0.15rem;">
                  <i class="fa-solid <%= item.status === 'unlimited' ? 'fa-infinity' : 'fa-clock' %>" style="margin-right: 0.25rem;"></i> <%= item.deadlineDate %>
                </div>
                
                <div style="margin-top: 0.4rem;">
                  <% if (item.status === 'unlimited') { %>
                    <span style="font-size: 0.72rem; font-weight: 700; background: rgba(13, 148, 136, 0.1); color: #0d9488; border: 1px solid rgba(13, 148, 136, 0.2); padding: 0.2rem 0.5rem; border-radius: 6px;">
                      <i class="fa-solid fa-infinity"></i> Tự học: Không giới hạn
                    </span>
                  <% } else if (item.status === 'overdue') { %>
                    <span style="font-size: 0.72rem; font-weight: 700; background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2); padding: 0.2rem 0.5rem; border-radius: 6px;">
                      <i class="fa-solid fa-circle-exclamation"></i> Quá hạn <%= Math.abs(item.daysRemaining) %> ngày
                    </span>
                  <% } else if (item.status === 'warning') { %>
                    <span style="font-size: 0.72rem; font-weight: 700; background: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2); padding: 0.2rem 0.5rem; border-radius: 6px;">
                      <i class="fa-solid fa-circle-nodes"></i> Cấp bách: Còn <%= item.daysRemaining %> ngày
                    </span>
                  <% } else { %>
                    <span style="font-size: 0.72rem; font-weight: 700; background: rgba(59, 130, 246, 0.1); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2); padding: 0.2rem 0.5rem; border-radius: 6px;">
                      <i class="fa-solid fa-circle-play"></i> Đang học: Còn <%= item.daysRemaining %> ngày
                    </span>
                  <% } %>
                </div>
              </div>

              <!-- Nút hành động -->
              <div style="flex-shrink: 0; min-width: 100px; text-align: right;">
                <a href="/courses/<%= item.course_id %>/lessons/1" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.8rem;">
                  <i class="fa-solid fa-door-open"></i> Vào học
                </a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Tab content: Completed -->
    <div id="completed-tab" class="deadline-tab-content" style="display: none;">
      <% if (completed.length === 0) { %>
        <div style="text-align: center; padding: 3rem 1rem;">
          <i class="fa-solid fa-hourglass-start fa-3x" style="color: var(--text-muted); margin-bottom: 1rem;"></i>
          <p style="color: var(--text-muted); font-size: 0.95rem;">Bạn chưa hoàn thành khóa học nào trong danh sách này.</p>
        </div>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <% completed.forEach(item => { %>
            <div class="deadline-item-card" style="border-left: 4px solid #10b981;">
              <!-- Thông tin khóa học -->
              <div style="display: flex; align-items: center; gap: 1rem; flex: 2; min-width: 250px;">
                <img src="<%= item.image_url %>" alt="<%= item.title %>" style="width: 70px; height: 50px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-light); flex-shrink: 0;">
                <div>
                  <h4 style="font-size: 1.05rem; font-weight: 700; margin: 0; color: var(--text-main);"><%= item.title %></h4>
                  <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0.25rem 0 0 0;">
                    Thể loại: <strong><%= item.is_assigned ? 'HR Chỉ định bắt buộc' : 'Đăng ký tự nguyện' %></strong>
                  </p>
                </div>
              </div>

              <!-- Tiến độ -->
              <div style="flex: 1; min-width: 150px;">
                <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.25rem;">
                  <span>Tiến độ:</span>
                  <span style="font-weight: 700; color: #10b981;"><%= item.progress %>%</span>
                </div>
                <div class="progress-container" style="height: 6px;">
                  <div class="progress-bar" style="width: <%= item.progress %>%;"></div>
                </div>
              </div>

              <!-- Mốc Deadline và Số ngày còn lại -->
              <div style="flex: 1; min-width: 180px; text-align: left;">
                <div style="font-size: 0.8rem; color: var(--text-muted);">Hạn chót hoàn thành:</div>
                <div style="font-size: 0.95rem; font-weight: 700; color: var(--text-main); margin-top: 0.15rem;">
                  <i class="fa-solid <%= item.status === 'unlimited' ? 'fa-infinity' : 'fa-clock' %>" style="margin-right: 0.25rem;"></i> <%= item.deadlineDate %>
                </div>
                
                <div style="margin-top: 0.4rem;">
                  <span style="font-size: 0.72rem; font-weight: 700; background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); padding: 0.2rem 0.5rem; border-radius: 6px;">
                    <i class="fa-solid fa-circle-check"></i> Đã hoàn thành
                  </span>
                </div>
              </div>

              <!-- Nút hành động -->
              <div style="flex-shrink: 0; min-width: 100px; text-align: right;">
                <a href="/courses/<%= item.course_id %>/lessons/1" class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.8rem;">
                  <i class="fa-solid fa-door-open"></i> Vào học
                </a>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% } %>
</div>

<script>
  function switchDeadlineTab(tabName) {
    document.querySelectorAll('.deadline-tab-content').forEach(el => {
      el.style.display = 'none';
    });
    document.querySelectorAll('.deadline-tab-btn').forEach(btn => {
      btn.classList.remove('active');
    });
    
    document.getElementById(tabName + '-tab').style.display = 'block';
    document.getElementById(tabName + '-btn').classList.add('active');
  }
</script>

<%- include('../partials/footer') %>
