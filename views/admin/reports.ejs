<%- include('../partials/header') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
  <div>
    <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
      Thống Kê & Báo Cáo Học Tập
    </h1>
    <p style="color: var(--text-muted); margin-top: 0.25rem;">Đánh giá chất lượng đào tạo, tiến độ học tập và xuất báo cáo điểm chi tiết toàn doanh nghiệp.</p>
  </div>
  
  <% if (user.permissions.includes('REPORT_EXPORT')) { %>
    <div style="display: flex; gap: 0.5rem; align-items: center;">
      <!-- Trạng thái xuất file ngầm của Web Worker -->
      <span id="export-status" style="font-size: 0.85rem; color: #10b981; display: none;">
        <i class="fa-solid fa-spinner fa-spin" style="color: #6366f1;"></i> Web Worker đang xuất báo cáo...
      </span>
      <button class="btn btn-primary" onclick="triggerWebWorkerExport()">
        <i class="fa-solid fa-file-excel"></i> Xuất Excel báo cáo điểm
      </button>
    </div>
  <% } %>
</div>

<%
// Tính toán các chỉ số vĩ mô phục vụ Admin
const totalCoursesCount = stats.length;
const avgCompanyProgress = totalCoursesCount > 0 ? Math.round(stats.reduce((acc, s) => acc + parseFloat(s.average_progress || 0), 0) / totalCoursesCount) : 0;
const totalEnrollmentsCount = stats.reduce((acc, s) => acc + parseInt(s.total_enrollments || 0), 0);
const totalCompletedCount = stats.reduce((acc, s) => acc + parseInt(s.completed_count || 0), 0);
const completionRate = totalEnrollmentsCount > 0 ? Math.round((totalCompletedCount / totalEnrollmentsCount) * 100) : 0;
const activeDeptCount = deptStats.filter(d => parseInt(d.total_users) > 0).length;
%>

<!-- Grid các chỉ số thống kê vĩ mô -->
<div class="kpi-grid" style="margin-bottom: 2rem;">
  <div class="glass-card kpi-card">
    <div class="kpi-title">Tiến độ trung bình</div>
    <div class="kpi-value"><%= avgCompanyProgress %>%</div>
  </div>
  
  <div class="glass-card kpi-card">
    <div class="kpi-title">Lượt tham gia</div>
    <div class="kpi-value" style="background: var(--secondary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
      <%= totalEnrollmentsCount %>
    </div>
  </div>
  
  <div class="glass-card kpi-card">
    <div class="kpi-title">Tỷ lệ hoàn thành</div>
    <div class="kpi-value secondary"><%= completionRate %>%</div>
  </div>
  
  <div class="glass-card kpi-card">
    <div class="kpi-title">Phòng ban hoạt động</div>
    <div class="kpi-value" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
      <%= activeDeptCount %>
    </div>
  </div>
</div>

<!-- Grid Phân tích & Bảng xếp hạng -->
<div style="display: grid; grid-template-columns: 1.6fr 1.4fr; gap: 2rem; margin-bottom: 2.5rem;">
  
  <!-- Cột bên trái: Biểu đồ Tiến độ Phòng ban -->
  <div class="glass-card" style="padding: 1.5rem; display: flex; flex-direction: column; height: 350px;">
    <h3 style="font-size: 1.15rem; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; color: #f1f5f9;">
      <i class="fa-solid fa-chart-simple" style="color: #06b6d4;"></i> Tiến độ trung bình theo phòng ban (%)
    </h3>
    <div style="flex-grow: 1; position: relative;">
      <canvas id="deptChart"></canvas>
    </div>
  </div>

  <!-- Cột bên phải: Bảng xếp hạng Học tập (Leaderboard) -->
  <div class="glass-card" style="padding: 1.5rem;">
    <h3 style="font-size: 1.15rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: #f1f5f9;">
      <i class="fa-solid fa-trophy" style="color: #fbbf24;"></i> Bảng xếp hạng KPI Học tập
    </h3>
    
    <% if (leaderboard.length === 0) { %>
      <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 2rem;">Chưa ghi nhận điểm học tập.</p>
    <% } else { %>
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        <% leaderboard.forEach((user, idx) => { %>
          <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); padding: 0.75rem 1rem; border-radius: 8px; border: 1px solid var(--border-light);">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <!-- Huy chương hoặc số hạng -->
              <div style="width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 0.85rem;
                <%= idx === 0 ? 'background: #fbbf24; color: #1e293b;' : 
                    idx === 1 ? 'background: #cbd5e1; color: #1e293b;' : 
                    idx === 2 ? 'background: #cd7f32; color: #1e293b;' : 
                    'background: rgba(255,255,255,0.05); color: var(--text-muted);' %>
              ">
                <% if (idx === 0) { %><i class="fa-solid fa-crown"></i><% } else { %><%= idx + 1 %><% } %>
              </div>
              <div>
                <strong style="color: #e2e8f0; font-size: 0.9rem;"><%= user.username %></strong>
                <div style="font-size: 0.75rem; color: var(--text-muted);"><%= user.department_name || 'Không thuộc phòng' %></div>
              </div>
            </div>
            <div style="text-align: right;">
              <span style="font-size: 0.85rem; color: #10b981; font-weight: bold;"><%= user.completed_count %> khóa hoàn thành</span>
              <div style="font-size: 0.7rem; color: var(--text-muted);">Tiến độ trung bình: <%= Math.round(user.average_progress) %>%</div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

</div>

<!-- Thống kê chi tiết từng khóa học -->
<div class="glass-card" style="padding: 2rem; margin-bottom: 2.5rem;">
  <h3 style="font-size: 1.25rem; margin-bottom: 1.25rem;"><i class="fa-solid fa-chart-column" style="color: #6366f1;"></i> Tổng quan tỷ lệ hoàn thành theo khóa học</h3>
  
  <table class="custom-table" style="margin-top: 0;">
    <thead>
      <tr>
        <th>Tên khóa học</th>
        <th style="text-align: center;">Đã tham gia (Nhân viên)</th>
        <th style="text-align: center;">Hoàn thành (100%)</th>
        <th>Tiến độ trung bình (%)</th>
        <th>Đánh giá hiệu suất học</th>
      </tr>
    </thead>
    <tbody>
      <% stats.forEach(s => { %>
        <tr>
          <td><strong><%= s.course_title %></strong></td>
          <td style="text-align: center;"><strong><%= s.total_enrollments %></strong></td>
          <td style="text-align: center; color: #10b981;">
            <strong><%= s.completed_count %></strong> (Tỷ lệ: <%= s.total_enrollments > 0 ? Math.round((s.completed_count / s.total_enrollments)*100) : 0 %>%)
          </td>
          <td>
            <div style="display: flex; align-items: center; gap: 1rem;">
              <span style="font-weight: 600; min-width: 45px;"><%= s.average_progress || 0 %>%</span>
              <div class="progress-container" style="flex-grow: 1; margin-top: 0; height: 6px;">
                <div class="progress-bar" style="width: <%= s.average_progress || 0 %>%; background: var(--primary-gradient);"></div>
              </div>
            </div>
          </td>
          <td>
            <% const progressVal = parseFloat(s.average_progress || 0); %>
            <% if (progressVal >= 80) { %>
              <span style="color: #10b981; font-weight: 600;"><i class="fa-solid fa-circle-check"></i> Xuất sắc</span>
            <% } else if (progressVal >= 50) { %>
              <span style="color: #f59e0b; font-weight: 600;"><i class="fa-solid fa-circle-exclamation"></i> Đang hoàn thiện</span>
            <% } else { %>
              <span style="color: var(--text-muted);"><i class="fa-solid fa-circle-notch"></i> Bắt đầu</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Sơ lược cấu trúc luồng Web Worker ngầm -->
<div class="glass-card" style="padding: 1.5rem; border-color: rgba(6, 182, 212, 0.2); background: rgba(6, 182, 212, 0.02);">
  <h4 style="font-weight: 700; margin-bottom: 0.5rem; color: #06b6d4;"><i class="fa-solid fa-gears"></i> Cơ chế tối ưu hóa hiệu suất (Web Worker)</h4>
  <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5;">
    Khi nhấp vào nút <strong>Xuất Excel báo cáo điểm</strong>, ứng dụng sẽ khởi chạy một <strong>Web Worker chạy song song</strong> trong luồng nền của trình duyệt. 
    Worker này thực hiện gọi API lấy dữ liệu thô, biên soạn định dạng CSV/Excel và trả kết quả về luồng UI chính để tải xuống. Điều này giúp ngăn ngừa việc trình duyệt bị đơ (freezing) khi xử lý hàng ngàn bản ghi nhân sự của doanh nghiệp lớn.
  </p>
</div>

<!-- Logic vẽ Chart.js và Web Worker -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const ctx = document.getElementById('deptChart').getContext('2d');
    const deptNames = <%- JSON.stringify(deptStats.map(d => d.department_name)) %>;
    const deptProgress = <%- JSON.stringify(deptStats.map(d => parseFloat(d.average_progress))) %>;

    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: deptNames,
        datasets: [{
          label: 'Tiến độ trung bình (%)',
          data: deptProgress,
          backgroundColor: 'rgba(6, 182, 212, 0.15)',
          borderColor: '#06b6d4',
          borderWidth: 1.5,
          borderRadius: 6,
          hoverBackgroundColor: 'rgba(6, 182, 212, 0.35)'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            grid: { color: 'rgba(255, 255, 255, 0.04)' },
            ticks: { color: '#94a3b8', font: { size: 10 } }
          },
          y: {
            grid: { color: 'rgba(255, 255, 255, 0.04)' },
            ticks: { color: '#94a3b8', font: { size: 10 } },
            min: 0,
            max: 100
          }
        },
        plugins: {
          legend: {
            display: false
          },
          tooltip: {
            backgroundColor: '#0f172a',
            titleColor: '#f1f5f9',
            bodyColor: '#cbd5e1',
            borderColor: 'rgba(255,255,255,0.08)',
            borderWidth: 1
          }
        }
      }
    });
  });

  function triggerWebWorkerExport() {
    const statusSpan = document.getElementById('export-status');
    statusSpan.style.display = 'inline-flex';

    // Tạo một Web Worker mới chỉ định tới file javascript chạy nền
    const worker = new Worker('/js/export-worker.js');

    // Lắng nghe kết quả từ Web Worker gửi về
    worker.onmessage = function(e) {
      statusSpan.style.display = 'none';
      const csvContent = e.data;

      if (csvContent.error) {
        alert('Lỗi xuất báo cáo từ Web Worker: ' + csvContent.error);
        return;
      }

      // Tạo một đối tượng Blob và thực hiện download file báo cáo về máy khách
      const blob = new Blob(["\ufeff" + csvContent], { type: 'text/csv;charset=utf-8;' });
      const link = document.createElement('a');
      const url = URL.createObjectURL(blob);
      
      const today = new Date().toISOString().slice(0,10);
      link.setAttribute('href', url);
      link.setAttribute('download', `BaoCao_LMS_Company_${today}.csv`);
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);

      // Giải phóng bộ nhớ của Worker
      worker.terminate();
    };

    // Gửi tín hiệu bắt đầu cho Web Worker cùng cookie/token (hoặc gọi API trong worker)
    worker.postMessage({ action: 'start_export' });
  }
</script>

<%- include('../partials/footer') %>
