<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <a href="/admin/assessments" style="color: var(--text-muted); text-decoration: none; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 1rem; transition: color 0.15s;" onmouseover="this.style.color='var(--text-accent)'" onmouseout="this.style.color='var(--text-muted)'">
    <i class="fa-solid fa-chevron-left"></i> Quản lý bài kiểm tra
  </a>
  <div style="display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <div>
      <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.4rem;"><%= assessment.title %></h1>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; font-size: 0.85rem; color: var(--text-muted);">
        <span><i class="fa-solid fa-user" style="margin-right:0.3rem;"></i>Tạo bởi: <strong><%= assessment.creator_name %></strong></span>
        <span><i class="fa-regular fa-calendar" style="margin-right:0.3rem;"></i><%= new Date(assessment.created_at).toLocaleDateString('vi-VN') %></span>
        <span style="padding: 0.2rem 0.65rem; border-radius: 20px; font-size: 0.78rem; font-weight: 700;
          background: <%= assessment.status === 'published' ? 'rgba(16,185,129,0.15)' : 'rgba(245,158,11,0.15)' %>;
          color: <%= assessment.status === 'published' ? '#34d399' : '#fbbf24' %>;
          border: 1px solid <%= assessment.status === 'published' ? 'rgba(52,211,153,0.3)' : 'rgba(251,191,36,0.3)' %>;">
          <%= assessment.status === 'published' ? '✅ Đã xuất bản' : '📝 Bản nháp' %>
        </span>
      </div>
    </div>
    <% if (assessment.status === 'draft' && user.permissions.includes('QUIZ_BANK_MANAGE')) { %>
    <form action="/admin/assessments/<%= assessment.id %>/publish" method="POST" onsubmit="return confirm('Xuất bản bài kiểm tra này?')">
      <button type="submit" class="btn btn-primary"><i class="fa-solid fa-rocket" style="margin-right:0.4rem;"></i>Xuất bản ngay</button>
    </form>
    <% } %>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
  <div class="glass-card" style="padding: 1.25rem; text-align: center;">
    <div style="font-size: 2rem; font-weight: 900; color: #a5b4fc;"><%= questions.length %></div>
    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem;">Câu hỏi</div>
  </div>
  <div class="glass-card" style="padding: 1.25rem; text-align: center;">
    <div style="font-size: 2rem; font-weight: 900; color: #6ee7b7;"><%= assignments.length %></div>
    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem;">Lượt phân phối</div>
  </div>
  <div class="glass-card" style="padding: 1.25rem; text-align: center;">
    <div style="font-size: 2rem; font-weight: 900; color: #fbbf24;"><%= submissions.length %></div>
    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem;">Đã nộp bài</div>
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start;">

  <!-- Bảng kết quả học viên -->
  <div class="glass-card" style="padding: 0; overflow: hidden;">
    <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-light);">
      <h3 style="font-size: 1.1rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
        <i class="fa-solid fa-chart-bar" style="color: #6366f1;"></i> Kết Quả Học Viên
      </h3>
    </div>
    <% if (submissions.length === 0) { %>
      <div style="padding: 2.5rem; text-align: center; color: var(--text-muted); font-size: 0.9rem;">
        Chưa có học viên nào nộp bài.
      </div>
    <% } else { %>
      <div style="max-height: 400px; overflow-y: auto;">
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); background: rgba(255,255,255,0.02);">
              <th style="padding: 0.75rem 1.25rem; text-align:left;">Học viên</th>
              <th style="padding: 0.75rem 0.75rem; text-align:center;">Điểm</th>
              <th style="padding: 0.75rem 0.75rem; text-align:center;">Kết quả</th>
            </tr>
          </thead>
          <tbody>
            <% submissions.forEach(sub => { %>
            <tr style="border-top: 1px solid var(--border-light);">
              <td style="padding: 0.8rem 1.25rem;">
                <div style="font-weight: 600; font-size: 0.88rem;"><%= sub.username %></div>
                <div style="font-size: 0.75rem; color: var(--text-muted);"><%= sub.department_name || '—' %></div>
              </td>
              <td style="padding: 0.8rem; text-align: center; font-weight: 800; font-size: 1rem; color: <%= parseFloat(sub.score) >= assessment.passing_score ? '#34d399' : '#f87171' %>;">
                <%= parseFloat(sub.score).toFixed(1) %>%
              </td>
              <td style="padding: 0.8rem; text-align: center;">
                <span style="font-size: 0.8rem; padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 600;
                  background: <%= sub.is_passed ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)' %>;
                  color: <%= sub.is_passed ? '#34d399' : '#f87171' %>;
                  border: 1px solid <%= sub.is_passed ? 'rgba(52,211,153,0.3)' : 'rgba(239,68,68,0.3)' %>;">
                  <%= sub.is_passed ? 'Đạt' : 'Chưa đạt' %>
                </span>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Danh sách phân phối -->
  <div class="glass-card" style="padding: 0; overflow: hidden;">
    <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-light);">
      <h3 style="font-size: 1.1rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
        <i class="fa-solid fa-paper-plane" style="color: #8b5cf6;"></i> Đã Phân Phối Tới
      </h3>
    </div>
    <% if (assignments.length === 0) { %>
      <div style="padding: 2.5rem; text-align: center; color: var(--text-muted); font-size: 0.9rem;">
        Chưa phân phối cho ai. Xuất bản và phân phối bài kiểm tra từ trang quản lý.
      </div>
    <% } else { %>
      <div style="max-height: 400px; overflow-y: auto;">
        <% assignments.forEach(a => { %>
        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.04);">
          <div style="width: 34px; height: 34px; border-radius: 50%; background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.3); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <i class="fa-solid fa-<%= a.target_type === 'user' ? 'user' : 'building' %>" style="font-size: 0.8rem; color: #8b5cf6;"></i>
          </div>
          <div style="flex: 1;">
            <div style="font-size: 0.88rem; font-weight: 600;"><%= a.target_name %></div>
            <div style="font-size: 0.75rem; color: var(--text-muted);">
              <%= a.target_type === 'user' ? 'Cá nhân' : 'Phòng ban' %>
              <% if (a.deadline) { %> · Hạn: <%= new Date(a.deadline).toLocaleDateString('vi-VN') %><% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<!-- Xem trước câu hỏi -->
<div class="glass-card" style="margin-top: 1.5rem; padding: 0; overflow: hidden;">
  <div style="padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border-light); display: flex; align-items: center; justify-content: space-between;">
    <h3 style="font-size: 1.1rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 0.5rem;">
      <i class="fa-solid fa-database" style="color: #06b6d4;"></i> Ngân Hàng Câu Hỏi (<%= questions.length %> câu)
    </h3>
    <button onclick="toggleQuestions()" id="btn-toggle-q" style="background: none; border: 1px solid var(--border-light); color: var(--text-muted); padding: 0.4rem 0.9rem; border-radius: 7px; cursor: pointer; font-size: 0.8rem;">
      <i class="fa-solid fa-chevron-down"></i> Xem tất cả
    </button>
  </div>
  <div id="questions-list" style="display: none; max-height: 600px; overflow-y: auto; padding: 1.25rem; flex-direction: column; gap: 1rem;">
    <% questions.forEach((q, idx) => { %>
    <div style="padding: 1rem; border-radius: 9px; background: rgba(255,255,255,0.02); border: 1px solid var(--border-light);">
      <p style="font-size: 0.9rem; font-weight: 600; margin: 0 0 0.75rem;"><%= idx + 1 %>. <%= q.question_text %></p>
      <ul style="list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 0.3rem; font-size: 0.82rem;">
        <% q.options.forEach((opt, oi) => { %>
        <li style="color: <%= opt.trim() === q.correct_answer.trim() ? '#10b981' : 'var(--text-muted)' %>; font-weight: <%= opt.trim() === q.correct_answer.trim() ? '700' : '400' %>;">
          <i class="fa-solid fa-<%= opt.trim() === q.correct_answer.trim() ? 'square-check' : 'square' %>" style="margin-right: 0.3rem;"></i>
          <%= ['A','B','C','D'][oi] %>. <%= opt %>
        </li>
        <% }) %>
      </ul>
    </div>
    <% }) %>
  </div>
</div>

<script>
let qVisible = false;
function toggleQuestions() {
  const list = document.getElementById('questions-list');
  const btn = document.getElementById('btn-toggle-q');
  qVisible = !qVisible;
  list.style.display = qVisible ? 'flex' : 'none';
  btn.innerHTML = qVisible
    ? '<i class="fa-solid fa-chevron-up"></i> Thu gọn'
    : '<i class="fa-solid fa-chevron-down"></i> Xem tất cả';
}
</script>

<%- include('../partials/footer') %>
