<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 1.55rem; font-weight: 700; color: var(--text-main);">
    Bài Kiểm Tra Doanh Nghiệp
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">Tạo bài kiểm tra bằng AI từ nội dung khóa học và phân phối đến từng cá nhân hoặc phòng ban.</p>
</div>

<!-- Flash Message -->
<% if (flash) { %>
  <div class="alert alert-<%= flashType === 'error' ? 'danger' : 'success' %>" style="margin-bottom: 1.5rem; padding: 1rem 1.25rem; border-radius: 10px; background: <%= flashType === 'error' ? 'rgba(239,68,68,0.12)' : 'rgba(16,185,129,0.12)' %>; border: 1px solid <%= flashType === 'error' ? '#f87171' : '#10b981' %>; color: <%= flashType === 'error' ? '#fca5a5' : '#6ee7b7' %>;">
    <i class="fa-solid fa-<%= flashType === 'error' ? 'circle-exclamation' : 'circle-check' %>" style="margin-right: 0.5rem;"></i>
    <%- flash %>
  </div>
<% } %>
<div id="flash-container"></div>

<!-- Nút tạo bài kiểm tra mới -->
<% if (user.permissions.includes('QUIZ_BANK_MANAGE')) { %>
<div style="margin-bottom: 2rem;">
  <button class="btn btn-primary" onclick="openCreateModal()" style="padding: 0.75rem 1.75rem; font-size: 1rem; display: inline-flex; align-items: center; gap: 0.6rem;">
    <i class="fa-solid fa-plus-circle"></i> Tạo Bài Kiểm Tra Mới
  </button>
</div>
<% } %>

<!-- Danh sách bài kiểm tra -->
<div class="glass-card" style="padding: 0; overflow: hidden;">
  <div style="padding: 1.5rem 1.75rem; border-bottom: 1px solid var(--border-light); display: flex; align-items: center; gap: 0.75rem;">
    <i class="fa-solid fa-clipboard-list" style="color: #8b5cf6; font-size: 1.2rem;"></i>
    <h3 style="font-size: 1.2rem; font-weight: 700; margin: 0;">Danh Sách Bài Kiểm Tra</h3>
    <span style="margin-left: auto; background: rgba(99,102,241,0.15); color: #a5b4fc; border: 1px solid rgba(99,102,241,0.3); padding: 0.2rem 0.7rem; border-radius: 20px; font-size: 0.8rem; font-weight: 600;">
      <%= assessments.length %> bài kiểm tra
    </span>
  </div>

  <!-- Bộ chọn Tab bài kiểm tra -->
  <div style="padding: 1rem 1.75rem 0 1.75rem; display: flex; gap: 0.75rem; border-bottom: 1px solid var(--border-light); background: rgba(255,255,255,0.01);">
    <button type="button" onclick="switchAssessmentTab('published')" id="tab-btn-published" class="btn" style="padding: 0.6rem 1.25rem; font-size: 0.85rem; font-weight: 600; border-radius: 8px 8px 0 0; border: none; border-bottom: 2px solid #8b5cf6; background: rgba(139,92,246,0.1); color: #a5b4fc; display: flex; align-items: center; gap: 0.4rem; cursor: pointer; margin-bottom: -1px; transition: all 0.2s;">
      <i class="fa-solid fa-circle-check" style="color: #10b981;"></i> Đã xuất bản (<%= assessments.filter(a => a.status === 'published').length %>)
    </button>
    <button type="button" onclick="switchAssessmentTab('draft')" id="tab-btn-draft" class="btn" style="padding: 0.6rem 1.25rem; font-size: 0.85rem; font-weight: 600; border-radius: 8px 8px 0 0; border: none; border-bottom: 2px solid transparent; background: transparent; color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem; cursor: pointer; margin-bottom: -1px; transition: all 0.2s;">
      <i class="fa-solid fa-pen-to-square" style="color: #fbbf24;"></i> Bản nháp (<%= assessments.filter(a => a.status === 'draft').length %>)
    </button>
  </div>

  <% if (assessments.length === 0) { %>
    <div style="text-align: center; padding: 4rem 2rem; color: var(--text-muted);">
      <i class="fa-solid fa-file-circle-question" style="font-size: 3rem; color: #4b5563; margin-bottom: 1rem; display: block;"></i>
      <p style="font-size: 1rem;">Chưa có bài kiểm tra nào. Hãy tạo bài kiểm tra đầu tiên bằng AI!</p>
    </div>
  <% } else { %>
    <div style="overflow-x: auto;">
      <table id="assessments-table" style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr style="background: rgba(255,255,255,0.03); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted);">
            <th style="padding: 0.85rem 1.5rem; text-align: left;">Tiêu Đề</th>
            <th style="padding: 0.85rem 1rem; text-align: center;">Số Câu</th>
            <th style="padding: 0.85rem 1rem; text-align: center;">Thời Gian</th>
            <th style="padding: 0.85rem 1rem; text-align: center;">Trạng Thái</th>
            <th style="padding: 0.85rem 1rem; text-align: center;">Đã Giao</th>
            <th style="padding: 0.85rem 1rem; text-align: center;">Người Tạo</th>
            <th style="padding: 0.85rem 1.5rem; text-align: right;">Thao Tác</th>
          </tr>
        </thead>
        <tbody>
          <% assessments.forEach(a => { %>
          <tr class="assessment-row" data-status="<%= a.status %>" style="border-top: 1px solid var(--border-light); transition: background 0.15s;" onmouseover="this.style.background='rgba(255,255,255,0.025)'" onmouseout="this.style.background='transparent'">
            <td style="padding: 1rem 1.5rem;">
              <div style="font-weight: 600; font-size: 0.95rem; margin-bottom: 0.2rem;"><%= a.title %></div>
              <% if (a.description) { %>
                <div style="font-size: 0.8rem; color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 260px;"><%= a.description %></div>
              <% } %>
            </td>
            <td style="padding: 1rem; text-align: center;">
              <span style="font-size: 0.9rem; font-weight: 700; color: #a5b4fc;"><%= a.question_count_actual || a.question_count %></span>
              <span style="font-size: 0.75rem; color: var(--text-muted);"> câu</span>
            </td>
            <td style="padding: 1rem; text-align: center; font-size: 0.85rem; color: var(--text-muted);">
              <i class="fa-regular fa-clock" style="margin-right: 0.3rem;"></i><%= a.duration_minutes %> phút
            </td>
            <td style="padding: 1rem; text-align: center;">
              <span style="padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.78rem; font-weight: 600;
                background: <%= a.status === 'published' ? 'rgba(16,185,129,0.15)' : 'rgba(245,158,11,0.15)' %>;
                color: <%= a.status === 'published' ? '#34d399' : '#fbbf24' %>;
                border: 1px solid <%= a.status === 'published' ? 'rgba(52,211,153,0.3)' : 'rgba(251,191,36,0.3)' %>;">
                <i class="fa-solid fa-<%= a.status === 'published' ? 'check-circle' : 'pen-to-square' %>" style="margin-right: 0.3rem;"></i>
                <%= a.status === 'published' ? 'Đã xuất bản' : 'Bản nháp' %>
              </span>
            </td>
            <td style="padding: 1rem; text-align: center;">
              <span style="font-size: 0.9rem; font-weight: 700; color: #6ee7b7;"><%= a.assignment_count %></span>
            </td>
            <td style="padding: 1rem; text-align: center; font-size: 0.85rem; color: var(--text-muted);">
              <i class="fa-solid fa-user" style="margin-right: 0.3rem;"></i><%= a.creator_name || 'Hệ thống' %>
            </td>
            <td style="padding: 1rem 1.5rem; text-align: right;">
              <div style="display: flex; gap: 0.5rem; justify-content: flex-end; flex-wrap: wrap;">
                <% if (user.permissions.includes('ENROLL_ASSIGN') && a.status === 'published') { %>
                  <button class="btn" onclick="openAssignModal(<%= a.id %>, '<%= a.title.replace(/'/g, "\\'") %>')"
                    style="padding: 0.4rem 0.9rem; font-size: 0.8rem; background: rgba(99,102,241,0.15); border: 1px solid rgba(99,102,241,0.4); color: #a5b4fc;">
                    <i class="fa-solid fa-paper-plane"></i> Phân phối
                  </button>
                <% } %>
                <% if (user.permissions.includes('QUIZ_BANK_MANAGE') && a.status === 'draft') { %>
                  <form action="/admin/assessments/<%= a.id %>/publish" method="POST" style="display:inline;" onsubmit="return confirm('Xuất bản bài kiểm tra này? Học viên sẽ thấy và làm bài sau khi được giao.')">
                    <button type="submit" class="btn btn-primary" style="padding: 0.4rem 0.9rem; font-size: 0.8rem;">
                      <i class="fa-solid fa-rocket"></i> Xuất bản
                    </button>
                  </form>
                <% } %>
                <% if (user.permissions.includes('QUIZ_BANK_VIEW')) { %>
                  <a href="/admin/assessments/<%= a.id %>" class="btn" style="padding: 0.4rem 0.9rem; font-size: 0.8rem; background: rgba(6,182,212,0.1); border: 1px solid rgba(6,182,212,0.3); color: #67e8f9;">
                    <i class="fa-solid fa-eye"></i> Xem
                  </a>
                <% } %>
                <% if (user.permissions.includes('QUIZ_BANK_MANAGE')) { %>
                  <form action="/admin/assessments/<%= a.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Xóa bài kiểm tra này? Hành động không thể hoàn tác.')">
                    <button type="submit" style="background: none; border: none; color: #f87171; cursor: pointer; padding: 0.4rem 0.5rem;">
                      <i class="fa-solid fa-trash-can"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Khung trống khi không có bài kiểm tra đã xuất bản -->
    <div id="empty-published" style="display: none; text-align: center; padding: 4rem 2rem; color: var(--text-muted);">
      <i class="fa-solid fa-circle-check" style="font-size: 3rem; color: #10b981; opacity: 0.6; margin-bottom: 1rem; display: block;"></i>
      <p style="font-size: 1rem;">Không có bài kiểm tra nào đã xuất bản.</p>
    </div>

    <!-- Khung trống khi không có bài kiểm tra nháp -->
    <div id="empty-draft" style="display: none; text-align: center; padding: 4rem 2rem; color: var(--text-muted);">
      <i class="fa-solid fa-pen-to-square" style="font-size: 3rem; color: #fbbf24; opacity: 0.6; margin-bottom: 1rem; display: block;"></i>
      <p style="font-size: 1rem;">Không có bài kiểm tra nháp nào.</p>
    </div>
  <% } %>
</div>

<!-- ====================== MODAL TẠO BÀI KIỂM TRA ====================== -->
<div id="modal-create" style="display:none; position:fixed; inset:0; z-index:9000; background:rgba(0,0,0,0.65); backdrop-filter:blur(4px); overflow-y:auto;">
  <div style="max-width: 680px; margin: 3rem auto; padding: 0 1rem;">
    <div class="glass-card" style="padding: 2rem; border-color: var(--border-glow);">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem;">
        <h3 style="font-size: 1.3rem; font-weight: 700; display: flex; align-items: center; gap: 0.6rem;">
          <i id="header-create-icon" class="fa-solid fa-wand-magic-sparkles" style="color: #8b5cf6;"></i>
          <span id="header-create-text">Tạo Bài Kiểm Tra Mới</span>
        </h3>
        <button onclick="closeCreateModal()" style="background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:1.25rem;">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <!-- Lựa chọn hình thức tạo -->
      <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); padding-bottom: 1rem;">
        <button type="button" onclick="switchCreateType('ai')" id="btn-create-type-ai" class="btn" style="flex: 1; padding: 0.75rem; border-radius: 8px; font-weight: 600; border: 2px solid #8b5cf6; background: rgba(139,92,246,0.1); color: #a5b4fc; display: flex; align-items: center; justify-content: center; gap: 0.5rem; cursor: pointer; transition: all 0.15s;">
          <i class="fa-solid fa-wand-magic-sparkles"></i> Tạo bằng AI
        </button>
        <button type="button" onclick="switchCreateType('manual')" id="btn-create-type-manual" class="btn" style="flex: 1; padding: 0.75rem; border-radius: 8px; font-weight: 600; border: 1px solid var(--border-light); background: transparent; color: var(--text-muted); display: flex; align-items: center; justify-content: center; gap: 0.5rem; cursor: pointer; transition: all 0.15s;">
          <i class="fa-solid fa-keyboard"></i> Tạo thủ công
        </button>
      </div>

      <div class="form-group">
        <label class="form-label">Tiêu đề bài kiểm tra <span style="color:#f87171">*</span></label>
        <input type="text" id="create-title" placeholder="VD: Kiểm tra năng lực Quý II/2025 — Phòng IT" style="width:100%;">
      </div>

      <div class="form-group">
        <label class="form-label">Mô tả (tuỳ chọn)</label>
        <textarea id="create-desc" rows="2" placeholder="Mô tả mục tiêu bài kiểm tra..." style="width:100%;"></textarea>
      </div>

      <div class="form-group" id="create-section-ai">
        <label class="form-label">Chọn khóa học làm nguồn câu hỏi <span style="color:#f87171">*</span></label>
        <p style="font-size:0.8rem; color:var(--text-muted); margin-bottom:0.75rem;">AI sẽ đọc nội dung tất cả bài học trong các khóa này để sinh câu hỏi kiểm tra.</p>
        <div style="display: grid; gap: 0.5rem; max-height: 200px; overflow-y: auto; padding-right: 0.5rem;">
          <% courses.forEach(c => { %>
          <label style="display: flex; align-items: center; gap: 0.6rem; padding: 0.6rem 0.75rem; border-radius: 8px; border: 1px solid var(--border-light); cursor: pointer; transition: border-color 0.15s;" onmouseover="this.style.borderColor='rgba(99,102,241,0.5)'" onmouseout="this.style.borderColor='var(--border-light)'">
            <input type="checkbox" name="courseIds" value="<%= c.id %>" id="course-<%= c.id %>" style="width:16px; height:16px; accent-color:#8b5cf6;">
            <span style="font-size:0.9rem;"><%= c.title %></span>
          </label>
          <% }) %>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
        <div class="form-group">
          <label class="form-label">Số câu hỏi</label>
          <input type="number" id="create-count" value="50" min="10" max="100">
        </div>
        <div class="form-group">
          <label class="form-label">Thời gian (phút)</label>
          <input type="number" id="create-duration" value="60" min="5" max="180">
        </div>
        <div class="form-group">
          <label class="form-label">Điểm đạt (%)</label>
          <input type="number" id="create-passing" value="70" min="0" max="100">
        </div>
      </div>

      <!-- Loading state -->
      <div id="create-loading" style="display:none; text-align:center; padding: 1.5rem; background: rgba(139,92,246,0.08); border-radius: 10px; border: 1px solid rgba(139,92,246,0.25); margin-bottom: 1.5rem;">
        <div style="display: flex; align-items: center; justify-content: center; gap: 0.75rem; color: #a5b4fc;">
          <i class="fa-solid fa-spinner fa-spin" style="font-size: 1.25rem; color: #8b5cf6;"></i>
          <div>
            <div style="font-weight: 600; margin-bottom: 0.2rem;">AI đang phân tích nội dung bài học...</div>
            <div style="font-size: 0.8rem; color: var(--text-muted);">Quá trình này có thể mất 30-60 giây. Vui lòng không đóng cửa sổ.</div>
          </div>
        </div>
        <div style="margin-top: 1rem; height: 4px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden;">
          <div style="height: 100%; width: 0; background: linear-gradient(90deg, #8b5cf6, #6366f1); border-radius: 4px; animation: progress-anim 45s linear forwards;" id="progress-bar"></div>
        </div>
      </div>

      <div style="display: flex; gap: 1rem; justify-content: flex-end;">
        <button onclick="closeCreateModal()" class="btn" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); color: var(--text-muted);">
          Huỷ
        </button>
        <button id="btn-create-submit" onclick="submitCreateAssessment()" class="btn btn-primary" style="padding: 0.75rem 1.75rem; display: inline-flex; align-items: center; gap: 0.5rem;">
          <i id="icon-create-submit" class="fa-solid fa-brain"></i> <span id="text-create-submit">AI Sinh Câu Hỏi & Tạo Bài</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ====================== MODAL PHÂN PHỐI ====================== -->
<div id="modal-assign" style="display:none; position:fixed; inset:0; z-index:9000; background:rgba(0,0,0,0.65); backdrop-filter:blur(4px); overflow-y:auto;">
  <div style="max-width: 560px; margin: 3rem auto; padding: 0 1rem;">
    <div class="glass-card" style="padding: 2rem; border-color: var(--border-glow);">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.75rem;">
        <h3 style="font-size: 1.2rem; font-weight: 700; display: flex; align-items: center; gap: 0.6rem;">
          <i class="fa-solid fa-paper-plane" style="color: #6366f1;"></i>
          Phân Phối Bài Kiểm Tra
        </h3>
        <button onclick="closeAssignModal()" style="background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:1.25rem;">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <div style="margin-bottom: 1.25rem; padding: 0.75rem 1rem; background: rgba(99,102,241,0.08); border-radius: 8px; border: 1px solid rgba(99,102,241,0.2);">
        <div style="font-size: 0.8rem; color: var(--text-muted);">Bài kiểm tra được chọn</div>
        <div id="assign-title-display" style="font-weight: 600; color: #a5b4fc; margin-top: 0.2rem;"></div>
      </div>
      <input type="hidden" id="assign-assessment-id">

      <div class="form-group">
        <label class="form-label">Phân phối theo</label>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
          <label onclick="switchAssignType('user')" id="tab-user" style="display:flex; align-items:center; gap:0.5rem; padding:0.75rem 1rem; border-radius:8px; border: 2px solid #8b5cf6; cursor:pointer; background: rgba(139,92,246,0.1);">
            <input type="radio" name="targetType" value="user" checked style="display:none;">
            <i class="fa-solid fa-user" style="color:#8b5cf6;"></i> <span style="font-weight:600;">Cá nhân</span>
          </label>
          <label onclick="switchAssignType('department')" id="tab-dept" style="display:flex; align-items:center; gap:0.5rem; padding:0.75rem 1rem; border-radius:8px; border: 1px solid var(--border-light); cursor:pointer;">
            <input type="radio" name="targetType" value="department" style="display:none;">
            <i class="fa-solid fa-building" style="color:#64748b;"></i> <span>Phòng ban</span>
          </label>
        </div>
      </div>

      <div class="form-group" id="assign-user-section">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
          <label class="form-label" style="margin-bottom: 0;">Chọn người dùng</label>
          <label style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.8rem; cursor: pointer; user-select: none; color: var(--text-accent); font-weight: 600;">
            <input type="checkbox" id="user-select-all" onchange="toggleSelectAllUsers(this)" style="width: 14px; height: 14px; accent-color: #8b5cf6;"> Chọn tất cả
          </label>
        </div>
        <input type="text" id="user-search" placeholder="🔍 Nhập tên hoặc email để tìm..." oninput="filterUsers()" style="margin-bottom: 0.75rem; padding: 0.55rem 0.85rem; font-size: 0.85rem; border-radius: 8px;">
        <div id="user-list-container" style="max-height: 200px; overflow-y: auto; display: grid; gap: 0.4rem; padding-right:0.5rem;">
          <% users.forEach(u => { %>
          <label class="user-item" data-search="<%= u.username.toLowerCase() %> <%= u.email.toLowerCase() %>" style="display:flex; align-items:center; gap:0.6rem; padding:0.5rem 0.75rem; border-radius:7px; border:1px solid var(--border-light); cursor:pointer; font-size:0.87rem; transition: border-color 0.15s;">
            <input type="checkbox" class="assign-user-cb" value="<%= u.id %>" style="accent-color:#8b5cf6;" onchange="updateSelectAllState('user')">
            <i class="fa-solid fa-user-circle" style="color: #6366f1;"></i> <%= u.username %> <span style="color:var(--text-muted); font-size:0.8rem;">— <%= u.email %></span>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group" id="assign-dept-section" style="display:none;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
          <label class="form-label" style="margin-bottom: 0;">Chọn phòng ban</label>
          <label style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.8rem; cursor: pointer; user-select: none; color: var(--text-accent); font-weight: 600;">
            <input type="checkbox" id="dept-select-all" onchange="toggleSelectAllDepts(this)" style="width: 14px; height: 14px; accent-color: #8b5cf6;"> Chọn tất cả
          </label>
        </div>
        <input type="text" id="dept-search" placeholder="🔍 Nhập tên phòng ban để tìm..." oninput="filterDepts()" style="margin-bottom: 0.75rem; padding: 0.55rem 0.85rem; font-size: 0.85rem; border-radius: 8px;">
        <div id="dept-list-container" style="max-height: 200px; overflow-y: auto; display: grid; gap: 0.4rem; padding-right:0.5rem;">
          <% departments.forEach(d => { %>
          <label class="dept-item" data-search="<%= d.name.toLowerCase() %>" style="display:flex; align-items:center; gap:0.6rem; padding:0.5rem 0.75rem; border-radius:7px; border:1px solid var(--border-light); cursor:pointer; font-size:0.87rem; transition: border-color 0.15s;">
            <input type="checkbox" class="assign-dept-cb" value="<%= d.id %>" style="accent-color:#8b5cf6;" onchange="updateSelectAllState('dept')">
            <i class="fa-solid fa-building" style="color:#6366f1;"></i> <%= d.name %>
          </label>
          <% }) %>
        </div>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
        <div class="form-group" style="margin-bottom: 0;">
          <label class="form-label">Thời gian mở đề (tuỳ chọn)</label>
          <input type="datetime-local" id="assign-starttime" style="width:100%;">
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label class="form-label">Hạn hoàn thành (tuỳ chọn)</label>
          <input type="datetime-local" id="assign-deadline" style="width:100%;">
        </div>
      </div>

      <div style="display: flex; gap: 1rem; justify-content: flex-end;">
        <button onclick="closeAssignModal()" class="btn" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); color: var(--text-muted);">Huỷ</button>
        <button onclick="submitAssign()" class="btn btn-primary" id="btn-assign-submit" style="padding: 0.75rem 1.5rem;">
          <i class="fa-solid fa-paper-plane" style="margin-right:0.4rem;"></i> Gửi Bài Kiểm Tra
        </button>
      </div>
    </div>
  </div>
</div>

<style>
@keyframes progress-anim {
  from { width: 0; }
  to { width: 100%; }
}
</style>

<script>
let currentAssignType = 'user';
let currentCreateType = 'ai';

function openCreateModal() {
  document.getElementById('modal-create').style.display = 'block';
  document.body.style.overflow = 'hidden';
  switchCreateType('ai'); // Default to AI
}

function switchCreateType(type) {
  currentCreateType = type;
  const btnAi = document.getElementById('btn-create-type-ai');
  const btnManual = document.getElementById('btn-create-type-manual');
  const sectionAi = document.getElementById('create-section-ai');
  const countInput = document.getElementById('create-count');
  const countGroup = countInput ? countInput.closest('.form-group') : null;
  const textSubmit = document.getElementById('text-create-submit');
  const iconSubmit = document.getElementById('icon-create-submit');
  const headerIcon = document.getElementById('header-create-icon');
  const headerText = document.getElementById('header-create-text');
  
  if (type === 'ai') {
    btnAi.style.border = '2px solid #8b5cf6';
    btnAi.style.background = 'rgba(139,92,246,0.1)';
    btnAi.style.color = '#a5b4fc';
    btnManual.style.border = '1px solid var(--border-light)';
    btnManual.style.background = 'transparent';
    btnManual.style.color = 'var(--text-muted)';
    
    if (sectionAi) sectionAi.style.display = '';
    if (countGroup) countGroup.style.display = '';
    if (textSubmit) textSubmit.textContent = 'AI Sinh Câu Hỏi & Tạo Bài';
    if (iconSubmit) {
      iconSubmit.className = 'fa-solid fa-brain';
    }
    if (headerIcon) {
      headerIcon.className = 'fa-solid fa-wand-magic-sparkles';
      headerIcon.style.color = '#8b5cf6';
    }
    if (headerText) headerText.textContent = 'Tạo Bài Kiểm Tra Mới Bằng AI';
  } else {
    btnManual.style.border = '2px solid #8b5cf6';
    btnManual.style.background = 'rgba(139,92,246,0.1)';
    btnManual.style.color = '#a5b4fc';
    btnAi.style.border = '1px solid var(--border-light)';
    btnAi.style.background = 'transparent';
    btnAi.style.color = 'var(--text-muted)';
    
    if (sectionAi) sectionAi.style.display = 'none';
    if (countGroup) countGroup.style.display = 'none';
    if (textSubmit) textSubmit.textContent = 'Tạo Bài & Tự Soạn Câu Hỏi';
    if (iconSubmit) {
      iconSubmit.className = 'fa-solid fa-keyboard';
    }
    if (headerIcon) {
      headerIcon.className = 'fa-solid fa-keyboard';
      headerIcon.style.color = '#6366f1';
    }
    if (headerText) headerText.textContent = 'Tạo Bài Kiểm Tra Thủ Công';
  }
}
function closeCreateModal() {
  document.getElementById('modal-create').style.display = 'none';
  document.body.style.overflow = '';
}
function openAssignModal(id, title) {
  document.getElementById('assign-assessment-id').value = id;
  document.getElementById('assign-title-display').textContent = title;
  
  // Reset checkboxes
  document.querySelectorAll('.assign-user-cb, .assign-dept-cb').forEach(cb => cb.checked = false);
  document.getElementById('user-select-all').checked = false;
  document.getElementById('dept-select-all').checked = false;
  
  // Reset search inputs
  document.getElementById('user-search').value = '';
  document.getElementById('dept-search').value = '';
  filterUsers();
  filterDepts();
  
  // Reset date times
  document.getElementById('assign-starttime').value = '';
  document.getElementById('assign-deadline').value = '';
  
  document.getElementById('modal-assign').style.display = 'block';
  document.body.style.overflow = 'hidden';
}

function filterUsers() {
  const query = document.getElementById('user-search').value.toLowerCase().trim();
  const items = document.querySelectorAll('#user-list-container .user-item');
  items.forEach(item => {
    const text = item.getAttribute('data-search') || '';
    if (text.includes(query)) {
      item.style.display = 'flex';
    } else {
      item.style.display = 'none';
    }
  });
  updateSelectAllState('user');
}

function toggleSelectAllUsers(selectAllCb) {
  const items = document.querySelectorAll('#user-list-container .user-item');
  items.forEach(item => {
    if (item.style.display !== 'none') {
      const cb = item.querySelector('.assign-user-cb');
      cb.checked = selectAllCb.checked;
    }
  });
}

function filterDepts() {
  const query = document.getElementById('dept-search').value.toLowerCase().trim();
  const items = document.querySelectorAll('#dept-list-container .dept-item');
  items.forEach(item => {
    const text = item.getAttribute('data-search') || '';
    if (text.includes(query)) {
      item.style.display = 'flex';
    } else {
      item.style.display = 'none';
    }
  });
  updateSelectAllState('dept');
}

function toggleSelectAllDepts(selectAllCb) {
  const items = document.querySelectorAll('#dept-list-container .dept-item');
  items.forEach(item => {
    if (item.style.display !== 'none') {
      const cb = item.querySelector('.assign-dept-cb');
      cb.checked = selectAllCb.checked;
    }
  });
}

function updateSelectAllState(type) {
  const items = document.querySelectorAll(type === 'user' ? '#user-list-container .user-item' : '#dept-list-container .dept-item');
  const visibleItems = Array.from(items).filter(item => item.style.display !== 'none');
  const selectAllCb = document.getElementById(type === 'user' ? 'user-select-all' : 'dept-select-all');
  
  if (visibleItems.length === 0) {
    selectAllCb.checked = false;
    return;
  }
  
  const cbClass = type === 'user' ? '.assign-user-cb' : '.assign-dept-cb';
  const allChecked = visibleItems.every(item => item.querySelector(cbClass).checked);
  selectAllCb.checked = allChecked;
}

function closeAssignModal() {
  document.getElementById('modal-assign').style.display = 'none';
  document.body.style.overflow = '';
}
function switchAssignType(type) {
  currentAssignType = type;
  const userSection = document.getElementById('assign-user-section');
  const deptSection = document.getElementById('assign-dept-section');
  const tabUser = document.getElementById('tab-user');
  const tabDept = document.getElementById('tab-dept');
  if (type === 'user') {
    userSection.style.display = '';
    deptSection.style.display = 'none';
    tabUser.style.border = '2px solid #8b5cf6';
    tabUser.style.background = 'rgba(139,92,246,0.1)';
    tabDept.style.border = '1px solid var(--border-light)';
    tabDept.style.background = 'transparent';
  } else {
    userSection.style.display = 'none';
    deptSection.style.display = '';
    tabDept.style.border = '2px solid #8b5cf6';
    tabDept.style.background = 'rgba(139,92,246,0.1)';
    tabUser.style.border = '1px solid var(--border-light)';
    tabUser.style.background = 'transparent';
  }
}

function showFlash(msg, type = 'success') {
  const fc = document.getElementById('flash-container');
  fc.innerHTML = `<div style="margin-bottom:1.5rem; padding:1rem 1.25rem; border-radius:10px; background:${type==='error'?'rgba(239,68,68,0.12)':'rgba(16,185,129,0.12)'}; border:1px solid ${type==='error'?'#f87171':'#10b981'}; color:${type==='error'?'#fca5a5':'#6ee7b7'};">
    <i class="fa-solid fa-${type==='error'?'circle-exclamation':'circle-check'}" style="margin-right:0.5rem;"></i>${msg}
  </div>`;
  fc.scrollIntoView({ behavior: 'smooth', block: 'start' });
  setTimeout(() => { fc.innerHTML = ''; }, 7000);
}

async function submitCreateAssessment() {
  const title = document.getElementById('create-title').value.trim();
  const description = document.getElementById('create-desc').value.trim();
  const checkedCourses = [...document.querySelectorAll('input[name="courseIds"]:checked')].map(cb => cb.value);
  const count = document.getElementById('create-count').value;
  const duration = document.getElementById('create-duration').value;
  const passing = document.getElementById('create-passing').value;

  if (!title) return alert('Vui lòng nhập tiêu đề bài kiểm tra.');
  if (currentCreateType === 'ai' && checkedCourses.length === 0) {
    return alert('Vui lòng chọn ít nhất 1 khóa học nguồn.');
  }

  // Show loading
  const textSubmit = document.getElementById('text-create-submit');
  if (currentCreateType === 'ai') {
    document.getElementById('create-loading').style.display = 'block';
    const bar = document.getElementById('progress-bar');
    bar.style.animation = 'none'; bar.offsetHeight;
    bar.style.animation = 'progress-anim 60s linear forwards';
  }
  
  document.getElementById('btn-create-submit').disabled = true;
  if (textSubmit) textSubmit.textContent = 'Đang xử lý...';

  try {
    const res = await fetch('/admin/assessments/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        type: currentCreateType,
        title,
        description,
        courseIds: currentCreateType === 'ai' ? checkedCourses : [],
        questionCount: count,
        durationMinutes: duration,
        passingScore: passing
      })
    });
    const data = await res.json();
    closeCreateModal();
    if (data.success) {
      showFlash(data.message);
      // Chuyển hướng đến trang chi tiết của bài kiểm tra mới tạo
      setTimeout(() => window.location.href = `/admin/assessments/${data.assessmentId}`, 1000);
    } else {
      showFlash(data.error || 'Có lỗi xảy ra.', 'error');
    }
  } catch (err) {
    closeCreateModal();
    showFlash('Lỗi kết nối máy chủ: ' + err.message, 'error');
  } finally {
    document.getElementById('create-loading').style.display = 'none';
    document.getElementById('btn-create-submit').disabled = false;
    if (textSubmit) {
      textSubmit.textContent = currentCreateType === 'ai' ? 'AI Sinh Câu Hỏi & Tạo Bài' : 'Tạo Bài & Tự Soạn Câu Hỏi';
    }
  }
}

async function submitAssign() {
  const assessmentId = document.getElementById('assign-assessment-id').value;
  const startTime = document.getElementById('assign-starttime').value;
  const deadline = document.getElementById('assign-deadline').value;
  const cbClass = currentAssignType === 'user' ? '.assign-user-cb' : '.assign-dept-cb';
  const targetIds = [...document.querySelectorAll(`${cbClass}:checked`)].map(cb => cb.value);

  if (targetIds.length === 0) return alert('Vui lòng chọn ít nhất 1 ' + (currentAssignType === 'user' ? 'người dùng' : 'phòng ban') + '.');

  document.getElementById('btn-assign-submit').disabled = true;
  document.getElementById('btn-assign-submit').innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang gửi...';

  try {
    const res = await fetch(`/admin/assessments/${assessmentId}/assign`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ assessmentId, targetType: currentAssignType, targetIds, startTime: startTime || null, deadline: deadline || null })
    });
    const data = await res.json();
    closeAssignModal();
    if (data.success) {
      showFlash(data.message);
    } else {
      showFlash(data.error || 'Có lỗi xảy ra.', 'error');
    }
  } catch (err) {
    closeAssignModal();
    showFlash('Lỗi kết nối: ' + err.message, 'error');
  } finally {
    document.getElementById('btn-assign-submit').disabled = false;
    document.getElementById('btn-assign-submit').innerHTML = '<i class="fa-solid fa-paper-plane" style="margin-right:0.4rem;"></i> Gửi Bài Kiểm Tra';
  }
}

function switchAssessmentTab(tab) {
  // Cập nhật kiểu dáng cho nút tab tích cực
  const btnPublished = document.getElementById('tab-btn-published');
  const btnDraft = document.getElementById('tab-btn-draft');
  
  if (!btnPublished || !btnDraft) return;

  if (tab === 'published') {
    btnPublished.style.borderBottom = '2px solid #8b5cf6';
    btnPublished.style.background = 'rgba(139,92,246,0.1)';
    btnPublished.style.color = '#a5b4fc';
    
    btnDraft.style.borderBottom = '2px solid transparent';
    btnDraft.style.background = 'transparent';
    btnDraft.style.color = 'var(--text-muted)';
  } else {
    btnDraft.style.borderBottom = '2px solid #8b5cf6';
    btnDraft.style.background = 'rgba(139,92,246,0.1)';
    btnDraft.style.color = '#a5b4fc';
    
    btnPublished.style.borderBottom = '2px solid transparent';
    btnPublished.style.background = 'transparent';
    btnPublished.style.color = 'var(--text-muted)';
  }
  
  // Lọc hiển thị các dòng tương ứng
  let visibleCount = 0;
  const rows = document.querySelectorAll('.assessment-row');
  rows.forEach(row => {
    if (row.dataset.status === tab) {
      row.style.display = '';
      visibleCount++;
    } else {
      row.style.display = 'none';
    }
  });
  
  // Hiển thị/ẩn trạng thái trống (empty state)
  const emptyPublished = document.getElementById('empty-published');
  const emptyDraft = document.getElementById('empty-draft');
  const tableEl = document.getElementById('assessments-table');
  
  if (emptyPublished) emptyPublished.style.display = 'none';
  if (emptyDraft) emptyDraft.style.display = 'none';
  
  if (visibleCount === 0) {
    if (tableEl) tableEl.style.display = 'none';
    if (tab === 'published' && emptyPublished) {
      emptyPublished.style.display = 'block';
    } else if (tab === 'draft' && emptyDraft) {
      emptyDraft.style.display = 'block';
    }
  } else {
    if (tableEl) tableEl.style.display = '';
  }
}

// Khởi chạy tab đã xuất bản khi tải trang hoàn tất
document.addEventListener('DOMContentLoaded', () => {
  switchAssessmentTab('published');
});

// Đóng modal khi click nền
document.getElementById('modal-create').addEventListener('click', function(e) {
  if (e.target === this) closeCreateModal();
});
document.getElementById('modal-assign').addEventListener('click', function(e) {
  if (e.target === this) closeAssignModal();
});
</script>

