<%- include('../partials/header') %>

<style>
  /* ── Page Header ───────────────────────────── */
  .as-header {
    margin-bottom: 2.25rem;
  }
  .as-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -0.025em;
    margin: 0;
  }
  .as-subtitle {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.35rem;
  }

  /* ── Alert banners ─────────────────────────── */
  .as-alert {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    border-radius: 12px;
    font-size: 0.88rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }
  .as-alert-success {
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.25);
    color: #059669;
  }
  .as-alert-error {
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.25);
    color: #dc2626;
  }

  /* ── Assessments List Card ─────────────────── */
  .as-card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.03);
  }
  .as-card-header {
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .as-card-title {
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }
  .as-card-title i {
    color: #8b5cf6;
  }
  .as-count-badge {
    background: rgba(139, 92, 246, 0.08);
    color: #8b5cf6;
    border: 1px solid rgba(139, 92, 246, 0.18);
    padding: 0.15rem 0.65rem;
    border-radius: 12px;
    font-size: 0.78rem;
    font-weight: 600;
  }

  /* Tabs selection */
  .as-tabs-bar {
    padding: 0.85rem 1.5rem 0 1.5rem;
    display: flex;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border-light);
    background: #fafbff;
  }
  .as-tab-btn {
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    padding: 0.6rem 1.1rem;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-radius: 8px 8px 0 0;
    transition: all 0.15s;
    font-family: var(--font-body);
  }
  .as-tab-btn:hover {
    color: var(--text-main);
    background: rgba(0, 0, 0, 0.02);
  }
  .as-tab-btn.active {
    border-bottom-color: #8b5cf6;
    color: #8b5cf6;
    background: rgba(139, 92, 246, 0.05);
  }

  /* Table styling */
  .as-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.86rem;
  }
  .as-table thead {
    background: #f8fafc;
  }
  .as-table th {
    padding: 0.85rem 1.25rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #94a3b8;
    border-bottom: 1px solid var(--border-light);
  }
  .as-table td {
    padding: 0.95rem 1.25rem;
    vertical-align: middle;
    border-bottom: 1px solid #f1f5f9;
  }
  .as-table tbody tr:last-child td {
    border-bottom: none;
  }
  .as-table tbody tr {
    transition: background 0.15s;
  }
  .as-table tbody tr:hover {
    background: #fafbff;
  }

  /* Badge styling */
  .as-badge-pub {
    background: rgba(16, 185, 129, 0.08);
    color: #059669;
    border: 1px solid rgba(16, 185, 129, 0.18);
    padding: 0.2rem 0.55rem;
    border-radius: 20px;
    font-size: 0.76rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .as-badge-draft {
    background: rgba(245, 158, 11, 0.08);
    color: #d97706;
    border: 1px solid rgba(245, 158, 11, 0.18);
    padding: 0.2rem 0.55rem;
    border-radius: 20px;
    font-size: 0.76rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  /* Action buttons */
  .as-btn-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.4rem 0.8rem;
    border-radius: 7px;
    font-size: 0.78rem;
    font-weight: 600;
    border: 1px solid #e2e8f0;
    background: #fff;
    cursor: pointer;
    transition: all 0.18s;
    text-decoration: none;
    font-family: var(--font-body);
  }
  .as-btn-action.assign {
    color: #4f46e5;
    border-color: rgba(79, 70, 229, 0.2);
    background: rgba(79, 70, 229, 0.04);
  }
  .as-btn-action.assign:hover {
    background: rgba(79, 70, 229, 0.08);
    border-color: rgba(79, 70, 229, 0.35);
  }
  .as-btn-action.view {
    color: #0891b2;
    border-color: rgba(6, 182, 212, 0.2);
    background: rgba(6, 182, 212, 0.04);
  }
  .as-btn-action.view:hover {
    background: rgba(6, 182, 212, 0.08);
    border-color: rgba(6, 182, 212, 0.35);
  }
  .as-btn-action.trash {
    color: #ef4444;
    border: none;
    background: none;
    padding: 0.4rem;
  }
  .as-btn-action.trash:hover {
    color: #b91c1c;
    background: rgba(239, 68, 68, 0.06);
  }

  /* Empty state */
  .as-empty {
    text-align: center;
    padding: 3.5rem 1rem;
    color: var(--text-muted);
  }
  .as-empty i {
    font-size: 2.2rem;
    opacity: 0.25;
    display: block;
    margin-bottom: 0.75rem;
  }

  /* ── Modals overlay ────────────────────────── */
  .as-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    z-index: 9000;
  }
  .as-modal {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    max-width: 92vw;
    max-height: 88vh;
    overflow-y: auto;
    z-index: 9001;
    background: #fff;
    border-radius: 18px;
    padding: 1.75rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
    border: 1px solid #cbd5e1;
  }
  .as-modal::-webkit-scrollbar { width: 5px; }
  .as-modal::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  .as-modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid #f1f5f9;
  }
  .as-modal-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
  }
  .as-modal-close {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    border: 1px solid #e2e8f0;
    background: #fff;
    color: #94a3b8;
    cursor: pointer;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.18s;
  }
  .as-modal-close:hover {
    background: #f8fafc;
    color: var(--text-main);
  }

  /* Form selection grid */
  .as-select-grid {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.6rem;
    max-height: 180px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .as-select-grid::-webkit-scrollbar { width: 4px; }
  .as-select-grid::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  .as-select-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.84rem;
    cursor: pointer;
    color: var(--text-main);
    padding: 0.3rem 0.5rem;
    border-radius: 6px;
    transition: background 0.15s;
    user-select: none;
  }
  .as-select-label:hover {
    background: rgba(99, 102, 241, 0.05);
  }
  .as-select-label input {
    accent-color: #8b5cf6;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
</style>

<!-- ── Page Header ──────────────────────────────── -->
<div class="as-header">
  <h1 class="as-title">Bài Kiểm Tra Doanh Nghiệp</h1>
  <p class="as-subtitle">Tạo bài kiểm tra và phân phối đến từng cá nhân hoặc phòng ban trong doanh nghiệp.</p>
</div>

<!-- ── Flash Notification ────────────────────────── -->
<% if (flash) { %>
  <div class="as-alert <%= flashType === 'error' ? 'as-alert-error' : 'as-alert-success' %>">
    <i class="fa-solid fa-<%= flashType === 'error' ? 'circle-exclamation' : 'circle-check' %>"></i>
    <span><%- flash %></span>
  </div>
<% } %>
<div id="flash-container"></div>

<!-- ── Top Action Trigger ───────────────────────── -->
<% if (user.permissions.includes('QUIZ_BANK_MANAGE')) { %>
  <div style="margin-bottom: 1.6rem;">
    <button class="btn btn-primary" onclick="openCreateModal()" style="border-radius: 9px; display: inline-flex; align-items: center; gap: 0.5rem;">
      <i class="fa-solid fa-circle-plus"></i> Tạo đề kiểm tra mới
    </button>
  </div>
<% } %>

<!-- ── Main Card ────────────────────────────────── -->
<div class="as-card">
  <div class="as-card-header">
    <h3 class="as-card-title">
      <i class="fa-solid fa-clipboard-list"></i>
      <span>Danh sách đề kiểm tra</span>
    </h3>
    <span class="as-count-badge">
      <%= assessments.length %> đề thi
    </span>
  </div>

  <!-- Tabs Selector -->
  <div class="as-tabs-bar">
    <button type="button" onclick="switchAssessmentTab('published')" id="tab-btn-published" class="as-tab-btn active">
      <i class="fa-solid fa-circle-check" style="color: #059669;"></i> Đã xuất bản (<%= assessments.filter(a => a.status === 'published').length %>)
    </button>
    <button type="button" onclick="switchAssessmentTab('draft')" id="tab-btn-draft" class="as-tab-btn">
      <i class="fa-solid fa-pen-to-square" style="color: #d97706;"></i> Bản nháp (<%= assessments.filter(a => a.status === 'draft').length %>)
    </button>
  </div>

  <% if (assessments.length === 0) { %>
    <div class="as-empty">
      <i class="fa-solid fa-inbox"></i>
      <p style="font-size: 0.9rem;">Chưa có bài kiểm tra nào được ghi nhận.</p>
    </div>
  <% } else { %>
    <div style="overflow-x: auto;">
      <table id="assessments-table" class="as-table">
        <thead>
          <tr>
            <th style="padding-left: 1.5rem; text-align: left;">Tiêu đề đề thi</th>
            <th style="text-align: center; width: 100px;">Số câu hỏi</th>
            <th style="text-align: center; width: 120px;">Thời lượng</th>
            <th style="text-align: center; width: 150px;">Trạng thái</th>
            <th style="text-align: center; width: 100px;">Đã giao</th>
            <th style="text-align: center; width: 140px;">Người tạo</th>
            <th style="padding-right: 1.5rem; text-align: right; width: 280px;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% assessments.forEach(a => { %>
            <tr class="assessment-row" data-status="<%= a.status %>">
              <td style="padding-left: 1.5rem;">
                <div style="font-weight: 700; color: var(--text-main); font-size: 0.9rem;"><%= a.title %></div>
                <% if (a.description) { %>
                  <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.15rem; max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= a.description %>">
                    <%= a.description %>
                  </div>
                <% } %>
              </td>
              <td style="text-align: center;">
                <span style="font-weight: 700; color: #4f46e5; font-size: 0.9rem;"><%= a.question_count_actual || a.question_count %></span>
                <span style="font-size: 0.78rem; color: var(--text-muted);"> câu</span>
              </td>
              <td style="text-align: center; font-size: 0.82rem; color: #475569;">
                <i class="fa-regular fa-clock" style="margin-right: 0.25rem;"></i><%= a.duration_minutes %> phút
              </td>
              <td style="text-align: center;">
                <% if (a.status === 'published') { %>
                  <span class="as-badge-pub">
                    <i class="fa-solid fa-circle-check"></i> Đã xuất bản
                  </span>
                <% } else { %>
                  <span class="as-badge-draft">
                    <i class="fa-solid fa-pen-to-square"></i> Bản nháp
                  </span>
                <% } %>
              </td>
              <td style="text-align: center; font-weight: 700; color: #0d9488; font-size: 0.9rem;">
                <%= a.assignment_count %>
              </td>
              <td style="text-align: center; font-size: 0.82rem; color: var(--text-muted);">
                <%= a.creator_name || 'Hệ thống' %>
              </td>
              <td style="padding-right: 1.5rem; text-align: right;">
                <div style="display: flex; gap: 0.4rem; justify-content: flex-end;">
                  <% if (user.permissions.includes('ENROLL_ASSIGN') && a.status === 'published') { %>
                    <button class="as-btn-action assign" onclick="openAssignModal(<%= a.id %>, '<%= a.title.replace(/'/g, "\\'") %>')">
                      <i class="fa-solid fa-paper-plane"></i> Phân phối
                    </button>
                  <% } %>
                  <% if (user.permissions.includes('QUIZ_BANK_MANAGE') && a.status === 'draft') { %>
                    <form action="/admin/assessments/<%= a.id %>/publish" method="POST" style="margin: 0;" onsubmit="return confirm('Xuất bản đề kiểm tra này?')">
                      <button type="submit" class="btn btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.78rem; border-radius: 7px;">
                        <i class="fa-solid fa-circle-check"></i> Xuất bản
                      </button>
                    </form>
                  <% } %>
                  <% if (user.permissions.includes('QUIZ_BANK_VIEW')) { %>
                    <a href="/admin/assessments/<%= a.id %>" class="as-btn-action view">
                      <i class="fa-solid fa-eye"></i> Xem đề
                    </a>
                  <% } %>
                  <% if (user.permissions.includes('QUIZ_BANK_MANAGE')) { %>
                    <form action="/admin/assessments/<%= a.id %>/delete" method="POST" style="margin: 0;" onsubmit="return confirm('Xác nhận xóa đề kiểm tra này?')">
                      <button type="submit" class="as-btn-action trash" title="Xóa đề thi">
                        <i class="fa-solid fa-trash-can"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Tab empty states -->
    <div id="empty-published" class="as-empty" style="display: none;">
      <i class="fa-solid fa-circle-check"></i>
      <p style="font-size: 0.9rem;">Không có đề kiểm tra nào đã xuất bản.</p>
    </div>

    <div id="empty-draft" class="as-empty" style="display: none;">
      <i class="fa-solid fa-pen-to-square"></i>
      <p style="font-size: 0.9rem;">Không có đề kiểm tra nháp nào.</p>
    </div>
  <% } %>
</div>

<!-- ── Backdrop Overlay ─────────────────────────── -->
<div id="as-overlay" class="as-overlay" onclick="closeAllModals()"></div>

<!-- ── Modal: Create Assessment ─────────────────── -->
<div id="modal-create" class="as-modal">
  <div class="as-modal-head">
    <h3 class="as-modal-title">
      <i id="header-create-icon" class="fa-solid fa-keyboard" style="color: #6366f1;"></i>
      <span id="header-create-text">Tạo Bài Kiểm Tra Mới</span>
    </h3>
    <button class="as-modal-close" onclick="closeCreateModal()"><i class="fa-solid fa-xmark"></i></button>
  </div>

  <div class="form-group">
    <label class="form-label">Tiêu đề bài kiểm tra <span style="color:#ef4444">*</span></label>
    <input type="text" id="create-title" placeholder="VD: Đánh giá năng lực Backend Quý II">
  </div>

  <div class="form-group">
    <label class="form-label">Mô tả mục tiêu</label>
    <textarea id="create-desc" rows="2" placeholder="Nhập mục tiêu đánh giá..."></textarea>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; margin-bottom: 1.25rem;">
    <div class="form-group" style="margin-bottom: 0;">
      <label class="form-label">Thời gian (phút)</label>
      <input type="number" id="create-duration" value="30" min="5" max="180">
    </div>
    <div class="form-group" style="margin-bottom: 0;">
      <label class="form-label">Điểm đạt (%)</label>
      <input type="number" id="create-passing" value="70" min="0" max="100">
    </div>
  </div>

  <div style="display: flex; gap: 0.5rem; justify-content: flex-end; border-top: 1px solid #f1f5f9; padding-top: 1.1rem; margin-top: 0.5rem;">
    <button onclick="closeCreateModal()" class="btn btn-secondary" style="border-radius: 8px;">Hủy</button>
    <button id="btn-create-submit" onclick="submitCreateAssessment()" class="btn btn-primary" style="border-radius: 8px; display: inline-flex; align-items: center; gap: 0.45rem;">
      <i id="icon-create-submit" class="fa-solid fa-circle-plus"></i>
      <span id="text-create-submit">Tạo đề thi</span>
    </button>
  </div>
</div>

<!-- ── Modal: Assign Assessment ─────────────────── -->
<div id="modal-assign" class="as-modal" style="width: 520px;">
  <div class="as-modal-head">
    <h3 class="as-modal-title">
      <i class="fa-solid fa-paper-plane" style="color: #6366f1;"></i>
      <span>Phân Phối Bài Kiểm Tra</span>
    </h3>
    <button class="as-modal-close" onclick="closeAssignModal()"><i class="fa-solid fa-xmark"></i></button>
  </div>
  
  <div style="margin-bottom: 1.25rem; padding: 0.75rem 1rem; background: rgba(99,102,241,0.06); border-radius: 8px; border: 1px solid rgba(99,102,241,0.18);">
    <div style="font-size: 0.76rem; color: var(--text-muted);">Đề thi được phân phối</div>
    <div id="assign-title-display" style="font-weight: 700; color: #4f46e5; margin-top: 0.15rem; font-size: 0.9rem;"></div>
  </div>
  <input type="hidden" id="assign-assessment-id">

  <div class="form-group">
    <label class="form-label" style="font-size: 0.8rem; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em;">Hình thức giao</label>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
      <label onclick="switchAssignType('user')" id="tab-user" class="as-btn-action assign" style="padding: 0.65rem; justify-content: center; font-size: 0.85rem; cursor: pointer;">
        <input type="radio" name="targetType" value="user" checked style="display:none;">
        <i class="fa-solid fa-user"></i> <span style="font-weight: 700; margin-left: 0.35rem;">Giao cá nhân</span>
      </label>
      <label onclick="switchAssignType('department')" id="tab-dept" class="as-btn-action" style="padding: 0.65rem; justify-content: center; font-size: 0.85rem; cursor: pointer;">
        <input type="radio" name="targetType" value="department" style="display:none;">
        <i class="fa-solid fa-building"></i> <span style="font-weight: 700; margin-left: 0.35rem;">Giao phòng ban</span>
      </label>
    </div>
  </div>

  <!-- User list selection -->
  <div class="form-group" id="assign-user-section">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.45rem;">
      <label class="form-label" style="margin: 0;">Danh sách nhân sự</label>
      <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.78rem; cursor: pointer; user-select: none; color: #4f46e5; font-weight: 700;">
        <input type="checkbox" id="user-select-all" onchange="toggleSelectAllUsers(this)" style="width: 14px; height: 14px; accent-color: #8b5cf6;"> Chọn hết
      </label>
    </div>
    <div style="position: relative; margin-bottom: 0.5rem;">
      <input type="text" id="user-search" placeholder="Tìm tên hoặc email..." oninput="filterUsers()" style="padding-left: 2rem;">
      <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 0.8rem;"></i>
    </div>
    <div id="user-list-container" class="as-select-grid">
      <% users.forEach(u => { %>
        <label class="as-select-label user-item" data-search="<%= u.username.toLowerCase() %> <%= u.email.toLowerCase() %>">
          <input type="checkbox" class="assign-user-cb" value="<%= u.id %>" onchange="updateSelectAllState('user')">
          <span><%= u.username %> <span style="color:var(--text-muted); font-size:0.76rem; font-weight:normal;">(<%= u.email %>)</span></span>
        </label>
      <% }) %>
    </div>
  </div>

  <!-- Department list selection -->
  <div class="form-group" id="assign-dept-section" style="display:none;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.45rem;">
      <label class="form-label" style="margin: 0;">Danh sách phòng ban</label>
      <label style="display: flex; align-items: center; gap: 0.3rem; font-size: 0.78rem; cursor: pointer; user-select: none; color: #4f46e5; font-weight: 700;">
        <input type="checkbox" id="dept-select-all" onchange="toggleSelectAllDepts(this)" style="width: 14px; height: 14px; accent-color: #8b5cf6;"> Chọn hết
      </label>
    </div>
    <div style="position: relative; margin-bottom: 0.5rem;">
      <input type="text" id="dept-search" placeholder="Tìm tên phòng ban..." oninput="filterDepts()" style="padding-left: 2rem;">
      <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 0.8rem;"></i>
    </div>
    <div id="dept-list-container" class="as-select-grid">
      <% departments.forEach(d => { %>
        <label class="as-select-label dept-item" data-search="<%= d.name.toLowerCase() %>">
          <input type="checkbox" class="assign-dept-cb" value="<%= d.id %>" onchange="updateSelectAllState('dept')">
          <span><%= d.name %></span>
        </label>
      <% }) %>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; margin-bottom: 1.25rem;">
    <div class="form-group" style="margin-bottom: 0;">
      <label class="form-label">Thời điểm mở đề</label>
      <input type="datetime-local" id="assign-starttime">
    </div>
    <div class="form-group" style="margin-bottom: 0;">
      <label class="form-label">Hạn hoàn thành</label>
      <input type="datetime-local" id="assign-deadline">
    </div>
  </div>

  <div style="display: flex; gap: 0.5rem; justify-content: flex-end; border-top: 1px solid #f1f5f9; padding-top: 1.1rem; margin-top: 0.5rem;">
    <button onclick="closeAssignModal()" class="btn btn-secondary" style="border-radius: 8px;">Hủy</button>
    <button onclick="submitAssign()" class="btn btn-primary" id="btn-assign-submit" style="border-radius: 8px; display: inline-flex; align-items: center; gap: 0.45rem;">
      <i class="fa-solid fa-paper-plane"></i> Giao bài thi
    </button>
  </div>
</div>

<script>
  let currentAssignType = 'user';

  function showModal(id) {
    document.getElementById(id).style.display = 'block';
    document.getElementById('as-overlay').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }
  function hideModal(id) {
    document.getElementById(id).style.display = 'none';
    document.getElementById('as-overlay').style.display = 'none';
    document.body.style.overflow = '';
  }
  function closeAllModals() {
    closeCreateModal();
    closeAssignModal();
  }

  function openCreateModal() {
    showModal('modal-create');
  }
  function closeCreateModal() {
    hideModal('modal-create');
  }

  function openAssignModal(id, title) {
    document.getElementById('assign-assessment-id').value = id;
    document.getElementById('assign-title-display').textContent = title;
    
    // Reset checkboxes
    document.querySelectorAll('.assign-user-cb, .assign-dept-cb').forEach(cb => cb.checked = false);
    document.getElementById('user-select-all').checked = false;
    document.getElementById('dept-select-all').checked = false;
    
    // Reset search
    document.getElementById('user-search').value = '';
    document.getElementById('dept-search').value = '';
    filterUsers();
    filterDepts();
    
    // Reset dates
    document.getElementById('assign-starttime').value = '';
    document.getElementById('assign-deadline').value = '';
    
    showModal('modal-assign');
  }

  function closeAssignModal() {
    hideModal('modal-assign');
  }

  function filterUsers() {
    const query = document.getElementById('user-search').value.toLowerCase().trim();
    const items = document.querySelectorAll('#user-list-container .user-item');
    items.forEach(item => {
      const text = item.getAttribute('data-search') || '';
      item.style.display = text.includes(query) ? 'flex' : 'none';
    });
    updateSelectAllState('user');
  }

  function toggleSelectAllUsers(selectAllCb) {
    const items = document.querySelectorAll('#user-list-container .user-item');
    items.forEach(item => {
      if (item.style.display !== 'none') {
        item.querySelector('.assign-user-cb').checked = selectAllCb.checked;
      }
    });
  }

  function filterDepts() {
    const query = document.getElementById('dept-search').value.toLowerCase().trim();
    const items = document.querySelectorAll('#dept-list-container .dept-item');
    items.forEach(item => {
      const text = item.getAttribute('data-search') || '';
      item.style.display = text.includes(query) ? 'flex' : 'none';
    });
    updateSelectAllState('dept');
  }

  function toggleSelectAllDepts(selectAllCb) {
    const items = document.querySelectorAll('#dept-list-container .dept-item');
    items.forEach(item => {
      if (item.style.display !== 'none') {
        item.querySelector('.assign-dept-cb').checked = selectAllCb.checked;
      }
    });
  }

  function updateSelectAllState(type) {
    const items = document.querySelectorAll(type === 'user' ? '#user-list-container .user-item' : '#dept-list-container .dept-item');
    const visibleItems = Array.from(items).filter(item => item.style.display !== 'none');
    const selectAllCb = document.getElementById(type === 'user' ? 'user-select-all' : 'dept-select-all');
    
    if (visibleItems.length === 0) {
      selectAllCb.checked = false;
      return;
    }
    
    const cbClass = type === 'user' ? '.assign-user-cb' : '.assign-dept-cb';
    const allChecked = visibleItems.every(item => item.querySelector(cbClass).checked);
    selectAllCb.checked = allChecked;
  }

  function switchAssignType(type) {
    currentAssignType = type;
    const userSection = document.getElementById('assign-user-section');
    const deptSection = document.getElementById('assign-dept-section');
    const tabUser = document.getElementById('tab-user');
    const tabDept = document.getElementById('tab-dept');
    if (type === 'user') {
      userSection.style.display = '';
      deptSection.style.display = 'none';
      tabUser.className = 'as-btn-action assign';
      tabUser.style.borderWidth = '2px';
      tabDept.className = 'as-btn-action';
      tabDept.style.borderWidth = '1px';
    } else {
      userSection.style.display = 'none';
      deptSection.style.display = '';
      tabDept.className = 'as-btn-action assign';
      tabDept.style.borderWidth = '2px';
      tabUser.className = 'as-btn-action';
      tabUser.style.borderWidth = '1px';
    }
  }

  function showFlash(msg, type = 'success') {
    const fc = document.getElementById('flash-container');
    fc.innerHTML = `<div class="as-alert ${type === 'error' ? 'as-alert-error' : 'as-alert-success'}">
      <i class="fa-solid fa-${type === 'error' ? 'circle-exclamation' : 'circle-check'}"></i>
      <span>${msg}</span>
    </div>`;
    fc.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setTimeout(() => { fc.innerHTML = ''; }, 6000);
  }

  async function submitCreateAssessment() {
    const title = document.getElementById('create-title').value.trim();
    const description = document.getElementById('create-desc').value.trim();
    const duration = document.getElementById('create-duration').value;
    const passing = document.getElementById('create-passing').value;

    if (!title) return alert('Vui lòng nhập tiêu đề bài kiểm tra.');

    const textSubmit = document.getElementById('text-create-submit');
    document.getElementById('btn-create-submit').disabled = true;
    if (textSubmit) textSubmit.textContent = 'Đang xử lý...';

    try {
      const res = await fetch('/admin/assessments/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          type: 'manual',
          title,
          description,
          durationMinutes: duration,
          passingScore: passing
        })
      });
      const data = await res.json();
      closeCreateModal();
      if (data.success) {
        showFlash(data.message);
        setTimeout(() => window.location.href = `/admin/assessments/${data.assessmentId}`, 1000);
      } else {
        showFlash(data.error || 'Có lỗi xảy ra.', 'error');
      }
    } catch (err) {
      closeCreateModal();
      showFlash('Lỗi kết nối máy chủ: ' + err.message, 'error');
    } finally {
      document.getElementById('btn-create-submit').disabled = false;
      if (textSubmit) {
        textSubmit.textContent = 'Tạo đề thi';
      }
    }
  }

  async function submitAssign() {
    const assessmentId = document.getElementById('assign-assessment-id').value;
    const startTime = document.getElementById('assign-starttime').value;
    const deadline = document.getElementById('assign-deadline').value;
    const cbClass = currentAssignType === 'user' ? '.assign-user-cb' : '.assign-dept-cb';
    const targetIds = [...document.querySelectorAll(`${cbClass}:checked`)].map(cb => cb.value);

    if (targetIds.length === 0) return alert('Vui lòng chọn ít nhất 1 ' + (currentAssignType === 'user' ? 'nhân sự' : 'phòng ban') + '.');

    const submitBtn = document.getElementById('btn-assign-submit');
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang giao...';

    try {
      const res = await fetch(`/admin/assessments/${assessmentId}/assign`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ assessmentId, targetType: currentAssignType, targetIds, startTime: startTime || null, deadline: deadline || null })
      });
      const data = await res.json();
      closeAssignModal();
      if (data.success) {
        showFlash(data.message);
      } else {
        showFlash(data.error || 'Có lỗi xảy ra.', 'error');
      }
    } catch (err) {
      closeAssignModal();
      showFlash('Lỗi kết nối: ' + err.message, 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Giao bài thi';
    }
  }

  function switchAssessmentTab(tab) {
    const btnPublished = document.getElementById('tab-btn-published');
    const btnDraft = document.getElementById('tab-btn-draft');
    if (!btnPublished || !btnDraft) return;

    if (tab === 'published') {
      btnPublished.classList.add('active');
      btnDraft.classList.remove('active');
    } else {
      btnDraft.classList.add('active');
      btnPublished.classList.remove('active');
    }
    
    let visibleCount = 0;
    const rows = document.querySelectorAll('.assessment-row');
    rows.forEach(row => {
      const match = row.dataset.status === tab;
      row.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });
    
    const emptyPublished = document.getElementById('empty-published');
    const emptyDraft = document.getElementById('empty-draft');
    const tableEl = document.getElementById('assessments-table');
    
    if (emptyPublished) emptyPublished.style.display = 'none';
    if (emptyDraft) emptyDraft.style.display = 'none';
    
    if (visibleCount === 0) {
      if (tableEl) tableEl.style.display = 'none';
      if (tab === 'published' && emptyPublished) {
        emptyPublished.style.display = 'block';
      } else if (tab === 'draft' && emptyDraft) {
        emptyDraft.style.display = 'block';
      }
    } else {
      if (tableEl) tableEl.style.display = '';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    switchAssessmentTab('published');
  });
</script>

<%- include('../partials/footer') %>
