<%- include('../partials/header') %>

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
  <div>
    <h1 style="font-size: 2.2rem; font-weight: 800; background: linear-gradient(135deg, #4f46e5, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; padding-top: 0.25rem; padding-bottom: 0.25rem;">
      <i class="fa-solid fa-file-video" style="-webkit-text-fill-color: #4f46e5; font-size: 1.8rem; margin-right: 0.5rem;"></i>Bài Học & Nội Dung
    </h1>
    <p style="color: var(--text-muted); margin-top: 0.25rem; font-size: 0.95rem;">
      Tổng hợp tất cả bài giảng trong hệ thống. Chọn một khóa học để thêm hoặc chỉnh sửa bài học chi tiết.
    </p>
  </div>
  <% if (user.permissions.includes('COURSE_VIEW')) { %>
    <a href="/course-management" class="btn btn-secondary" style="white-space: nowrap; display: inline-flex; align-items: center; gap: 0.5rem; border-radius: 12px;">
      <i class="fa-solid fa-folder-open" style="color: #4f46e5;"></i> Đến Quản lý khóa học
    </a>
  <% } %>
</div>

<!-- Stats nhanh -->
<%
const totalLessons = allLessons.length;
const coursesWithLessons = lessonsByCourse.filter(g => g.lessons.length > 0).length;
const coursesEmpty = lessonsByCourse.filter(g => g.lessons.length === 0).length;
const hasVideo = allLessons.filter(l => l.video_url && l.video_url.trim() !== '').length;
%>
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem;">
  <!-- Thống kê: Tổng bài học -->
  <div class="glass-card" style="padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; border-left: 4px solid #a78bfa; overflow: hidden; position: relative;">
    <div>
      <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Tổng bài học</div>
      <div style="font-size: 2.2rem; font-weight: 800; color: var(--text-main); margin-top: 0.25rem; line-height: 1.2;"><%= totalLessons %></div>
    </div>
    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(167,139,250,0.1); display: flex; align-items: center; justify-content: center; color: #a78bfa; font-size: 1.3rem;">
      <i class="fa-solid fa-file-video"></i>
    </div>
  </div>

  <!-- Thống kê: Khóa học -->
  <div class="glass-card" style="padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; border-left: 4px solid #06b6d4; overflow: hidden; position: relative;">
    <div>
      <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Khóa học</div>
      <div style="font-size: 2.2rem; font-weight: 800; color: var(--text-main); margin-top: 0.25rem; line-height: 1.2;"><%= courses.length %></div>
    </div>
    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(6,182,212,0.1); display: flex; align-items: center; justify-content: center; color: #06b6d4; font-size: 1.3rem;">
      <i class="fa-solid fa-graduation-cap"></i>
    </div>
  </div>

  <!-- Thống kê: Có video -->
  <div class="glass-card" style="padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; border-left: 4px solid #10b981; overflow: hidden; position: relative;">
    <div>
      <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Có bài giảng video</div>
      <div style="font-size: 2.2rem; font-weight: 800; color: var(--text-main); margin-top: 0.25rem; line-height: 1.2;"><%= hasVideo %></div>
    </div>
    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(16,185,129,0.1); display: flex; align-items: center; justify-content: center; color: #10b981; font-size: 1.3rem;">
      <i class="fa-solid fa-circle-play"></i>
    </div>
  </div>

  <!-- Thống kê: Chưa có bài -->
  <div class="glass-card" style="padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; border-left: 4px solid #f59e0b; overflow: hidden; position: relative;">
    <div>
      <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Chưa có bài giảng</div>
      <div style="font-size: 2.2rem; font-weight: 800; color: var(--text-main); margin-top: 0.25rem; line-height: 1.2;"><%= coursesEmpty %></div>
    </div>
    <div style="width: 48px; height: 48px; border-radius: 12px; background: rgba(245,158,11,0.1); display: flex; align-items: center; justify-content: center; color: #f59e0b; font-size: 1.3rem;">
      <i class="fa-solid fa-folder-minus"></i>
    </div>
  </div>
</div>

<!-- Bộ lọc tìm kiếm -->
<div class="glass-card" style="padding: 1.25rem 1.75rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; border-radius: 16px;">
  <div style="flex: 1; min-width: 260px; position: relative;">
    <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.9rem;"></i>
    <input
      id="lesson-search-input"
      type="text"
      placeholder="Tìm tên bài học, nội dung hoặc tên khóa học..."
      oninput="filterLessons()"
      style="width: 100%; padding: 0.75rem 1rem 0.75rem 2.6rem; border: 1px solid var(--border-light); border-radius: 12px; color: var(--text-main); font-size: 0.9rem; outline: none; box-sizing: border-box; transition: all 0.3s;"
    >
  </div>
  <div>
    <select id="course-filter" onchange="filterLessons()" style="padding: 0.75rem 1.25rem; border: 1px solid var(--border-light); border-radius: 12px; color: var(--text-main); font-size: 0.9rem; min-width: 220px; transition: all 0.3s; background: #fff;">
      <option value="">— Tất cả khóa học —</option>
      <% courses.forEach(c => { %>
        <option value="<%= c.id %>"><%= c.title %></option>
      <% }) %>
    </select>
  </div>
  <div>
    <select id="video-filter" onchange="filterLessons()" style="padding: 0.75rem 1.25rem; border: 1px solid var(--border-light); border-radius: 12px; color: var(--text-main); font-size: 0.9rem; transition: all 0.3s; background: #fff;">
      <option value="">— Tất cả loại bài học —</option>
      <option value="has_video">Có video bài giảng</option>
      <option value="no_video">Chưa có video bài giảng</option>
    </select>
  </div>
  <div style="font-size: 0.88rem; color: var(--text-muted); font-weight: 500; white-space: nowrap; margin-left: auto;">
    Hiển thị: <span id="lesson-count-display" style="font-weight: 700; color: #4f46e5; font-size: 1.1rem;"><%= totalLessons %></span> bài học
  </div>
</div>

<!-- Bảng tổng hợp tất cả bài học -->
<div class="glass-card" style="padding: 1.5rem; overflow-x: auto; border-radius: 16px;">
  <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.6rem; color: var(--text-main);">
    <i class="fa-solid fa-layer-group" style="color: #4f46e5;"></i> Danh sách tất cả bài học
  </h3>

  <% if (allLessons.length === 0) { %>
    <div style="text-align: center; padding: 4rem 1rem; color: var(--text-muted);">
      <i class="fa-solid fa-file-circle-question" style="font-size: 3rem; opacity: 0.3; display: block; margin-bottom: 1rem;"></i>
      Chưa có bài học nào trong hệ thống.<br>
      <small>Hãy vào <a href="/course-management" style="color: #6366f1; font-weight: 600;">Quản lý khóa học</a> để thêm bài học đầu tiên.</small>
    </div>
  <% } else { %>
    <table class="custom-table" style="margin-top: 0; font-size: 0.85rem;" id="lessons-table">
      <thead>
        <tr>
          <th style="width: 60px;">STT</th>
          <th>Tên bài học</th>
          <th>Thuộc khóa học</th>
          <th style="text-align: center; width: 90px;">Thứ tự</th>
          <th style="text-align: center; width: 120px;">Video</th>
          <th style="text-align: center; width: 120px;">Tài liệu</th>
          <% if (user.permissions.includes('LESSON_MANAGE')) { %>
          <th style="text-align: center; width: 100px;">Thao tác</th>
          <% } %>
        </tr>
      </thead>
      <tbody id="lessons-tbody">
        <% let rowIndex = 0; allLessons.forEach(lesson => { rowIndex++; %>
          <tr
            class="lesson-row"
            data-title="<%= lesson.title.toLowerCase() %>"
            data-course="<%= lesson.course_id %>"
            data-course-title="<%= lesson.course_title.toLowerCase() %>"
            data-has-video="<%= (lesson.video_url && lesson.video_url.trim()) ? 'yes' : 'no' %>"
          >
            <td style="color: var(--text-muted); font-size: 0.8rem; font-weight: 500;"><%= rowIndex %></td>
            <td>
              <div style="font-weight: 600; color: var(--text-main); margin-bottom: 0.2rem; font-size: 0.92rem;"><%= lesson.title %></div>
              <% if (lesson.content) { %>
              <div style="font-size: 0.78rem; color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 320px;">
                <%= lesson.content.substring(0, 80) %><%= lesson.content.length > 80 ? '…' : '' %>
              </div>
              <% } %>
            </td>
            <td>
              <a href="/course-management/<%= lesson.course_id %>/lessons"
                style="display: inline-flex; align-items: center; gap: 0.4rem; color: #4f46e5; text-decoration: none; font-size: 0.82rem; font-weight: 600; padding: 0.25rem 0.65rem; background: rgba(79, 70, 229, 0.06); border: 1px solid rgba(79, 70, 229, 0.1); border-radius: 8px; transition: all 0.2s;"
                onmouseover="this.style.background='rgba(79, 70, 229, 0.12)'" onmouseout="this.style.background='rgba(79, 70, 229, 0.06)'"
              >
                <i class="fa-solid fa-folder-open" style="font-size: 0.75rem;"></i>
                <%= lesson.course_title %>
              </a>
            </td>
            <td style="text-align: center;">
              <span style="background: rgba(79, 70, 229, 0.04); border: 1px solid rgba(79, 70, 229, 0.1); padding: 0.2rem 0.6rem; border-radius: 6px; font-size: 0.8rem; font-weight: 700; color: #4f46e5;">
                #<%= lesson.order_index %>
              </span>
            </td>
            <td style="text-align: center;">
              <% if (lesson.is_quiz) { %>
                <span class="badge badge-info"><i class="fa-solid fa-circle-question"></i> Trắc nghiệm</span>
              <% } else if (lesson.video_url && lesson.video_url.trim()) { %>
                <span class="badge badge-success" title="<%= lesson.video_url %>">
                  <i class="fa-solid fa-circle-play"></i> Sẵn sàng
                </span>
              <% } else { %>
                <span class="badge badge-secondary">
                  <i class="fa-solid fa-circle-xmark"></i> Trống
                </span>
              <% } %>
            </td>
            <td style="text-align: center;">
              <% if (lesson.is_quiz) { %>
                <span class="badge badge-info"><i class="fa-solid fa-brain"></i> AI tạo đề</span>
              <% } else if (lesson.attachment_url && lesson.attachment_url.trim()) { %>
                <span class="badge badge-warning" title="<%= lesson.attachment_url %>">
                  <i class="fa-solid fa-paperclip"></i> Đính kèm
                </span>
              <% } else { %>
                <span class="badge badge-secondary">
                  <i class="fa-solid fa-minus"></i> Trống
                </span>
              <% } %>
            </td>
            <% if (user.permissions.includes('LESSON_MANAGE')) { %>
            <td style="text-align: center;">
              <div style="display: flex; justify-content: center; gap: 0.35rem;">
                <a href="/course-management/<%= lesson.course_id %>/lessons"
                  class="btn btn-secondary"
                  style="padding: 0.35rem 0.65rem; font-size: 0.78rem; color: #4f46e5; border-color: rgba(79, 70, 229, 0.2); text-decoration: none; border-radius: 8px;"
                  title="Đến trang chỉnh sửa bài học này">
                  <i class="fa-solid fa-pen-to-square"></i> Sửa
                </a>
              </div>
            </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Phân trang -->
    <div id="pagination-controls" style="display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-top: 1.5rem; flex-wrap: wrap;"></div>

    <!-- Thông báo khi lọc không có kết quả -->
    <div id="no-filter-result" style="display: none; text-align: center; padding: 3rem; color: var(--text-muted);">
      <i class="fa-solid fa-filter-circle-xmark" style="font-size: 2rem; opacity: 0.4; display: block; margin-bottom: 0.75rem;"></i>
      Không tìm thấy bài học phù hợp với bộ lọc.
    </div>
  <% } %>
</div>

<!-- Phân nhóm theo khóa học (accordion) -->
<% if (lessonsByCourse.length > 0) { %>
<div style="margin-top: 2.5rem; border-top: 1px solid var(--border-light); padding-top: 2rem;">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
    <h3 
      onclick="toggleSectionGroup()" 
      style="font-size: 1.15rem; font-weight: 700; display: inline-flex; align-items: center; gap: 0.6rem; color: var(--text-muted); cursor: pointer; user-select: none;"
    >
      <i class="fa-solid fa-folder-tree" style="color: #06b6d4;"></i> Phân nhóm theo khóa học
      <span id="group-toggle-badge" class="badge badge-secondary" style="font-size: 0.72rem; padding: 0.15rem 0.5rem; margin-left: 0.4rem;">Ẩn</span>
      <i id="group-chevron" class="fa-solid fa-chevron-right" style="color: var(--text-muted); font-size: 0.85rem; transition: transform 0.3s; margin-left: 0.25rem;"></i>
    </h3>
    <button onclick="toggleSectionGroup()" class="btn btn-secondary" style="padding: 0.4rem 0.85rem; font-size: 0.82rem; border-radius: 8px; display: inline-flex; align-items: center; gap: 0.35rem;">
      <i id="group-btn-icon" class="fa-solid fa-eye"></i> <span id="group-btn-text">Hiển thị</span>
    </button>
  </div>
  <div id="course-groups-list" style="display: none; flex-direction: column; gap: 1rem; transition: all 0.3s ease;">
    <% lessonsByCourse.forEach((group, gi) => { %>
    <div class="glass-card" style="padding: 0; overflow: hidden; border-radius: 16px; border: 1px solid var(--border-light); transition: all 0.3s;">
      <!-- Header accordion -->
      <button
        onclick="toggleAccordion(<%= gi %>)"
        style="width: 100%; background: none; border: none; padding: 1.25rem 1.5rem; display: flex; align-items: center; justify-content: space-between; cursor: pointer; color: var(--text-main); text-align: left; transition: background 0.2s;"
        onmouseover="this.style.background='rgba(79, 70, 229, 0.015)'"
        onmouseout="this.style.background='none'"
      >
        <div style="display: flex; align-items: center; gap: 0.85rem;">
          <div style="width: 38px; height: 38px; border-radius: 10px; background: linear-gradient(135deg, #4f46e5, #6366f1); display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4px 10px rgba(79,70,229,0.15);">
            <i class="fa-solid fa-book-open" style="color: #fff; font-size: 0.9rem;"></i>
          </div>
          <div>
            <div style="font-weight: 700; font-size: 0.95rem; color: var(--text-main);"><%= group.course.title %></div>
            <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.15rem; display: flex; align-items: center; gap: 0.5rem;">
              <span><%= group.lessons.length %> bài học</span>
              <span>•</span>
              <span class="badge <%= group.course.is_published ? 'badge-success' : 'badge-warning' %>" style="padding: 0.1rem 0.45rem; font-size: 0.65rem;">
                <%= group.course.is_published ? 'Đã xuất bản' : 'Bản nháp' %>
              </span>
            </div>
          </div>
        </div>
        <div style="display: flex; align-items: center; gap: 0.85rem;">
          <% if (user.permissions.includes('LESSON_CREATE') || user.permissions.includes('LESSON_MANAGE')) { %>
          <a href="/course-management/<%= group.course.id %>/lessons"
            onclick="event.stopPropagation()"
            style="font-size: 0.78rem; color: #4f46e5; text-decoration: none; padding: 0.35rem 0.75rem; border: 1px solid rgba(79, 70, 229, 0.2); border-radius: 8px; background: rgba(79, 70, 229, 0.05); font-weight: 600; display: inline-flex; align-items: center; gap: 0.3rem; transition: all 0.2s;"
            onmouseover="this.style.background='rgba(79,70,229,0.1)'" onmouseout="this.style.background='rgba(79,70,229,0.05)'"
          >
            <i class="fa-solid fa-gear" style="font-size: 0.75rem;"></i> Cấu hình
          </a>
          <% } %>
          <i id="accordion-icon-<%= gi %>" class="fa-solid fa-chevron-down" style="color: var(--text-muted); font-size: 0.85rem; transition: transform 0.3s; padding: 0.25rem;"></i>
        </div>
      </button>

      <!-- Nội dung accordion -->
      <div id="accordion-body-<%= gi %>" style="display: none; border-top: 1px solid var(--border-light); background: rgba(248, 250, 252, 0.65);">
        <% if (group.lessons.length === 0) { %>
          <div style="padding: 2rem; text-align: center; color: var(--text-muted); font-size: 0.88rem;">
            <i class="fa-solid fa-inbox" style="margin-right: 0.4rem; font-size: 1.2rem; opacity: 0.5;"></i> Khóa học chưa có bài giảng nào.
            <% if (user.permissions.includes('LESSON_CREATE')) { %>
              <a href="/course-management/<%= group.course.id %>/lessons" style="color: #4f46e5; margin-left: 0.4rem; font-weight: 600;">Thêm ngay →</a>
            <% } %>
          </div>
        <% } else { %>
          <div style="padding: 0.25rem 0;">
            <% group.lessons.forEach((lesson, li) => { %>
              <div style="
                display: flex; align-items: center; gap: 0.85rem;
                padding: 0.85rem 1.5rem;
                border-bottom: 1px solid rgba(226, 232, 240, 0.5);
                transition: background 0.15s;
              " onmouseover="this.style.background='#ffffff'" onmouseout="this.style.background='none'">
                <span style="font-size: 0.8rem; color: var(--text-muted); min-width: 28px; text-align: right; font-weight: 600;">#<%= lesson.order_index %></span>
                
                <div style="font-size: 1rem; width: 24px; display: flex; justify-content: center; align-items: center;">
                  <% if (lesson.is_quiz) { %>
                    <i class="fa-solid fa-circle-question" style="color: #4f46e5;" title="Bài kiểm tra trắc nghiệm"></i>
                  <% } else if (lesson.video_url && lesson.video_url.trim()) { %>
                    <i class="fa-solid fa-circle-play" style="color: #10b981;" title="Bài giảng video"></i>
                  <% } else { %>
                    <i class="fa-solid fa-file-lines" style="color: #64748b;" title="Bài học lý thuyết"></i>
                  <% } %>
                </div>

                <div style="flex: 1; min-width: 0;">
                  <div style="font-size: 0.9rem; font-weight: 600; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    <%= lesson.title %>
                  </div>
                </div>
                
                <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;">
                  <% if (lesson.is_quiz) { %>
                    <span class="badge badge-info" style="padding: 0.15rem 0.5rem; font-size: 0.7rem;">AI Quiz</span>
                  <% } %>
                  <% if (lesson.video_url && lesson.video_url.trim()) { %>
                    <span class="badge badge-success" style="padding: 0.15rem 0.5rem; font-size: 0.7rem;"><i class="fa-solid fa-circle-play"></i> Video</span>
                  <% } %>
                  <% if (lesson.attachment_url && lesson.attachment_url.trim()) { %>
                    <span class="badge badge-warning" style="padding: 0.15rem 0.5rem; font-size: 0.7rem;"><i class="fa-solid fa-paperclip"></i> Tài liệu</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% } %>

<script>
  // Toggle hiển thị phân nhóm khóa học
  function toggleSectionGroup() {
    const list = document.getElementById('course-groups-list');
    const chevron = document.getElementById('group-chevron');
    const badge = document.getElementById('group-toggle-badge');
    const btnIcon = document.getElementById('group-btn-icon');
    const btnText = document.getElementById('group-btn-text');
    
    const isHidden = list.style.display === 'none';
    
    if (isHidden) {
      list.style.display = 'flex';
      chevron.style.transform = 'rotate(90deg)';
      badge.textContent = 'Đang hiện';
      badge.className = 'badge badge-info';
      btnIcon.className = 'fa-solid fa-eye-slash';
      btnText.textContent = 'Ẩn đi';
    } else {
      list.style.display = 'none';
      chevron.style.transform = '';
      badge.textContent = 'Ẩn';
      badge.className = 'badge badge-secondary';
      btnIcon.className = 'fa-solid fa-eye';
      btnText.textContent = 'Hiển thị';
    }
  }

  // Accordion toggle
  function toggleAccordion(index) {
    const body = document.getElementById(`accordion-body-${index}`);
    const icon = document.getElementById(`accordion-icon-${index}`);
    const isOpen = body.style.display !== 'none';
    body.style.display = isOpen ? 'none' : 'block';
    icon.style.transform = isOpen ? '' : 'rotate(180deg)';
  }

  let currentPage = 1;
  const pageSize = 20;

  // Lọc và phân trang bài học
  function filterLessons(resetPage = true) {
    if (resetPage) {
      currentPage = 1;
    }

    const search  = document.getElementById('lesson-search-input').value.toLowerCase().trim();
    const courseId = document.getElementById('course-filter').value;
    const videoFilter = document.getElementById('video-filter').value;

    const rows = document.querySelectorAll('.lesson-row');
    const matchedRows = [];

    rows.forEach(row => {
      const title       = row.dataset.title || '';
      const courseTitle = row.dataset.courseTitle || '';
      const rowCourse   = row.dataset.course;
      const hasVideo    = row.dataset.hasVideo;

      const matchText   = !search || title.includes(search) || courseTitle.includes(search);
      const matchCourse = !courseId || rowCourse === courseId;
      const matchVideo  = !videoFilter
        || (videoFilter === 'has_video' && hasVideo === 'yes')
        || (videoFilter === 'no_video'  && hasVideo === 'no');

      if (matchText && matchCourse && matchVideo) {
        matchedRows.push(row);
      } else {
        row.style.display = 'none';
      }
    });

    const totalMatched = matchedRows.length;
    const totalPages = Math.ceil(totalMatched / pageSize);

    // Đảm bảo currentPage không vượt quá totalPages
    if (currentPage > totalPages && totalPages > 0) {
      currentPage = totalPages;
    }

    // Hiển thị các dòng thuộc trang hiện tại
    const startIndex = (currentPage - 1) * pageSize;
    const endIndex = startIndex + pageSize;

    matchedRows.forEach((row, index) => {
      if (index >= startIndex && index < endIndex) {
        row.style.display = '';
        // Cập nhật lại số thứ tự hiển thị của các bài học theo thứ tự thực tế trong trang
        const sttCell = row.querySelector('td:first-child');
        if (sttCell) {
          sttCell.textContent = index + 1;
        }
      } else {
        row.style.display = 'none';
      }
    });

    document.getElementById('lesson-count-display').textContent = totalMatched;
    const noResult = document.getElementById('no-filter-result');
    if (noResult) noResult.style.display = totalMatched === 0 ? 'block' : 'none';

    renderPaginationControls(totalPages);
  }

  // Tạo giao diện các nút phân trang
  function renderPaginationControls(totalPages) {
    const container = document.getElementById('pagination-controls');
    if (!container) return;

    if (totalPages <= 1) {
      container.innerHTML = '';
      return;
    }

    let html = '';

    // Nút Trước
    html += `
      <button 
        onclick="changePage(${currentPage - 1})" 
        class="btn btn-secondary" 
        style="padding: 0.4rem 0.85rem; font-size: 0.82rem; border-radius: 10px; display: inline-flex; align-items: center; gap: 0.25rem;"
        ${currentPage === 1 ? 'disabled style="opacity: 0.4; cursor: not-allowed;"' : ''}
      >
        <i class="fa-solid fa-chevron-left" style="font-size: 0.75rem;"></i> Trước
      </button>
    `;

    // Giới hạn hiển thị tối đa 5 nút số trang xung quanh trang hiện tại
    const maxVisiblePages = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));
    let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);

    if (endPage - startPage + 1 < maxVisiblePages) {
      startPage = Math.max(1, endPage - maxVisiblePages + 1);
    }

    if (startPage > 1) {
      html += `<button onclick="changePage(1)" class="btn btn-secondary" style="padding: 0.4rem 0.75rem; font-size: 0.82rem; border-radius: 10px;">1</button>`;
      if (startPage > 2) {
        html += `<span style="color: var(--text-muted); font-size: 0.85rem; padding: 0 0.25rem;">...</span>`;
      }
    }

    for (let p = startPage; p <= endPage; p++) {
      const isActive = p === currentPage;
      html += `
        <button 
          onclick="changePage(${p})" 
          class="btn ${isActive ? 'btn-primary' : 'btn-secondary'}" 
          style="padding: 0.4rem 0.75rem; font-size: 0.82rem; border-radius: 10px; ${isActive ? 'background: var(--primary-gradient); color: #fff; border: none; box-shadow: 0 4px 10px rgba(79,70,229,0.15);' : ''}"
        >
          ${p}
        </button>
      `;
    }

    if (endPage < totalPages) {
      if (endPage < totalPages - 1) {
        html += `<span style="color: var(--text-muted); font-size: 0.85rem; padding: 0 0.25rem;">...</span>`;
      }
      html += `<button onclick="changePage(${totalPages})" class="btn btn-secondary" style="padding: 0.4rem 0.75rem; font-size: 0.82rem; border-radius: 10px;">${totalPages}</button>`;
    }

    // Nút Sau
    html += `
      <button 
        onclick="changePage(${currentPage + 1})" 
        class="btn btn-secondary" 
        style="padding: 0.4rem 0.85rem; font-size: 0.82rem; border-radius: 10px; display: inline-flex; align-items: center; gap: 0.25rem;"
        ${currentPage === totalPages ? 'disabled style="opacity: 0.4; cursor: not-allowed;"' : ''}
      >
        Sau <i class="fa-solid fa-chevron-right" style="font-size: 0.75rem;"></i>
      </button>
    `;

    container.innerHTML = html;
  }

  // Xử lý sự kiện chuyển trang
  function changePage(page) {
    currentPage = page;
    filterLessons(false);
    
    // Cuộn mượt lên vị trí bảng
    const tableHeader = document.getElementById('lessons-table');
    if (tableHeader) {
      tableHeader.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  // Chạy lọc và hiển thị phân trang khi tải xong trang
  document.addEventListener('DOMContentLoaded', () => {
    filterLessons(true);
  });
</script>

