<%- include('../partials/header') %>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert-banner alert-success" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); color: #10b981; display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem;">
    <i class="fa-solid fa-circle-check"></i>
    <span><%= success %></span>
  </div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert-banner alert-error" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #f87171; display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem;">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span><%= error %></span>
  </div>
<% } %>

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
  <div>
    <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
      Quản Lý Khóa Học
    </h1>
    <p style="color: var(--text-muted); margin-top: 0.25rem;">Thêm mới khóa đào tạo, cập nhật học liệu và xuất bản cho nhân viên học tập.</p>
  </div>
  
  <% if (user.permissions.includes('COURSE_CREATE')) { %>
    <button class="btn btn-primary" onclick="toggleCreateForm()">
      <i class="fa-solid fa-plus"></i> Tạo khóa học mới
    </button>
  <% } %>
</div>

<!-- Form tạo khóa học ẩn/hiện mờ kính -->
<div id="create-course-form" class="glass-card" style="display: none; margin-bottom: 2.5rem; animation: slideDown 0.3s ease;">
  <h3 style="font-size: 1.3rem; margin-bottom: 1.5rem;"><i class="fa-solid fa-plus-circle" style="color: #6366f1;"></i> Thêm Khóa Học Mới</h3>
  <form action="/course-management" method="POST">
    <div class="form-group">
      <label class="form-label">Tiêu đề khóa học</label>
      <input type="text" name="title" placeholder="Ví dụ: Kỹ năng Quản lý thời gian" required>
    </div>
    
    <div class="form-group">
      <label class="form-label">Mô tả tóm tắt</label>
      <textarea name="description" rows="3" placeholder="Nhập mô tả chi tiết khóa học tại đây..." required></textarea>
    </div>

    <div class="form-group">
      <label class="form-label">Đường dẫn ảnh đại diện (Ảnh URL)</label>
      <input type="text" name="image_url" placeholder="/images/default_course.svg">
    </div>

    <div class="form-group">
      <label class="form-label">Hình thức đăng ký học</label>
      <select name="enrollment_type" style="width: 100%; padding: 0.65rem 1rem; background: rgba(15, 23, 42, 0.5); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.9rem; outline: none;">
        <option value="open">Tự học (Học ngay, không cần xét duyệt)</option>
        <option value="restricted">Cần phê duyệt (Gửi yêu cầu, đợi HR/Admin duyệt)</option>
      </select>
    </div>

    <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
      <button type="submit" class="btn btn-primary">Lưu khóa học</button>
      <button type="button" class="btn btn-secondary" onclick="toggleCreateForm()">Hủy</button>
    </div>
  </form>
</div>

<!-- Bảng danh sách tất cả các khóa học -->
<div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
  <table class="custom-table" style="margin-top: 0;">
    <thead>
      <tr>
        <th>Ảnh</th>
        <th>Tên khóa học</th>
        <th>Mô tả</th>
        <th>Hình thức học</th>
        <th>Trạng thái</th>
        <th style="text-align: center;">Hành động</th>
      </tr>
    </thead>
    <tbody>
      <% courses.forEach(course => { %>
        <tr>
          <td style="width: 100px;">
            <img src="<%= course.image_url %>" alt="" style="width: 80px; height: 50px; object-fit: cover; border-radius: 6px; border: 1px solid var(--border-light);">
          </td>
          <td>
            <strong style="font-size: 1.05rem;"><%= course.title %></strong>
          </td>
          <td style="max-width: 300px; color: var(--text-muted); font-size: 0.85rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3.2em;">
            <%= course.description %>
          </td>
          <td>
            <% if (course.enrollment_type === 'restricted') { %>
              <span style="color: #fbbf24; font-weight: 600;"><i class="fa-solid fa-shield-halved"></i> Cần phê duyệt</span>
            <% } else { %>
              <span style="color: #34d399; font-weight: 600;"><i class="fa-solid fa-globe"></i> Tự học tự do</span>
            <% } %>
          </td>
          <td>
            <span class="btn" style="padding: 0.2rem 0.5rem; font-size: 0.75rem; cursor: default; <%= course.status === 'published' ? 'background: rgba(16,185,129,0.1); color: #10b981; border: 1px solid #10b981;' : 'background: rgba(255,255,255,0.05); color: var(--text-muted); border: 1px solid var(--border-light);' %>">
              <%= course.status === 'published' ? 'Công khai' : 'Bản nháp' %>
            </span>
          </td>
          <td>
            <div style="display: flex; justify-content: center; gap: 0.5rem;">
              
              <!-- Xem/quản lý bài học -->
              <a href="/course-management/<%= course.id %>/lessons" class="btn btn-secondary" style="padding: 0.35rem 0.75rem; font-size: 0.80rem;" title="Quản lý bài giảng">
                <i class="fa-solid fa-list"></i> Bài học
              </a>
 
              <% if (user.permissions.includes('ENROLL_ASSIGN')) { %>
                <!-- Giao khóa học trực tiếp -->
                <button type="button" class="btn btn-primary" onclick="openAssignCourseModal(<%= course.id %>)" style="padding: 0.35rem 0.75rem; font-size: 0.80rem; border-radius: 6px;" title="Giao khóa học">
                  <i class="fa-solid fa-user-plus"></i> Giao học
                </button>
              <% } %>
              <% if (user.permissions.includes('COURSE_PUBLISH')) { %>
                <!-- Form bật/tắt xuất bản -->
                <form action="/course-management/<%= course.id %>/publish" method="POST" style="display: inline;">
                  <input type="hidden" name="status" value="<%= course.status === 'published' ? 'draft' : 'published' %>">
                  <button type="submit" class="btn btn-secondary" style="padding: 0.35rem 0.75rem; font-size: 0.8rem; <%= course.status === 'published' ? 'color: #f59e0b;' : 'color: #10b981;' %>" title="<%= course.status === 'published' ? 'Chuyển thành Nháp' : 'Xuất bản khóa học' %>">
                    <i class="fa-solid <%= course.status === 'published' ? 'fa-eye-slash' : 'fa-share-from-square' %>"></i>
                  </button>
                </form>
              <% } %>
 
              <% if (user.permissions.includes('COURSE_UPDATE')) { %>
                <!-- Nút sửa mở rộng -->
                <button class="btn btn-secondary" onclick="openEditForm('<%= course.id %>', '<%= course.title %>', `<%= course.description %>`, '<%= course.image_url %>', '<%= course.status %>', '<%= course.enrollment_type %>')" style="padding: 0.35rem 0.75rem; font-size: 0.8rem;" title="Sửa khóa học">
                  <i class="fa-solid fa-pen"></i>
                </button>
              <% } %>
 
              <% if (user.permissions.includes('COURSE_DELETE')) { %>
                <!-- Xóa khóa học -->
                <form action="/course-management/<%= course.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa khóa học này cùng toàn bộ bài học kèm theo?')">
                  <button type="submit" class="btn btn-danger" style="padding: 0.35rem 0.75rem; font-size: 0.8rem;" title="Xóa khóa học">
                    <i class="fa-solid fa-trash-can"></i>
                  </button>
                </form>
              <% } %>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
 
<!-- Modal Sửa Khóa Học Mờ Kính -->
<div id="edit-course-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 500px; max-width: 90%; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
  <h3 style="font-size: 1.3rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
    <span><i class="fa-solid fa-pen-to-square" style="color: #8b5cf6;"></i> Sửa Thông Tin Khóa Học</span>
    <button class="btn btn-secondary" onclick="closeEditForm()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
  </h3>
  <form id="edit-course-form-element" action="" method="POST">
    <div class="form-group">
      <label class="form-label">Tiêu đề khóa học</label>
      <input type="text" id="edit-title" name="title" required>
    </div>
    
    <div class="form-group">
      <label class="form-label">Mô tả tóm tắt</label>
      <textarea id="edit-description" name="description" rows="3" required></textarea>
    </div>
 
    <div class="form-group">
      <label class="form-label">Đường dẫn ảnh đại diện (Ảnh URL)</label>
      <input type="text" id="edit-image-url" name="image_url">
    </div>
 
    <div class="form-group">
      <label class="form-label">Hình thức đăng ký học</label>
      <select id="edit-enrollment-type" name="enrollment_type" style="width: 100%; padding: 0.65rem 1rem; background: rgba(15, 23, 42, 0.5); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.9rem; outline: none;">
        <option value="open">Tự học (Học ngay, không cần xét duyệt)</option>
        <option value="restricted">Cần phê duyệt (Gửi yêu cầu, đợi HR/Admin duyệt)</option>
      </select>
    </div>

    <div class="form-group">
      <label class="form-label">Trạng thái xuất bản</label>
      <select id="edit-status" name="status">
        <option value="draft">Bản nháp (Draft)</option>
        <option value="published">Công khai (Published)</option>
      </select>
    </div>
 
    <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
      <button type="submit" class="btn btn-primary">Cập nhật</button>
      <button type="button" class="btn btn-secondary" onclick="closeEditForm()">Hủy</button>
    </div>
  </form>
</div>
<!-- Lớp phủ modal -->
<div id="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 999;"></div>

<!-- Render các Modal Giao Khóa Học ở cấp độ gốc -->
<% if (user.permissions.includes('ENROLL_ASSIGN') && courses.length > 0) { %>
  <% courses.forEach(course => { %>
    <div id="assignCourseModal-<%= course.id %>" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 640px; max-width: 95%; max-height: 85vh; overflow-y: auto; z-index: 2050; box-shadow: 0 10px 50px rgba(0,0,0,0.9); border-color: var(--border-glow); padding: 1.75rem;">
      <h3 style="font-size: 1.3rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 0.75rem;">
        <span><i class="fa-solid fa-user-plus" style="color: #10b981; margin-right: 0.5rem;"></i>Giao Khóa Học: <%= course.title %></span>
        <button type="button" class="btn btn-secondary" onclick="closeAssignCourseModal(<%= course.id %>)" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
      </h3>
      
      <form action="/course-management/<%= course.id %>/assign" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1.3fr; gap: 1.5rem; margin-bottom: 1.5rem; text-align: left;">
          
          <!-- Cột trái: Chọn Phòng ban -->
          <div>
            <h4 style="font-size: 0.92rem; margin-bottom: 0.75rem; color: #06b6d4; display: flex; justify-content: space-between; align-items: center;">
              <span><i class="fa-solid fa-building"></i> Chọn Phòng ban</span>
              <button type="button" onclick="selectAllDeptsForCourse(<%= course.id %>)" style="background: none; border: none; color: var(--text-accent); font-size: 0.72rem; cursor: pointer; font-weight: 600;">Chọn hết</button>
            </h4>
            <div style="background: rgba(0,0,0,0.4); border: 1px solid var(--border-light); border-radius: 8px; padding: 0.75rem; max-height: 270px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.5rem;">
              <% departments.forEach(d => { %>
                <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; cursor: pointer; color: #cbd5e1;">
                  <input type="checkbox" name="departmentIds" value="<%= d.id %>" class="course-dept-check-<%= course.id %>">
                  <%= d.name %>
                </label>
              <% }) %>
            </div>
          </div>

          <!-- Cột phải: Chọn Cá nhân -->
          <div>
            <h4 style="font-size: 0.92rem; margin-bottom: 0.75rem; color: #a78bfa; display: flex; justify-content: space-between; align-items: center;">
              <span><i class="fa-solid fa-users"></i> Chọn Cá nhân</span>
              <button type="button" onclick="selectAllUsersForCourse(<%= course.id %>)" style="background: none; border: none; color: var(--text-accent); font-size: 0.72rem; cursor: pointer; font-weight: 600;">Chọn hết</button>
            </h4>

            <!-- Ô tìm kiếm nhân sự thời gian thực -->
            <div style="margin-bottom: 0.5rem; position: relative;">
              <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.6rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.8rem;"></i>
              <input type="text" id="courseUserSearch-<%= course.id %>" placeholder="Tìm tên nhân sự..." oninput="filterCourseUsersList(<%= course.id %>)" style="width: 100%; padding: 0.45rem 0.6rem 0.45rem 1.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 6px; color: var(--text-main); font-size: 0.8rem; outline: none; box-sizing: border-box;">
            </div>

            <!-- Container danh sách nhân sự phân nhóm -->
            <div id="courseUsersListContainer-<%= course.id %>" style="background: rgba(0,0,0,0.4); border: 1px solid var(--border-light); border-radius: 8px; padding: 0.75rem; max-height: 220px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.75rem;">
              <% 
                const groupedUsers = {};
                departments.forEach(d => {
                  groupedUsers[d.id] = { name: d.name, list: [] };
                });
                groupedUsers['none'] = { name: 'Không thuộc phòng ban', list: [] };

                users.forEach(u => {
                  const dId = u.department_id || 'none';
                  if (!groupedUsers[dId]) {
                    groupedUsers[dId] = { name: u.department_name || 'Không thuộc phòng ban', list: [] };
                  }
                  groupedUsers[dId].list.push(u);
                });
              %>
              <% Object.keys(groupedUsers).forEach(dId => { %>
                <% if (groupedUsers[dId].list.length > 0) { %>
                  <div class="course-user-group-container-<%= course.id %>" data-dept-id="<%= dId %>">
                    <div class="user-group-header" style="font-size: 0.78rem; font-weight: 700; color: #a78bfa; margin-bottom: 0.35rem; border-bottom: 1px solid rgba(167, 139, 250, 0.15); padding-bottom: 0.15rem; display: flex; justify-content: space-between; align-items: center;">
                      <span><i class="fa-solid fa-folder-open" style="font-size: 0.7rem; margin-right: 0.25rem;"></i> <%= groupedUsers[dId].name %></span>
                      <button type="button" onclick="selectCourseGroupUsers(<%= course.id %>, '<%= dId %>')" style="background: none; border: none; color: var(--text-accent); font-size: 0.65rem; cursor: pointer; font-weight: 600; padding: 0;">Chọn nhóm</button>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 0.4rem; padding-left: 0.4rem;">
                      <% groupedUsers[dId].list.forEach(u => { %>
                        <label class="course-user-item-label-<%= course.id %>" data-search-name="<%= u.username.toLowerCase() %>" style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; cursor: pointer; color: #cbd5e1;">
                          <input type="checkbox" name="userIds" value="<%= u.id %>" class="course-user-check-<%= course.id %>" data-dept-id="<%= dId %>">
                          <span><%= u.username %></span>
                        </label>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
              <% }) %>
            </div>

          </div>

        </div>

        <div style="margin-top: 1rem; margin-bottom: 1.5rem; text-align: left;">
          <label class="form-label" style="font-size: 0.85rem; margin-bottom: 0.4rem; display: block;">Thời hạn hoàn thành (ngày)</label>
          <input type="number" name="timeLimitDays" min="1" placeholder="Ví dụ: 30 (Bỏ trống nếu không giới hạn)" style="width: 100%; padding: 0.65rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none; box-sizing: border-box;">
        </div>

        <div style="display: flex; gap: 1rem; justify-content: flex-end; border-top: 1px solid var(--border-light); padding-top: 1.25rem;">
          <button type="button" class="btn btn-secondary" onclick="closeAssignCourseModal(<%= course.id %>)">Hủy</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check"></i> Xác nhận giao</button>
        </div>
      </form>
    </div>
  <% }) %>
<% } %>

<script>
  function toggleCreateForm() {
    const form = document.getElementById('create-course-form');
    form.style.display = form.style.display === 'none' ? 'block' : 'none';
  }
 
  function openEditForm(id, title, desc, imageUrl, status, enrollmentType) {
    document.getElementById('edit-course-form-element').action = `/course-management/${id}/update`;
    document.getElementById('edit-title').value = title;
    document.getElementById('edit-description').value = desc;
    document.getElementById('edit-image-url').value = imageUrl;
    document.getElementById('edit-status').value = status;
    document.getElementById('edit-enrollment-type').value = enrollmentType || 'open';
    
    document.getElementById('edit-course-modal').style.display = 'block';
    document.getElementById('modal-overlay').style.display = 'block';
  }

  function closeEditForm() {
    document.getElementById('edit-course-modal').style.display = 'none';
    document.getElementById('modal-overlay').style.display = 'none';
  }

  function openAssignCourseModal(courseId) {
    document.getElementById(`assignCourseModal-${courseId}`).style.display = 'block';
    document.getElementById('modal-overlay').style.display = 'block';
  }

  function closeAssignCourseModal(courseId) {
    document.getElementById(`assignCourseModal-${courseId}`).style.display = 'none';
    document.getElementById('modal-overlay').style.display = 'none';
  }

  function selectAllDeptsForCourse(courseId) {
    const checkboxes = document.querySelectorAll(`.course-dept-check-${courseId}`);
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => cb.checked = !allChecked);
  }

  function selectAllUsersForCourse(courseId) {
    const checkboxes = document.querySelectorAll(`.course-user-check-${courseId}`);
    const visibleCheckboxes = Array.from(checkboxes).filter(cb => {
      const parentLabel = cb.closest(`.course-user-item-label-${courseId}`);
      return parentLabel && parentLabel.style.display !== 'none';
    });
    const allChecked = visibleCheckboxes.every(cb => cb.checked);
    visibleCheckboxes.forEach(cb => cb.checked = !allChecked);
  }

  function selectCourseGroupUsers(courseId, deptId) {
    const checkboxes = document.querySelectorAll(`.course-user-check-${courseId}[data-dept-id="${deptId}"]`);
    const visibleCheckboxes = Array.from(checkboxes).filter(cb => {
      const parentLabel = cb.closest(`.course-user-item-label-${courseId}`);
      return parentLabel && parentLabel.style.display !== 'none';
    });
    const allChecked = visibleCheckboxes.every(cb => cb.checked);
    visibleCheckboxes.forEach(cb => cb.checked = !allChecked);
  }

  function filterCourseUsersList(courseId) {
    const query = document.getElementById(`courseUserSearch-${courseId}`).value.toLowerCase().trim();
    const container = document.getElementById(`courseUsersListContainer-${courseId}`);
    const groups = container.querySelectorAll(`.course-user-group-container-${courseId}`);

    groups.forEach(group => {
      let visibleInGroup = 0;
      const items = group.querySelectorAll(`.course-user-item-label-${courseId}`);
      
      items.forEach(item => {
        const name = item.getAttribute('data-search-name');
        if (name.includes(query)) {
          item.style.display = 'flex';
          visibleInGroup++;
        } else {
          item.style.display = 'none';
        }
      });

      if (visibleInGroup > 0) {
        group.style.display = 'block';
      } else {
        group.style.display = 'none';
      }
    });
  }

  // Đóng modal khi nhấp ra ngoài (lớp phủ)
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('modal-overlay');
    if (overlay) {
      overlay.addEventListener('click', () => {
        const editModal = document.getElementById('edit-course-modal');
        if (editModal) editModal.style.display = 'none';
        
        const assignModals = document.querySelectorAll('[id^="assignCourseModal-"]');
        assignModals.forEach(m => m.style.display = 'none');
        
        overlay.style.display = 'none';
      });
    }
  });
</script>

<style>
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<%- include('../partials/footer') %>
