<%- include('../partials/header') %>

<style>
  /* ===== PAGE HEADER ===== */
  .cm-page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .cm-page-title {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -0.03em;
    margin: 0;
  }
  .cm-page-subtitle {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.3rem;
  }

  /* ===== ALERT BANNERS ===== */
  .cm-alert {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.25rem;
    border-radius: 12px;
    font-size: 0.88rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }
  .cm-alert-success {
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.25);
    color: #059669;
  }
  .cm-alert-error {
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.25);
    color: #dc2626;
  }

  /* ===== CREATE FORM ===== */
  .cm-create-form {
    background: #ffffff;
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 20px;
    padding: 2.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
    animation: cmSlideDown 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cm-create-header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-light);
  }
  .cm-create-icon {
    width: 54px;
    height: 54px;
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.1), rgba(99, 102, 241, 0.1));
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4f46e5;
    font-size: 1.75rem;
  }
  .cm-create-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-main);
  }
  .cm-create-subtitle {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }
  .cm-modern-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .cm-input-wrapper {
    position: relative;
  }
  .cm-input-wrapper i {
    position: absolute;
    left: 1.1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 0.95rem;
  }
  .cm-input-wrapper.align-top i {
    top: 1.1rem;
    transform: none;
  }
  .cm-input-wrapper input, .cm-input-wrapper select, .cm-input-wrapper textarea {
    padding-left: 2.75rem !important;
    border-radius: 10px;
  }
  .cm-form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-light);
  }
  .cm-btn-submit {
    background: linear-gradient(135deg, #4f46e5, #6366f1) !important;
    border: none !important;
    padding: 0.65rem 1.75rem !important;
    border-radius: 10px !important;
    font-weight: 600 !important;
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25) !important;
    transition: all 0.2s !important;
  }
  .cm-btn-submit:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 6px 16px rgba(79, 70, 229, 0.35) !important;
  }
  @keyframes cmSlideDown {
    from { opacity: 0; transform: translateY(-12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ===== COURSES TABLE WRAPPER ===== */
  .cm-table-card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  /* ===== TABLE ===== */
  .cm-table {
    width: 100%;
    border-collapse: collapse;
  }
  .cm-table thead {
    background: #f8fafc;
    border-bottom: 1px solid var(--border-light);
  }
  .cm-table th {
    padding: 0.85rem 1rem;
    text-align: left;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #94a3b8;
    white-space: nowrap;
  }
  .cm-table th:last-child {
    text-align: center;
  }
  .cm-table td {
    padding: 1rem;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
  }
  .cm-table tbody tr:last-child td {
    border-bottom: none;
  }
  .cm-table tbody tr {
    transition: background 0.18s;
  }
  .cm-table tbody tr:hover {
    background: #fafbff;
  }

  /* ===== COURSE IMAGE ===== */
  .cm-course-img {
    width: 72px;
    height: 46px;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--border-light);
    display: block;
    background: #f1f5f9;
  }

  /* ===== COURSE TITLE CELL ===== */
  .cm-course-title {
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--text-main);
    line-height: 1.4;
    max-width: 220px;
  }

  /* ===== DESCRIPTION CELL (FIXED!) ===== */
  .cm-course-desc {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.5;
    max-width: 260px;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ===== BADGES ===== */
  .cm-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .cm-badge-open {
    background: rgba(13, 148, 136, 0.1);
    color: #0d9488;
    border: 1px solid rgba(13, 148, 136, 0.2);
  }
  .cm-badge-restricted {
    background: rgba(245, 158, 11, 0.1);
    color: #d97706;
    border: 1px solid rgba(245, 158, 11, 0.2);
  }
  .cm-badge-published {
    background: rgba(16, 185, 129, 0.1);
    color: #059669;
    border: 1px solid rgba(16, 185, 129, 0.2);
  }
  .cm-badge-draft {
    background: rgba(100, 116, 139, 0.08);
    color: #64748b;
    border: 1px solid rgba(100, 116, 139, 0.18);
  }

  /* ===== ACTION BUTTONS ===== */
  .cm-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: nowrap;
  }
  .cm-btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.4rem 0.7rem;
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    font-family: var(--font-body);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
    text-decoration: none;
  }
  .cm-btn-lessons {
    background: #f1f5f9;
    color: #475569;
    border: 1px solid #e2e8f0;
  }
  .cm-btn-lessons:hover {
    background: #e2e8f0;
    color: #1e293b;
    transform: translateY(-1px);
  }
  .cm-btn-assign {
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    color: #fff;
    box-shadow: 0 2px 8px rgba(79, 70, 229, 0.25);
  }
  .cm-btn-assign:hover {
    box-shadow: 0 4px 14px rgba(79, 70, 229, 0.4);
    transform: translateY(-1px);
    color: #fff;
  }
  .cm-btn-toggle {
    background: #fff;
    border: 1px solid #e2e8f0;
    color: #64748b;
  }
  .cm-btn-toggle:hover {
    border-color: #94a3b8;
    background: #f8fafc;
    transform: translateY(-1px);
  }
  .cm-btn-toggle.is-published {
    color: #d97706;
  }
  .cm-btn-toggle.is-draft {
    color: #059669;
  }
  .cm-btn-edit {
    background: #fff;
    border: 1px solid #e2e8f0;
    color: #6366f1;
  }
  .cm-btn-edit:hover {
    background: rgba(99, 102, 241, 0.06);
    border-color: #a5b4fc;
    transform: translateY(-1px);
  }
  .cm-btn-delete {
    background: #fff;
    border: 1px solid #fecaca;
    color: #ef4444;
  }
  .cm-btn-delete:hover {
    background: rgba(239, 68, 68, 0.06);
    border-color: #f87171;
    transform: translateY(-1px);
  }

  /* ===== EMPTY STATE ===== */
  .cm-empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
  }
  .cm-empty i {
    font-size: 2.5rem;
    opacity: 0.25;
    display: block;
    margin-bottom: 1rem;
  }

  /* ===== PAGINATION ===== */
  .cm-pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--border-light);
    background: #fafbff;
  }
  .cm-pagination-info {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .cm-pagination-pages {
    display: flex;
    gap: 0.35rem;
    align-items: center;
  }
  .cm-page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    min-width: 36px;
    height: 36px;
    padding: 0 0.6rem;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid var(--border-light);
    background: #fff;
    color: var(--text-muted);
    transition: all 0.2s;
    text-decoration: none;
  }
  .cm-page-btn:hover {
    border-color: #a5b4fc;
    color: #4f46e5;
    background: rgba(99,102,241,0.05);
  }
  .cm-page-btn.active {
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(79,70,229,0.3);
    cursor: default;
  }
  .cm-page-btn[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }
  .cm-page-sep {
    color: var(--text-muted);
    padding: 0 0.15rem;
    font-size: 0.85rem;
  }

  /* ===== MODAL ===== */
  .cm-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    z-index: 999;
  }
  .cm-modal {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 520px;
    max-width: 92vw;
    max-height: 90vh;
    overflow-y: auto;
    z-index: 1000;
    background: #fff;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
    border: 1px solid rgba(226, 232, 240, 0.8);
  }
  .cm-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-light);
  }
  .cm-modal-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .cm-modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    border: 1px solid var(--border-light);
    background: #fff;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .cm-modal-close:hover {
    background: #f1f5f9;
    color: var(--text-main);
  }

  /* ===== ASSIGN MODAL (wide) ===== */
  .cm-assign-modal {
    width: 660px;
  }
  .cm-assign-panel {
    background: #f8fafc;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 0.75rem;
    max-height: 250px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .cm-assign-panel::-webkit-scrollbar { width: 4px; }
  .cm-assign-panel::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  .cm-assign-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--text-main);
    padding: 0.2rem 0.3rem;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .cm-assign-label:hover {
    background: rgba(99, 102, 241, 0.05);
  }
  .cm-assign-group-header {
    font-size: 0.75rem;
    font-weight: 700;
    color: #6366f1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(99, 102, 241, 0.12);
    padding-bottom: 0.25rem;
    margin-top: 0.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cm-assign-group-btn {
    background: none;
    border: none;
    font-size: 0.7rem;
    color: var(--text-accent);
    cursor: pointer;
    font-weight: 600;
    font-family: var(--font-body);
  }
  .cm-search-box {
    position: relative;
    margin-bottom: 0.5rem;
  }
  .cm-search-box i {
    position: absolute;
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 0.8rem;
  }
  .cm-search-box input {
    padding-left: 2rem !important;
    font-size: 0.82rem !important;
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }

  /* ===== SCROLLBAR for modals ===== */
  .cm-modal::-webkit-scrollbar { width: 6px; }
  .cm-modal::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 6px; }
</style>

<%- /* ====== ALERTS ====== */ '' %>
<% if (typeof success !== 'undefined' && success) { %>
  <div class="cm-alert cm-alert-success">
    <i class="fa-solid fa-circle-check"></i>
    <span><%= success %></span>
  </div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="cm-alert cm-alert-error">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span><%= error %></span>
  </div>
<% } %>

<style>
  .cm-sticky-toolbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(248, 250, 252, 0.95);
    backdrop-filter: blur(10px);
    padding-top: 1.5rem;
    margin-top: -1.5rem;
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(226, 232, 240, 0.6);
  }
</style>

<div class="cm-sticky-toolbar">
  <%- /* ====== PAGE HEADER ====== */ '' %>
  <div class="cm-page-header" style="margin-bottom: 1rem;">
    <div>
      <h1 class="cm-page-title">Quản Lý Khóa Học</h1>
      <p class="cm-page-subtitle">Thêm mới khóa đào tạo, cập nhật học liệu và xuất bản cho nhân viên học tập.</p>
    </div>
    <% if (user.permissions.includes('COURSE_CREATE')) { %>
      <button class="btn btn-primary" onclick="openCreateForm()" id="btn-toggle-create">
        <i class="fa-solid fa-plus"></i> Tạo khóa học mới
      </button>
    <% } %>
  </div>

  <%- /* ====== FILTER BAR ====== */ '' %>
  <div class="cm-filter-bar" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
    <div class="cm-filter-tabs" style="display: flex; gap: 0.5rem; background: #ffffff; padding: 0.25rem; border-radius: 12px; border: 1px solid var(--border-light); box-shadow: 0 2px 5px rgba(0,0,0,0.02);">
      <button class="cm-tab-btn active" onclick="filterCourses('all', this)" style="padding: 0.5rem 1.2rem; border-radius: 8px; border: none; background: rgba(99, 102, 241, 0.1); color: #4f46e5; font-weight: 600; cursor: pointer; transition: all 0.2s;">Tất cả</button>
      <button class="cm-tab-btn" onclick="filterCourses('published', this)" style="padding: 0.5rem 1.2rem; border-radius: 8px; border: none; background: transparent; color: var(--text-muted); font-weight: 500; cursor: pointer; transition: all 0.2s;">Công khai</button>
      <button class="cm-tab-btn" onclick="filterCourses('draft', this)" style="padding: 0.5rem 1.2rem; border-radius: 8px; border: none; background: transparent; color: var(--text-muted); font-weight: 500; cursor: pointer; transition: all 0.2s;">Bản nháp</button>
    </div>
    
    <div class="cm-search-wrapper" style="position: relative; width: 100%; max-width: 320px;">
      <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
      <input type="text" id="courseSearchInput" class="form-control" placeholder="Tìm kiếm tên khóa học..." onkeyup="searchCourses()" style="padding-left: 2.5rem; border-radius: 12px; border: 1px solid var(--border-light); box-shadow: 0 2px 5px rgba(0,0,0,0.02);">
    </div>
  </div>
</div>

<%- /* ====== CREATE MODAL ====== */ '' %>
<div id="create-course-modal" class="cm-modal" style="width: 700px; padding: 2.5rem;">
  <div class="cm-create-header" style="justify-content: space-between; align-items: flex-start; border-bottom: none; margin-bottom: 1rem;">
    <div style="display: flex; gap: 1.2rem; align-items: center;">
      <div class="cm-create-icon">
        <i class="fa-solid fa-graduation-cap"></i>
      </div>
      <div>
        <h3 class="cm-create-title">Thêm Khóa Học Mới</h3>
        <p class="cm-create-subtitle">Thiết lập thông tin cơ bản cho khóa đào tạo của bạn</p>
      </div>
    </div>
    <button type="button" class="cm-modal-close" onclick="closeCreateForm()"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <div class="cm-modal-tabs" style="display: flex; gap: 1rem; border-bottom: 1px solid var(--border-light); margin-bottom: 1.5rem;">
    <button type="button" id="tab-btn-single" onclick="switchCreateTab('single')" style="padding: 0.5rem 1rem; border: none; background: transparent; font-weight: 700; color: #4f46e5; border-bottom: 2px solid #4f46e5; cursor: pointer; transition: all 0.2s;">Tạo đơn lẻ</button>
    <button type="button" id="tab-btn-bulk" onclick="switchCreateTab('bulk')" style="padding: 0.5rem 1rem; border: none; background: transparent; font-weight: 600; color: var(--text-muted); border-bottom: 2px solid transparent; cursor: pointer; transition: all 0.2s;">Tạo hàng loạt</button>
  </div>

  <form id="create-course-form" action="/course-management" method="POST">
    <!-- SINGLE CREATE FORM -->
    <div id="create-single-form">
      <div class="cm-modern-grid">
        <div class="cm-form-section">
          <div class="form-group">
            <label class="form-label">Tiêu đề khóa học <span class="text-danger">*</span></label>
            <div class="cm-input-wrapper">
              <i class="fa-solid fa-book-open"></i>
              <input type="text" name="title" id="single-title" placeholder="Ví dụ: Kỹ năng Quản lý thời gian" required class="form-control">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Mô tả tóm tắt (Tùy chọn)</label>
            <div class="cm-input-wrapper align-top">
              <i class="fa-solid fa-align-left"></i>
              <textarea name="description" rows="3" placeholder="Nhập mô tả chi tiết khóa học..." class="form-control"></textarea>
            </div>
          </div>
        </div>
        
        <div class="cm-form-section">
          <div class="form-group">
            <label class="form-label">Đường dẫn ảnh đại diện</label>
            <div class="cm-input-wrapper">
              <i class="fa-regular fa-image"></i>
              <input type="text" name="image_url" placeholder="/images/default_course.svg" class="form-control">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Hình thức đăng ký học</label>
            <div class="cm-input-wrapper">
              <i class="fa-solid fa-shield-halved"></i>
              <select name="enrollment_type" class="form-control">
                <option value="open">Tự học (Học ngay, không cần xét duyệt)</option>
                <option value="restricted">Cần phê duyệt (Gửi yêu cầu, đợi HR/Admin duyệt)</option>
              </select>
            </div>
          </div>
          <div class="cm-alert" style="background: rgba(99, 102, 241, 0.08); border: 1px dashed rgba(99, 102, 241, 0.3); color: #4f46e5; margin-bottom: 0;">
            <i class="fa-solid fa-circle-info"></i>
            <span>Sau khi tạo, bạn sẽ được chuyển đến trang quản lý bài giảng. Khóa học sẽ được lưu dưới dạng <b>Bản nháp</b>.</span>
          </div>
        </div>
      </div>
    </div>

    <!-- BULK CREATE FORM -->
    <div id="create-bulk-form" style="display: none;">
      <div class="form-group">
        <label class="form-label">Danh sách tên khóa học <span class="text-danger">*</span></label>
        <p style="font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.75rem;">Mỗi khóa học nằm trên 1 dòng. Hệ thống sẽ tự động tạo dưới dạng Bản nháp và hình thức Tự học.</p>
        <textarea name="bulk_titles" id="bulk-titles" rows="10" placeholder="Khóa học A&#10;Khóa học B&#10;Khóa học C" class="form-control" style="width: 100%; border-radius: 12px; padding: 1rem; border: 1px solid var(--border-light);" disabled></textarea>
      </div>
    </div>
    
    <div class="cm-form-actions">
      <button type="button" class="btn btn-secondary" onclick="closeCreateForm()" style="padding: 0.6rem 1.5rem; border-radius: 10px;">Hủy bỏ</button>
      <button type="submit" class="btn btn-primary cm-btn-submit">
        Tạo & Tiếp tục <i class="fa-solid fa-arrow-right" style="margin-left: 0.3rem;"></i>
      </button>
    </div>
  </form>
</div>

<%- /* ====== TABLE CARD ====== */ '' %>
<div class="cm-table-card">
  <% if (courses.length === 0) { %>
    <div class="cm-empty">
      <i class="fa-solid fa-graduation-cap"></i>
      <span style="font-size: 0.95rem;">Chưa có khóa học nào trong hệ thống.</span>
    </div>
  <% } else { %>
    <div style="overflow-x: auto;">
      <table class="cm-table">
        <thead>
          <tr>
            <th style="width: 90px;">Ảnh</th>
            <th>Tên khóa học</th>
            <th>Mô tả</th>
            <th>Hình thức học</th>
            <th>Trạng thái</th>
            <th style="min-width: 220px;">Hành động</th>
          </tr>
        </thead>
        <tbody>
          <% courses.forEach(course => { %>
            <%
              let displayImg = course.image_url;
              if (!displayImg || !displayImg.trim() || displayImg === '/images/default_course.jpg') {
                displayImg = '/images/default_course.svg';
              }
            %>
            <tr class="cm-course-row" data-status="<%= course.status %>" data-title="<%= course.title %>">
              <td>
                <img
                  src="<%= displayImg %>"
                  onerror="this.onerror=null; this.src='/images/default_course.svg';"
                  alt="<%= course.title %>"
                  class="cm-course-img"
                >
              </td>
              <td>
                <div class="cm-course-title"><%= course.title %></div>
              </td>
              <td>
                <div class="cm-course-desc"><%= course.description %></div>
              </td>
              <td>
                <% if (course.enrollment_type === 'restricted') { %>
                  <span class="cm-badge cm-badge-restricted">
                    <i class="fa-solid fa-shield-halved"></i> Cần duyệt
                  </span>
                <% } else { %>
                  <span class="cm-badge cm-badge-open">
                    <i class="fa-solid fa-globe"></i> Tự học
                  </span>
                <% } %>
              </td>
              <td>
                <% if (course.status === 'published') { %>
                  <span class="cm-badge cm-badge-published">
                    <i class="fa-solid fa-circle" style="font-size:0.5rem;"></i> Công khai
                  </span>
                <% } else { %>
                  <span class="cm-badge cm-badge-draft">
                    <i class="fa-solid fa-circle" style="font-size:0.5rem;"></i> Bản nháp
                  </span>
                <% } %>
              </td>
              <td>
                <div class="cm-actions">

                  <%- /* Quản lý bài học */ '' %>
                  <a href="/course-management/<%= course.id %>/lessons"
                     class="cm-btn-icon cm-btn-lessons"
                     title="Quản lý bài giảng">
                    <i class="fa-solid fa-list"></i> Bài học
                  </a>

                  <% if (user.permissions.includes('ENROLL_ASSIGN')) { %>
                    <%- /* Giao khóa học */ '' %>
                    <button
                      type="button"
                      class="cm-btn-icon cm-btn-assign"
                      onclick="openAssignCourseModal(<%= course.id %>)"
                      title="Giao khóa học">
                      <i class="fa-solid fa-user-plus"></i> Giao học
                    </button>
                  <% } %>

                  <% if (user.permissions.includes('COURSE_PUBLISH')) { %>
                    <%- /* Toggle xuất bản */ '' %>
                    <form action="/course-management/<%= course.id %>/publish" method="POST" style="display:inline;">
                      <input type="hidden" name="status" value="<%= course.status === 'published' ? 'draft' : 'published' %>">
                      <button
                        type="submit"
                        class="cm-btn-icon cm-btn-toggle <%= course.status === 'published' ? 'is-published' : 'is-draft' %>"
                        title="<%= course.status === 'published' ? 'Chuyển thành Nháp' : 'Xuất bản khóa học' %>">
                        <i class="fa-solid <%= course.status === 'published' ? 'fa-eye-slash' : 'fa-share-from-square' %>"></i>
                      </button>
                    </form>
                  <% } %>

                  <% if (user.permissions.includes('COURSE_UPDATE')) { %>
                    <%- /* Sửa */ '' %>
                    <button
                      class="cm-btn-icon cm-btn-edit"
                      onclick="openEditForm('<%= course.id %>', '<%= course.title %>', `<%= course.description %>`, '<%= course.image_url %>', '<%= course.status %>', '<%= course.enrollment_type %>')"
                      title="Sửa khóa học">
                      <i class="fa-solid fa-pen"></i>
                    </button>
                  <% } %>

                  <% if (user.permissions.includes('COURSE_DELETE')) { %>
                    <%- /* Xóa */ '' %>
                    <form action="/course-management/<%= course.id %>/delete" method="POST" style="display:inline;"
                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa khóa học này cùng toàn bộ bài học kèm theo?')">
                      <button type="submit" class="cm-btn-icon cm-btn-delete" title="Xóa khóa học">
                        <i class="fa-solid fa-trash-can"></i>
                      </button>
                    </form>
                  <% } %>

                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <%- /* ====== PAGINATION ====== */ '' %>
    <% if (totalCourses > 0) { %>
      <div class="cm-pagination">
        <div class="cm-pagination-info">
          Hiển thị <strong><%= (currentPage - 1) * 15 + 1 %></strong> –
          <strong><%= Math.min(currentPage * 15, totalCourses) %></strong>
          trong <strong><%= totalCourses %></strong> khóa học
        </div>

        <% if (totalPages > 1) { %>
          <div class="cm-pagination-pages">
            <% if (currentPage > 1) { %>
              <a href="/course-management?page=<%= currentPage - 1 %>" class="cm-page-btn" title="Trang trước">
                <i class="fa-solid fa-chevron-left" style="font-size:0.7rem;"></i> Trước
              </a>
            <% } else { %>
              <button class="cm-page-btn" disabled>
                <i class="fa-solid fa-chevron-left" style="font-size:0.7rem;"></i> Trước
              </button>
            <% } %>

            <%
              let startPage = Math.max(1, currentPage - 2);
              let endPage   = Math.min(totalPages, currentPage + 2);
            %>
            <% if (startPage > 1) { %>
              <a href="/course-management?page=1" class="cm-page-btn">1</a>
              <% if (startPage > 2) { %><span class="cm-page-sep">…</span><% } %>
            <% } %>

            <% for (let i = startPage; i <= endPage; i++) { %>
              <% if (i === currentPage) { %>
                <span class="cm-page-btn active"><%= i %></span>
              <% } else { %>
                <a href="/course-management?page=<%= i %>" class="cm-page-btn"><%= i %></a>
              <% } %>
            <% } %>

            <% if (endPage < totalPages) { %>
              <% if (endPage < totalPages - 1) { %><span class="cm-page-sep">…</span><% } %>
              <a href="/course-management?page=<%= totalPages %>" class="cm-page-btn"><%= totalPages %></a>
            <% } %>

            <% if (currentPage < totalPages) { %>
              <a href="/course-management?page=<%= currentPage + 1 %>" class="cm-page-btn" title="Trang sau">
                Sau <i class="fa-solid fa-chevron-right" style="font-size:0.7rem;"></i>
              </a>
            <% } else { %>
              <button class="cm-page-btn" disabled>
                Sau <i class="fa-solid fa-chevron-right" style="font-size:0.7rem;"></i>
              </button>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } %>

  <% } %>
  <div id="cm-empty-search" class="cm-empty" style="display: none; text-align: center; padding: 3rem 1rem;">
    <i class="fa-solid fa-magnifying-glass" style="font-size: 2.5rem; color: #cbd5e1; margin-bottom: 1rem;"></i>
    <h4 style="color: var(--text-main); font-weight: 600; margin-bottom: 0.5rem;">Không tìm thấy kết quả</h4>
    <span style="font-size: 0.95rem; color: var(--text-muted);">Thử thay đổi từ khóa hoặc bộ lọc trạng thái.</span>
  </div>
</div>

<%- /* ====== MODAL OVERLAY ====== */ '' %>
<div id="cm-modal-overlay" class="cm-modal-overlay" onclick="closeAllModals()"></div>

<%- /* ====== EDIT MODAL ====== */ '' %>
<div id="edit-course-modal" class="cm-modal">
  <div class="cm-modal-header">
    <div class="cm-modal-title">
      <i class="fa-solid fa-pen-to-square" style="color: #6366f1;"></i> Sửa Thông Tin Khóa Học
    </div>
    <button class="cm-modal-close" onclick="closeEditForm()"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <form id="edit-course-form-element" action="" method="POST">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group" style="margin-bottom: 0;">
        <label class="form-label">Tiêu đề khóa học</label>
        <input type="text" id="edit-title" name="title" required>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <label class="form-label">Đường dẫn ảnh đại diện</label>
        <input type="text" id="edit-image-url" name="image_url">
      </div>
    </div>
    <div class="form-group" style="margin-top: 1rem;">
      <label class="form-label">Mô tả tóm tắt (Tùy chọn)</label>
      <textarea id="edit-description" name="description" rows="3"></textarea>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group" style="margin-bottom: 0;">
        <label class="form-label">Hình thức đăng ký học</label>
        <select id="edit-enrollment-type" name="enrollment_type">
          <option value="open">Tự học (Không cần duyệt)</option>
          <option value="restricted">Cần phê duyệt</option>
        </select>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <label class="form-label">Trạng thái xuất bản</label>
        <select id="edit-status" name="status">
          <option value="draft">Bản nháp</option>
          <option value="published">Công khai</option>
        </select>
      </div>
    </div>
    <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem; justify-content: flex-end;">
      <button type="button" class="btn btn-secondary" onclick="closeEditForm()">Hủy</button>
      <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Cập nhật</button>
    </div>
  </form>
</div>

<%- /* ====== ASSIGN COURSE MODALS ====== */ '' %>
<% if (user.permissions.includes('ENROLL_ASSIGN') && courses.length > 0) { %>
  <% courses.forEach(course => { %>
    <div id="assignCourseModal-<%= course.id %>" class="cm-modal cm-assign-modal">
      <div class="cm-modal-header">
        <div class="cm-modal-title">
          <i class="fa-solid fa-user-plus" style="color: #10b981;"></i>
          Giao Khóa Học: <span style="color: #6366f1; margin-left: 0.3rem;"><%= course.title %></span>
        </div>
        <button class="cm-modal-close" onclick="closeAssignCourseModal(<%= course.id %>)">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <form action="/course-management/<%= course.id %>/assign" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1.3fr; gap: 1.25rem; margin-bottom: 1.25rem;">

          <%- /* Cột trái: Phòng ban */ '' %>
          <div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem;">
              <label style="font-size: 0.82rem; font-weight: 700; color: #06b6d4;">
                <i class="fa-solid fa-building"></i> Phòng ban
              </label>
              <button type="button" onclick="selectAllDeptsForCourse(<%= course.id %>)"
                      class="cm-assign-group-btn">Chọn hết</button>
            </div>
            <div class="cm-assign-panel">
              <% departments.forEach(d => { %>
                <label class="cm-assign-label">
                  <input type="checkbox" name="departmentIds" value="<%= d.id %>"
                         class="course-dept-check-<%= course.id %>" style="accent-color:#6366f1; width:14px; height:14px;">
                  <span><%= d.name %></span>
                </label>
              <% }) %>
            </div>
          </div>

          <%- /* Cột phải: Cá nhân */ '' %>
          <div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem;">
              <label style="font-size: 0.82rem; font-weight: 700; color: #8b5cf6;">
                <i class="fa-solid fa-users"></i> Cá nhân
              </label>
              <button type="button" onclick="selectAllUsersForCourse(<%= course.id %>)"
                      class="cm-assign-group-btn">Chọn hết</button>
            </div>
            <div class="cm-search-box">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input type="text"
                     id="courseUserSearch-<%= course.id %>"
                     placeholder="Tìm tên nhân sự..."
                     oninput="filterCourseUsersList(<%= course.id %>)">
            </div>
            <div id="courseUsersListContainer-<%= course.id %>" class="cm-assign-panel" style="max-height: 200px;">
              <%
                const groupedUsers = {};
                departments.forEach(d => { groupedUsers[d.id] = { name: d.name, list: [] }; });
                groupedUsers['none'] = { name: 'Không thuộc phòng ban', list: [] };
                users.forEach(u => {
                  const dId = u.department_id || 'none';
                  if (!groupedUsers[dId]) groupedUsers[dId] = { name: u.department_name || 'Không thuộc phòng ban', list: [] };
                  groupedUsers[dId].list.push(u);
                });
              %>
              <% Object.keys(groupedUsers).forEach(dId => { %>
                <% if (groupedUsers[dId].list.length > 0) { %>
                  <div class="course-user-group-container-<%= course.id %>" data-dept-id="<%= dId %>">
                    <div class="cm-assign-group-header">
                      <span><i class="fa-solid fa-folder-open" style="font-size:0.68rem; margin-right:0.2rem;"></i> <%= groupedUsers[dId].name %></span>
                      <button type="button" onclick="selectCourseGroupUsers(<%= course.id %>, '<%= dId %>')"
                              class="cm-assign-group-btn">Chọn nhóm</button>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 0.2rem; padding-left: 0.35rem; margin-top: 0.25rem;">
                      <% groupedUsers[dId].list.forEach(u => { %>
                        <label class="cm-assign-label course-user-item-label-<%= course.id %>"
                               data-search-name="<%= u.username.toLowerCase() %>">
                          <input type="checkbox" name="userIds" value="<%= u.id %>"
                                 class="course-user-check-<%= course.id %>"
                                 data-dept-id="<%= dId %>"
                                 style="accent-color:#6366f1; width:14px; height:14px;">
                          <span><%= u.username %></span>
                        </label>
                      <% }) %>
                    </div>
                  </div>
                <% } %>
              <% }) %>
            </div>
          </div>

        </div>

        <div class="form-group">
          <label class="form-label">Thời hạn hoàn thành (ngày)</label>
          <input type="number" name="timeLimitDays" min="1" placeholder="Bỏ trống nếu không giới hạn">
        </div>

        <div style="display: flex; gap: 0.75rem; justify-content: flex-end; border-top: 1px solid var(--border-light); padding-top: 1.25rem; margin-top: 0.5rem;">
          <button type="button" class="btn btn-secondary" onclick="closeAssignCourseModal(<%= course.id %>)">Hủy</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check"></i> Xác nhận giao</button>
        </div>
      </form>
    </div>
  <% }) %>
<% } %>

<script>
  /* ---- Filter & Search Courses ---- */
  function filterCourses(status, btn) {
    // Update UI for Tabs
    document.querySelectorAll('.cm-tab-btn').forEach(el => {
      el.style.background = 'transparent';
      el.style.color = 'var(--text-muted)';
      el.style.fontWeight = '500';
    });
    btn.style.background = 'rgba(99, 102, 241, 0.1)';
    btn.style.color = '#4f46e5';
    btn.style.fontWeight = '600';
    
    window.currentCourseFilter = status;
    applyCourseFilters();
  }

  function searchCourses() {
    applyCourseFilters();
  }
  
  function applyCourseFilters() {
    const status = window.currentCourseFilter || 'all';
    const keyword = (document.getElementById('courseSearchInput').value || '').toLowerCase().trim();
    const rows = document.querySelectorAll('.cm-course-row');
    
    let visibleCount = 0;
    rows.forEach(row => {
      const rowStatus = row.getAttribute('data-status');
      const rowTitle = row.getAttribute('data-title').toLowerCase();
      
      const statusMatch = (status === 'all' || rowStatus === status);
      const titleMatch = rowTitle.includes(keyword);
      
      if (statusMatch && titleMatch) {
        row.style.display = '';
        visibleCount++;
      } else {
        row.style.display = 'none';
      }
    });
    
    // Check empty search state
    const tableContainer = document.querySelector('.cm-table-card table');
    const emptySearchState = document.getElementById('cm-empty-search');
    
    if (visibleCount === 0 && rows.length > 0) {
      if(tableContainer) tableContainer.style.display = 'none';
      if(emptySearchState) emptySearchState.style.display = 'block';
    } else if (rows.length > 0) {
      if(tableContainer) tableContainer.style.display = 'table';
      if(emptySearchState) emptySearchState.style.display = 'none';
    }
  }

  /* ---- Toggle create form ---- */
  function openCreateForm() {
    switchCreateTab('single'); // default
    showModal('create-course-modal');
  }
  function closeCreateForm() {
    hideModal('create-course-modal');
  }

  function switchCreateTab(tab) {
    const btnSingle = document.getElementById('tab-btn-single');
    const btnBulk = document.getElementById('tab-btn-bulk');
    const formSingle = document.getElementById('create-single-form');
    const formBulk = document.getElementById('create-bulk-form');
    const formEl = document.getElementById('create-course-form');
    const singleTitle = document.getElementById('single-title');
    const bulkTitles = document.getElementById('bulk-titles');
    
    if (tab === 'single') {
      btnSingle.style.color = '#4f46e5';
      btnSingle.style.fontWeight = '700';
      btnSingle.style.borderBottomColor = '#4f46e5';
      btnBulk.style.color = 'var(--text-muted)';
      btnBulk.style.fontWeight = '600';
      btnBulk.style.borderBottomColor = 'transparent';
      
      formSingle.style.display = 'block';
      formBulk.style.display = 'none';
      formEl.action = '/course-management';
      
      singleTitle.disabled = false;
      bulkTitles.disabled = true;
      bulkTitles.required = false;
    } else {
      btnBulk.style.color = '#4f46e5';
      btnBulk.style.fontWeight = '700';
      btnBulk.style.borderBottomColor = '#4f46e5';
      btnSingle.style.color = 'var(--text-muted)';
      btnSingle.style.fontWeight = '600';
      btnSingle.style.borderBottomColor = 'transparent';
      
      formSingle.style.display = 'none';
      formBulk.style.display = 'block';
      formEl.action = '/course-management/bulk';
      
      singleTitle.disabled = true;
      bulkTitles.disabled = false;
      bulkTitles.required = true;
    }
  }

  /* ---- Edit modal ---- */
  function openEditForm(id, title, desc, imageUrl, status, enrollmentType) {
    document.getElementById('edit-course-form-element').action = `/course-management/${id}/update`;
    document.getElementById('edit-title').value = title;
    document.getElementById('edit-description').value = desc;
    document.getElementById('edit-image-url').value = imageUrl || '';
    document.getElementById('edit-status').value = status;
    document.getElementById('edit-enrollment-type').value = enrollmentType || 'open';
    showModal('edit-course-modal');
  }
  function closeEditForm() { hideModal('edit-course-modal'); }

  /* ---- Assign modal ---- */
  function openAssignCourseModal(courseId) {
    showModal(`assignCourseModal-${courseId}`);
  }
  function closeAssignCourseModal(courseId) {
    hideModal(`assignCourseModal-${courseId}`);
  }

  /* ---- Core modal helpers ---- */
  function showModal(id) {
    document.getElementById(id).style.display = 'block';
    document.getElementById('cm-modal-overlay').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }
  function hideModal(id) {
    document.getElementById(id).style.display = 'none';
    const anyOpen = document.querySelectorAll('.cm-modal[style*="display: block"]').length > 0;
    if (!anyOpen) {
      document.getElementById('cm-modal-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }
  }
  function closeAllModals() {
    document.querySelectorAll('.cm-modal').forEach(m => m.style.display = 'none');
    document.getElementById('cm-modal-overlay').style.display = 'none';
    document.body.style.overflow = '';
  }

  /* ---- Select helpers ---- */
  function selectAllDeptsForCourse(courseId) {
    const cbs = document.querySelectorAll(`.course-dept-check-${courseId}`);
    const allChecked = Array.from(cbs).every(cb => cb.checked);
    cbs.forEach(cb => cb.checked = !allChecked);
  }
  function selectAllUsersForCourse(courseId) {
    const cbs = Array.from(document.querySelectorAll(`.course-user-check-${courseId}`))
                     .filter(cb => cb.closest(`.course-user-item-label-${courseId}`)?.style.display !== 'none');
    const allChecked = cbs.every(cb => cb.checked);
    cbs.forEach(cb => cb.checked = !allChecked);
  }
  function selectCourseGroupUsers(courseId, deptId) {
    const cbs = Array.from(document.querySelectorAll(`.course-user-check-${courseId}[data-dept-id="${deptId}"]`))
                     .filter(cb => cb.closest(`.course-user-item-label-${courseId}`)?.style.display !== 'none');
    const allChecked = cbs.every(cb => cb.checked);
    cbs.forEach(cb => cb.checked = !allChecked);
  }
  function filterCourseUsersList(courseId) {
    const query = document.getElementById(`courseUserSearch-${courseId}`).value.toLowerCase().trim();
    const container = document.getElementById(`courseUsersListContainer-${courseId}`);
    container.querySelectorAll(`.course-user-group-container-${courseId}`).forEach(group => {
      let visible = 0;
      group.querySelectorAll(`.course-user-item-label-${courseId}`).forEach(item => {
        const match = item.getAttribute('data-search-name').includes(query);
        item.style.display = match ? 'flex' : 'none';
        if (match) visible++;
      });
      group.style.display = visible > 0 ? 'block' : 'none';
    });
  }
</script>

