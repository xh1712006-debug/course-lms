<script>
  // Chuyển cấu trúc bài học EJS sang Client JS
  const allLessons = [];
  // Gieo dữ liệu từ EJS sang JS
  <% courses.forEach(c => { %>
    // Sẽ được cập nhật bằng fetch động hoặc EJS lặp
  <% }) %>

  // Định nghĩa hàm tải bài giảng và đề thi
  function loadLessonsForCourse(courseId) {
    const lessonSelect = document.getElementById('ai-select-lesson');
    const quizSelect = document.getElementById('ai-select-quiz');
    const generateBtn = document.getElementById('btn-ai-generate-quiz');

    lessonSelect.innerHTML = '<option value="">-- Chọn bài học --</option>';
    quizSelect.innerHTML = '<option value="">-- Chọn đề thi --</option>';

    if (!courseId) {
      lessonSelect.disabled = true;
      quizSelect.disabled = true;
      generateBtn.disabled = true;
      return;
    }

    // 1. Tải bài học từ API JSON
    fetch(`/course-management/${courseId}/lessons?json=true`)
      .then(res => res.json())
      .then(lessons => {
        if(lessons.length === 0) {
          lessonSelect.innerHTML = '<option value="">(Khóa học chưa có bài giảng)</option>';
        } else {
          lessons.forEach(l => {
            const opt = document.createElement('option');
            opt.value = l.id;
            opt.textContent = l.title;
            lessonSelect.appendChild(opt);
          });
          lessonSelect.disabled = false;
        }
      }).catch(err => {
        console.error('Lỗi lấy bài giảng:', err);
      });

    // 2. Tải đề thi tương ứng
    const matchedQuizzes = globalQuizzes.filter(q => q.courseId === courseId && q.id !== '');
    if (matchedQuizzes.length === 0) {
      quizSelect.innerHTML = '<option value="">(Khóa học chưa thiết lập đề thi)</option>';
      quizSelect.disabled = true;
      generateBtn.disabled = true;
    } else {
      matchedQuizzes.forEach(q => {
        const opt = document.createElement('option');
        opt.value = q.id;
        opt.textContent = q.title;
        quizSelect.appendChild(opt);
      });
      quizSelect.disabled = false;
      generateBtn.disabled = false;
    }
  }

  // AI sinh trắc nghiệm và nạp vào DB
  function triggerAiQuizGeneration() {
    const lessonId = document.getElementById('ai-select-lesson').value;
    const quizId = document.getElementById('ai-select-quiz').value;
    const statusDiv = document.getElementById('ai-generation-status');
    const generateBtn = document.getElementById('btn-ai-generate-quiz');

    if (!lessonId || !quizId) {
      alert('Vui lòng chọn đầy đủ Bài học làm tư liệu và Đề thi cần gán.');
      return;
    }

    statusDiv.style.display = 'block';
    generateBtn.disabled = true;

    // Gọi API sinh đề thi trắc nghiệm bằng AI và lưu vào Postgres
    fetch('/ai/quiz-to-bank', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ lessonId, quizId })
    })
    .then(res => res.json())
    .then(data => {
      statusDiv.style.display = 'none';
      generateBtn.disabled = false;
      if (data.error) {
        alert('Lỗi: ' + data.error);
      } else {
        alert(data.success);
        // Reload trang để cập nhật ngân hàng câu hỏi
        window.location.reload();
      }
    })
    .catch(err => {
      statusDiv.style.display = 'none';
      generateBtn.disabled = false;
      alert('Lỗi máy chủ: ' + err.message);
    });
  }
</script>

<%- include('../partials/footer') %>
