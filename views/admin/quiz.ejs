<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
    Đề Thi & Ngân Hàng Câu Hỏi
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">Quản lý kho câu hỏi trắc nghiệm, cấu hình đề thi cuối khóa và tích hợp soạn câu hỏi tự động bằng AI.</p>
</div>

<!-- KHU VỰC AI SOẠN ĐỀ THI TỰ ĐỘNG (AGENTIC AI IN ACTION) -->
<div class="glass-card" style="margin-bottom: 2.5rem; border-color: var(--border-glow); box-shadow: 0 4px 30px rgba(139, 92, 246, 0.1);">
  <h3 style="font-size: 1.25rem; margin-bottom: 1rem; color: #a5b4fc; display: flex; align-items: center; gap: 0.5rem;">
    <i class="fa-solid fa-wand-magic-sparkles" style="color: #8b5cf6;"></i>
    Soạn Đề Thi Tự Động Bằng Trợ Lý AI (Gemini)
  </h3>
  <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem;">
    Hệ thống sẽ lấy nội dung bài giảng chi tiết của bạn, gửi tới Gemini AI để sinh tự động 3 câu hỏi trắc nghiệm chất lượng cao bám sát nội dung và nạp trực tiếp vào CSDL.
  </p>
  
  <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: flex-end;">
    <div style="flex: 1; min-width: 200px;">
      <label class="form-label">Bước 1: Chọn Khóa học</label>
      <select id="ai-select-course" onchange="loadLessonsForCourse(this.value)">
        <option value="">-- Chọn khóa học --</option>
        <% courses.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.title %></option>
        <% }) %>
      </select>
    </div>
    
    <div style="flex: 1; min-width: 200px;">
      <label class="form-label">Bước 2: Chọn Bài học làm nguồn tài liệu</label>
      <select id="ai-select-lesson" disabled>
        <option value="">-- Chọn bài học --</option>
      </select>
    </div>

    <div style="flex: 1; min-width: 200px;">
      <label class="form-label">Bước 3: Chọn Đề thi cần thêm vào</label>
      <select id="ai-select-quiz" disabled>
        <option value="">-- Chọn đề thi --</option>
      </select>
    </div>

    <button class="btn btn-primary" id="btn-ai-generate-quiz" onclick="triggerAiQuizGeneration()" style="padding: 0.75rem 1.5rem;" disabled>
      <i class="fa-solid fa-brain"></i> AI Soạn & Nạp Đề Thi
    </button>
  </div>
  
  <div id="ai-generation-status" style="margin-top: 1rem; font-size: 0.85rem; color: #10b981; display: none;">
    <i class="fa-solid fa-spinner fa-spin" style="margin-right: 0.5rem; color: #8b5cf6;"></i> AI đang đọc tài liệu bài học và biên soạn đề thi, vui lòng đợi...
  </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1.3fr; gap: 2rem; align-items: start;">
  
  <!-- Cột bên trái: Thiết lập đề thi và câu hỏi -->
  <div style="display: flex; flex-direction: column; gap: 2rem;">
    
    <!-- 1. Form thiết lập đề thi -->
    <% if (user.permissions.includes('QUIZ_SETTING')) { %>
      <div class="glass-card">
        <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem;"><i class="fa-solid fa-clock-rotate-left" style="color: #6366f1;"></i> Thiết lập Đề thi khóa học</h3>
        <form action="/quiz-management/settings" method="POST">
          <div class="form-group">
            <label class="form-label">Chọn khóa học áp dụng đề thi</label>
            <select name="courseId" required>
              <option value="">-- Chọn khóa học --</option>
              <% courses.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.title %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Tên đề thi cuối khóa</label>
            <input type="text" name="title" placeholder="Ví dụ: Bài kiểm tra cuối khóa Node.js" required>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
              <label class="form-label">Thời gian (phút)</label>
              <input type="number" name="durationMinutes" value="15" min="1" required>
            </div>
            <div class="form-group">
              <label class="form-label">Điểm đạt (%)</label>
              <input type="number" name="passingScore" value="80" min="0" max="100" required>
            </div>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 0.5rem;">
            Lưu / Cập nhật cấu hình đề
          </button>
        </form>
      </div>
    <% } %>

    <!-- 2. Form thêm câu hỏi thủ công -->
    <% if (user.permissions.includes('QUIZ_BANK_MANAGE')) { %>
      <div class="glass-card">
        <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem;"><i class="fa-solid fa-plus" style="color: #06b6d4;"></i> Thêm Câu Hỏi Thủ Công</h3>
        <form action="/quiz-management/questions" method="POST">
          <div class="form-group">
            <label class="form-label">Chọn Đề thi cần thêm vào</label>
            <select name="quizId" required>
              <option value="">-- Chọn đề thi --</option>
              <% quizzes.forEach(q => { %>
                <% if (q.quiz) { %>
                  <option value="<%= q.quiz.id %>"><%= q.quiz.title %> (<%= q.course.title %>)</option>
                <% } %>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Nội dung câu hỏi</label>
            <textarea name="questionText" rows="2" placeholder="Ví dụ: Khái niệm non-blocking I/O là gì?" required></textarea>
          </div>

          <div class="form-group">
            <label class="form-label">Đáp án A</label>
            <input type="text" name="optionA" required>
          </div>
          <div class="form-group">
            <label class="form-label">Đáp án B</label>
            <input type="text" name="optionB" required>
          </div>
          <div class="form-group">
            <label class="form-label">Đáp án C</label>
            <input type="text" name="optionC" required>
          </div>
          <div class="form-group">
            <label class="form-label">Đáp án D</label>
            <input type="text" name="optionD" required>
          </div>

          <div class="form-group">
            <label class="form-label">Đáp án đúng</label>
            <select name="correctOption" required>
              <option value="A">Đáp án A</option>
              <option value="B">Đáp án B</option>
              <option value="C">Đáp án C</option>
              <option value="D">Đáp án D</option>
            </select>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%;">
            Thêm vào kho đề thi
          </button>
        </form>
      </div>
    <% } %>

  </div>

  <!-- Cột bên phải: Danh sách ngân hàng câu hỏi -->
  <div class="glass-card" style="padding: 1.5rem; max-height: 80vh; overflow-y: auto;">
    <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem;"><i class="fa-solid fa-database" style="color: #8b5cf6;"></i> Kho câu hỏi của hệ thống</h3>
    
    <% if (questions.length === 0) { %>
      <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center; padding: 2rem;">Chưa có câu hỏi nào trong ngân hàng.</p>
    <% } else { %>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <% questions.forEach((q, idx) => { %>
          <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-light); padding: 1rem; border-radius: 10px; position: relative;">
            
            <% if (user.permissions.includes('QUIZ_BANK_MANAGE')) { %>
              <!-- Nút xóa câu hỏi -->
              <form action="/quiz-management/questions/<%= q.id %>/delete" method="POST" style="position: absolute; right: 0.5rem; top: 0.5rem;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa câu hỏi này?')">
                <button type="submit" style="background: none; border: none; color: #f87171; cursor: pointer;">
                  <i class="fa-solid fa-trash-can"></i>
                </button>
              </form>
            <% } %>

            <span style="font-size: 0.7rem; background: rgba(99, 102, 241, 0.15); color: var(--text-accent); padding: 0.15rem 0.5rem; border-radius: 4px; border: 1px solid rgba(99, 102, 241, 0.3); font-weight: 600;">
              <%= q.quiz_title || 'Độc lập' %>
            </span>

            <h4 style="font-size: 0.95rem; font-weight: 600; margin-top: 0.5rem; margin-bottom: 0.5rem; padding-right: 1.5rem;">
              <%= idx + 1 %>. <%= q.question_text %>
            </h4>
            
            <ul style="list-style: none; font-size: 0.85rem; color: var(--text-muted); display: grid; grid-template-columns: 1fr 1fr; gap: 0.25rem;">
              <% q.options.forEach(opt => { %>
                <li style="<%= opt === q.correct_answer ? 'color: #10b981; font-weight: 600;' : '' %>">
                  <i class="fa-solid <%= opt === q.correct_answer ? 'fa-square-check' : 'fa-square' %>" style="margin-right: 0.25rem;"></i> <%= opt %>
                </li>
              <% }) %>
            </ul>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<!-- Script hỗ trợ gọi REST API tương tác nạp đề bằng AI -->
