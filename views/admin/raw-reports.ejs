<%- include('../partials/header') %>

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
  <div>
    <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
      Báo Cáo Điểm Chi Tiết
    </h1>
    <p style="color: var(--text-muted); margin-top: 0.25rem;">Danh sách điểm số, tiến độ học tập chi tiết của từng nhân sự toàn doanh nghiệp.</p>
  </div>
  
  <% if (user.permissions.includes('REPORT_EXPORT')) { %>
    <div style="display: flex; gap: 0.5rem; align-items: center;">
      <!-- Trạng thái xuất file ngầm của Web Worker -->
      <span id="export-status" style="font-size: 0.85rem; color: #10b981; display: none;">
        <i class="fa-solid fa-spinner fa-spin" style="color: #6366f1;"></i> Web Worker đang xuất báo cáo...
      </span>
      <button class="btn btn-primary" onclick="triggerWebWorkerExport()">
        <i class="fa-solid fa-file-excel"></i> Xuất Excel báo cáo điểm
      </button>
    </div>
  <% } %>
</div>

<!-- Bộ lọc và Tìm kiếm Nhật ký -->
<div class="glass-card" style="padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; border-color: rgba(255, 255, 255, 0.05);">
  <form action="/reports/raw" method="GET" style="display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
    <div style="flex: 1.5; min-width: 220px;">
      <label class="form-label" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); font-weight: 600; display: block; margin-bottom: 0.4rem;">
        Tìm kiếm nhân sự / Email / Khóa học
      </label>
      <div style="position: relative;">
        <input 
          type="text" 
          name="search" 
          placeholder="Nhập tên, email hoặc khóa học..." 
          value="<%= search %>"
          style="width: 100%; padding: 0.65rem 1rem 0.65rem 2.5rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.9rem; outline: none; transition: border-color 0.2s;"
        >
        <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.9rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.85rem;"></i>
      </div>
    </div>
    
    <div style="flex: 1; min-width: 180px;">
      <label class="form-label" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); font-weight: 600; display: block; margin-bottom: 0.4rem;">
        Khóa học
      </label>
      <select name="course" style="width: 100%; padding: 0.65rem 1rem; background: rgba(15, 23, 42, 0.5); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.9rem; outline: none;">
        <option value="all">Tất cả khóa học</option>
        <% coursesList.forEach(courseTitle => { %>
          <option value="<%= courseTitle %>" <%= selectedCourse === courseTitle ? 'selected' : '' %>><%= courseTitle %></option>
        <% }) %>
      </select>
    </div>

    <div style="flex: 1; min-width: 180px;">
      <label class="form-label" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); font-weight: 600; display: block; margin-bottom: 0.4rem;">
        Phòng ban
      </label>
      <select name="department" style="width: 100%; padding: 0.65rem 1rem; background: rgba(15, 23, 42, 0.5); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.9rem; outline: none;">
        <option value="all">Tất cả phòng ban</option>
        <% deptsList.forEach(deptName => { %>
          <option value="<%= deptName %>" <%= selectedDept === deptName ? 'selected' : '' %>><%= deptName %></option>
        <% }) %>
      </select>
    </div>
    
    <div style="display: flex; gap: 0.5rem;">
      <button type="submit" class="btn btn-primary" style="padding: 0.65rem 1.25rem; font-size: 0.85rem; border-radius: 8px; height: 38px;">
        <i class="fa-solid fa-filter"></i> Lọc kết quả
      </button>
      <% if (search || (selectedCourse && selectedCourse !== 'all') || (selectedDept && selectedDept !== 'all')) { %>
        <a href="/reports/raw" class="btn btn-secondary" style="padding: 0.65rem 1.25rem; font-size: 0.85rem; border-radius: 8px; height: 38px; display: inline-flex; align-items: center; justify-content: center;">
          <i class="fa-solid fa-arrow-rotate-left"></i> Nhập lại
        </a>
      <% } %>
    </div>
  </form>
</div>

<!-- Bảng hiển thị báo cáo điểm chi tiết -->
<div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
  <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem;">
    <i class="fa-solid fa-list-check" style="color: #a5b4fc;"></i> Bảng điểm & Tiến độ học tập chi tiết (Tổng số: <%= totalRows %>)
  </h3>
  
  <table class="custom-table" style="margin-top: 0; font-size: 0.85rem;">
    <thead>
      <tr>
        <th>Nhân sự</th>
        <th>Phòng ban</th>
        <th>Khóa học</th>
        <th style="min-width: 150px;">Tiến độ</th>
        <th>Hình thức học</th>
        <th>Trạng thái duyệt</th>
        <th>Truy cập cuối</th>
      </tr>
    </thead>
    <tbody>
      <% if (reportData.length === 0) { %>
        <tr>
          <td colspan="7" style="text-align: center; color: var(--text-muted); padding: 2rem;">Không tìm thấy dữ liệu báo cáo nào khớp với bộ lọc.</td>
        </tr>
      <% } else { %>
        <% reportData.forEach(row => { %>
          <tr>
            <td>
              <div>
                <strong><%= row.username %></strong>
                <div style="font-size: 0.75rem; color: var(--text-muted);"><%= row.email %></div>
              </div>
            </td>
            <td><%= row.department_name || 'Chưa gán phòng ban' %></td>
            <td style="max-width: 250px; font-weight: 500;"><%= row.course_title %></td>
            <td>
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-weight: 600; min-width: 35px;"><%= row.progress %>%</span>
                <div class="progress-container" style="flex-grow: 1; margin-top: 0; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px;">
                  <div class="progress-bar" style="width: <%= row.progress %>%; height: 100%; border-radius: 3px; background: <%= row.progress === 100 ? '#10b981' : 'var(--primary-gradient)' %>;"></div>
                </div>
              </div>
            </td>
            <td>
              <% if (row.is_assigned) { %>
                <span style="background: rgba(239, 68, 68, 0.15); color: #f87171; padding: 0.15rem 0.4rem; border-radius: 4px; font-weight: 600; font-size: 0.75rem; border: 1px solid rgba(239, 68, 68, 0.3);">
                  Bắt buộc (HR giao)
                </span>
              <% } else { %>
                <span style="background: rgba(99, 102, 241, 0.15); color: var(--text-accent); padding: 0.15rem 0.4rem; border-radius: 4px; font-weight: 600; font-size: 0.75rem; border: 1px solid rgba(99, 102, 241, 0.3);">
                  Tự đăng ký học
                </span>
              <% } %>
            </td>
            <td>
              <% if (row.status === 'approved') { %>
                <span style="color: #10b981; font-weight: 600;"><i class="fa-solid fa-circle-check"></i> Đã duyệt học</span>
              <% } else if (row.status === 'rejected') { %>
                <span style="color: #ef4444; font-weight: 600;"><i class="fa-solid fa-circle-xmark"></i> Bị từ chối</span>
              <% } else { %>
                <span style="color: #f59e0b; font-weight: 600;"><i class="fa-solid fa-clock"></i> Chờ phê duyệt</span>
              <% } %>
            </td>
            <td style="color: var(--text-muted);">
              <%= row.last_accessed ? new Date(row.last_accessed).toLocaleString('vi-VN') : 'Chưa từng học' %>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>

  <!-- Bộ điều khiển phân trang Glassmorphism -->
  <div style="margin-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
    <div style="font-size: 0.85rem; color: var(--text-muted);">
      Hiển thị <%= reportData.length > 0 ? (currentPage - 1) * 20 + 1 : 0 %> - <%= Math.min(currentPage * 20, totalRows) %> trong tổng số <strong><%= totalRows %></strong> lượt tham gia
    </div>
    
    <% if (totalPages > 1) { %>
      <div style="display: flex; gap: 0.35rem; align-items: center;">
        <!-- Nút trang trước -->
        <% if (currentPage > 1) { %>
          <a href="/reports/raw?page=<%= currentPage - 1 %>&search=<%= encodeURIComponent(search) %>&course=<%= encodeURIComponent(selectedCourse) %>&department=<%= encodeURIComponent(selectedDept) %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px;">
            <i class="fa-solid fa-chevron-left"></i> Trước
          </a>
        <% } else { %>
          <button class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px; opacity: 0.4; cursor: not-allowed;" disabled>
            <i class="fa-solid fa-chevron-left"></i> Trước
          </button>
        <% } %>
        
        <!-- Các số trang -->
        <% 
          let startPage = Math.max(1, currentPage - 2);
          let endPage = Math.min(totalPages, currentPage + 2);
          
          if (startPage > 1) { %>
            <a href="/reports/raw?page=1&search=<%= encodeURIComponent(search) %>&course=<%= encodeURIComponent(selectedCourse) %>&department=<%= encodeURIComponent(selectedDept) %>" class="btn <%= currentPage === 1 ? 'btn-primary' : 'btn-secondary' %>" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px;">1</a>
            <% if (startPage > 2) { %>
              <span style="color: var(--text-muted); padding: 0 0.25rem;">...</span>
            <% } %>
          <% } %>
          
          <% for (let i = startPage; i <= endPage; i++) { %>
            <a href="/reports/raw?page=<%= i %>&search=<%= encodeURIComponent(search) %>&course=<%= encodeURIComponent(selectedCourse) %>&department=<%= encodeURIComponent(selectedDept) %>" class="btn <%= currentPage === i ? 'btn-primary' : 'btn-secondary' %>" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px; <%= currentPage === i ? 'pointer-events: none;' : '' %>">
              <%= i %>
            </a>
          <% } %>
          
          <% if (endPage < totalPages) { %>
            <% if (endPage < totalPages - 1) { %>
              <span style="color: var(--text-muted); padding: 0 0.25rem;">...</span>
            <% } %>
            <a href="/reports/raw?page=<%= totalPages %>&search=<%= encodeURIComponent(search) %>&course=<%= encodeURIComponent(selectedCourse) %>&department=<%= encodeURIComponent(selectedDept) %>" class="btn <%= currentPage === totalPages ? 'btn-primary' : 'btn-secondary' %>" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px;"><%= totalPages %></a>
          <% } 
        %>
        
        <!-- Nút trang sau -->
        <% if (currentPage < totalPages) { %>
          <a href="/reports/raw?page=<%= currentPage + 1 %>&search=<%= encodeURIComponent(search) %>&course=<%= encodeURIComponent(selectedCourse) %>&department=<%= encodeURIComponent(selectedDept) %>" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px;">
            Sau <i class="fa-solid fa-chevron-right"></i>
          </a>
        <% } else { %>
          <button class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px; opacity: 0.4; cursor: not-allowed;" disabled>
            Sau <i class="fa-solid fa-chevron-right"></i>
          </button>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<script>
  function triggerWebWorkerExport() {
    const statusSpan = document.getElementById('export-status');
    statusSpan.style.display = 'inline-flex';

    // Tạo một Web Worker mới chỉ định tới file javascript chạy nền
    const worker = new Worker('/js/export-worker.js');

    // Lắng nghe kết quả từ Web Worker gửi về
    worker.onmessage = function(e) {
      statusSpan.style.display = 'none';
      const csvContent = e.data;

      if (csvContent.error) {
        alert('Lỗi xuất báo cáo từ Web Worker: ' + csvContent.error);
        return;
      }

      // Tạo một đối tượng Blob và thực hiện download file báo cáo về máy khách
      const blob = new Blob(["\ufeff" + csvContent], { type: 'text/csv;charset=utf-8;' });
      const link = document.createElement('a');
      const url = URL.createObjectURL(blob);
      
      const today = new Date().toISOString().slice(0,10);
      link.setAttribute('href', url);
      link.setAttribute('download', `BaoCao_LMS_Company_${today}.csv`);
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);

      // Giải phóng bộ nhớ của Worker
      worker.terminate();
    };

    // Gửi tín hiệu bắt đầu cho Web Worker cùng cookie/token (hoặc gọi API trong worker)
    worker.postMessage({ action: 'start_export' });
  }
</script>

<%- include('../partials/footer') %>
