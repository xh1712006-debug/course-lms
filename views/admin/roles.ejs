<!-- ── Matrix Card ──────────────────────────────── -->
<div class="rbac-matrix-card">
  <div style="overflow-x: auto;">
    <table class="rbac-table">
      <thead>
        <tr>
          <th style="width: 40%; font-size: 0.85rem; font-weight: 700; color: var(--text-main);">Quyền hạn &amp; Chức năng</th>
          <% roles.forEach(role => { %>
            <th class="role-header">
              <div class="rbac-role-name"><%= role.name %></div>
              <div class="rbac-role-id">ID: <%= role.id %></div>
              <% if (role.id !== 1) { %>
                <form action="/permissions/<%= role.id %>/delete" method="POST" id="delete-form-<%= role.id %>" style="display:inline;">
                  <button type="button" 
                    onclick="confirmDeleteRole('<%= role.id %>', '<%= role.name %>')"
                    title="Xóa vai trò <%= role.name %>"
                    class="rbac-btn-delete">
                    <i class="fa-solid fa-trash-can"></i>
                  </button>
                </form>
              <% } else { %>
                <span class="rbac-badge-lock">
                  <i class="fa-solid fa-lock"></i> Hệ thống
                </span>
              <% } %>
            </th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% permissionGroups.forEach((group) => { %>
          <!-- Group row header -->
          <tr class="rbac-group-row">
            <td colspan="<%= roles.length + 1 %>">
              <div style="display: flex; align-items: center; flex-wrap: wrap;">
                <span class="rbac-group-title" style="color: <%= group.color %>;">
                  <i class="fa-solid <%= group.icon %>"></i>
                  <%= group.title %>
                </span>
                <% if (group.sidebarNote) { %>
                  <a href="<%= group.sidebarUrl %>" target="_blank" class="rbac-group-link"
                     style="border: 1px solid <%= group.border %>; background: <%= group.bg %>; color: <%= group.color %>;"
                     title="Xem trang liên kết">
                    <i class="fa-solid fa-sidebar" style="font-size: 0.62rem;"></i>
                    Sidebar: <%= group.sidebarNote %>
                    <i class="fa-solid fa-arrow-up-right-from-square" style="font-size: 0.55rem; opacity: 0.8;"></i>
                  </a>
                <% } %>
              </div>
            </td>
          </tr>

          <!-- Permission Rows -->
          <% group.perms.forEach(perm => { %>
            <tr class="rbac-item-row">
              <td>
                <div class="rbac-perm-desc"><%= perm.desc %></div>
                <div class="rbac-perm-key"><%= perm.key %></div>
              </td>
              <% roles.forEach(role => { %>
                <td class="rbac-cell-center">
                  <input type="checkbox" 
                         class="rbac-checkbox" 
                         data-role-id="<%= role.id %>" 
                         data-role-name="<%= role.name %>"
                         data-permission="<%= perm.key %>"
                         <%= role.permissions.includes(perm.key) ? 'checked' : '' %>
                         <%= role.id === 1 ? 'disabled' : '' %>
                         title="<%= role.id === 1 ? 'Quyền của Super Admin được bảo vệ cố định' : '' %>"
                  >
                </td>
              <% }) %>
            </tr>
          <% }) %>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- ── Toast Notifications area ──────────────────── -->
<div id="toast-container" style="position: fixed; bottom: 2rem; right: 2rem; display: flex; flex-direction: column; gap: 0.75rem; z-index: 9999;"></div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const checkboxes = document.querySelectorAll('.rbac-checkbox');
    const toastContainer = document.getElementById('toast-container');

    function showToast(message, type = 'success') {
      const toast = document.createElement('div');
      toast.className = 'toast-box';
      
      let icon = '<i class="fa-solid fa-circle-check" style="color: #059669;"></i>';
      if (type === 'error') {
        icon = '<i class="fa-solid fa-circle-exclamation" style="color: #dc2626;"></i>';
        toast.style.borderLeft = '4px solid #dc2626';
      } else {
        toast.style.borderLeft = '4px solid #059669';
      }

      toast.innerHTML = `${icon} <span style="flex-grow: 1; font-weight: 500;">${message}</span>`;
      toastContainer.appendChild(toast);

      setTimeout(() => {
        toast.classList.add('show');
      }, 50);

      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => {
          toast.remove();
        }, 350);
      }, 3000);
    }

    checkboxes.forEach(cb => {
      cb.addEventListener('change', async (e) => {
        const checkbox = e.target;
        const roleId = parseInt(checkbox.getAttribute('data-role-id'));
        const roleName = checkbox.getAttribute('data-role-name');
        const permission = checkbox.getAttribute('data-permission');
        const isChecked = checkbox.checked;

        checkbox.disabled = true;

        try {
          const response = await fetch('/permissions/toggle', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              roleId,
              permission,
              isChecked
            })
          });

          const resData = await response.json();

          if (resData.success) {
            showToast(`Đã ${isChecked ? 'cấp' : 'thu hồi'} quyền "${permission}" cho vai trò ${roleName}.`, 'success');
          } else {
            showToast(`Lỗi: ${resData.error || 'Cập nhật thất bại'}`, 'error');
            checkbox.checked = !isChecked;
          }
        } catch (err) {
          showToast(`Lỗi hệ thống khi kết nối: ${err.message}`, 'error');
          checkbox.checked = !isChecked;
        } finally {
          checkbox.disabled = false;
        }
      });
    });
  });

  // Toggle form tạo vai trò mới
  function toggleCreateForm() {
    const form = document.getElementById('create-role-form');
    const chevron = document.getElementById('form-chevron');
    const btn = document.getElementById('toggle-create-form');
    const isHidden = form.style.display === 'none';
    
    if (isHidden) {
      form.style.display = 'block';
      chevron.className = 'fa-solid fa-chevron-up';
      btn.innerHTML = '<i class="fa-solid fa-chevron-up" id="form-chevron" style="margin-right: 0.25rem;"></i> Thu gọn';
      document.getElementById('role-name-input').focus();
    } else {
      form.style.display = 'none';
      chevron.className = 'fa-solid fa-chevron-down';
      btn.innerHTML = '<i class="fa-solid fa-chevron-down" id="form-chevron" style="margin-right: 0.25rem;"></i> Mở rộng';
    }
  }

  // Xác nhận trước khi xóa vai trò
  function confirmDeleteRole(roleId, roleName) {
    const confirmMsg = `⚠️ Bạn có chắc muốn xóa vai trò "${roleName}"?\n\nHành động này sẽ:\n• Xóa toàn bộ quyền hạn của vai trò\n• Không thể hoàn tác\n\nLưu ý: Chỉ có thể xóa nếu không có nhân viên nào đang dùng vai trò này.`;
    if (confirm(confirmMsg)) {
      document.getElementById('delete-form-' + roleId).submit();
    }
  }

  // Tự động ẩn alert sau 5 giây
  setTimeout(() => {
    document.querySelectorAll('.rbac-alert').forEach(el => {
      el.style.transition = 'opacity 0.5s';
      el.style.opacity = '0';
      setTimeout(() => el.remove(), 500);
    });
  }, 5000);
</script>

