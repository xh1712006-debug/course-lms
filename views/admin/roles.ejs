<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
    Ma Trận Vai Trò & Quyền Hạn (RBAC Matrix)
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">
    Quản lý đặc quyền tập trung. Bật/tắt các đặc quyền của từng vai trò tức thời và an toàn thông qua bảng ma trận.
  </p>
</div>

<!-- Thông báo thành công / lỗi -->
<% if (success) { %>
  <div class="alert-banner alert-success" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); color: #10b981; display: flex; align-items: center; gap: 0.75rem;">
    <i class="fa-solid fa-circle-check"></i>
    <span><%= success %></span>
  </div>
<% } %>
<% if (error) { %>
  <div class="alert-banner alert-error" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #f87171; display: flex; align-items: center; gap: 0.75rem;">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span><%= error %></span>
  </div>
<% } %>

<!-- Panel tạo vai trò mới -->
<div class="glass-card" style="padding: 1.5rem; margin-bottom: 1.5rem; border: 1px solid rgba(99, 102, 241, 0.2);">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
    <h2 style="font-size: 1.1rem; font-weight: 700; color: var(--text-accent); display: flex; align-items: center; gap: 0.6rem;">
      <i class="fa-solid fa-circle-plus"></i> Tạo vai trò mới
    </h2>
    <button id="toggle-create-form" onclick="toggleCreateForm()" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.5rem 1rem;">
      <i class="fa-solid fa-chevron-down" id="form-chevron"></i> Mở rộng
    </button>
  </div>
  
  <div id="create-role-form" style="display: none;">
    <form action="/permissions/create" method="POST">
      <div style="display: grid; grid-template-columns: 1fr 2fr auto; gap: 1rem; align-items: end;">
        <div>
          <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;">
            Tên vai trò <span style="color: #f87171;">*</span>
          </label>
          <input 
            type="text" 
            name="name" 
            id="role-name-input"
            placeholder="Ví dụ: Content Manager" 
            required
            style="width: 100%; padding: 0.7rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none; transition: border-color 0.2s;"
            onfocus="this.style.borderColor='rgba(99,102,241,0.5)'"
            onblur="this.style.borderColor='var(--border-light)'"
          >
        </div>
        <div>
          <label style="display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em;">
            Mô tả vai trò
          </label>
          <input 
            type="text" 
            name="description" 
            placeholder="Mô tả ngắn chức năng và phạm vi của vai trò này" 
            style="width: 100%; padding: 0.7rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none; transition: border-color 0.2s;"
            onfocus="this.style.borderColor='rgba(99,102,241,0.5)'"
            onblur="this.style.borderColor='var(--border-light)'"
          >
        </div>
        <button type="submit" class="btn btn-primary" style="padding: 0.7rem 1.5rem; white-space: nowrap;">
          <i class="fa-solid fa-plus"></i> Tạo vai trò
        </button>
      </div>
      <p style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.75rem;">
        <i class="fa-solid fa-circle-info" style="margin-right: 0.3rem; color: #818cf8;"></i>
        Sau khi tạo, bạn có thể gán quyền hạn cho vai trò này ngay trong bảng ma trận bên dưới.
      </p>
    </form>
  </div>
</div>


