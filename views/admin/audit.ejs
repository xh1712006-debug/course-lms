<!-- ── Page Header ──────────────────────────────── -->
<div class="aud-header">
  <h1 class="aud-title">Nhật Ký Hệ Thống (Audit Logs)</h1>
  <p class="aud-subtitle">Giám sát vết hoạt động, kiểm tra các thay đổi cấu hình bảo mật và phân quyền vai trò.</p>
</div>

<!-- ── Filters ─────────────────────────────────── -->
<div class="aud-filter-card">
  <form action="/audit" method="GET" class="aud-filter-form">
    <div class="aud-field-group">
      <label class="aud-label">Tìm kiếm nhân sự / Email</label>
      <div class="aud-input-wrap">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input 
          type="text" 
          name="search" 
          placeholder="Nhập họ tên hoặc email..." 
          value="<%= search %>"
        >
      </div>
    </div>
    
    <div class="aud-field-group">
      <label class="aud-label">Loại hành động</label>
      <select name="action" class="aud-select">
        <% actionTypes.forEach(type => { %>
          <option value="<%= type.value %>" <%= action === type.value ? 'selected' : '' %>><%= type.label %></option>
        <% }) %>
      </select>
    </div>

    <div class="aud-field-group">
      <label class="aud-label">Từ ngày</label>
      <input 
        type="date" 
        name="startDate" 
        value="<%= startDate %>"
        class="aud-date-input"
      >
    </div>

    <div class="aud-field-group">
      <label class="aud-label">Đến ngày</label>
      <input 
        type="date" 
        name="endDate" 
        value="<%= endDate %>"
        class="aud-date-input"
      >
    </div>
    
    <div class="aud-form-actions">
      <button type="submit" class="aud-btn-filter">
        <i class="fa-solid fa-filter"></i> Lọc kết quả
      </button>
      <% if (search || (action && action !== 'all') || startDate || endDate) { %>
        <a href="/audit" class="aud-btn-reset">
          <i class="fa-solid fa-arrow-rotate-left"></i> Nhập lại
        </a>
      <% } %>
    </div>
  </form>
</div>

<!-- ── Main Table Card ─────────────────────────── -->
<div class="aud-card">
  <div class="aud-card-header">
    <div class="aud-card-title">
      <i class="fa-solid fa-clock-rotate-left"></i>
      <span>Nhật ký hoạt động hệ thống</span>
      <span style="font-size: 0.8rem; font-weight: 600; color: var(--text-muted); background: #f1f5f9; padding: 0.15rem 0.55rem; border-radius: 12px; margin-left: 0.35rem;">
        Tổng số: <%= totalLogs %>
      </span>
    </div>
  </div>
  
  <div style="overflow-x: auto;">
    <table class="aud-table">
      <thead>
        <tr>
          <th style="width: 80px;">Mã log</th>
          <th style="width: 170px;">Thời gian</th>
          <th style="width: 150px;">Nhân sự</th>
          <th style="width: 200px;">Email</th>
          <th style="width: 220px;">Hành động</th>
          <th>Chi tiết hoạt động</th>
        </tr>
      </thead>
      <tbody>
        <% if (logs.length === 0) { %>
          <tr>
            <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 3.5rem 1rem;">
              <i class="fa-solid fa-inbox" style="font-size: 2rem; opacity: 0.25; display: block; margin-bottom: 0.75rem;"></i>
              Không tìm thấy nhật ký hoạt động nào khớp với bộ lọc.
            </td>
          </tr>
        <% } else { %>
          <% logs.forEach(log => { %>
            <tr>
              <td class="aud-log-id">#<%= log.id %></td>
              <td class="aud-time">
                <%= new Date(log.created_at).toLocaleString('vi-VN') %>
              </td>
              <td>
                <span class="aud-user-name"><%= log.username || 'Hệ thống' %></span>
              </td>
              <td style="color: var(--text-muted);"><%= log.email || '—' %></td>
              <td>
                <span class="aud-action-badge">
                  <%= actionLabels[log.action] || log.action %>
                </span>
              </td>
              <td>
                <div class="aud-detail-text">
                  <%- formatAuditDetails(log.details) %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination Bar -->
  <% if (totalPages > 1) { %>
    <div class="aud-pagination-bar">
      <div class="aud-pagination-info">
        Hiển thị <strong><%= logs.length > 0 ? (currentPage - 1) * 20 + 1 : 0 %></strong> – 
        <strong><%= Math.min(currentPage * 20, totalLogs) %></strong> 
        trong <strong><%= totalLogs %></strong> hoạt động
      </div>
      
      <div class="aud-pagination-pages">
        <!-- Prev Button -->
        <% if (currentPage > 1) { %>
          <a href="/audit?page=<%= currentPage - 1 %>&search=<%= encodeURIComponent(search) %>&action=<%= encodeURIComponent(action) %>&startDate=<%= encodeURIComponent(startDate) %>&endDate=<%= encodeURIComponent(endDate) %>" class="aud-page-btn" title="Trang trước">
            <i class="fa-solid fa-chevron-left" style="font-size: 0.7rem;"></i> Trước
          </a>
        <% } else { %>
          <button class="aud-page-btn" disabled>
            <i class="fa-solid fa-chevron-left" style="font-size: 0.7rem;"></i> Trước
          </button>
        <% } %>
        
        <!-- Page Numbers -->
        <% 
          let startPage = Math.max(1, currentPage - 2);
          let endPage = Math.min(totalPages, currentPage + 2);
          
          if (startPage > 1) { %>
            <a href="/audit?page=1&search=<%= encodeURIComponent(search) %>&action=<%= encodeURIComponent(action) %>&startDate=<%= encodeURIComponent(startDate) %>&endDate=<%= encodeURIComponent(endDate) %>" class="aud-page-btn">1</a>
            <% if (startPage > 2) { %>
              <span class="aud-page-sep">…</span>
            <% } %>
          <% } %>
          
          <% for (let i = startPage; i <= endPage; i++) { %>
            <% if (currentPage === i) { %>
              <span class="aud-page-btn active"><%= i %></span>
            <% } else { %>
              <a href="/audit?page=<%= i %>&search=<%= encodeURIComponent(search) %>&action=<%= encodeURIComponent(action) %>&startDate=<%= encodeURIComponent(startDate) %>&endDate=<%= encodeURIComponent(endDate) %>" class="aud-page-btn">
                <%= i %>
              </a>
            <% } %>
          <% } %>
          
          <% if (endPage < totalPages) { %>
            <% if (endPage < totalPages - 1) { %>
              <span class="aud-page-sep">…</span>
            <% } %>
            <a href="/audit?page=<%= totalPages %>&search=<%= encodeURIComponent(search) %>&action=<%= encodeURIComponent(action) %>&startDate=<%= encodeURIComponent(startDate) %>&endDate=<%= encodeURIComponent(endDate) %>" class="aud-page-btn"><%= totalPages %></a>
          <% } 
        %>
        
        <!-- Next Button -->
        <% if (currentPage < totalPages) { %>
          <a href="/audit?page=<%= currentPage + 1 %>&search=<%= encodeURIComponent(search) %>&action=<%= encodeURIComponent(action) %>&startDate=<%= encodeURIComponent(startDate) %>&endDate=<%= encodeURIComponent(endDate) %>" class="aud-page-btn" title="Trang sau">
            Sau <i class="fa-solid fa-chevron-right" style="font-size: 0.7rem;"></i>
          </a>
        <% } else { %>
          <button class="aud-page-btn" disabled>
            Sau <i class="fa-solid fa-chevron-right" style="font-size: 0.7rem;"></i>
          </button>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
