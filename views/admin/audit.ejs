    'COURSE_ENROLL_REQUEST': 'Yêu cầu tham gia khóa học',
    'HISTORY_VIEW': 'Xem lịch sử học tập',
    'PROGRESS_TRACK': 'Theo dõi tiến độ học tập'
  };

  function formatAuditDetails(details) {
    if (!details) {
      return '<span class="aud-detail-empty">Không có chi tiết</span>';
    }
    
    let parsedDetails = details;
    if (typeof details === 'string') {
      try {
        parsedDetails = JSON.parse(details);
      } catch (e) {
        return details;
      }
    }
    
    if (!parsedDetails || typeof parsedDetails !== 'object' || Object.keys(parsedDetails).length === 0) {
      return '<span class="aud-detail-empty">Không có chi tiết</span>';
    }
    
    return Object.entries(parsedDetails).map(([key, val]) => {
      const label = detailKeys[key] || key;
      let displayVal = val;
      
      if (val === true) {
        displayVal = 'Có';
      } else if (val === false) {
        displayVal = 'Không';
      } else if (val === null || val === undefined) {
        displayVal = 'Rỗng';
      } else if (Array.isArray(val)) {
        displayVal = val.map(item => detailValues[item] || item).join(', ');
      } else {
        displayVal = detailValues[val] !== undefined ? detailValues[val] : val;
      }
      
      return `<span class="aud-detail-item"><strong>${label}</strong>: <span>${displayVal}</span></span>`;
    }).join(' ');
  }
%>

