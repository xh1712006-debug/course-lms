<%- include('../partials/header') %>

<%
const canManagePath  = user.permissions.includes('PATH_MANAGE');
const canAssignPath  = user.permissions.includes('ENROLL_ASSIGN');
%>

<style>
  /* ── Page ─────────────────────────────── */
  .lp-layout {
    display: grid;
    gap: 1.75rem;
    align-items: start;
  }
  .lp-layout.has-form {
    grid-template-columns: 380px 1fr;
  }
  @media (max-width: 900px) {
    .lp-layout.has-form { grid-template-columns: 1fr; }
  }

  /* ── Alerts ──────────────────────────── */
  .lp-alert {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.2rem;
    border-radius: 12px;
    font-size: 0.88rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }
  .lp-alert-ok  { background:rgba(16,185,129,.08); border:1px solid rgba(16,185,129,.25); color:#059669; }
  .lp-alert-err { background:rgba(239,68,68,.08);  border:1px solid rgba(239,68,68,.25);  color:#dc2626; }

  /* ── Create form card ────────────────── */
  .lp-form-card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
    position: sticky;
    top: 1.5rem;
  }
  .lp-form-title {
    font-size: 0.97rem;
    font-weight: 700;
    color: var(--text-main);
    margin: 0 0 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  /* ── Course checkbox list ────────────── */
  .lp-course-panel {
    background: #f8fafc;
    border: 1px solid var(--border-light);
    border-radius: 9px;
    padding: 0.6rem;
    max-height: 168px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .lp-course-panel::-webkit-scrollbar { width: 4px; }
  .lp-course-panel::-webkit-scrollbar-thumb { background:#cbd5e1; border-radius:4px; }
  .lp-check-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.84rem;
    cursor: pointer;
    color: var(--text-main);
    padding: 0.22rem 0.4rem;
    border-radius: 6px;
    transition: background .14s;
    user-select: none;
  }
  .lp-check-label:hover { background: rgba(99,102,241,.06); }
  .lp-check-label input { accent-color: #6366f1; width:14px; height:14px; flex-shrink:0; }
  .lp-select-all-btn {
    background: none;
    border: none;
    font-size: 0.72rem;
    font-weight: 700;
    color: #6366f1;
    cursor: pointer;
    font-family: var(--font-body);
    padding: 0;
    transition: color .15s;
  }
  .lp-select-all-btn:hover { color: #4338ca; }
  .lp-search-wrap {
    position: relative;
    margin-bottom: 0.5rem;
  }
  .lp-search-wrap i {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 0.78rem;
    pointer-events: none;
  }
  .lp-search-wrap input { padding-left: 2.1rem !important; }

  /* ── Right panel ─────────────────────── */
  .lp-right-card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,.04);
  }
  .lp-right-head {
    padding: 1.1rem 1.4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border-light);
    background: #fafbff;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .lp-right-title {
    font-size: 0.97rem;
    font-weight: 700;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
  }
  .lp-count-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 0.5rem;
    border-radius: 20px;
    background: linear-gradient(135deg, #0d9488, #14b8a6);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
  }
  .lp-path-search-wrap {
    position: relative;
    width: 220px;
  }
  .lp-path-search-wrap i {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 0.8rem;
    pointer-events: none;
  }
  .lp-path-search-wrap input {
    padding-left: 2.2rem !important;
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
    font-size: 0.84rem !important;
    border-radius: 9px !important;
  }

  /* ── Path cards list ─────────────────── */
  .lp-paths-list {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    max-height: 78vh;
    overflow-y: auto;
  }
  .lp-paths-list::-webkit-scrollbar { width: 5px; }
  .lp-paths-list::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }

  .lp-path-card {
    border: 1px solid var(--border-light);
    border-radius: 13px;
    padding: 1.1rem 1.25rem;
    background: #fff;
    transition: box-shadow .2s, border-color .2s;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .lp-path-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,.07);
    border-color: #c7d2fe;
  }
  .lp-path-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }
  .lp-path-name {
    font-size: 1rem;
    font-weight: 700;
    color: #4f46e5;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }
  .lp-path-actions {
    display: flex;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  .lp-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 7px;
    border: 1px solid #e2e8f0;
    background: #fff;
    cursor: pointer;
    font-size: 0.8rem;
    transition: all .18s;
    font-family: var(--font-body);
  }
  .lp-icon-btn:hover { background: #f1f5f9; border-color: #94a3b8; }
  .lp-icon-btn.edit  { color: #8b5cf6; }
  .lp-icon-btn.edit:hover  { background: rgba(139,92,246,.08); border-color: rgba(139,92,246,.3); }
  .lp-icon-btn.trash { color: #ef4444; }
  .lp-icon-btn.trash:hover { background: rgba(239,68,68,.07); border-color: rgba(239,68,68,.28); }

  .lp-path-desc {
    font-size: 0.83rem;
    color: var(--text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  /* ── Course steps ─────────────────────── */
  .lp-steps-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #94a3b8;
    margin-bottom: 0.35rem;
  }
  .lp-steps {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-height: 88px;
    overflow-y: auto;
    padding-right: 0.2rem;
  }
  .lp-steps::-webkit-scrollbar { width: 3px; }
  .lp-steps::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 3px; }
  .lp-step-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.81rem;
    color: var(--text-main);
  }
  .lp-step-num {
    font-size: 0.68rem;
    font-weight: 700;
    color: #06b6d4;
    background: rgba(6,182,212,.09);
    border: 1px solid rgba(6,182,212,.18);
    border-radius: 5px;
    padding: 0.08rem 0.38rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .lp-step-title {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .lp-no-courses {
    font-size: 0.8rem;
    color: #94a3b8;
    font-style: italic;
  }

  /* ── Assign button ────────────────────── */
  .lp-assign-bar {
    border-top: 1px dashed #e2e8f0;
    padding-top: 0.7rem;
    margin-top: 0.25rem;
  }
  .lp-assign-btn {
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    padding: 0.55rem;
    border-radius: 9px;
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    color: #fff;
    font-size: 0.84rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    box-shadow: 0 3px 10px rgba(79,70,229,.2);
    transition: all .2s;
  }
  .lp-assign-btn:hover {
    box-shadow: 0 5px 16px rgba(79,70,229,.35);
    transform: translateY(-1px);
  }

  /* ── Empty / no-match ────────────────── */
  .lp-empty {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
  }
  .lp-empty i { font-size: 2rem; opacity: .25; display: block; margin-bottom: .75rem; }

  /* ── Modal overlay ───────────────────── */
  .lp-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,.45);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    z-index: 999;
  }
  .lp-modal {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 520px;
    max-width: 92vw;
    max-height: 88vh;
    overflow-y: auto;
    z-index: 1000;
    background: #fff;
    border-radius: 18px;
    padding: 1.75rem;
    box-shadow: 0 20px 60px rgba(0,0,0,.16);
    border: 1px solid #e2e8f0;
  }
  .lp-assign-modal { width: 660px; }
  .lp-modal::-webkit-scrollbar { width: 5px; }
  .lp-modal::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 4px; }
  .lp-modal-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-light);
  }
  .lp-modal-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
  }
  .lp-modal-close {
    width: 28px;
    height: 28px;
    border-radius: 7px;
    border: 1px solid #e2e8f0;
    background: #fff;
    color: #94a3b8;
    cursor: pointer;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .18s;
    font-family: var(--font-body);
  }
  .lp-modal-close:hover { background: #f1f5f9; color: var(--text-main); }

  /* assign modal panels */
  .lp-assign-panel {
    background: #f8fafc;
    border: 1px solid var(--border-light);
    border-radius: 9px;
    padding: 0.6rem;
    max-height: 240px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
  }
  .lp-assign-panel::-webkit-scrollbar { width: 4px; }
  .lp-assign-panel::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  .lp-assign-group-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: #8b5cf6;
    text-transform: uppercase;
    letter-spacing: .05em;
    padding: 0.18rem 0.2rem;
    border-bottom: 1px solid rgba(139,92,246,.12);
    margin-top: 0.2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .lp-assign-group-btn {
    background: none; border: none; font-size: .68rem;
    color: #6366f1; cursor: pointer; font-weight: 700;
    font-family: var(--font-body);
  }
</style>

<!-- ── Alerts ──────────────────────────────── -->
<% if (typeof success !== 'undefined' && success) { %>
  <div class="lp-alert lp-alert-ok"><i class="fa-solid fa-circle-check"></i> <span><%= success %></span></div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="lp-alert lp-alert-err"><i class="fa-solid fa-circle-exclamation"></i> <span><%= error %></span></div>
<% } %>

<!-- ── Page header ─────────────────────────── -->
<div style="margin-bottom:1.6rem;">
  <h1 style="font-size:1.5rem; font-weight:800; color:var(--text-main); letter-spacing:-.025em; margin:0;">
    Lộ Trình Đào Tạo
  </h1>
  <p style="color:var(--text-muted); font-size:.88rem; margin-top:.3rem;">
    Gom nhóm nhiều khóa học riêng lẻ thành một chuỗi lộ trình bắt buộc cho từng vai trò nhân sự.
  </p>
</div>

<!-- ── Two-column layout ───────────────────── -->
<div class="lp-layout <%= canManagePath ? 'has-form' : '' %>">

  <!-- LEFT: Create form -->
  <% if (canManagePath) { %>
  <div class="lp-form-card">
    <h3 class="lp-form-title">
      <i class="fa-solid fa-square-plus" style="color:#6366f1;"></i> Thêm lộ trình mới
    </h3>
    <form action="/paths" method="POST">
      <div class="form-group">
        <label class="form-label">Tên lộ trình đào tạo</label>
        <input type="text" name="name" placeholder="Ví dụ: Lộ trình Thử việc Backend Dev" required>
      </div>
      <div class="form-group">
        <label class="form-label">Mô tả mục tiêu lộ trình</label>
        <textarea name="description" rows="3" placeholder="Nhập mục tiêu đào tạo..." required></textarea>
      </div>
      <div class="form-group">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:.45rem;">
          <label class="form-label" style="margin:0; font-size:.84rem;">Chọn khóa học thuộc lộ trình</label>
          <button type="button" class="lp-select-all-btn" onclick="selectAllCreateCourses()">Chọn tất cả</button>
        </div>
        <div class="lp-search-wrap">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" id="courseSearchCreate" placeholder="Tìm tên khóa học..." oninput="filterCreateCourses()">
        </div>
        <div class="lp-course-panel" id="courseListCreate">
          <% courses.forEach(course => { %>
            <label class="lp-check-label course-item-label-create" data-search-title="<%= course.title.toLowerCase() %>">
              <input type="checkbox" name="courseIds" value="<%= course.id %>" class="course-check-create">
              <span><%= course.title %></span>
            </label>
          <% }) %>
        </div>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%; margin-top:.75rem;">
        <i class="fa-solid fa-plus"></i> Tạo lộ trình học
      </button>
    </form>
  </div>
  <% } %>

  <!-- RIGHT: Paths list -->
  <div class="lp-right-card">
    <div class="lp-right-head">
      <h3 class="lp-right-title">
        <i class="fa-solid fa-route" style="color:#06b6d4;"></i>
        Các lộ trình hiện tại
        <span class="lp-count-pill" id="path-count-badge"><%= paths.length %></span>
      </h3>
      <div class="lp-path-search-wrap">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" id="pathSearch" placeholder="Tìm kiếm lộ trình..." oninput="filterPathsList()">
      </div>
    </div>

    <div class="lp-paths-list" id="pathsListContainer">
      <% if (paths.length === 0) { %>
        <div class="lp-empty">
          <i class="fa-solid fa-route"></i>
          <span style="font-size:.9rem;">Chưa có lộ trình nào được tạo.</span>
        </div>
      <% } else { %>
        <% paths.forEach(path => { %>
          <div class="lp-path-card path-card-item"
               data-name="<%= path.name.toLowerCase() %>"
               data-desc="<%= path.description.toLowerCase() %>"
               data-courses="<%= path.courses.map(c => c.title).join(' ').toLowerCase() %>">

            <!-- Top row: name + edit/delete -->
            <div class="lp-path-top">
              <h4 class="lp-path-name" title="<%= path.name %>"><%= path.name %></h4>
              <div class="lp-path-actions">
                <% if (canManagePath) { %>
                  <button class="lp-icon-btn edit"
                          onclick="openEditModal(<%= path.id %>)"
                          title="Sửa lộ trình">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </button>
                  <form action="/paths/<%= path.id %>/delete" method="POST" style="margin:0;"
                        onsubmit="return confirm('Bạn có chắc muốn xóa lộ trình này?')">
                    <button type="submit" class="lp-icon-btn trash" title="Xóa lộ trình">
                      <i class="fa-solid fa-trash-can"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </div>

            <!-- Description -->
            <p class="lp-path-desc"><%= path.description %></p>

            <!-- Course steps -->
            <div>
              <div class="lp-steps-label">Chuỗi khóa học trong lộ trình:</div>
              <% if (path.courses.length === 0) { %>
                <span class="lp-no-courses">(Chưa liên kết khóa học nào)</span>
              <% } else { %>
                <div class="lp-steps">
                  <% path.courses.forEach((c, idx) => { %>
                    <div class="lp-step-row">
                      <span class="lp-step-num">Step <%= idx + 1 %></span>
                      <span class="lp-step-title" title="<%= c.title %>"><%= c.title %></span>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>

            <!-- Assign button -->
            <% if (canAssignPath) { %>
              <div class="lp-assign-bar">
                <button type="button" class="lp-assign-btn" onclick="openAssignModal(<%= path.id %>)">
                  <i class="fa-solid fa-user-plus"></i> Giao lộ trình học tập
                </button>
              </div>
            <% } %>
          </div>
        <% }) %>

        <div id="no-paths-match-msg" class="lp-empty" style="display:none;">
          <i class="fa-solid fa-magnifying-glass"></i>
          <span>Không tìm thấy lộ trình nào khớp.</span>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- ── Modal overlay ──────────────────────── -->
<div id="lp-overlay" class="lp-overlay" onclick="closeAllModals()"></div>

<!-- ── Edit modals ─────────────────────────── -->
<% if (canManagePath && paths.length > 0) { %>
  <% paths.forEach(path => { %>
    <div id="editModal-<%= path.id %>" class="lp-modal">
      <div class="lp-modal-head">
        <h3 class="lp-modal-title">
          <i class="fa-solid fa-pen-to-square" style="color:#8b5cf6;"></i>
          Sửa: <span style="color:#6366f1; margin-left:.25rem;"><%= path.name %></span>
        </h3>
        <button class="lp-modal-close" onclick="closeEditModal(<%= path.id %>)"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form action="/paths/<%= path.id %>/update" method="POST">
        <div class="form-group">
          <label class="form-label">Tên lộ trình đào tạo</label>
          <input type="text" name="name" value="<%= path.name %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Mô tả mục tiêu lộ trình</label>
          <textarea name="description" rows="3" required><%= path.description %></textarea>
        </div>
        <div class="form-group">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:.45rem;">
            <label class="form-label" style="margin:0; font-size:.84rem;">Khóa học thuộc lộ trình</label>
            <button type="button" class="lp-select-all-btn" onclick="selectAllEditCourses(<%= path.id %>)">Chọn tất cả</button>
          </div>
          <div class="lp-search-wrap">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="courseSearchEdit-<%= path.id %>" placeholder="Tìm tên khóa học..."
                   oninput="filterEditCourses(<%= path.id %>)">
          </div>
          <div class="lp-course-panel" id="courseListEdit-<%= path.id %>">
            <% const associatedIds = path.courses.map(c => c.id); %>
            <% courses.forEach(course => { %>
              <label class="lp-check-label course-item-label-edit-<%= path.id %>"
                     data-search-title="<%= course.title.toLowerCase() %>">
                <input type="checkbox" name="courseIds" value="<%= course.id %>"
                       class="course-check-edit-<%= path.id %>"
                       <%= associatedIds.includes(course.id) ? 'checked' : '' %>>
                <span><%= course.title %></span>
              </label>
            <% }) %>
          </div>
        </div>
        <div style="display:flex; gap:.75rem; justify-content:flex-end; border-top:1px solid var(--border-light); padding-top:1.1rem; margin-top:.5rem;">
          <button type="button" class="btn btn-secondary" onclick="closeEditModal(<%= path.id %>)">Hủy</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi</button>
        </div>
      </form>
    </div>
  <% }) %>
<% } %>

<!-- ── Assign modals ────────────────────────── -->
<% if (canAssignPath && paths.length > 0) { %>
  <% paths.forEach(path => { %>
    <div id="assignModal-<%= path.id %>" class="lp-modal lp-assign-modal">
      <div class="lp-modal-head">
        <h3 class="lp-modal-title">
          <i class="fa-solid fa-user-plus" style="color:#10b981;"></i>
          Giao lộ trình: <span style="color:#6366f1; margin-left:.25rem;"><%= path.name %></span>
        </h3>
        <button class="lp-modal-close" onclick="closeAssignModal(<%= path.id %>)"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form action="/paths/<%= path.id %>/assign" method="POST">
        <div style="display:grid; grid-template-columns:1fr 1.3fr; gap:1.25rem; margin-bottom:1.25rem;">

          <!-- Departments -->
          <div>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:.5rem;">
              <label style="font-size:.8rem; font-weight:700; color:#06b6d4;">
                <i class="fa-solid fa-building"></i> Phòng ban
              </label>
              <button type="button" class="lp-assign-group-btn" onclick="selectAllDeptsModal(<%= path.id %>)">Chọn hết</button>
            </div>
            <div class="lp-assign-panel" id="deptListContainer-<%= path.id %>">
              <% departments.forEach(d => { %>
                <label class="lp-check-label dept-item-label-<%= path.id %>">
                  <input type="checkbox" name="departmentIds" value="<%= d.id %>"
                         class="dept-check-cb-<%= path.id %>"
                         style="accent-color:#6366f1; width:14px; height:14px; flex-shrink:0;">
                  <span><%= d.name %></span>
                </label>
              <% }) %>
            </div>
          </div>

          <!-- Users -->
          <div>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:.5rem;">
              <label style="font-size:.8rem; font-weight:700; color:#8b5cf6;">
                <i class="fa-solid fa-users"></i> Cá nhân
              </label>
              <button type="button" class="lp-assign-group-btn" onclick="selectAllUsersModal(<%= path.id %>)">Chọn hết</button>
            </div>
            <div class="lp-search-wrap" style="margin-bottom:.5rem;">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input type="text" id="userSearch-<%= path.id %>" placeholder="Tìm tên nhân sự..."
                     oninput="filterUsersModal(<%= path.id %>)">
            </div>
            <div class="lp-assign-panel" id="usersListContainer-<%= path.id %>">
              <%
                const gu = {};
                departments.forEach(d => { gu[d.id] = { name: d.name, list: [] }; });
                gu['none'] = { name: 'Không thuộc phòng ban', list: [] };
                users.forEach(u => {
                  const dId = u.department_id || 'none';
                  if (!gu[dId]) gu[dId] = { name: u.department_name || 'Không thuộc phòng ban', list: [] };
                  gu[dId].list.push(u);
                });
              %>
              <% Object.keys(gu).forEach(dId => { %>
                <% if (gu[dId].list.length > 0) { %>
                  <div class="user-group-block-<%= path.id %>" data-dept-id="<%= dId %>">
                    <div class="lp-assign-group-label">
                      <span><i class="fa-solid fa-folder-open" style="font-size:.65rem; margin-right:.2rem;"></i> <%= gu[dId].name %></span>
                      <button type="button" class="lp-assign-group-btn" onclick="selectGroupUsersModal(<%= path.id %>, '<%= dId %>')">Chọn nhóm</button>
                    </div>
                    <% gu[dId].list.forEach(u => { %>
                      <label class="lp-check-label user-item-label-<%= path.id %>"
                             data-search-name="<%= u.username.toLowerCase() %>"
                             style="padding-left:.6rem;">
                        <input type="checkbox" name="userIds" value="<%= u.id %>"
                               class="user-check-cb-<%= path.id %>"
                               data-dept-id="<%= dId %>"
                               style="accent-color:#6366f1; width:14px; height:14px; flex-shrink:0;">
                        <span><%= u.username %></span>
                      </label>
                    <% }) %>
                  </div>
                <% } %>
              <% }) %>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Thời hạn hoàn thành (ngày)</label>
          <input type="number" name="timeLimitDays" min="1" placeholder="Bỏ trống nếu không giới hạn">
        </div>

        <div style="display:flex; gap:.75rem; justify-content:flex-end; border-top:1px solid var(--border-light); padding-top:1.1rem; margin-top:.5rem;">
          <button type="button" class="btn btn-secondary" onclick="closeAssignModal(<%= path.id %>)">Hủy</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check"></i> Xác nhận giao</button>
        </div>
      </form>
    </div>
  <% }) %>
<% } %>

<script>
  /* ── Modal helpers ── */
  function showModal(id) {
    document.getElementById(id).style.display = 'block';
    document.getElementById('lp-overlay').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }
  function hideModal(id) {
    document.getElementById(id).style.display = 'none';
    if (!document.querySelector('.lp-modal[style*="display: block"]')) {
      document.getElementById('lp-overlay').style.display = 'none';
      document.body.style.overflow = '';
    }
  }
  function closeAllModals() {
    document.querySelectorAll('.lp-modal').forEach(m => m.style.display = 'none');
    document.getElementById('lp-overlay').style.display = 'none';
    document.body.style.overflow = '';
  }
  function openEditModal(id)   { showModal(`editModal-${id}`); }
  function closeEditModal(id)  { hideModal(`editModal-${id}`); }
  function openAssignModal(id)  { showModal(`assignModal-${id}`); }
  function closeAssignModal(id) { hideModal(`assignModal-${id}`); }

  /* ── Path search ── */
  function filterPathsList() {
    const q = document.getElementById('pathSearch').value.toLowerCase().trim();
    const cards = document.querySelectorAll('.path-card-item');
    let visible = 0;
    cards.forEach(card => {
      const match = !q
        || card.dataset.name.includes(q)
        || card.dataset.desc.includes(q)
        || card.dataset.courses.includes(q);
      card.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    document.getElementById('path-count-badge').textContent = visible;
    const noMsg = document.getElementById('no-paths-match-msg');
    if (noMsg) noMsg.style.display = visible === 0 ? 'block' : 'none';
  }

  /* ── Create form course filter ── */
  function filterCreateCourses() {
    const q = document.getElementById('courseSearchCreate').value.toLowerCase().trim();
    document.querySelectorAll('.course-item-label-create').forEach(el => {
      el.style.display = el.dataset.searchTitle.includes(q) ? 'flex' : 'none';
    });
  }
  function selectAllCreateCourses() {
    const cbs = Array.from(document.querySelectorAll('.course-check-create'))
                     .filter(cb => cb.closest('.course-item-label-create')?.style.display !== 'none');
    const all = cbs.every(cb => cb.checked);
    cbs.forEach(cb => cb.checked = !all);
  }

  /* ── Edit modal course filter ── */
  function filterEditCourses(pathId) {
    const q = document.getElementById(`courseSearchEdit-${pathId}`).value.toLowerCase().trim();
    document.querySelectorAll(`.course-item-label-edit-${pathId}`).forEach(el => {
      el.style.display = el.dataset.searchTitle.includes(q) ? 'flex' : 'none';
    });
  }
  function selectAllEditCourses(pathId) {
    const cbs = Array.from(document.querySelectorAll(`.course-check-edit-${pathId}`))
                     .filter(cb => cb.closest(`.course-item-label-edit-${pathId}`)?.style.display !== 'none');
    const all = cbs.every(cb => cb.checked);
    cbs.forEach(cb => cb.checked = !all);
  }

  /* ── Assign modal helpers ── */
  function selectAllDeptsModal(pathId) {
    const cbs = document.querySelectorAll(`.dept-check-cb-${pathId}`);
    const all = Array.from(cbs).every(cb => cb.checked);
    cbs.forEach(cb => cb.checked = !all);
  }
  function selectAllUsersModal(pathId) {
    const cbs = Array.from(document.querySelectorAll(`.user-check-cb-${pathId}`))
                     .filter(cb => cb.closest(`.user-item-label-${pathId}`)?.style.display !== 'none');
    const all = cbs.every(cb => cb.checked);
    cbs.forEach(cb => cb.checked = !all);
  }
  function selectGroupUsersModal(pathId, deptId) {
    const cbs = Array.from(document.querySelectorAll(`.user-check-cb-${pathId}[data-dept-id="${deptId}"]`))
                     .filter(cb => cb.closest(`.user-item-label-${pathId}`)?.style.display !== 'none');
    const all = cbs.every(cb => cb.checked);
    cbs.forEach(cb => cb.checked = !all);
  }
  function filterUsersModal(pathId) {
    const q = document.getElementById(`userSearch-${pathId}`).value.toLowerCase().trim();
    document.querySelectorAll(`.user-group-block-${pathId}`).forEach(group => {
      let vis = 0;
      group.querySelectorAll(`.user-item-label-${pathId}`).forEach(item => {
        const match = item.dataset.searchName.includes(q);
        item.style.display = match ? 'flex' : 'none';
        if (match) vis++;
      });
      group.style.display = vis > 0 ? 'block' : 'none';
    });
  }
</script>

<%- include('../partials/footer') %>
