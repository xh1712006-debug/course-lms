<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
    Lộ Trình Đào Tạo (Learning Paths)
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">Gom nhóm nhiều khóa học riêng lẻ thành một chuỗi lộ trình bắt buộc cho từng vai trò nhân sự.</p>
</div>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert-banner alert-success" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); color: #10b981; display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem;">
    <i class="fa-solid fa-circle-check"></i>
    <span><%= success %></span>
  </div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert-banner alert-error" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #f87171; display: flex; align-items: center; gap: 0.75rem; font-size: 0.9rem;">
    <i class="fa-solid fa-circle-exclamation"></i>
    <span><%= error %></span>
  </div>
<% } %>

<style>
  .path-item-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 1.25rem;
    border-radius: 12px;
    transition: var(--transition-smooth);
    box-shadow: var(--shadow-card);
  }
  .path-item-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-glow);
    box-shadow: var(--shadow-hover);
    background: rgba(255, 255, 255, 0.98);
  }
  .step-badge {
    font-weight: 800; 
    color: #06b6d4;
    background: rgba(6, 182, 212, 0.08);
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    font-size: 0.72rem;
  }
  .virtual-scroll-container {
    padding: 0 0.75rem !important;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.2) transparent;
  }
  .virtual-scroll-container::-webkit-scrollbar {
    width: 6px;
  }
  .virtual-scroll-container::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.2);
    border-radius: 3px;
  }
  .virtual-item {
    height: 32px !important;
    box-sizing: border-box !important;
    display: flex !important;
    align-items: center !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  .path-virtual-item {
    height: 280px !important;
    box-sizing: border-box !important;
    margin-bottom: 1rem !important;
  }
</style>

<%
const canManagePath = user.permissions.includes('PATH_MANAGE');
%>
<div style="display: grid; <%= canManagePath ? 'grid-template-columns: 1fr 1.8fr;' : 'grid-template-columns: 1fr;' %> gap: 2rem; align-items: start;">
  
  <!-- Cột bên trái: Thêm lộ trình mới -->
  <% if (canManagePath) { %>
    <div class="glass-card" style="position: sticky; top: 2rem; z-index: 10;">
      <h3 style="font-size: 1.2rem; margin-bottom: 1.5rem;"><i class="fa-solid fa-square-plus" style="color: #6366f1;"></i> Thêm lộ trình mới</h3>
      <form action="/paths" method="POST">
        <div class="form-group">
          <label class="form-label">Tên lộ trình đào tạo</label>
          <input type="text" name="name" placeholder="Ví dụ: Lộ trình Thử việc Backend Dev" required>
        </div>

        <div class="form-group">
          <label class="form-label">Mô tả mục tiêu lộ trình</label>
          <textarea name="description" rows="3" placeholder="Nhập mục tiêu đào tạo..." required></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" style="display: flex; justify-content: space-between; align-items: center;">
            <span>Chọn các khóa học thuộc lộ trình (Tích chọn nhiều)</span>
            <button type="button" onclick="selectAllCreateCourses()" style="background: none; border: none; color: var(--text-accent); font-size: 0.72rem; cursor: pointer; font-weight: 600; padding: 0;">Chọn tất cả</button>
          </label>
          <!-- Ô tìm kiếm khóa học -->
          <div style="margin-bottom: 0.5rem; position: relative;">
            <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.6rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.8rem;"></i>
            <input type="text" id="courseSearchCreate" placeholder="Tìm tên khóa học..." oninput="filterCreateCourses()" style="width: 100%; padding: 0.45rem 0.6rem 0.45rem 1.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 6px; color: var(--text-main); font-size: 0.8rem; outline: none; box-sizing: border-box;">
          </div>
          <div id="courseListCreate" style="display: flex; flex-direction: column; gap: 0.5rem; background: rgba(0,0,0,0.15); padding: 1rem; border-radius: 8px; max-height: 150px; overflow-y: auto; border: 1px solid var(--border-light);">
            <% courses.forEach(course => { %>
              <label class="course-item-label-create" data-search-title="<%= course.title.toLowerCase() %>" style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; cursor: pointer;">
                <input type="checkbox" name="courseIds" value="<%= course.id %>" class="course-check-create"> <%= course.title %>
              </label>
            <% }) %>
          </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">
          Tạo lộ trình học
        </button>
      </form>
    </div>
  <% } %>

  <!-- Cột bên phải: Danh sách lộ trình đang vận hành -->
  <div class="glass-card" style="padding: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
      <h3 style="font-size: 1.2rem; margin: 0; color: var(--text-main); font-weight: 700;">
        <i class="fa-solid fa-route" style="color: #06b6d4;"></i> Các lộ trình hiện tại 
        <span id="path-count-badge" style="font-size: 0.75rem; background: var(--secondary-gradient); color: #fff; padding: 0.15rem 0.5rem; border-radius: 20px; margin-left: 0.4rem; vertical-align: middle;"><%= paths.length %></span>
      </h3>
      
      <!-- Search Input -->
      <div style="position: relative; width: 250px; max-width: 100%;">
        <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.85rem;"></i>
        <input type="text" id="pathSearch" placeholder="Tìm kiếm lộ trình..." oninput="filterPathsList()" style="width: 100%; padding: 0.45rem 0.75rem 0.45rem 2rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.85rem; outline: none; box-sizing: border-box; transition: var(--transition-smooth);">
      </div>
    </div>
    
    <div id="pathsListContainer" class="virtual-scroll-container" style="max-height: 75vh; overflow-y: auto; position: relative; box-sizing: border-box; padding: 0 !important;">
      <div class="top-spacer" style="height: 0px;"></div>
      <div class="visible-items" style="display: flex; flex-direction: column;"></div>
      <div class="bottom-spacer" style="height: 0px;"></div>
      
      <!-- Trạng thái không tìm thấy kết quả search -->
      <div id="no-paths-match-msg" style="display: none; text-align: center; padding: 3rem 1rem; color: var(--text-muted);">
        <i class="fa-solid fa-magnifying-glass fa-2x" style="margin-bottom: 1rem; color: var(--text-muted);"></i>
        <p style="font-size: 0.95rem;">Không tìm thấy lộ trình đào tạo nào khớp với từ khóa tìm kiếm.</p>
      </div>
    </div>
  </div>
</div>

<!-- Lớp phủ modal dùng chung -->
<div id="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); z-index: 1999;"></div>

<!-- Render các Modal Giao Lộ Trình ở cấp độ gốc (Root Level) để tránh lỗi Stacking Context của CSS -->
<% if (user.permissions.includes('ENROLL_ASSIGN') && paths.length > 0) { %>
  <% paths.forEach(path => { %>
    <div id="assignModal-<%= path.id %>" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 640px; max-width: 95%; max-height: 85vh; overflow-y: auto; z-index: 2050; box-shadow: 0 10px 50px rgba(0,0,0,0.9); border-color: var(--border-glow); padding: 1.75rem;">
      <h3 style="font-size: 1.3rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 0.75rem;">
        <span><i class="fa-solid fa-user-plus" style="color: #10b981; margin-right: 0.5rem;"></i>Giao Lộ Trình: <%= path.name %></span>
        <button class="btn btn-secondary" onclick="closeAssignModal(<%= path.id %>)" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
      </h3>
      
      <form action="/paths/<%= path.id %>/assign" method="POST">
        <div style="display: grid; grid-template-columns: 1fr 1.3fr; gap: 1.5rem; margin-bottom: 1.5rem; text-align: left;">
          
          <!-- Cột trái: Danh sách Phòng ban -->
          <div>
            <h4 style="font-size: 0.92rem; margin-bottom: 0.75rem; color: #06b6d4; display: flex; justify-content: space-between; align-items: center;">
              <span><i class="fa-solid fa-building"></i> Chọn Phòng ban</span>
              <button type="button" onclick="selectAllDepts(<%= path.id %>)" style="background: none; border: none; color: var(--text-accent); font-size: 0.72rem; cursor: pointer; font-weight: 600;">Chọn hết</button>
            </h4>
            <div id="deptListContainer-<%= path.id %>" class="virtual-scroll-container" style="background: rgba(0,0,0,0.4); border: 1px solid var(--border-light); border-radius: 8px; max-height: 270px; overflow-y: auto; position: relative; box-sizing: border-box;">
              <div class="top-spacer" style="height: 0px;"></div>
              <div class="visible-items" style="display: flex; flex-direction: column;"></div>
              <div class="bottom-spacer" style="height: 0px;"></div>
            </div>
          </div>

          <!-- Cột phải: Danh sách Nhân viên (Phân nhóm theo Phòng ban + Tìm kiếm) -->
          <div>
            <h4 style="font-size: 0.92rem; margin-bottom: 0.75rem; color: #a78bfa; display: flex; justify-content: space-between; align-items: center;">
              <span><i class="fa-solid fa-users"></i> Chọn Cá nhân</span>
              <button type="button" onclick="selectAllUsers(<%= path.id %>)" style="background: none; border: none; color: var(--text-accent); font-size: 0.72rem; cursor: pointer; font-weight: 600;">Chọn hết</button>
            </h4>

            <!-- Ô tìm kiếm nhân sự thời gian thực -->
            <div style="margin-bottom: 0.5rem; position: relative;">
              <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.6rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.8rem;"></i>
              <input type="text" id="userSearch-<%= path.id %>" placeholder="Tìm tên nhân sự..." oninput="filterUsersList(<%= path.id %>)" style="width: 100%; padding: 0.45rem 0.6rem 0.45rem 1.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 6px; color: var(--text-main); font-size: 0.8rem; outline: none; box-sizing: border-box;">
            </div>

            <!-- Container danh sách nhân sự phân nhóm -->
            <div id="usersListContainer-<%= path.id %>" class="virtual-scroll-container" style="background: rgba(0,0,0,0.4); border: 1px solid var(--border-light); border-radius: 8px; max-height: 220px; overflow-y: auto; position: relative; box-sizing: border-box;">
              <div class="top-spacer" style="height: 0px;"></div>
              <div class="visible-items" style="display: flex; flex-direction: column;"></div>
              <div class="bottom-spacer" style="height: 0px;"></div>
            </div>

          </div>

        </div>

        <div style="margin-top: 1rem; margin-bottom: 1.5rem; text-align: left;">
          <label class="form-label" style="font-size: 0.85rem; margin-bottom: 0.4rem; display: block;">Thời hạn hoàn thành cho tất cả các khóa học (ngày)</label>
          <input type="number" name="timeLimitDays" min="1" placeholder="Ví dụ: 30 (Bỏ trống nếu không giới hạn)" style="width: 100%; padding: 0.65rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none; box-sizing: border-box;">
        </div>

        <div style="display: flex; gap: 1rem; justify-content: flex-end; border-top: 1px solid var(--border-light); padding-top: 1.25rem;">
          <button type="button" class="btn btn-secondary" onclick="closeAssignModal(<%= path.id %>)">Hủy</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check"></i> Xác nhận giao</button>
        </div>
      </form>
    </div>
  <% }) %>
<% } %>

<!-- Render các Modal Chỉnh Sửa Lộ Trình ở cấp độ gốc -->
<% if (user.permissions.includes('PATH_MANAGE') && paths.length > 0) { %>
  <% paths.forEach(path => { %>
    <div id="editModal-<%= path.id %>" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 500px; max-width: 95%; max-height: 85vh; overflow-y: auto; z-index: 2050; box-shadow: 0 10px 50px rgba(0,0,0,0.9); border-color: var(--border-glow); padding: 1.75rem;">
      <h3 style="font-size: 1.3rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); padding-bottom: 0.75rem;">
        <span><i class="fa-solid fa-pen-to-square" style="color: #8b5cf6; margin-right: 0.5rem;"></i>Sửa Lộ Trình: <%= path.name %></span>
        <button class="btn btn-secondary" onclick="closeEditModal(<%= path.id %>)" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
      </h3>
      
      <form action="/paths/<%= path.id %>/update" method="POST">
        <div class="form-group" style="text-align: left; margin-bottom: 1rem;">
          <label class="form-label">Tên lộ trình đào tạo</label>
          <input type="text" name="name" value="<%= path.name %>" required style="width: 100%; padding: 0.65rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none; box-sizing: border-box;">
        </div>

        <div class="form-group" style="text-align: left; margin-bottom: 1rem;">
          <label class="form-label">Mô tả mục tiêu lộ trình</label>
          <textarea name="description" rows="3" required style="width: 100%; padding: 0.65rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none; box-sizing: border-box;"><%= path.description %></textarea>
        </div>

        <div class="form-group" style="text-align: left; margin-bottom: 1.5rem;">
          <label class="form-label" style="display: flex; justify-content: space-between; align-items: center;">
            <span>Chọn các khóa học thuộc lộ trình (Tích chọn nhiều)</span>
            <button type="button" onclick="selectAllEditCourses(<%= path.id %>)" style="background: none; border: none; color: var(--text-accent); font-size: 0.72rem; cursor: pointer; font-weight: 600; padding: 0;">Chọn tất cả</button>
          </label>
          <!-- Ô tìm kiếm khóa học -->
          <div style="margin-bottom: 0.5rem; position: relative;">
            <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.6rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.8rem;"></i>
            <input type="text" id="courseSearchEdit-<%= path.id %>" placeholder="Tìm tên khóa học..." oninput="filterEditCourses(<%= path.id %>)" style="width: 100%; padding: 0.45rem 0.6rem 0.45rem 1.8rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 6px; color: var(--text-main); font-size: 0.8rem; outline: none; box-sizing: border-box;">
          </div>
          <div id="courseListEdit-<%= path.id %>" style="display: flex; flex-direction: column; gap: 0.5rem; background: rgba(0,0,0,0.15); padding: 1rem; border-radius: 8px; max-height: 150px; overflow-y: auto; border: 1px solid var(--border-light);">
            <% 
              const associatedIds = path.courses.map(c => c.id);
            %>
            <% courses.forEach(course => { %>
              <label class="course-item-label-edit-<%= path.id %>" data-search-title="<%= course.title.toLowerCase() %>" style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; cursor: pointer; color: #cbd5e1;">
                <input type="checkbox" name="courseIds" value="<%= course.id %>" class="course-check-edit-<%= path.id %>" <%= associatedIds.includes(course.id) ? 'checked' : '' %>> <%= course.title %>
              </label>
            <% }) %>
          </div>
        </div>

        <div style="display: flex; gap: 1rem; justify-content: flex-end; border-top: 1px solid var(--border-light); padding-top: 1.25rem;">
          <button type="button" class="btn btn-secondary" onclick="closeEditModal(<%= path.id %>)">Hủy</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-check"></i> Lưu thay đổi</button>
        </div>
      </form>
    </div>
  <% }) %>
<% } %>

<script>
  // Chuyển đổi dữ liệu EJS thành mảng JS ở client
  const globalDepartments = <%- JSON.stringify(departments) %>;
  const globalUsers = <%- JSON.stringify(users) %>;
  const globalPaths = <%- JSON.stringify(paths) %>;
  const canManagePath = <%= user.permissions.includes('PATH_MANAGE') %>;
  const canEnrollAssign = <%= user.permissions.includes('ENROLL_ASSIGN') %>;

  function escapeHtml(str) {
    if (!str) return '';
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  class VirtualList {
    constructor({
      container,
      items,
      itemHeight = 32,
      windowSize = 20,
      step = 10,
      selectedSet,
      renderItem,
      onUpdate
    }) {
      this.container = container;
      this.items = items;
      this.itemHeight = itemHeight;
      this.windowSize = windowSize;
      this.step = step;
      this.selectedSet = selectedSet;
      this.renderItem = renderItem;
      this.onUpdate = onUpdate;

      this.startIndex = 0;

      this.topSpacer = container.querySelector('.top-spacer');
      this.bottomSpacer = container.querySelector('.bottom-spacer');
      this.visibleItemsContainer = container.querySelector('.visible-items');

      this.container.addEventListener('scroll', () => this.handleScroll());
    }

    setItems(newItems) {
      this.items = newItems;
      this.startIndex = 0;
      this.container.scrollTop = 0;
      this.render();
    }

    handleScroll() {
      const scrollTop = this.container.scrollTop;
      const rawStartIndex = Math.floor(scrollTop / this.itemHeight);
      
      let targetStartIndex = this.startIndex;

      // Cuộn xuống: nếu đã cuộn qua startIndex + step, dịch cửa sổ trượt xuống
      if (rawStartIndex > this.startIndex + this.step) {
        targetStartIndex = Math.min(this.items.length - this.windowSize, this.startIndex + this.step);
        targetStartIndex = Math.max(0, targetStartIndex);
      }
      // Cuộn lên: nếu đã cuộn ngược lên trước startIndex, dịch cửa sổ trượt lên
      else if (rawStartIndex < this.startIndex) {
        targetStartIndex = Math.max(0, this.startIndex - this.step);
      }

      if (targetStartIndex !== this.startIndex) {
        this.startIndex = targetStartIndex;
        this.render();
      }
    }

    render() {
      const total = this.items.length;
      const end = Math.min(total, this.startIndex + this.windowSize);

      // Cập nhật chiều cao các phần đệm
      const topHeight = this.startIndex * this.itemHeight;
      const bottomHeight = Math.max(0, (total - end) * this.itemHeight);

      this.topSpacer.style.height = `${topHeight}px`;
      this.bottomSpacer.style.height = `${bottomHeight}px`;

      // Vẽ các phần tử hiển thị trong DOM
      let html = '';
      for (let i = this.startIndex; i < end; i++) {
        const item = this.items[i];
        const isChecked = (this.selectedSet && item.type === 'user') 
          ? this.selectedSet.has(item.id) 
          : ((this.selectedSet && item.type === 'dept') ? this.selectedSet.has(item.id) : false);
        html += this.renderItem(item, isChecked);
      }
      this.visibleItemsContainer.innerHTML = html;

      if (this.onUpdate) {
        this.onUpdate();
      }
    }
  }

  const deptVirtualLists = {};
  const userVirtualLists = {};
  const selectedDeptsMap = {};
  const selectedUsersMap = {};
  const allUserVirtualItems = {};
  let pathsVirtualList;

  function initVirtualScrollForPath(pathId) {
    if (deptVirtualLists[pathId]) return; // Đã khởi tạo trước đó

    selectedDeptsMap[pathId] = new Set();
    selectedUsersMap[pathId] = new Set();

    // 1. Thiết lập danh sách cuộn ảo cho Phòng ban
    const deptContainer = document.getElementById(`deptListContainer-${pathId}`);
    if (deptContainer) {
      const deptItems = globalDepartments.map(d => ({
        type: 'dept',
        id: d.id,
        name: d.name
      }));

      deptVirtualLists[pathId] = new VirtualList({
        container: deptContainer,
        items: deptItems,
        itemHeight: 32,
        windowSize: 20,
        step: 10,
        selectedSet: selectedDeptsMap[pathId],
        renderItem: (item, isChecked) => {
          return `
            <label class="virtual-item dept-item-label" style="height: 32px; box-sizing: border-box; display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; cursor: pointer; color: #cbd5e1; margin: 0; user-select: none;">
              <input type="checkbox" class="dept-check-cb" data-dept-id="${item.id}" ${isChecked ? 'checked' : ''}>
              <span>${item.name}</span>
            </label>
          `;
        }
      });
      deptVirtualLists[pathId].render();

      // Ủy quyền sự kiện cho các thay đổi của checkbox
      deptContainer.addEventListener('change', (e) => {
        if (e.target.classList.contains('dept-check-cb')) {
          const deptId = parseInt(e.target.dataset.deptId);
          if (e.target.checked) {
            selectedDeptsMap[pathId].add(deptId);
          } else {
            selectedDeptsMap[pathId].delete(deptId);
          }
        }
      });
    }

    // 2. Thiết lập danh sách cuộn ảo cho Nhân viên
    const userContainer = document.getElementById(`usersListContainer-${pathId}`);
    if (userContainer) {
      // Xây dựng danh sách phẳng chứa nhân viên phân nhóm theo phòng ban
      const items = [];
      const groupedUsers = {};
      globalDepartments.forEach(d => {
        groupedUsers[d.id] = { name: d.name, list: [] };
      });
      groupedUsers['none'] = { name: 'Không thuộc phòng ban', list: [] };

      globalUsers.forEach(u => {
        const dId = u.department_id || 'none';
        if (!groupedUsers[dId]) {
          groupedUsers[dId] = { name: u.department_name || 'Không thuộc phòng ban', list: [] };
        }
        groupedUsers[dId].list.push(u);
      });

      globalDepartments.forEach(d => {
        if (groupedUsers[d.id].list.length > 0) {
          items.push({ type: 'header', deptId: d.id, name: d.name });
          groupedUsers[d.id].list.forEach(u => {
            items.push({ type: 'user', id: u.id, username: u.username, deptId: d.id });
          });
        }
      });
      if (groupedUsers['none'].list.length > 0) {
        items.push({ type: 'header', deptId: 'none', name: 'Không thuộc phòng ban' });
        groupedUsers['none'].list.forEach(u => {
          items.push({ type: 'user', id: u.id, username: u.username, deptId: 'none' });
        });
      }

      allUserVirtualItems[pathId] = items;

      userVirtualLists[pathId] = new VirtualList({
        container: userContainer,
        items: items,
        itemHeight: 32,
        windowSize: 20,
        step: 10,
        selectedSet: selectedUsersMap[pathId],
        renderItem: (item, isChecked) => {
          if (item.type === 'header') {
            return `
              <div class="virtual-item user-group-header" style="height: 32px; box-sizing: border-box; font-size: 0.78rem; font-weight: 700; color: #a78bfa; border-bottom: 1px solid rgba(167, 139, 250, 0.15); display: flex; justify-content: space-between; align-items: center; padding-right: 0.5rem; user-select: none;">
                <span><i class="fa-solid fa-folder-open" style="font-size: 0.7rem; margin-right: 0.25rem;"></i> ${item.name}</span>
                <button type="button" onclick="selectGroupUsers(${pathId}, '${item.deptId}')" style="background: none; border: none; color: var(--text-accent); font-size: 0.65rem; cursor: pointer; font-weight: 600; padding: 0;">Chọn nhóm</button>
              </div>
            `;
          } else {
            return `
              <label class="virtual-item user-item-label" style="height: 32px; box-sizing: border-box; display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; cursor: pointer; color: #cbd5e1; padding-left: 0.4rem; margin: 0; user-select: none;">
                <input type="checkbox" class="user-check-cb" data-user-id="${item.id}" data-dept-id="${item.deptId}" ${isChecked ? 'checked' : ''}>
                <span>${item.username}</span>
              </label>
            `;
          }
        }
      });
      userVirtualLists[pathId].render();

      // Ủy quyền sự kiện cho các thay đổi của checkbox
      userContainer.addEventListener('change', (e) => {
        if (e.target.classList.contains('user-check-cb')) {
          const userId = parseInt(e.target.dataset.userId);
          if (e.target.checked) {
            selectedUsersMap[pathId].add(userId);
          } else {
            selectedUsersMap[pathId].delete(userId);
          }
        }
      });
    }

    // 3. Chặn sự kiện gửi form để chèn các input ẩn
    const modal = document.getElementById(`assignModal-${pathId}`);
    const form = modal ? modal.querySelector('form') : null;
    if (form) {
      form.addEventListener('submit', (e) => {
        // Xóa các input ẩn cũ nếu có
        form.querySelectorAll('.temp-hidden-input').forEach(el => el.remove());

        // Chèn danh sách nhân viên đã chọn
        selectedUsersMap[pathId].forEach(userId => {
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'userIds';
          input.value = userId;
          input.classList.add('temp-hidden-input');
          form.appendChild(input);
        });

        // Chèn danh sách phòng ban đã chọn
        selectedDeptsMap[pathId].forEach(deptId => {
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'departmentIds';
          input.value = deptId;
          input.classList.add('temp-hidden-input');
          form.appendChild(input);
        });
      });
    }
  }

  function openAssignModal(pathId) {
    document.getElementById(`assignModal-${pathId}`).style.display = 'block';
    document.getElementById('modal-overlay').style.display = 'block';
    initVirtualScrollForPath(pathId);
  }

  function closeAssignModal(pathId) {
    document.getElementById(`assignModal-${pathId}`).style.display = 'none';
    document.getElementById('modal-overlay').style.display = 'none';
  }

  function openEditModal(pathId) {
    document.getElementById(`editModal-${pathId}`).style.display = 'block';
    document.getElementById('modal-overlay').style.display = 'block';
  }

  function closeEditModal(pathId) {
    document.getElementById(`editModal-${pathId}`).style.display = 'none';
    document.getElementById('modal-overlay').style.display = 'none';
  }

  function selectAllDepts(pathId) {
    const virtualList = deptVirtualLists[pathId];
    if (!virtualList) return;
    
    const availableDepts = virtualList.items;
    const allChecked = availableDepts.every(d => selectedDeptsMap[pathId].has(d.id));
    
    availableDepts.forEach(d => {
      if (allChecked) {
        selectedDeptsMap[pathId].delete(d.id);
      } else {
        selectedDeptsMap[pathId].add(d.id);
      }
    });
    virtualList.render();
  }

  function selectAllUsers(pathId) {
    const virtualList = userVirtualLists[pathId];
    if (!virtualList) return;
    
    const availableUsers = virtualList.items.filter(item => item.type === 'user');
    const allChecked = availableUsers.every(u => selectedUsersMap[pathId].has(u.id));
    
    availableUsers.forEach(u => {
      if (allChecked) {
        selectedUsersMap[pathId].delete(u.id);
      } else {
        selectedUsersMap[pathId].add(u.id);
      }
    });
    virtualList.render();
  }

  function selectGroupUsers(pathId, deptId) {
    const virtualList = userVirtualLists[pathId];
    if (!virtualList) return;
    
    const deptIdInt = deptId === 'none' ? 'none' : parseInt(deptId);
    const deptUsers = virtualList.items.filter(item => item.type === 'user' && item.deptId === deptIdInt);
    
    const allChecked = deptUsers.every(u => selectedUsersMap[pathId].has(u.id));
    deptUsers.forEach(u => {
      if (allChecked) {
        selectedUsersMap[pathId].delete(u.id);
      } else {
        selectedUsersMap[pathId].add(u.id);
      }
    });
    virtualList.render();
  }

  function filterUsersList(pathId) {
    const query = document.getElementById(`userSearch-${pathId}`).value.toLowerCase().trim();
    const virtualList = userVirtualLists[pathId];
    if (!virtualList) return;
    
    if (!query) {
      virtualList.setItems(allUserVirtualItems[pathId]);
      return;
    }
    
    const filtered = [];
    let currentHeader = null;
    let headerAdded = false;
    
    const allItems = allUserVirtualItems[pathId];
    for (let item of allItems) {
      if (item.type === 'header') {
        currentHeader = item;
        headerAdded = false;
      } else if (item.type === 'user') {
        if (item.username.toLowerCase().includes(query)) {
          if (currentHeader && !headerAdded) {
            filtered.push(currentHeader);
            headerAdded = true;
          }
          filtered.push(item);
        }
      }
    }
    virtualList.setItems(filtered);
  }

  // Lọc danh sách khóa học ở form tạo mới
  function filterCreateCourses() {
    const query = document.getElementById('courseSearchCreate').value.toLowerCase().trim();
    const items = document.querySelectorAll('.course-item-label-create');
    items.forEach(item => {
      const title = item.getAttribute('data-search-title');
      if (title.includes(query)) {
        item.style.display = 'flex';
      } else {
        item.style.display = 'none';
      }
    });
  }

  // Chọn/bỏ chọn tất cả khóa học đang hiển thị ở form tạo mới
  function selectAllCreateCourses() {
    const checkboxes = document.querySelectorAll('.course-check-create');
    const visibleCheckboxes = Array.from(checkboxes).filter(cb => {
      const parentLabel = cb.closest('.course-item-label-create');
      return parentLabel && parentLabel.style.display !== 'none';
    });
    const allChecked = visibleCheckboxes.every(cb => cb.checked);
    visibleCheckboxes.forEach(cb => cb.checked = !allChecked);
  }

  // Lọc danh sách khóa học ở modal sửa
  function filterEditCourses(pathId) {
    const query = document.getElementById(`courseSearchEdit-${pathId}`).value.toLowerCase().trim();
    const items = document.querySelectorAll(`.course-item-label-edit-${pathId}`);
    items.forEach(item => {
      const title = item.getAttribute('data-search-title');
      if (title.includes(query)) {
        item.style.display = 'flex';
      } else {
        item.style.display = 'none';
      }
    });
  }

  // Chọn/bỏ chọn tất cả khóa học đang hiển thị ở modal sửa
  function selectAllEditCourses(pathId) {
    const checkboxes = document.querySelectorAll(`.course-check-edit-${pathId}`);
    const visibleCheckboxes = Array.from(checkboxes).filter(cb => {
      const parentLabel = cb.closest(`.course-item-label-edit-${pathId}`);
      return parentLabel && parentLabel.style.display !== 'none';
    });
    const allChecked = visibleCheckboxes.every(cb => cb.checked);
    visibleCheckboxes.forEach(cb => cb.checked = !allChecked);
  }
  
  function filterPathsList() {
    const query = document.getElementById('pathSearch').value.toLowerCase().trim();
    if (!pathsVirtualList) return;

    if (!query) {
      pathsVirtualList.setItems(globalPaths);
      document.getElementById('path-count-badge').textContent = globalPaths.length;
      updatePathsEmptyState(globalPaths.length);
      return;
    }

    const filtered = globalPaths.filter(path => {
      const name = path.name.toLowerCase();
      const desc = path.description.toLowerCase();
      const courses = path.courses.map(c => c.title.toLowerCase()).join(', ');
      return name.includes(query) || desc.includes(query) || courses.includes(query);
    });

    pathsVirtualList.setItems(filtered);
    document.getElementById('path-count-badge').textContent = filtered.length;
    updatePathsEmptyState(filtered.length);
  }

  function updatePathsEmptyState(count) {
    const noMatchMsg = document.getElementById('no-paths-match-msg');
    if (noMatchMsg) {
      noMatchMsg.style.display = count === 0 ? 'block' : 'none';
    }
  }

  // Khởi tạo các danh sách cuộn ảo khi tải trang hoàn tất
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Tải danh sách lộ trình học tập ảo
    const pathsContainer = document.getElementById('pathsListContainer');
    if (pathsContainer) {
      pathsVirtualList = new VirtualList({
        container: pathsContainer,
        items: globalPaths,
        itemHeight: 296,
        windowSize: 10,
        step: 5,
        renderItem: (path) => {
          let editButtonsHtml = '';
          if (canManagePath) {
            editButtonsHtml = `
              <button type="button" class="btn btn-secondary" onclick="openEditModal(${path.id})" style="padding: 0.35rem 0.6rem; font-size: 0.8rem; color: #8b5cf6; border-color: rgba(139, 92, 246, 0.2); background: rgba(139, 92, 246, 0.05);" title="Sửa lộ trình">
                <i class="fa-solid fa-pen-to-square"></i>
              </button>
              <form action="/paths/${path.id}/delete" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa lộ trình này không? Hành động này không thể hoàn tác.');" style="margin: 0;">
                <button type="submit" class="btn btn-secondary" style="padding: 0.35rem 0.6rem; font-size: 0.8rem; color: #ef4444; border-color: rgba(239, 68, 68, 0.2); background: rgba(239, 68, 68, 0.05);" title="Xóa lộ trình">
                  <i class="fa-solid fa-trash-can"></i>
                </button>
              </form>
            `;
          }

          let coursesHtml = '';
          if (path.courses.length === 0) {
            coursesHtml = `<span style="font-size: 0.8rem; color: var(--text-muted); font-style: italic;">(Chưa liên kết khóa học nào)</span>`;
          } else {
            coursesHtml = path.courses.map((c, idx) => `
              <div style="font-size: 0.82rem; display: flex; align-items: center; gap: 0.5rem; color: var(--text-main);">
                <span class="step-badge">Step ${idx + 1}</span>
                <span>${escapeHtml(c.title)}</span>
              </div>
            `).join('');
          }

          let assignButtonHtml = '';
          if (canEnrollAssign) {
            assignButtonHtml = `
              <div style="border-top: 1px dashed var(--border-light); margin-top: 1.25rem; padding-top: 1rem;">
                <button type="button" class="btn btn-primary" onclick="openAssignModal(${path.id})" style="width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.6rem 1.2rem; font-size: 0.85rem; border-radius: 8px;">
                  <i class="fa-solid fa-user-plus"></i> Giao lộ trình học tập
                </button>
              </div>
            `;
          }

          return `
            <div class="path-item-card path-virtual-item" style="height: 280px; box-sizing: border-box; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; margin-bottom: 1rem;">
              <div>
                <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                  <h4 style="font-size: 1.1rem; font-weight: 700; color: var(--text-accent); margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${escapeHtml(path.name)}">${escapeHtml(path.name)}</h4>
                  <div style="display: flex; gap: 0.35rem; flex-shrink: 0;">
                    ${editButtonsHtml}
                  </div>
                </div>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem; margin-bottom: 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; height: 2.6rem; line-height: 1.3rem;" title="${escapeHtml(path.description)}">${escapeHtml(path.description)}</p>
              </div>
              
              <div style="border-top: 1px solid var(--border-light); padding-top: 0.5rem; flex-grow: 1; overflow-y: auto; min-height: 50px; max-height: 80px; scrollbar-width: thin;">
                <span style="font-size: 0.75rem; color: var(--text-muted); font-weight: 600; display: block; margin-bottom: 0.3rem;">Chuỗi khóa học trong lộ trình:</span>
                <div style="display: flex; flex-direction: column; gap: 0.3rem;">
                  ${coursesHtml}
                </div>
              </div>

              ${assignButtonHtml}
            </div>
          `;
        }
      });
      pathsVirtualList.render();
      updatePathsEmptyState(globalPaths.length);
    }

    // 2. Đăng ký sự kiện click lớp phủ để đóng modal
    const overlay = document.getElementById('modal-overlay');
    if (overlay) {
      overlay.addEventListener('click', () => {
        const assignModals = document.querySelectorAll('[id^="assignModal-"]');
        assignModals.forEach(m => m.style.display = 'none');
        const editModals = document.querySelectorAll('[id^="editModal-"]');
        editModals.forEach(m => m.style.display = 'none');
        overlay.style.display = 'none';
      });
    }
  });
</script>

