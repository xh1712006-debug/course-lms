<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
    Bảng Quản Trị Hệ Thống LMS
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">Quản lý đào tạo nội bộ, thiết lập chương trình học và phân phối quyền hạn.</p>
</div>

<!-- Grid các thông số thống kê KPIs -->
<div class="kpi-grid">
  <% if (stats.totalUsers !== null) { %>
    <div class="glass-card kpi-card">
      <div class="kpi-title">Tổng nhân sự</div>
      <div class="kpi-value"><%= stats.totalUsers %></div>
    </div>
  <% } %>
  
  <div class="glass-card kpi-card">
    <div class="kpi-title">Đang online (Socket)</div>
    <div class="kpi-value" style="background: var(--secondary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
      <%= stats.onlineCount %>
    </div>
  </div>

  <% if (stats.totalCourses !== null) { %>
    <div class="glass-card kpi-card">
      <div class="kpi-title">Tổng khóa học</div>
      <div class="kpi-value"><%= stats.totalCourses %></div>
    </div>
  <% } %>

  <% if (stats.pendingApprovals !== null) { %>
    <div class="glass-card kpi-card">
      <div class="kpi-title">Chờ HR duyệt đăng ký</div>
      <div class="kpi-value" style="background: var(--alert-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
        <%= stats.pendingApprovals %>
      </div>
    </div>
  <% } %>
</div>

<% 
  const hasQuickAction = user.permissions.includes('COURSE_CREATE') || 
                        user.permissions.includes('USER_MANAGE') || 
                        user.permissions.includes('ROLE_MANAGE') || 
                        user.permissions.includes('REPORT_VIEW');
  const hasAuditLog = user.permissions.includes('AUDIT_LOG_VIEW');

  // Điều chỉnh grid 2 cột hoặc 1 cột tùy thuộc vào số lượng widget hiển thị
  let gridStyle = "display: grid; gap: 2rem; margin-top: 1rem;";
  if (hasQuickAction && hasAuditLog) {
    gridStyle += " grid-template-columns: 1.2fr 2fr;";
  } else {
    gridStyle += " grid-template-columns: 1fr;";
  }
%>

<% if (hasQuickAction || hasAuditLog) { %>
<div style="<%= gridStyle %>">
  
  <!-- Phân khu thao tác nhanh -->
  <% if (hasQuickAction) { %>
    <div>
      <h2 style="font-size: 1.4rem; margin-bottom: 1.25rem;"><i class="fa-solid fa-bolt" style="color: #f59e0b;"></i> Thao tác nhanh</h2>
      <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem; padding: 1.5rem;">
        <% if (user.permissions.includes('COURSE_CREATE')) { %>
          <a href="/course-management" class="btn btn-primary" style="justify-content: flex-start; padding: 0.85rem 1rem;">
            <i class="fa-solid fa-plus"></i> Tạo khóa học mới
          </a>
        <% } %>
        
        <% if (user.permissions.includes('USER_MANAGE')) { %>
          <a href="/users" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.85rem 1rem;">
            <i class="fa-solid fa-user-plus"></i> Quản lý & giao khóa học
          </a>
        <% } %>

        <% if (user.permissions.includes('ROLE_MANAGE')) { %>
          <a href="/permissions" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.85rem 1rem;">
            <i class="fa-solid fa-shield-halved"></i> Cấu hình Phân quyền & Matrix
          </a>
        <% } %>

        <% if (user.permissions.includes('REPORT_VIEW')) { %>
          <a href="/reports" class="btn btn-secondary" style="justify-content: flex-start; padding: 0.85rem 1rem;">
            <i class="fa-solid fa-chart-pie"></i> Xem báo cáo thống kê Excel
          </a>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- Phân khu xem nhật ký vết (Audit Logs) gần đây -->
  <% if (hasAuditLog) { %>
    <div>
      <h2 style="font-size: 1.4rem; margin-bottom: 1.25rem; display: flex; align-items: center; justify-content: space-between;">
        <span><i class="fa-solid fa-clock-rotate-left" style="color: #a5b4fc;"></i> Nhật ký hoạt động gần đây</span>
        <a href="/audit" style="font-size: 0.8rem; color: var(--text-accent);">Xem tất cả <i class="fa-solid fa-arrow-right"></i></a>
      </h2>

      <div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
        <% if (recentLogs.length === 0) { %>
          <div style="text-align: center; color: var(--text-muted); padding: 2rem;">Chưa có lịch sử hoạt động ghi nhận.</div>
        <% } else { %>
          <table class="custom-table" style="margin-top: 0; font-size: 0.85rem;">
            <thead>
              <tr>
                <th>Thời gian</th>
                <th>Nhân sự</th>
                <th>Hành động</th>
                <th>Chi tiết</th>
              </tr>
            </thead>
            <tbody>
              <% recentLogs.forEach(log => { %>
                <tr>
                  <td style="color: var(--text-muted);"><%= new Date(log.created_at).toLocaleTimeString() %></td>
                  <td><strong><%= log.username || 'Hệ thống' %></strong></td>
                  <td>
                    <% 
                      let badgeStyle = "background: rgba(99, 102, 241, 0.15); color: var(--text-accent); border: 1px solid rgba(99, 102, 241, 0.3);";
                      if (log.action.includes('SUCCESS') || log.action === 'USER_LOGIN') {
                        badgeStyle = "background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3);";
                      } else if (log.action.includes('REQUESTED') || log.action.includes('FAIL')) {
                        badgeStyle = "background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3);";
                      } else if (log.action === 'USER_LOGOUT') {
                        badgeStyle = "background: rgba(148, 163, 184, 0.15); color: #94a3b8; border: 1px solid rgba(148, 163, 184, 0.3);";
                      }
                    %>
                    <span style="<%= badgeStyle %> padding: 0.2rem 0.5rem; border-radius: 4px; font-family: monospace; font-size: 0.75rem;">
                      <%= log.action %>
                    </span>
                  </td>
                  <td style="color: var(--text-muted); font-size: 0.8rem; font-family: monospace; max-width: 300px; overflow-x: auto; white-space: nowrap;"><%= JSON.stringify(log.details) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
<% } %>

<%- include('../partials/footer') %>
