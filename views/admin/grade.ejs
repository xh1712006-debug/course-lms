<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
    Chấm Điểm & Đánh Giá Bài Làm
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">Chấm thi các bài làm tự luận hoặc bài thực hành, viết nhận xét cải thiện năng lực.</p>
</div>

<div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
  <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem;"><i class="fa-solid fa-list-check" style="color: #6366f1;"></i> Danh sách bài làm chờ chấm điểm</h3>
  
  <table class="custom-table" style="margin-top: 0; font-size: 0.85rem;">
    <thead>
      <tr>
        <th>Mã bài làm</th>
        <th>Học viên</th>
        <th>Khóa học</th>
        <th>Đề thi</th>
        <th>Thời gian nộp</th>
        <th>Nội dung tự luận</th>
        <th style="text-align: center;">Thao tác</th>
      </tr>
    </thead>
    <tbody>
      <% if (submissions.length === 0) { %>
        <tr>
          <td colspan="7" style="text-align: center; color: var(--text-muted); padding: 2rem;">Hiện không có bài làm tự luận nào chờ chấm điểm. Tất cả bài trắc nghiệm đã được tự động chấm điểm tức thì.</td>
        </tr>
      <% } else { %>
        <% submissions.forEach(sub => { %>
          <tr>
            <td><strong>#<%= sub.id %></strong></td>
            <td><strong><%= sub.username %></strong> (<%= sub.email %>)</td>
            <td><%= sub.course_title %></td>
            <td><%= sub.quiz_title %></td>
            <td><%= new Date(sub.created_at).toLocaleString() %></td>
            <td style="max-width: 200px; color: var(--text-muted); display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">
              <%= sub.essay_answer || '(Trống)' %>
            </td>
            <td>
              <div style="display: flex; justify-content: center;">
                <button class="btn btn-primary" style="padding: 0.3rem 0.6rem; font-size: 0.75rem;" onclick="openGradeModal('<%= sub.id %>', '<%= sub.username %>', `<%= sub.essay_answer %>`)">
                  Chấm điểm
                </button>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Modal chấm điểm -->
<div id="grade-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 500px; max-width: 90%; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
  <h3 style="font-size: 1.3rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
    <span><i class="fa-solid fa-marker" style="color: #8b5cf6;"></i> Chấm Điểm Bài Tập</span>
    <button class="btn btn-secondary" onclick="closeGradeModal()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
  </h3>
  <h4 id="grade-student-name" style="margin-bottom: 1rem; color: var(--text-accent);">Học viên: Nguyễn Văn A</h4>
  
  <div class="form-group">
    <label class="form-label">Nội dung bài làm tự luận của học viên:</label>
    <div id="grade-essay-content" style="background: rgba(0,0,0,0.2); border: 1px solid var(--border-light); padding: 1rem; border-radius: 8px; font-size: 0.85rem; max-height: 150px; overflow-y: auto; white-space: pre-line;"></div>
  </div>

  <form id="grade-form" action="" method="POST">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group">
        <label class="form-label">Điểm số (Thang 100)</label>
        <input type="number" name="score" min="0" max="100" value="80" required>
      </div>
      <div class="form-group">
        <label class="form-label">Kết quả</label>
        <select name="isPassed" required>
          <option value="true">ĐẠT (Passed)</option>
          <option value="false">CHƯA ĐẠT (Failed)</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Nhận xét chi tiết cho nhân viên</label>
      <textarea name="feedback" rows="3" placeholder="Viết đánh giá, góp ý chỉnh sửa cho học viên..." required></textarea>
    </div>

    <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
      <button type="submit" class="btn btn-primary">Lưu điểm số</button>
      <button type="button" class="btn btn-secondary" onclick="closeGradeModal()">Hủy</button>
    </div>
  </form>
</div>
<!-- Lớp phủ modal -->
<div id="modal-overlay-grade" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 999;" onclick="closeGradeModal()"></div>

<script>
  function openGradeModal(id, studentName, essayContent) {
    document.getElementById('grade-form').action = `/grade/${id}`;
    document.getElementById('grade-student-name').textContent = `Học viên: ${studentName}`;
    document.getElementById('grade-essay-content').textContent = essayContent || '(Học viên không nộp bài viết tự luận)';
    
    document.getElementById('grade-modal').style.display = 'block';
    document.getElementById('modal-overlay-grade').style.display = 'block';
  }

  function closeGradeModal() {
    document.getElementById('grade-modal').style.display = 'none';
    document.getElementById('modal-overlay-grade').style.display = 'none';
  }
</script>

<%- include('../partials/footer') %>
