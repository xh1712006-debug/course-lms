<%- include('../partials/header') %>

<style>
  .dept-tree-node {
    transition: all 0.25s ease;
  }
  .dept-tree-node:hover {
    background: rgba(6, 182, 212, 0.08) !important;
    border-color: rgba(6, 182, 212, 0.45) !important;
    box-shadow: 0 0 15px rgba(6, 182, 212, 0.1);
  }
  .custom-scroll::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  .custom-scroll::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.02);
    border-radius: 4px;
  }
  .custom-scroll::-webkit-scrollbar-thumb {
    background: rgba(6, 182, 212, 0.25);
    border-radius: 4px;
  }
  .custom-scroll::-webkit-scrollbar-thumb:hover {
    background: rgba(6, 182, 212, 0.45);
  }
</style>

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
  <div>
    <h1 style="font-size: 1.55rem; font-weight: 700; color: var(--text-main);">
      <i class="fa-solid fa-building" style="-webkit-text-fill-color: #06b6d4; font-size: 1.8rem; margin-right: 0.5rem;"></i>Quản Lý Phòng Ban
    </h1>
    <p style="color: var(--text-muted); margin-top: 0.25rem;">Xây dựng cơ cấu tổ chức, quản lý sơ đồ phòng ban và cấp bậc trong công ty.</p>
  </div>
  <% if (user.permissions.includes('DEPARTMENT_MANAGE')) { %>
    <button onclick="toggleCreateDeptDrawer(true)" class="btn btn-primary" style="white-space: nowrap; background: linear-gradient(135deg, #06b6d4, #3b82f6); border: none;">
      <i class="fa-solid fa-plus"></i> Thêm phòng ban mới
    </button>
  <% } %>
</div>

<!-- Thông báo -->
<% if (locals.success) { %>
  <div id="dept-success-alert" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3); color: #10b981; display: flex; align-items: center; gap: 0.75rem;">
    <i class="fa-solid fa-circle-check fa-lg"></i>
    <span><%= success %></span>
  </div>
<% } %>
<% if (locals.error) { %>
  <div id="dept-error-alert" style="margin-bottom: 1.5rem; padding: 1rem 1.5rem; border-radius: 12px; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #f87171; display: flex; align-items: center; gap: 0.75rem;">
    <i class="fa-solid fa-circle-exclamation fa-lg"></i>
    <span><%= error %></span>
  </div>
<% } %>

<!-- Drawer thêm phòng ban mới -->
<% if (user.permissions.includes('DEPARTMENT_MANAGE')) { %>
<div id="create-dept-drawer" style="position: fixed; top: 0; right: -460px; width: 440px; max-width: 100vw; height: 100vh; background: linear-gradient(135deg, rgba(20, 20, 35, 0.98) 0%, rgba(15, 23, 42, 0.98) 100%); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: -10px 0 50px rgba(0,0,0,0.8); z-index: 3000; transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1); border-left: 1px solid rgba(6, 182, 212, 0.3); display: flex; flex-direction: column;">
  
  <!-- Header Drawer -->
  <div style="padding: 1.75rem; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center;">
    <h2 style="font-size: 1.25rem; font-weight: 700; color: #06b6d4; display: flex; align-items: center; gap: 0.6rem; margin: 0;">
      <i class="fa-solid fa-building-circle-arrow-right"></i> Thêm phòng ban mới
    </h2>
    <button onclick="toggleCreateDeptDrawer(false)" style="background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 50%; color: var(--text-muted); cursor: pointer; font-size: 1.1rem; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.color='#fff';" onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.color='var(--text-muted)';">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <!-- Body Form -->
  <form action="/departments" method="POST" style="padding: 2rem 1.75rem; flex: 1; display: flex; flex-direction: column; gap: 1.5rem; justify-content: space-between; height: calc(100vh - 80px); box-sizing: border-box;">
    <div style="display: flex; flex-direction: column; gap: 1.5rem;">
      <div class="form-group">
        <label class="form-label" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: #e2e8f0; font-weight: 700;">
          Tên phòng ban <span style="color: #f87171;">*</span>
        </label>
        <input
          type="text"
          name="name"
          placeholder="Ví dụ: Phòng Kỹ thuật – R&D"
          required
          style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 10px; color: #f1f5f9; font-size: 0.9rem; outline: none; box-sizing: border-box; transition: border-color 0.2s;"
          onfocus="this.style.borderColor='#06b6d4'"
          onblur="this.style.borderColor='var(--border-light)'"
        >
      </div>

      <div class="form-group">
        <label class="form-label" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: #e2e8f0; font-weight: 700;">
          Phòng ban cấp trên
        </label>
        <select name="parentId" style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 10px; color: #f1f5f9; font-size: 0.9rem; outline: none; box-sizing: border-box;">
          <option value="">— Không có (cấp cao nhất) —</option>
          <% departments.forEach(dept => { %>
            <option value="<%= dept.id %>"><%= dept.name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <!-- Footer Action -->
    <div style="display: flex; gap: 1rem; border-top: 1px solid var(--border-light); padding-top: 1.5rem;">
      <button type="button" onclick="toggleCreateDeptDrawer(false)" class="btn btn-secondary" style="flex: 1; height: 42px;">
        Hủy
      </button>
      <button type="submit" class="btn btn-primary" style="flex: 1.2; background: linear-gradient(135deg, #06b6d4, #3b82f6); border: none; height: 42px; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; font-weight: 700;">
        <i class="fa-solid fa-floppy-disk"></i> Tạo phòng ban
      </button>
    </div>
  </form>
</div>

<!-- Lớp phủ cho Drawer -->
<div id="drawer-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 2999; opacity: 0; transition: opacity 0.3s ease;" onclick="toggleCreateDeptDrawer(false)"></div>
<% } %>

<!-- Stats nhanh -->
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1.25rem; margin-bottom: 2rem;">
  <%
  const topLevel = departments.filter(d => !d.parent_id);
  const subLevel  = departments.filter(d =>  d.parent_id);
  const totalUsers = deptUserCounts ? Object.values(deptUserCounts).reduce((a,b) => a+b, 0) : 0;
  %>
  <div class="glass-card" style="padding: 1.25rem; text-align: center; border: 1px solid rgba(6,182,212,0.2);">
    <div style="font-size: 2rem; font-weight: 800; color: #06b6d4;"><%= departments.length %></div>
    <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.25rem;">Tổng phòng ban</div>
  </div>
  <div class="glass-card" style="padding: 1.25rem; text-align: center; border: 1px solid rgba(99,102,241,0.2);">
    <div style="font-size: 2rem; font-weight: 800; color: #818cf8;"><%= topLevel.length %></div>
    <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.25rem;">Phòng ban cấp 1</div>
  </div>
  <div class="glass-card" style="padding: 1.25rem; text-align: center; border: 1px solid rgba(245,158,11,0.2);">
    <div style="font-size: 2rem; font-weight: 800; color: #f59e0b;"><%= subLevel.length %></div>
    <div style="font-size: 0.78rem; color: var(--text-muted); margin-top: 0.25rem;">Phòng ban con</div>
  </div>
</div>

<!-- Nội dung chính: 2 cột -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; align-items: start;">

  <!-- Cột trái: Sơ đồ tổ chức dạng cây -->
  <div class="glass-card" style="padding: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 0.5rem;">
      <h3 style="font-size: 1.1rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 0.6rem;">
        <i class="fa-solid fa-sitemap" style="color: #06b6d4;"></i> Sơ đồ tổ chức
      </h3>
      <% if (departments.length > 0) { %>
        <div style="display: flex; gap: 0.4rem;">
          <button onclick="toggleAllDepts(true)" style="background: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.2); border-radius: 6px; color: #06b6d4; font-size: 0.72rem; padding: 0.25rem 0.5rem; cursor: pointer; display: flex; align-items: center; gap: 0.25rem; transition: all 0.2s;" onmouseover="this.style.background='rgba(6,182,212,0.15)'" onmouseout="this.style.background='rgba(6,182,212,0.08)'">
            <i class="fa-solid fa-folder-open"></i> Mở rộng
          </button>
          <button onclick="toggleAllDepts(false)" style="background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-light); border-radius: 6px; color: var(--text-muted); font-size: 0.72rem; padding: 0.25rem 0.5rem; cursor: pointer; display: flex; align-items: center; gap: 0.25rem; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.08)'; this.style.color='#fff';" onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.color='var(--text-muted)';">
            <i class="fa-solid fa-folder"></i> Thu gọn
          </button>
        </div>
      <% } %>
    </div>

    <!-- Tìm kiếm nhanh sơ đồ -->
    <div style="margin-bottom: 1rem; position: relative;">
      <input 
        type="text" 
        id="dept-tree-search" 
        placeholder="Tìm nhanh trong sơ đồ..." 
        onkeyup="filterDeptTreeInput()" 
        style="width: 100%; padding: 0.6rem 1rem 0.6rem 2.2rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.85rem; outline: none; box-sizing: border-box; transition: all 0.2s;"
        onfocus="this.style.borderColor='#06b6d4'; this.style.boxShadow='0 0 10px rgba(6,182,212,0.1)';"
        onblur="this.style.borderColor='var(--border-light)'; this.style.boxShadow='none';"
      >
      <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.8rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.85rem;"></i>
    </div>

    <% if (departments.length === 0) { %>
      <div style="text-align: center; padding: 3rem 1rem; color: var(--text-muted);">
        <i class="fa-solid fa-building-circle-xmark" style="font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.4; display: block;"></i>
        Chưa có phòng ban nào.<br>
        <small>Nhấn "Thêm phòng ban mới" để bắt đầu xây dựng cơ cấu tổ chức.</small>
      </div>
    <% } else { %>
      <div class="custom-scroll" style="max-height: 480px; overflow-y: auto; padding-right: 0.25rem;">
        <!-- Phòng ban phân cấp đệ quy -->
        <%
        // Khai báo hàm đệ quy để dựng cây phòng ban không giới hạn cấp độ
        function renderDeptTree(parentDept, level) {
          const children = departments.filter(d => d.parent_id === parentDept.id);
          const memberCount = (deptUserCounts && deptUserCounts[parentDept.id]) || 0;
          const hasChildren = children.length > 0;
          
          // CSS style theo từng cấp độ
          let style = '';
          let iconAndInfo = '';
          
          if (level === 1) {
            style = `
              display: flex; align-items: center; justify-content: space-between;
              background: linear-gradient(135deg, rgba(6,182,212,0.08), rgba(59,130,246,0.04));
              border: 1px solid rgba(6,182,212,0.25);
              border-radius: 10px; padding: 0.85rem 1rem;
              cursor: ${hasChildren ? 'pointer' : 'default'};
            `;
            
            const chevronHtml = hasChildren 
              ? `<i class="fa-solid fa-chevron-down" id="chevron-${parentDept.id}" style="color: #06b6d4; font-size: 0.8rem; margin-right: 0.5rem; transition: transform 0.2s; transform: rotate(-90deg);"></i>`
              : `<i class="fa-solid fa-circle" style="color: rgba(6,182,212,0.2); font-size: 0.4rem; margin-right: 0.8rem; margin-left: 0.4rem;"></i>`;
            
            iconAndInfo = `
              <div style="display: flex; align-items: center; gap: 0.75rem;">
                ${chevronHtml}
                <div style="width: 36px; height: 36px; border-radius: 8px; background: linear-gradient(135deg, #06b6d4, #3b82f6); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <i class="fa-solid fa-folder" id="folder-${parentDept.id}" style="color: #fff; font-size: 0.9rem;"></i>
                </div>
                <div>
                  <div style="font-weight: 700; font-size: 0.9rem; color: #e2e8f0;">${parentDept.name}</div>
                  <div style="font-size: 0.72rem; color: var(--text-muted);">
                    <i class="fa-solid fa-users" style="font-size: 0.65rem;"></i>
                    ${memberCount} nhân viên · Cấp ${level} ${parentDept.manager_name ? `· <i class="fa-solid fa-user-tie" style="color: #06b6d4; font-size: 0.65rem; margin-left: 0.25rem;"></i> Trưởng phòng: <strong style="color: #06b6d4;">${parentDept.manager_name}</strong>` : ''}
                  </div>
                </div>
              </div>
            `;
          } else {
            const indent = Math.min(2, (level - 1) * 1.2);
            style = `
              display: flex; align-items: center; justify-content: space-between;
              background: rgba(255,255,255,0.015);
              border: 1px solid var(--border-light);
              border-left: 3px solid rgba(6, 182, 212, ${Math.max(0.2, 0.7 - (level - 2) * 0.15)});
              border-radius: 8px; padding: 0.65rem 1rem;
              margin-left: ${indent}rem;
              margin-top: 0.5rem;
              cursor: ${hasChildren ? 'pointer' : 'default'};
            `;
            
            const chevronHtml = hasChildren 
              ? `<i class="fa-solid fa-chevron-down" id="chevron-${parentDept.id}" style="color: rgba(6,182,212,0.7); font-size: 0.75rem; margin-right: 0.4rem; transition: transform 0.2s; transform: rotate(-90deg);"></i>`
              : `<i class="fa-solid fa-circle" style="color: rgba(255,255,255,0.15); font-size: 0.35rem; margin-right: 0.6rem; margin-left: 0.3rem;"></i>`;
            
            iconAndInfo = `
              <div style="display: flex; align-items: center; gap: 0.6rem;">
                ${chevronHtml}
                <i class="fa-solid fa-folder" id="folder-${parentDept.id}" style="color: rgba(6,182,212,0.7); font-size: 0.85rem;"></i>
                <div>
                  <div style="font-weight: 600; font-size: 0.85rem; color: #cbd5e1;">${parentDept.name}</div>
                  <div style="font-size: 0.7rem; color: var(--text-muted);">
                    <i class="fa-solid fa-users" style="font-size: 0.62rem;"></i>
                    ${memberCount} nhân viên · Trực thuộc ${parentDept.parent_name || ''} ${parentDept.manager_name ? `· <i class="fa-solid fa-user-tie" style="color: rgba(6,182,212,0.7); margin-left: 0.25rem;"></i> Trưởng phòng: <strong style="color: rgba(6,182,212,0.9);">${parentDept.manager_name}</strong>` : ''}
                  </div>
                </div>
              </div>
            `;
          }

          let actionsHtml = '';
          if (user.permissions.includes('DEPARTMENT_MANAGE')) {
            const escapedName = parentDept.name.replace(/'/g, "\\'").replace(/"/g, "&quot;");
            actionsHtml = `
              <div style="display: flex; gap: 0.35rem; align-items: center;" onclick="event.stopPropagation()">
                <button onclick="openAssignManagerModal('${parentDept.id}', '${escapedName}', '${parentDept.manager_id || ''}')"
                  style="background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.2); border-radius: 6px; color: #10b981; cursor: pointer; padding: 0.3rem 0.5rem; font-size: 0.75rem; transition: all 0.2s;"
                  title="Phân công Trưởng phòng">
                  <i class="fa-solid fa-user-tie"></i>
                </button>
                <button onclick="openEditDeptModal('${parentDept.id}', '${escapedName}', '${parentDept.parent_id || ''}')"
                  style="background: rgba(255,255,255,0.06); border: 1px solid var(--border-light); border-radius: 6px; color: #a5b4fc; cursor: pointer; padding: 0.3rem 0.5rem; font-size: 0.75rem; transition: all 0.2s;"
                  title="Đổi tên / di chuyển">
                  <i class="fa-solid fa-pen"></i>
                </button>
                <form action="/departments/${parentDept.id}/delete" method="POST" style="display: inline;" onsubmit="return confirm('Xóa phòng ban «${escapedName}»? Các phòng ban con sẽ mất liên kết cha.')">
                  <button type="submit" style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 6px; color: #f87171; cursor: pointer; padding: 0.3rem 0.5rem; font-size: 0.75rem; transition: all 0.2s;" title="Xóa phòng ban">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              </div>
            `;
          }

          let html = `
            <div style="margin-bottom: 0.75rem;">
              <div class="dept-tree-node" style="${style}" ${hasChildren ? `onclick="toggleDeptNode('${parentDept.id}')"` : ''}>
                ${iconAndInfo}
                ${actionsHtml}
              </div>
          `;

          if (hasChildren) {
            html += `<div class="dept-children-container" id="children-${parentDept.id}" style="display: none;">`;
            children.forEach(child => {
              child.parent_name = parentDept.name;
              html += renderDeptTree(child, level + 1);
            });
            html += `</div>`;
          }

          html += `</div>`;
          return html;
        }
        %>

        <% topLevel.forEach(parent => { %>
          <%- renderDeptTree(parent, 1) %>
        <% }) %>

        <!-- Phòng ban chưa phân cấp (orphan với parent_id không khớp) -->
        <%
        const orphans = departments.filter(d => d.parent_id && !departments.find(p => p.id === d.parent_id));
        if (orphans.length > 0) { %>
        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border-light);">
          <div style="font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.5rem;">Phòng ban chưa xác định cấp:</div>
          <% orphans.forEach(d => { %>
          <div style="display: flex; align-items: center; justify-content: space-between; background: rgba(245,158,11,0.05); border: 1px solid rgba(245,158,11,0.2); border-radius: 8px; padding: 0.65rem 1rem; margin-bottom: 0.4rem;">
            <span style="font-size: 0.85rem; color: #fbbf24;"><%= d.name %></span>
            <% if (user.permissions.includes('DEPARTMENT_MANAGE')) { %>
            <form action="/departments/<%= d.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Xóa phòng ban «<%= d.name %>»?')">
              <button type="submit" style="background: none; border: none; color: #f87171; cursor: pointer; font-size: 0.8rem;">
                <i class="fa-solid fa-trash"></i>
              </button>
            </form>
            <% } %>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <!-- Cột phải: Danh sách phòng ban dạng bảng + nhân viên -->
  <div style="display: flex; flex-direction: column; gap: 1.5rem;">

    <!-- Bảng danh sách phòng ban -->
    <div class="glass-card" style="padding: 1.5rem; display: flex; flex-direction: column;">
      <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.6rem;">
        <i class="fa-solid fa-table-list" style="color: #818cf8;"></i> Danh sách phòng ban
      </h3>

      <!-- Tìm kiếm phòng ban -->
      <div style="margin-bottom: 1rem; position: relative;">
        <input 
          type="text" 
          id="dept-table-search" 
          placeholder="Tìm nhanh phòng ban..." 
          onkeyup="filterDeptTable()" 
          style="width: 100%; padding: 0.6rem 1rem 0.6rem 2.2rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.85rem; outline: none; box-sizing: border-box; transition: all 0.2s;"
          onfocus="this.style.borderColor='#06b6d4'; this.style.boxShadow='0 0 10px rgba(6,182,212,0.1)';"
          onblur="this.style.borderColor='var(--border-light)'; this.style.boxShadow='none';"
        >
        <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 0.8rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 0.85rem;"></i>
      </div>

      <% if (departments.length === 0) { %>
        <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 2rem 0;">Chưa có dữ liệu.</p>
      <% } else { %>
        <div class="custom-scroll" style="max-height: 480px; overflow-y: auto; padding-right: 0.25rem;">
          <table class="custom-table" style="font-size: 0.83rem; margin-top: 0; width: 100%;">
            <thead>
              <tr style="position: sticky; top: 0; background: #141423; z-index: 10; box-shadow: 0 1px 0 rgba(255,255,255,0.05);">
                <th>Tên phòng ban</th>
                <th>Trực thuộc</th>
                <th>Trưởng phòng</th>
                <th style="text-align: center;">Nhân sự</th>
                <% if (user.permissions.includes('DEPARTMENT_MANAGE')) { %>
                <th style="text-align: center;">Thao tác</th>
                <% } %>
              </tr>
            </thead>
            <tbody id="dept-table-body">
              <% departments.forEach(dept => {
                const mCount = (deptUserCounts && deptUserCounts[dept.id]) || 0;
              %>
                <tr data-dept-name="<%= dept.name %>" data-parent-name="<%= dept.parent_name || '' %>">
                  <td>
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                      <% if (dept.parent_id) { %>
                        <i class="fa-solid fa-turn-down-right" style="color: rgba(6,182,212,0.5); font-size: 0.7rem;"></i>
                      <% } else { %>
                        <i class="fa-solid fa-building" style="color: #06b6d4; font-size: 0.75rem;"></i>
                      <% } %>
                      <strong><%= dept.name %></strong>
                    </div>
                  </td>
                  <td style="color: var(--text-muted);">
                    <% if (dept.parent_name) { %>
                      <%= dept.parent_name %>
                    <% } else { %>
                      <span style="opacity: 0.4;">—</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (dept.manager_name) { %>
                      <span style="background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); padding: 0.15rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.25rem;">
                        <i class="fa-solid fa-user-tie"></i> <%= dept.manager_name %>
                      </span>
                    <% } else { %>
                      <span style="opacity: 0.4;">Chưa gán</span>
                    <% } %>
                  </td>
                  <td style="text-align: center;">
                    <span style="background: rgba(6,182,212,0.1); color: #06b6d4; border: 1px solid rgba(6,182,212,0.3); padding: 0.15rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600;">
                      <%= mCount %>
                    </span>
                  </td>
                  <% if (user.permissions.includes('DEPARTMENT_MANAGE')) { %>
                  <td>
                    <div style="display: flex; justify-content: center; gap: 0.35rem;">
                      <button onclick="openAssignManagerModal('<%= dept.id %>', '<%= dept.name.replace(/'/g, `\\'`) %>', '<%= dept.manager_id || '' %>')"
                        class="btn btn-secondary"
                        style="padding: 0.3rem 0.5rem; font-size: 0.75rem; color: #10b981;"
                        title="Phân công Trưởng phòng">
                        <i class="fa-solid fa-user-tie"></i>
                      </button>
                      <button onclick="openEditDeptModal('<%= dept.id %>', '<%= dept.name.replace(/'/g, `\\'`) %>', '<%= dept.parent_id || '' %>')"
                        class="btn btn-secondary"
                        style="padding: 0.3rem 0.5rem; font-size: 0.75rem; color: #a5b4fc;"
                        title="Đổi tên / chỉnh sửa">
                        <i class="fa-solid fa-pen"></i>
                      </button>
                      <form action="/departments/<%= dept.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Xóa phòng ban «<%= dept.name %>»?')">
                        <button type="submit" class="btn btn-secondary" style="padding: 0.3rem 0.5rem; font-size: 0.75rem; color: #f87171;" title="Xóa">
                          <i class="fa-solid fa-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                  <% } %>
                </tr>
              <% }) %>
              <tr id="no-dept-row" style="display: none;">
                <td colspan="<%= user.permissions.includes('DEPARTMENT_MANAGE') ? 5 : 4 %>" style="text-align: center; color: var(--text-muted); padding: 2rem 0;">
                  Không tìm thấy phòng ban nào khớp với từ khóa tìm kiếm.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div><!-- /cột phải -->
</div>

<!-- Modal chỉnh sửa phòng ban -->
<div id="edit-dept-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 420px; max-width: 90%; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: rgba(6,182,212,0.4);">
  <h3 style="font-size: 1.1rem; margin-bottom: 1.25rem; display: flex; justify-content: space-between; align-items: center;">
    <span><i class="fa-solid fa-pen" style="color: #06b6d4;"></i> Chỉnh sửa phòng ban</span>
    <button class="btn btn-secondary" onclick="closeEditDeptModal()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
  </h3>
  <form id="edit-dept-form" action="" method="POST">
    <div class="form-group">
      <label class="form-label" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em;">Tên phòng ban</label>
      <input type="text" name="name" id="edit-dept-name" required
        style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none;">
    </div>
    <div class="form-group">
      <label class="form-label" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em;">Phòng ban cấp trên</label>
      <select name="parentId" id="edit-dept-parent"
        style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem;">
        <option value="">— Không có (cấp cao nhất) —</option>
        <% departments.forEach(d => { %>
          <option value="<%= d.id %>"><%= d.name %></option>
        <% }) %>
      </select>
    </div>
    <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
      <button type="submit" class="btn btn-primary" style="flex: 1; background: linear-gradient(135deg, #06b6d4, #3b82f6); border: none;">Lưu thay đổi</button>
      <button type="button" class="btn btn-secondary" onclick="closeEditDeptModal()">Hủy</button>
    </div>
  </form>
</div>
<div id="modal-overlay-dept" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 999;" onclick="closeEditDeptModal()"></div>

<!-- Modal phân công Trưởng phòng -->
<div id="assign-manager-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 420px; max-width: 90%; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: rgba(16, 185, 129, 0.4);">
  <h3 style="font-size: 1.1rem; margin-bottom: 1.25rem; display: flex; justify-content: space-between; align-items: center;">
    <span><i class="fa-solid fa-user-tie" style="color: #10b981;"></i> Phân công Trưởng phòng</span>
    <button class="btn btn-secondary" onclick="closeAssignManagerModal()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
  </h3>
  <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">
    Chọn nhân sự làm Trưởng phòng cho phòng ban <strong id="assign-dept-name" style="color: #10b981;"></strong>. Mỗi phòng ban chỉ có tối đa 1 Trưởng phòng.
  </p>
  <form id="assign-manager-form" action="" method="POST">
    <div class="form-group" style="margin-bottom: 1rem;">
      <label class="form-label" style="font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); font-weight: 700; margin-bottom: 0.5rem; display: block;">
        Trưởng phòng ban
      </label>
      <select name="managerId" id="assign-manager-select"
        style="width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border-light); border-radius: 10px; color: var(--text-main); font-size: 0.9rem; outline: none;">
        <option value="">— Không có / Gỡ bỏ Trưởng phòng —</option>
        <% eligibleManagers.forEach(user => { %>
          <option value="<%= user.id %>"><%= user.username %> (<%= user.email %>)</option>
        <% }) %>
      </select>
    </div>
    <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
      <button type="submit" class="btn btn-primary" style="flex: 1; background: linear-gradient(135deg, #10b981, #059669); border: none;">Lưu phân công</button>
      <button type="button" class="btn btn-secondary" onclick="closeAssignManagerModal()">Hủy</button>
    </div>
  </form>
</div>
<div id="modal-overlay-manager" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 999;" onclick="closeAssignManagerModal()"></div>

<script>
  function openAssignManagerModal(id, name, managerId) {
    document.getElementById('assign-manager-form').action = `/departments/${id}/assign-manager`;
    document.getElementById('assign-dept-name').textContent = name;
    document.getElementById('assign-manager-select').value = managerId || '';
    document.getElementById('assign-manager-modal').style.display = 'block';
    document.getElementById('modal-overlay-manager').style.display = 'block';
  }

  function closeAssignManagerModal() {
    document.getElementById('assign-manager-modal').style.display = 'none';
    document.getElementById('modal-overlay-manager').style.display = 'none';
  }

  function toggleDeptNode(deptId) {
    const container = document.getElementById('children-' + deptId);
    const chevron = document.getElementById('chevron-' + deptId);
    const folder = document.getElementById('folder-' + deptId);
    if (!container) return;

    if (container.style.display === 'none') {
      container.style.display = 'block';
      if (chevron) chevron.style.transform = 'rotate(0deg)';
      if (folder) {
        folder.classList.remove('fa-folder');
        folder.classList.add('fa-folder-open');
      }
    } else {
      container.style.display = 'none';
      if (chevron) chevron.style.transform = 'rotate(-90deg)';
      if (folder) {
        folder.classList.remove('fa-folder-open');
        folder.classList.add('fa-folder');
      }
    }
  }

  function toggleAllDepts(expand) {
    const containers = document.querySelectorAll('.dept-children-container');
    containers.forEach(container => {
      container.style.display = expand ? 'block' : 'none';
      const deptId = container.id.replace('children-', '');
      const chevron = document.getElementById('chevron-' + deptId);
      const folder = document.getElementById('folder-' + deptId);
      if (chevron) {
        chevron.style.transform = expand ? 'rotate(0deg)' : 'rotate(-90deg)';
      }
      if (folder) {
        if (expand) {
          folder.classList.remove('fa-folder');
          folder.classList.add('fa-folder-open');
        } else {
          folder.classList.remove('fa-folder-open');
          folder.classList.add('fa-folder');
        }
      }
    });
  }

  function filterDeptTable() {
    const query = document.getElementById('dept-table-search').value.toLowerCase().trim();
    const rows = document.querySelectorAll('#dept-table-body tr:not(#no-dept-row)');
    const noDeptRow = document.getElementById('no-dept-row');
    let visibleCount = 0;

    rows.forEach(row => {
      const deptName = row.getAttribute('data-dept-name').toLowerCase();
      const parentName = row.getAttribute('data-parent-name').toLowerCase();
      if (deptName.includes(query) || parentName.includes(query)) {
        row.style.display = '';
        visibleCount++;
      } else {
        row.style.display = 'none';
      }
    });

    if (noDeptRow) {
      noDeptRow.style.display = visibleCount === 0 ? '' : 'none';
    }
  }

  function filterDeptTreeInput() {
    const query = document.getElementById('dept-tree-search').value.toLowerCase().trim();
    const allNodes = document.querySelectorAll('.dept-tree-node');
    const allContainers = document.querySelectorAll('.dept-children-container');

    if (!query) {
      // Reset to default view: show all nodes, collapse all child containers
      allNodes.forEach(node => {
        node.style.display = '';
      });
      allContainers.forEach(container => {
        container.style.display = 'none';
        const deptId = container.id.replace('children-', '');
        const chevron = document.getElementById('chevron-' + deptId);
        const folder = document.getElementById('folder-' + deptId);
        if (chevron) chevron.style.transform = 'rotate(-90deg)';
        if (folder) {
          folder.classList.remove('fa-folder-open');
          folder.classList.add('fa-folder');
        }
      });
      return;
    }

    // First, hide everything
    allNodes.forEach(node => {
      node.style.display = 'none';
    });
    allContainers.forEach(container => {
      container.style.display = 'none';
    });

    // Now, find matching nodes
    allNodes.forEach(node => {
      const clone = node.cloneNode(true);
      const actions = clone.querySelector('div[onclick]');
      if (actions) actions.remove();
      const nodeText = clone.textContent.toLowerCase();

      if (nodeText.includes(query)) {
        // Show this node
        node.style.display = '';

        // Show all descendent nodes and containers so we can see the sub-tree
        const parentDiv = node.parentElement;
        const childContainer = parentDiv.querySelector('.dept-children-container');
        if (childContainer) {
          childContainer.style.display = 'block';
          const childNodes = childContainer.querySelectorAll('.dept-tree-node');
          childNodes.forEach(cn => cn.style.display = '');
          const childContainers = childContainer.querySelectorAll('.dept-children-container');
          childContainers.forEach(cc => cc.style.display = 'block');
          // update icons
          const deptId = childContainer.id.replace('children-', '');
          const chevron = document.getElementById('chevron-' + deptId);
          const folder = document.getElementById('folder-' + deptId);
          if (chevron) chevron.style.transform = 'rotate(0deg)';
          if (folder) {
            folder.classList.remove('fa-folder');
            folder.classList.add('fa-folder-open');
          }
        }

        // Travel up and show all ancestor nodes and containers
        let ancestor = node.parentElement;
        while (ancestor && !ancestor.classList.contains('glass-card')) {
          if (ancestor.classList.contains('dept-children-container')) {
            ancestor.style.display = 'block';
            const deptId = ancestor.id.replace('children-', '');
            const chevron = document.getElementById('chevron-' + deptId);
            const folder = document.getElementById('folder-' + deptId);
            if (chevron) chevron.style.transform = 'rotate(0deg)';
            if (folder) {
              folder.classList.remove('fa-folder');
              folder.classList.add('fa-folder-open');
            }

            const parentNodeOfContainer = ancestor.previousElementSibling;
            if (parentNodeOfContainer && parentNodeOfContainer.classList.contains('dept-tree-node')) {
              parentNodeOfContainer.style.display = '';
            }
          }
          ancestor = ancestor.parentElement;
        }
      }
    });
  }

  function toggleCreateDeptDrawer(show) {
    const drawer = document.getElementById('create-dept-drawer');
    const overlay = document.getElementById('drawer-overlay');
    if (!drawer || !overlay) return;

    if (show) {
      overlay.style.display = 'block';
      setTimeout(() => {
        overlay.style.opacity = '1';
        drawer.style.right = '0';
      }, 10);
    } else {
      drawer.style.right = '-460px';
      overlay.style.opacity = '0';
      setTimeout(() => {
        overlay.style.display = 'none';
      }, 400);
    }
  }

  function openEditDeptModal(id, name, parentId) {
    document.getElementById('edit-dept-form').action = `/departments/${id}/update`;
    document.getElementById('edit-dept-name').value = name;
    document.getElementById('edit-dept-parent').value = parentId || '';
    document.getElementById('edit-dept-modal').style.display = 'block';
    document.getElementById('modal-overlay-dept').style.display = 'block';
  }

  function closeEditDeptModal() {
    document.getElementById('edit-dept-modal').style.display = 'none';
    document.getElementById('modal-overlay-dept').style.display = 'none';
  }

  // Tự ẩn thông báo sau 5 giây
  setTimeout(() => {
    ['dept-success-alert', 'dept-error-alert'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        el.style.transition = 'opacity 0.5s';
        el.style.opacity = '0';
        setTimeout(() => el.remove(), 500);
      }
    });
  }, 5000);
</script>

<%- include('../partials/footer') %>
