<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <h1 style="font-size: 2.2rem; font-weight: 800; background: var(--primary-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
    Quản Trị Thực Nghiệm Khoa Học & Thuật Toán
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">
    Tiền xử lý dữ liệu (khử định danh PII, nội suy dữ liệu khuyết) và huấn luyện mô hình CNN 1D dưới luồng nền Worker.
  </p>
</div>

<!-- Grid chính: Bảng điều khiển & Đồ thị trực quan hóa -->
<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem; margin-bottom: 2rem;">
  
  <!-- Cột 1: Bảng điều khiển siêu tham số -->
  <div>
    <h2 style="font-size: 1.4rem; margin-bottom: 1rem;"><i class="fa-solid fa-sliders" style="color: #6366f1;"></i> Thiết lập tham số</h2>
    
    <div class="glass-card" style="padding: 1.5rem;">
      <form id="experimentForm" style="display: flex; flex-direction: column; gap: 1.2rem;">
        <div class="form-group">
          <label for="name" class="form-label">Tên Thực Nghiệm</label>
          <input type="text" id="name" name="name" class="form-input" placeholder="Ví dụ: CNN_1D_BatchNorm_v1" required>
        </div>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-group">
            <label for="epochs" class="form-label">Số Epochs</label>
            <input type="number" id="epochs" name="epochs" class="form-input" value="20" min="5" max="100" required>
          </div>
          
          <div class="form-group">
            <label for="batchSize" class="form-label">Batch Size</label>
            <input type="number" id="batchSize" name="batchSize" class="form-input" value="32" min="8" max="128" required>
          </div>
        </div>

        <div class="form-group">
          <label for="learningRate" class="form-label">Tốc độ học (Learning Rate)</label>
          <input type="number" id="learningRate" name="learningRate" class="form-input" value="0.005" step="0.001" min="0.0001" max="0.1" required>
        </div>

        <button type="submit" id="btnStart" class="btn btn-primary" style="width: 100%; padding: 0.85rem; justify-content: center;">
          <i class="fa-solid fa-play"></i> Bắt đầu huấn luyện
        </button>
      </form>
    </div>

    <!-- Hộp thông tin tiến trình hiện tại -->
    <div id="progressBox" class="glass-card" style="margin-top: 1.5rem; padding: 1.5rem; display: none; border-left: 4px solid #f59e0b;">
      <h3 style="font-size: 1.1rem; margin-bottom: 0.75rem; color: #f59e0b; display: flex; align-items: center; gap: 0.5rem;">
        <i class="fa-solid fa-spinner fa-spin"></i> Đang chạy thực nghiệm...
      </h3>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; font-size: 0.9rem;">
        <div>Epoch hiện tại: <strong id="progEpoch">-</strong></div>
        <div>Độ chính xác Train: <strong id="progAcc">-</strong></div>
        <div>Loss Train: <strong id="progLoss">-</strong></div>
        <div>Độ chính xác Val: <strong id="progValAcc">-</strong></div>
      </div>
    </div>
  </div>

  <!-- Cột 2: Đồ thị huấn luyện -->
  <div style="display: flex; flex-direction: column; gap: 1.5rem;">
    <h2 style="font-size: 1.4rem; margin-bottom: 0.5rem;"><i class="fa-solid fa-chart-line" style="color: #10b981;"></i> Đồ thị tiến trình thời gian thực</h2>
    
    <div class="glass-card" style="padding: 1.5rem; min-height: 350px; display: flex; justify-content: center; align-items: center;">
      <!-- Biểu đồ Chart.js -->
      <canvas id="metricsChart" style="max-height: 340px; width: 100%;"></canvas>
    </div>
  </div>

</div>

<!-- Phân khu Console Logs và Báo cáo tệp đặc tả -->
<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-bottom: 2rem;">
  
  <!-- Console Output logs cuộn tự động -->
  <div>
    <h2 style="font-size: 1.3rem; margin-bottom: 0.85rem;"><i class="fa-solid fa-terminal" style="color: #38bdf8;"></i> Tiến trình huấn luyện (Console Logs)</h2>
    <div id="consoleLogs" class="glass-card" style="padding: 1rem; height: 180px; overflow-y: auto; font-family: monospace; font-size: 0.85rem; background: rgba(15, 23, 42, 0.9); border: 1px solid rgba(255,255,255,0.05); color: #38bdf8; line-height: 1.5;">
      <div style="color: var(--text-muted);">[System] Chờ khởi chạy thực nghiệm...</div>
    </div>
  </div>

  <!-- Thông báo Doc Sync -->
  <div>
    <h2 style="font-size: 1.3rem; margin-bottom: 0.85rem;"><i class="fa-solid fa-file-shield" style="color: #fb7185;"></i> Bảo mật & Đặc tả</h2>
    <div class="glass-card" style="padding: 1.2rem; font-size: 0.85rem; display: flex; flex-direction: column; gap: 0.8rem; height: 180px;">
      <p style="color: var(--text-muted); line-height: 1.4;">
        <i class="fa-solid fa-shield-halved" style="color: #10b981; margin-right: 0.4rem;"></i> 
        Dữ liệu đã được **Khử định danh PII hoàn toàn** bằng mã băm HMAC-SHA256 kết hợp mã muối cục bộ trước khi đưa vào luồng nền.
      </p>
      <p style="color: var(--text-muted); line-height: 1.4;">
        <i class="fa-solid fa-sync" style="color: #3b82f6; margin-right: 0.4rem;"></i> 
        Kết quả huấn luyện và siêu tham số tối ưu sẽ tự động đồng bộ hóa vào file tài liệu khoa học:
      </p>
      <a href="#" id="specLink" style="color: var(--text-accent); text-decoration: underline; font-weight: 500;">
        docs/features/01-cnn-time-series.md
      </a>
    </div>
  </div>

</div>

<!-- Phân khu Bảng lịch sử các thực nghiệm trước đó -->
<div>
  <h2 style="font-size: 1.4rem; margin-bottom: 1rem;"><i class="fa-solid fa-history" style="color: #a5b4fc;"></i> Lịch sử chạy thực nghiệm</h2>
  
  <div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
    <table class="custom-table" style="margin-top: 0; font-size: 0.9rem;">
      <thead>
        <tr>
          <th>ID</th>
          <th>Tên Thực Nghiệm</th>
          <th>Epochs</th>
          <th>Learning Rate</th>
          <th>Batch Size</th>
          <th>Độ chính xác (Val)</th>
          <th>Loss (Val)</th>
          <th>Trạng thái</th>
          <th>Thời gian chạy</th>
        </tr>
      </thead>
      <tbody id="experimentsTableBody">
        <% if (experiments.length === 0) { %>
          <tr id="noDataRow">
            <td colspan="9" style="text-align: center; color: var(--text-muted); padding: 2rem;">Chưa có thực nghiệm nào được chạy.</td>
          </tr>
        <% } %>
        <% experiments.forEach(exp => { %>
          <tr data-exp-id="<%= exp.id %>">
            <td><%= exp.id %></td>
            <td><strong><%= exp.name %></strong></td>
            <td><%= exp.epochs %></td>
            <td><%= exp.learning_rate %></td>
            <td><%= exp.batch_size %></td>
            <td class="exp-accuracy"><%= exp.accuracy ? exp.accuracy + '%' : '-' %></td>
            <td class="exp-loss"><%= exp.loss || '-' %></td>
            <td class="exp-status">
              <% if (exp.status === 'running') { %>
                <span class="status-badge status-pending" style="animation: pulse 1.5s infinite;"><i class="fa-solid fa-spinner fa-spin"></i> Đang chạy</span>
              <% } else if (exp.status === 'success') { %>
                <span class="status-badge status-approved"><i class="fa-solid fa-check"></i> Thành công</span>
              <% } else { %>
                <span class="status-badge status-rejected"><i class="fa-solid fa-xmark"></i> Thất bại</span>
              <% } %>
            </td>
            <td style="color: var(--text-muted);"><%= new Date(exp.created_at).toLocaleString('vi-VN') %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Script hỗ trợ WebSocket Socket.io và Thư viện Vẽ biểu đồ Chart.js -->
<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/experiment-client.js"></script>

<%- include('../partials/footer') %>
