<%- include('../partials/header') %>

<div style="margin-bottom: 2rem;">
  <a href="/course-management" style="font-size: 0.9rem; font-weight: 500; color: var(--text-muted);">
    <i class="fa-solid fa-chevron-left" style="font-size: 0.8rem; margin-right: 0.25rem;"></i> Quay lại danh sách khóa học
  </a>
  <h1 style="font-size: 1.55rem; font-weight: 700; color: var(--text-main); margin-top: 0.5rem;">
    Quản Lý Bài Học: <%= course.title %>
  </h1>
  <p style="color: var(--text-muted); margin-top: 0.25rem;">Thêm bài học lý thuyết, tải tài liệu đính kèm và cấu hình thứ tự học tập.</p>
</div>

<div style="display: grid; grid-template-columns: 1.2fr 2fr; gap: 2rem; align-items: start;">
  
  <!-- Cột trái: Thêm bài học mới -->
  <% if (user.permissions.includes('LESSON_CREATE')) { %>
    <div class="glass-card">
      <h3 style="font-size: 1.2rem; margin-bottom: 1.5rem;"><i class="fa-solid fa-file-circle-plus" style="color: #6366f1;"></i> Thêm bài học</h3>
      <form action="/course-management/<%= course.id %>/lessons" method="POST">
        <div class="form-group">
          <label class="form-label">Thứ tự bài học (Order Index)</label>
          <input type="number" name="order_index" value="<%= lessons.length + 1 %>" required>
        </div>

        <div class="form-group">
          <label class="form-label">Loại bài học</label>
          <select name="is_quiz" style="width: 100%; padding: 0.65rem 1rem; background: rgba(15, 23, 42, 0.5); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.9rem; outline: none;" onchange="toggleQuizFields(this.value, 'add')">
            <option value="false">Bài học lý thuyết / Video</option>
            <option value="true">Bài kiểm tra trắc nghiệm (AI tự sinh)</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label">Tiêu đề bài học</label>
          <input type="text" name="title" placeholder="Bài 1: Giới thiệu..." required>
        </div>

        <div id="add-theory-fields">
          <div class="form-group">
            <label class="form-label">Nội dung bài học lý thuyết (Dùng làm học liệu cho AI)</label>
            <textarea id="add-lesson-content" name="content" rows="6" placeholder="Nhập nội dung bài giảng chi tiết..."></textarea>
          </div>

          <div class="form-group">
            <label class="form-label">Đường dẫn Video bài giảng (URL)</label>
            <input type="text" name="video_url" value="https://www.w3schools.com/html/mov_bbb.mp4" placeholder="https://...">
          </div>

          <div class="form-group">
            <label class="form-label">Tài liệu đính kèm (URL Slide/PDF)</label>
            <input type="text" name="attachment_url" placeholder="Đường dẫn Slide hoặc file PDF đính kèm...">
          </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">
          <i class="fa-solid fa-save"></i> Lưu bài học
        </button>
      </form>
    </div>
  <% } else { %>
    <div class="glass-card" style="text-align: center; color: var(--text-muted);">
      Bạn không có quyền thêm bài giảng mới.
    </div>
  <% } %>

  <!-- Cột phải: Danh sách bài học đang có -->
  <div class="glass-card" style="padding: 1.5rem; overflow-x: auto;">
    <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem;"><i class="fa-solid fa-layer-group" style="color: #06b6d4;"></i> Cấu trúc bài giảng hiện tại</h3>
    
    <% if (lessons.length === 0) { %>
      <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center; padding: 2rem;">Khóa học chưa có bài giảng nào.</p>
    <% } else { %>
      <table class="custom-table" style="margin-top: 0; font-size: 0.85rem;">
        <thead>
          <tr>
            <th>Thứ tự</th>
            <th>Tiêu đề</th>
            <th>Xem trước nội dung</th>
            <th style="text-align: center;">Hành động</th>
          </tr>
        </thead>
        <tbody>
          <% lessons.forEach(lesson => { %>
            <tr>
              <td><strong>#<%= lesson.order_index %></strong></td>
              <td><strong><a href="/courses/<%= course.id %>/lessons/<%= lesson.id %>" target="_blank" style="color: inherit; text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'" title="Xem trải nghiệm bài học"><%= lesson.title %></a></strong></td>
              <td style="max-width: 200px;">
                <% if (lesson.is_quiz) { %>
                  <span style="color: #fbbf24; font-weight: 600;"><i class="fa-solid fa-circle-question"></i> Bài kiểm tra trắc nghiệm AI</span>
                <% } else { %>
                  <span style="color: var(--text-muted); font-size: 0.8rem; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;"><%= lesson.content %></span>
                <% } %>
              </td>
              <td>
                <div style="display: flex; justify-content: center; gap: 0.25rem;">
                  
                  <% if (user.permissions.includes('LESSON_MANAGE')) { %>
                    <!-- Nút xem trải nghiệm bài học -->
                    <a href="/courses/<%= course.id %>/lessons/<%= lesson.id %>" target="_blank" class="btn btn-secondary" style="padding: 0.3rem 0.6rem; font-size: 0.75rem; background: rgba(99, 102, 241, 0.15); border: 1px solid rgba(99, 102, 241, 0.3); color: #818cf8; display: inline-flex; align-items: center;" title="Xem trải nghiệm bài học">
                      <i class="fa-solid fa-eye"></i>
                    </a>

                    <!-- Nút mở modal chỉnh sửa bài học -->
                    <button class="btn btn-secondary" onclick="openEditLessonModal('<%= lesson.id %>', '<%= lesson.title %>', `<%= lesson.content %>`, '<%= lesson.video_url %>', '<%= lesson.attachment_url %>', '<%= lesson.order_index %>', '<%= lesson.is_quiz %>')" style="padding: 0.3rem 0.6rem; font-size: 0.75rem;">
                      <i class="fa-solid fa-pen"></i>
                    </button>

                    <!-- Form xóa bài học -->
                    <form action="/course-management/<%= course.id %>/lessons/<%= lesson.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Xóa bài học này?')">
                      <button type="submit" class="btn btn-danger" style="padding: 0.3rem 0.6rem; font-size: 0.75rem;">
                        <i class="fa-solid fa-trash-can"></i>
                      </button>
                    </form>
                  <% } %>

                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<!-- Modal Sửa Bài Học Mờ Kính -->
<div id="edit-lesson-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 550px; max-width: 95%; max-height: 90vh; overflow-y: auto; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
  <h3 style="font-size: 1.3rem; margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
    <span><i class="fa-solid fa-file-pen" style="color: #8b5cf6;"></i> Sửa Thông Tin Bài Học</span>
    <button class="btn btn-secondary" onclick="closeEditLessonModal()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
  </h3>
  <form id="edit-lesson-form" action="" method="POST">
    <div class="form-group">
      <label class="form-label">Thứ tự bài học (Order Index)</label>
      <input type="number" id="edit-lesson-order" name="order_index" required>
    </div>

    <div class="form-group">
      <label class="form-label">Tiêu đề bài học</label>
      <input type="text" id="edit-lesson-title" name="title" required>
    </div>

    <div class="form-group">
      <label class="form-label">Loại bài học</label>
      <select id="edit-lesson-is-quiz" name="is_quiz" style="width: 100%; padding: 0.65rem 1rem; background: rgba(15, 23, 42, 0.5); border: 1px solid var(--border-light); border-radius: 8px; color: var(--text-main); font-size: 0.9rem; outline: none;" onchange="toggleQuizFields(this.value, 'edit')">
        <option value="false">Bài học lý thuyết / Video</option>
        <option value="true">Bài kiểm tra trắc nghiệm (AI tự sinh)</option>
      </select>
    </div>

    <div id="edit-theory-fields">
      <div class="form-group">
        <label class="form-label">Nội dung bài học lý thuyết</label>
        <textarea id="edit-lesson-content" name="content" rows="8"></textarea>
      </div>

      <div class="form-group">
        <label class="form-label">Đường dẫn Video bài giảng (URL)</label>
        <input type="text" id="edit-lesson-video" name="video_url">
      </div>

      <div class="form-group">
        <label class="form-label">Tài liệu đính kèm (URL Slide/PDF)</label>
        <input type="text" id="edit-lesson-attachment" name="attachment_url">
      </div>
    </div>

    <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
      <button type="submit" class="btn btn-primary">Cập nhật bài học</button>
      <button type="button" class="btn btn-secondary" onclick="closeEditLessonModal()">Hủy</button>
    </div>
  </form>
</div>
<!-- Lớp phủ modal -->
<div id="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 999;" onclick="closeEditLessonModal()"></div>

<script>
  function toggleQuizFields(isQuizValue, prefix) {
    const displayStyle = (isQuizValue === 'true' || isQuizValue === true) ? 'none' : 'block';
    const theoryWrapper = document.getElementById(prefix + '-theory-fields');
    if (theoryWrapper) {
      theoryWrapper.style.display = displayStyle;
    }
  }

  // Khởi tạo trạng thái ban đầu của form thêm
  document.addEventListener('DOMContentLoaded', () => {
    toggleQuizFields('false', 'add');
  });

  function openEditLessonModal(id, title, content, video, attachment, order, isQuiz) {
    document.getElementById('edit-lesson-form').action = `/course-management/<%= course.id %>/lessons/${id}/update`;
    document.getElementById('edit-lesson-title').value = title;
    document.getElementById('edit-lesson-content').value = content;
    document.getElementById('edit-lesson-video').value = video;
    document.getElementById('edit-lesson-attachment').value = attachment;
    document.getElementById('edit-lesson-order').value = order;
    
    const isQuizVal = isQuiz === 'true' || isQuiz === true;
    document.getElementById('edit-lesson-is-quiz').value = isQuizVal ? 'true' : 'false';
    toggleQuizFields(isQuizVal, 'edit');
    
    document.getElementById('edit-lesson-modal').style.display = 'block';
    document.getElementById('modal-overlay').style.display = 'block';
  }

  function closeEditLessonModal() {
    document.getElementById('edit-lesson-modal').style.display = 'none';
    document.getElementById('modal-overlay').style.display = 'none';
  }
</script>

<%- include('../partials/footer') %>
