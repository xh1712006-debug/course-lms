<%- include('../partials/header') %>

<style>
  /* Ẩn hoàn toàn sidebar ở trang Bài Học (Lessons) để tối đa hóa không gian */
  .sidebar { display: none !important; }
  .main-content { margin-left: 0 !important; max-width: 100% !important; width: 100% !important; }
  
  /* Nút quay lại (Back) hiện đại */
  .btn-back-modern {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: #ffffff;
    border: 1px solid var(--border-light);
    border-radius: 12px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 1.15rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }
  .btn-back-modern:hover {
    background: #f8fafc;
    border-color: #cbd5e1;
    color: #4f46e5;
    transform: translateX(-4px);
    box-shadow: 0 4px 12px rgba(79, 70, 229, 0.12);
  }
</style>

<div style="max-width: 1000px; margin: 0 auto;">
  <div style="margin-bottom: 2.5rem; display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
    
    <div style="display: flex; gap: 1.25rem; align-items: flex-start; flex: 1; min-width: 250px;">
      <!-- Nút Quay Lại Nổi Bật -->
      <a href="/course-management" class="btn-back-modern" title="Quay lại danh sách khóa học">
        <i class="fa-solid fa-arrow-left"></i>
      </a>

      <div>
        <!-- Breadcrumb -->
        <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; font-weight: 500; color: var(--text-muted); margin-bottom: 0.75rem;">
          <a href="/course-management" style="color: inherit; text-decoration: none; transition: color 0.2s;" onmouseover="this.style.color='#4f46e5'" onmouseout="this.style.color='inherit'">
            Quản lý khóa học
          </a>
          <i class="fa-solid fa-angle-right" style="font-size: 0.7rem;"></i>
          <span style="color: var(--text-main); font-weight: 600;"><%= course.title %></span>
          <i class="fa-solid fa-angle-right" style="font-size: 0.7rem;"></i>
          <span>Bài học</span>
        </div>

        <!-- Course Header -->
        <div style="display: flex; align-items: center; gap: 1rem; width: 100%;">
          <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(79, 70, 229, 0.15)); color: #4f46e5; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; flex-shrink: 0; box-shadow: 0 4px 10px rgba(79, 70, 229, 0.1);">
            <i class="fa-solid fa-book-open"></i>
          </div>
          <div style="flex: 1; min-width: 0;">
            <h1 style="font-size: 1.65rem; font-weight: 800; color: var(--text-main); margin: 0; line-height: 1.2; letter-spacing: -0.02em;">
              <%= course.title %>
            </h1>
            <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0.3rem 0 0 0; line-height: 1.4;">
              Quản lý giáo trình, tải lên bài giảng video/tài liệu lý thuyết, và lập ngân hàng câu hỏi.
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <% if (user.permissions.includes('LESSON_CREATE')) { %>
      <div style="display: flex; align-items: center; margin-top: 1.5rem;">
        <button type="button" class="btn btn-primary" onclick="openAddChapterModal()" style="padding: 0.75rem 1.5rem; font-weight: 600; border-radius: 10px; flex-shrink: 0; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25);">
          <i class="fa-solid fa-folder-plus" style="margin-right: 0.35rem;"></i> Thêm chương mới
        </button>
      </div>
    <% } %>
  </div>

  <!-- Curriculum Outline List (Chapters and Lessons) -->
  <div class="glass-card fade-in" style="animation-delay: 0.2s; padding: 2rem;">
    <h3 class="glass-card-title" style="margin-bottom: 2rem;"><i class="fa-solid fa-layer-group" style="color: #06b6d4;"></i> Cấu trúc chương trình</h3>

    <% if (!chapters || chapters.length === 0) { %>
      <div class="empty-state-card">
        <div class="empty-state-icon">
          <i class="fa-solid fa-folder-open"></i>
        </div>
        <h4 class="empty-state-title">Chương trình chưa được xây dựng</h4>
        <p class="empty-state-desc">Khóa học này hiện chưa có chương nào. Bạn hãy bấm nút "+ Thêm chương mới" ở góc trên để bắt đầu.</p>
      </div>
    <% } else { %>
      <div class="curriculum-chapters">
        <% chapters.forEach((chapter, chIndex) => { %>
          <div class="chapter-block" style="border: 1px solid var(--border-light); border-radius: 10px; margin-bottom: 1rem; overflow: hidden; background: #fff; box-shadow: 0 2px 6px rgba(0,0,0,0.02); transition: all 0.2s;">
            
            <!-- Chapter Header -->
            <div class="chapter-header" onclick="toggleChapterLessons('<%= chapter.id %>')" style="background: #fcfcfd; padding: 0.85rem 1.25rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-light); cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='#fcfcfd'">
              <div style="display: flex; align-items: center; gap: 1rem;">
                <i id="chevron-<%= chapter.id %>" class="fa-solid fa-chevron-down" style="transition: transform 0.3s; color: #94a3b8; font-size: 0.9rem;"></i>
                <div style="width: 28px; height: 28px; background: rgba(99, 102, 241, 0.1); color: #4f46e5; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem;">
                  <%= chIndex + 1 %>
                </div>
                <div>
                  <h4 style="margin: 0; font-size: 1.15rem; font-weight: 700; color: var(--text-main);"><%= chapter.title %></h4>
                  <% if (chapter.description) { %>
                    <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--text-muted);"><%= chapter.description %></p>
                  <% } %>
                </div>
              </div>
              
              <div style="display: flex; gap: 0.5rem;" onclick="event.stopPropagation()">
                <% if (user.permissions.includes('LESSON_CREATE')) { %>
                  <button type="button" class="btn btn-outline" onclick="openAddLessonModal('<%= chapter.id %>')" style="padding: 0.4rem 0.8rem; font-size: 0.85rem; display: flex; align-items: center; gap: 0.3rem; border: 1px solid #4f46e5; color: #4f46e5; background: #fff; border-radius: 6px; cursor: pointer;">
                    <i class="fa-solid fa-plus"></i> Thêm bài học
                  </button>
                <% } %>
                <% if (user.permissions.includes('LESSON_MANAGE')) { %>
                  <button type="button" class="btn btn-icon" onclick="openEditChapterModal('<%= chapter.id %>', '<%= chapter.title %>', '<%= chapter.description %>', '<%= chapter.order_index %>')" title="Sửa chương" style="background: none; border: none; color: #64748b; cursor: pointer; padding: 0.5rem;">
                    <i class="fa-solid fa-pen"></i>
                  </button>
                  <form action="/course-management/<%= course.id %>/chapters/<%= chapter.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Bạn có chắc muốn xóa chương này và toàn bộ bài học bên trong không?')">
                    <button type="submit" class="btn btn-icon text-danger" title="Xóa chương" style="background: none; border: none; color: #ef4444; cursor: pointer; padding: 0.5rem;">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </div>

            <!-- Chapter Lessons List -->
            <div id="lessons-<%= chapter.id %>" class="chapter-lessons" style="padding: 0.5rem 1.25rem; display: none;">
              <% if (!chapter.lessons || chapter.lessons.length === 0) { %>
                <div style="text-align: center; padding: 1.5rem; color: #94a3b8; font-size: 0.9rem; font-style: italic;">
                  Chưa có nội dung bài học trong chương này.
                </div>
              <% } else { %>
                <div class="syllabus-list" style="gap: 0.5rem; padding: 0.5rem 0;">
                  <% chapter.lessons.forEach(lesson => { %>
                    <div class="syllabus-item" style="margin-bottom: 0; padding: 0.75rem; border-radius: 8px; border: 1px solid transparent; transition: all 0.2s;" onmouseover="this.style.background='#f8fafc'; this.style.borderColor='var(--border-light)';" onmouseout="this.style.background='transparent'; this.style.borderColor='transparent';">
                      <div class="syllabus-item-main">
                        <div class="syllabus-item-index"><%= lesson.order_index %></div>
                        
                        <div style="width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0;
                          <% if (lesson.is_quiz) { %>
                            background: rgba(139, 92, 246, 0.08); color: #8b5cf6;
                          <% } else if (lesson.video_url) { %>
                            background: rgba(6, 182, 212, 0.08); color: #06b6d4;
                          <% } else { %>
                            background: rgba(59, 130, 246, 0.08); color: #3b82f6;
                          <% } %>
                        ">
                          <% if (lesson.is_quiz) { %>
                            <i class="fa-solid fa-clipboard-question" title="Bài kiểm tra trắc nghiệm"></i>
                          <% } else if (lesson.video_url) { %>
                            <i class="fa-solid fa-circle-play" title="Bài giảng Video"></i>
                          <% } else { %>
                            <i class="fa-solid fa-file-invoice" title="Bài giảng Lý thuyết"></i>
                          <% } %>
                        </div>

                        <div class="syllabus-item-content">
                          <div style="display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;">
                            <h4 class="syllabus-item-title">
                              <a href="/courses/<%= course.id %>/lessons/<%= lesson.id %>" target="_blank"
                                style="color: inherit; text-decoration: none;"
                                onmouseover="this.style.color='var(--text-accent)'"
                                onmouseout="this.style.color='inherit'">
                                <%= lesson.title || 'Bài học chưa đặt tiêu đề' %>
                              </a>
                            </h4>
                            
                            <% if (lesson.is_quiz) { %>
                              <span class="chip-badge purple" style="font-size: 0.68rem; padding: 0.05rem 0.35rem;">Trắc nghiệm</span>
                            <% } else { %>
                              <span class="chip-badge blue" style="font-size: 0.68rem; padding: 0.05rem 0.35rem;">Lý thuyết</span>
                              <% if (lesson.video_url) { %>
                                <span class="chip-badge green" style="font-size: 0.68rem; padding: 0.05rem 0.35rem;">Video</span>
                              <% } %>
                              <% if (lesson.attachment_url) { %>
                                <span class="chip-badge amber" style="font-size: 0.68rem; padding: 0.05rem 0.35rem;"><i class="fa-solid fa-paperclip"></i> Tài liệu</span>
                              <% } %>
                            <% } %>
                          </div>
                        </div>
                      </div>

                      <div class="syllabus-item-actions">
                        <% if (user.permissions.includes('LESSON_MANAGE')) { %>
                          <button type="button" class="syllabus-action-btn edit"
                                  onclick="openEditLessonModal('<%= chapter.id %>', '<%= lesson.id %>', '<%= lesson.title %>', `<%= lesson.content %>`, '<%= lesson.video_url %>', '<%= lesson.attachment_url %>', '<%= lesson.order_index %>', '<%= lesson.is_quiz %>')"
                                  title="Chỉnh sửa">
                            <i class="fa-solid fa-pen"></i>
                          </button>
                          <form action="/course-management/<%= course.id %>/lessons/<%= lesson.id %>/delete"
                                method="POST" style="display: inline;" onsubmit="return confirm('Xóa bài học?')">
                            <button type="submit" class="syllabus-action-btn delete" title="Xóa bài học">
                              <i class="fa-solid fa-trash-can"></i>
                            </button>
                          </form>
                        <% } %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

  <!-- Modal Thêm Bài Học Mờ Kính -->
  <div id="add-lesson-modal" class="glass-card"
    style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 620px; max-width: 95%; max-height: 90vh; overflow-y: auto; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
    <h3
      style="font-size: 1.25rem; margin-bottom: 1.5rem; font-weight: 700; display: flex; justify-content: space-between; align-items: center; color: var(--text-main);">
      <span><i class="fa-solid fa-file-circle-plus" style="color: #6366f1;"></i> Thêm bài học mới</span>
      <button type="button" class="btn btn-secondary" onclick="closeAddLessonModal()"
        style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
    </h3>
    
    <!-- Tab Controls -->
    <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); padding-bottom: 0.5rem;">
      <button type="button" id="tab-lesson-single" onclick="switchLessonMode('single')" style="background: none; border: none; font-weight: 600; color: #4f46e5; border-bottom: 2px solid #4f46e5; padding-bottom: 0.5rem; cursor: pointer;">Thêm 1 bài học</button>
      <button type="button" id="tab-lesson-bulk" onclick="switchLessonMode('bulk')" style="background: none; border: none; font-weight: 600; color: var(--text-muted); padding-bottom: 0.5rem; cursor: pointer;">Thêm nhiều (Hàng loạt)</button>
    </div>

    <!-- Single Mode -->
    <form id="form-lesson-single" action="/course-management/<%= course.id %>/lessons" method="POST">
      <input type="hidden" name="chapter_id" id="add-lesson-chapter-id">
      <div class="form-group">
        <label class="form-label">Thứ tự bài học (Order Index)</label>
        <input type="number" name="order_index" value="1" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
      </div>

      <div class="form-group">
        <label class="form-label">Loại bài học</label>
        <select name="lesson_type" onchange="toggleQuizFields(this.value, 'add')" class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
          <option value="theory">🎥/📄 Bài học Video hoặc Văn bản</option>
          <option value="quiz">📝 Bài kiểm tra trắc nghiệm</option>
        </select>
      </div>

      <div class="form-group">
        <label class="form-label">Tiêu đề bài học</label>
        <input type="text" name="title" placeholder="Bài 1: Giới thiệu chung..." required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
      </div>

      <div id="add-theory-fields">
        <input type="hidden" name="content" value="">

        <div class="form-group">
          <label class="form-label">Tệp Video bài giảng (.mp4, .webm)</label>
          <div class="compact-upload-zone" id="add-lesson-video-zone" onclick="triggerFileUpload('add-lesson-video', 'video')">
            <div class="compact-upload-info">
              <i class="fa-solid fa-film compact-upload-icon" style="color: #06b6d4;"></i>
              <span class="compact-upload-text" id="add-lesson-video-text">Kéo thả tệp video (.mp4) hoặc click để chọn</span>
            </div>
            <button type="button" class="compact-upload-btn">Tải lên</button>
            <input type="hidden" id="add-lesson-video" name="video_url">
          </div>
          <small id="add-lesson-video-status" style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-top: 0.25rem;"></small>
        </div>

        <div class="form-group">
          <label class="form-label">Tài liệu học tập đính kèm (Slide, PDF...)</label>
          <div class="compact-upload-zone" id="add-lesson-attachment-zone" onclick="triggerFileUpload('add-lesson-attachment', 'attachment')">
            <div class="compact-upload-info">
              <i class="fa-solid fa-file-pdf compact-upload-icon" style="color: #ef4444;"></i>
              <span class="compact-upload-text" id="add-lesson-attachment-text">Kéo & thả tài liệu (.pdf, .zip...) hoặc click để chọn</span>
            </div>
            <button type="button" class="compact-upload-btn">Tải lên</button>
            <input type="hidden" id="add-lesson-attachment" name="attachment_url">
          </div>
          <small id="add-lesson-attachment-status" style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-top: 0.25rem;"></small>
        </div>
      </div>

      <!-- Quiz Mode Fields -->
      <div id="add-quiz-fields" style="display: none; border-top: 1px dashed var(--border-light); margin-top: 1.5rem; padding-top: 1.5rem;">
        <div class="form-group">
          <label class="form-label">Số lượng câu hỏi trắc nghiệm</label>
          <div style="display: flex; gap: 1rem;">
            <input type="number" id="add-quiz-count" min="1" max="50" value="5" class="form-control" style="width: 150px; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            <button type="button" class="btn btn-outline" onclick="generateQuizQuestionTabs()" style="padding: 0.5rem 1.25rem; border-radius: 8px;">Tạo bộ câu hỏi</button>
          </div>
        </div>

        <div id="add-quiz-tabs-container" style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; overflow-x: auto; padding-bottom: 0.5rem;"></div>
        <div id="add-quiz-pages-container"></div>
      </div>

      <div style="position: sticky; bottom: -1.25rem; background: #fff; z-index: 100; border-top: 1px solid var(--border-light); padding: 1.25rem 0; margin-top: 1.5rem; margin-bottom: -1.25rem; display: flex; gap: 1rem; border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
        <button type="submit" class="btn btn-primary" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Lưu bài học</button>
        <button type="button" class="btn btn-secondary" onclick="closeAddLessonModal()" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Hủy</button>
      </div>
    </form>

    <!-- Bulk Mode -->
    <div id="form-lesson-bulk" style="display: none;">
      <!-- Wizard Setup Step -->
      <div id="bulk-wizard-setup">
        <div class="form-group">
          <label class="form-label">Số lượng bài học muốn tạo</label>
          <div style="display: flex; gap: 1rem;">
            <input type="number" id="bulk-lesson-count" min="1" max="50" value="3" class="form-control" style="width: 150px; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            <button type="button" class="btn btn-primary" onclick="generateBulkLessonTabs()" style="padding: 0.5rem 1.25rem; border-radius: 8px;">Tạo khung phân trang</button>
          </div>
        </div>
      </div>

      <!-- Wizard Form Area (Hidden by default) -->
      <form id="bulk-wizard-form" action="/course-management/<%= course.id %>/lessons/bulk" method="POST" style="display: none; margin-top: 1.5rem; border-top: 1px solid var(--border-light); padding-top: 1.5rem;">
        <input type="hidden" name="chapter_id" id="add-lesson-chapter-id-bulk">
        <input type="hidden" name="start_order_index" value="1">
        
        <!-- Tab Bar -->
        <div id="bulk-tabs-container" style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; overflow-x: auto; padding-bottom: 0.5rem;">
        </div>

        <!-- Pages Container -->
        <div id="bulk-pages-container">
        </div>

        <div style="position: sticky; bottom: -1.25rem; background: #fff; z-index: 100; border-top: 1px solid var(--border-light); padding: 1.25rem 0; margin-top: 1.5rem; margin-bottom: -1.25rem; display: flex; gap: 1rem; border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">
          <button type="submit" class="btn btn-primary" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Lưu toàn bộ bài học</button>
          <button type="button" class="btn btn-secondary" onclick="closeAddLessonModal()" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Hủy</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Sửa Bài Học Mờ Kính -->
  <div id="edit-lesson-modal" class="glass-card"
    style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 620px; max-width: 95%; max-height: 90vh; overflow-y: auto; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
    <h3
      style="font-size: 1.25rem; margin-bottom: 1.5rem; font-weight: 700; display: flex; justify-content: space-between; align-items: center; color: var(--text-main);">
      <span><i class="fa-solid fa-file-pen" style="color: #8b5cf6;"></i> Chỉnh sửa thông tin bài học</span>
      <button type="button" class="btn btn-secondary" onclick="closeEditLessonModal()"
        style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
    </h3>
    
    <form id="edit-lesson-form" action="" method="POST">
      <input type="hidden" id="edit-lesson-chapter-id" name="chapter_id">
      <div class="form-group">
        <label class="form-label">Thứ tự bài học (Order Index)</label>
        <input type="number" id="edit-lesson-order" name="order_index" required>
      </div>

      <div class="form-group">
        <label class="form-label">Tiêu đề bài học</label>
        <input type="text" id="edit-lesson-title" name="title" required>
      </div>

      <div class="form-group">
        <label class="form-label">Loại bài học</label>
        <select id="edit-lesson-type" name="lesson_type" onchange="toggleQuizFields(this.value, 'edit')">
          <option value="theory">🎥/📄 Bài học Video hoặc Văn bản</option>
          <option value="quiz">📝 Bài kiểm tra trắc nghiệm</option>
        </select>
      </div>

      <div id="edit-theory-fields">
        <input type="hidden" id="edit-lesson-content" name="content">

        <div class="form-group">
          <label class="form-label">Tệp Video bài giảng (.mp4, .webm)</label>
          <div class="compact-upload-zone" id="edit-lesson-video-zone" onclick="triggerFileUpload('edit-lesson-video', 'video')">
            <div class="compact-upload-info">
              <i class="fa-solid fa-film compact-upload-icon" style="color: #06b6d4;"></i>
              <span class="compact-upload-text" id="edit-lesson-video-text">Kéo thả tệp video (.mp4) hoặc click để thay đổi</span>
            </div>
            <button type="button" class="compact-upload-btn">Thay đổi</button>
            <input type="hidden" id="edit-lesson-video" name="video_url">
          </div>
          <small id="edit-lesson-video-status" style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-top: 0.25rem;"></small>
        </div>

        <div class="form-group">
          <label class="form-label">Tài liệu học tập đính kèm (Slide, PDF...)</label>
          <div class="compact-upload-zone" id="edit-lesson-attachment-zone" onclick="triggerFileUpload('edit-lesson-attachment', 'attachment')">
            <div class="compact-upload-info">
              <i class="fa-solid fa-file-pdf compact-upload-icon" style="color: #ef4444;"></i>
              <span class="compact-upload-text" id="edit-lesson-attachment-text">Kéo thả tài liệu (.pdf, .zip) hoặc click để thay đổi</span>
            </div>
            <button type="button" class="compact-upload-btn">Thay đổi</button>
            <input type="hidden" id="edit-lesson-attachment" name="attachment_url">
          </div>
          <small id="edit-lesson-attachment-status" style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-top: 0.25rem;"></small>
        </div>
      </div>

      <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
        <button type="submit" class="btn btn-primary" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Cập nhật bài học</button>
        <button type="button" class="btn btn-secondary" onclick="closeEditLessonModal()" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Hủy</button>
      </div>
    </form>
  </div>

  <!-- Modal Thêm Chương -->
  <div id="add-chapter-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 500px; max-width: 95%; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
    <h3 style="font-size: 1.25rem; margin-bottom: 1.5rem; font-weight: 700; display: flex; justify-content: space-between; align-items: center; color: var(--text-main);">
      <span><i class="fa-solid fa-folder-plus" style="color: #6366f1;"></i> Thêm chương mới</span>
      <button type="button" class="btn btn-secondary" onclick="closeAddChapterModal()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
    </h3>
    <!-- Tab Controls -->
    <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); padding-bottom: 0.5rem;">
      <button type="button" id="tab-chapter-single" onclick="switchChapterMode('single')" style="background: none; border: none; font-weight: 600; color: #4f46e5; border-bottom: 2px solid #4f46e5; padding-bottom: 0.5rem; cursor: pointer;">Thêm 1 chương</button>
      <button type="button" id="tab-chapter-bulk" onclick="switchChapterMode('bulk')" style="background: none; border: none; font-weight: 600; color: var(--text-muted); padding-bottom: 0.5rem; cursor: pointer;">Thêm nhiều (Hàng loạt)</button>
    </div>

    <!-- Single Mode -->
    <form id="form-chapter-single" action="/course-management/<%= course.id %>/chapters" method="POST">
      <div class="form-group">
        <label class="form-label">Tên chương</label>
        <input type="text" name="title" placeholder="VD: Chương 1: Kiến thức nền tảng..." required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
      </div>
      <div class="form-group">
        <label class="form-label">Mô tả (Tùy chọn)</label>
        <textarea name="description" rows="2" placeholder="Nhập mô tả cho chương này..." class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;"></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Thứ tự</label>
        <input type="number" name="order_index" value="<%= chapters ? chapters.length + 1 : 1 %>" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
      </div>
      <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
        <button type="submit" class="btn btn-primary" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Tạo chương</button>
      </div>
    </form>

    <!-- Bulk Mode -->
    <form id="form-chapter-bulk" action="/course-management/<%= course.id %>/chapters/bulk" method="POST" style="display: none;">
      <div class="form-group">
        <label class="form-label">Danh sách tên chương (Mỗi dòng 1 chương)</label>
        <textarea name="bulk_titles" rows="5" placeholder="Chương 1: Kiến thức nền tảng&#10;Chương 2: Cài đặt công cụ&#10;Chương 3: Thực hành dự án" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.75rem;"></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Bắt đầu từ thứ tự</label>
        <input type="number" name="start_order_index" value="<%= chapters ? chapters.length + 1 : 1 %>" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
      </div>
      <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
        <button type="submit" class="btn btn-primary" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Tạo hàng loạt</button>
      </div>
    </form>
  </div>

  <!-- Modal Sửa Chương -->
  <div id="edit-chapter-modal" class="glass-card" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 500px; max-width: 95%; z-index: 1000; box-shadow: 0 10px 50px rgba(0,0,0,0.8); border-color: var(--border-glow);">
    <h3 style="font-size: 1.25rem; margin-bottom: 1.5rem; font-weight: 700; display: flex; justify-content: space-between; align-items: center; color: var(--text-main);">
      <span><i class="fa-solid fa-folder-open" style="color: #6366f1;"></i> Sửa chương</span>
      <button type="button" class="btn btn-secondary" onclick="closeEditChapterModal()" style="padding: 0.25rem 0.5rem; font-size: 0.85rem;"><i class="fa-solid fa-xmark"></i></button>
    </h3>
    <form id="edit-chapter-form" action="" method="POST">
      <div class="form-group">
        <label class="form-label">Tên chương</label>
        <input type="text" id="edit-chapter-title" name="title" required>
      </div>
      <div class="form-group">
        <label class="form-label">Mô tả (Tùy chọn)</label>
        <textarea id="edit-chapter-desc" name="description" rows="2"></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Thứ tự</label>
        <input type="number" id="edit-chapter-order" name="order_index" required>
      </div>
      <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
        <button type="submit" class="btn btn-primary" style="padding: 0.65rem 1.25rem; border-radius: 8px;">Lưu thay đổi</button>
      </div>
    </form>
  </div>

  <!-- Lớp phủ modal -->
  <div id="modal-overlay"
    style="display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 999;"
    onclick="closeAllModals()"></div>

  <script>
    function toggleChapterLessons(chapterId) {
      const lessonsDiv = document.getElementById('lessons-' + chapterId);
      const chevronIcon = document.getElementById('chevron-' + chapterId);
      
      if (lessonsDiv.style.display === 'none') {
        lessonsDiv.style.display = 'block';
        chevronIcon.style.transform = 'rotate(-180deg)';
      } else {
        lessonsDiv.style.display = 'none';
        chevronIcon.style.transform = 'rotate(0deg)';
      }
    }

    function toggleQuizFields(isQuizValue, prefix) {
      const isQuiz = (isQuizValue === 'quiz' || isQuizValue === 'true' || isQuizValue === true);
      
      const theoryWrapper = document.getElementById(prefix + '-theory-fields');
      if (theoryWrapper) {
        theoryWrapper.style.display = isQuiz ? 'none' : 'block';
      }
      
      const quizWrapper = document.getElementById(prefix + '-quiz-fields');
      if (quizWrapper) {
        quizWrapper.style.display = isQuiz ? 'block' : 'none';
      }
    }

    function generateQuizQuestionTabs() {
      const count = parseInt(document.getElementById('add-quiz-count').value);
      if (isNaN(count) || count < 1 || count > 50) {
        alert("Vui lòng nhập số lượng câu hỏi từ 1 đến 50");
        return;
      }
      
      const tabsContainer = document.getElementById('add-quiz-tabs-container');
      const pagesContainer = document.getElementById('add-quiz-pages-container');
      
      tabsContainer.innerHTML = '';
      pagesContainer.innerHTML = '';
      
      for (let i = 1; i <= count; i++) {
        // Tạo Tab
        const tab = document.createElement('button');
        tab.type = 'button';
        tab.className = `btn ${i === 1 ? 'btn-primary' : 'btn-outline'}`;
        tab.style.padding = '0.3rem 0.8rem';
        tab.style.borderRadius = '20px';
        tab.style.whiteSpace = 'nowrap';
        if (i !== 1) {
          tab.style.border = '1px solid #cbd5e1';
          tab.style.color = '#64748b';
        }
        tab.innerText = `Câu ${i}`;
        tab.onclick = () => switchQuizTab(i, count);
        tab.id = `add-quiz-tab-${i}`;
        tabsContainer.appendChild(tab);
        
        // Tạo Page
        const page = document.createElement('div');
        page.id = `add-quiz-page-${i}`;
        page.style.display = i === 1 ? 'block' : 'none';
        page.className = 'glass-card';
        page.style.padding = '1.25rem';
        
        page.innerHTML = `
          <h5 style="margin-top: 0; margin-bottom: 1rem; color: var(--text-main);">Nội dung Câu ${i}</h5>
          <div class="form-group">
            <label class="form-label">Câu hỏi</label>
            <textarea name="q_text[]" required rows="2" class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;"></textarea>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
              <label class="form-label">Đáp án A</label>
              <input type="text" name="q_optA[]" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            </div>
            <div class="form-group">
              <label class="form-label">Đáp án B</label>
              <input type="text" name="q_optB[]" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            </div>
            <div class="form-group">
              <label class="form-label">Đáp án C</label>
              <input type="text" name="q_optC[]" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            </div>
            <div class="form-group">
              <label class="form-label">Đáp án D</label>
              <input type="text" name="q_optD[]" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            </div>
          </div>
          <div class="form-group" style="margin-top: 1rem;">
            <label class="form-label">Đáp án đúng</label>
            <select name="q_correct[]" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem; background: #ecfdf5; color: #059669; font-weight: 600;">
              <option value="A">Đáp án A</option>
              <option value="B">Đáp án B</option>
              <option value="C">Đáp án C</option>
              <option value="D">Đáp án D</option>
            </select>
          </div>
        `;
        pagesContainer.appendChild(page);
      }
    }

    function switchQuizTab(activeIndex, total) {
      for (let i = 1; i <= total; i++) {
        const tab = document.getElementById(`add-quiz-tab-${i}`);
        const page = document.getElementById(`add-quiz-page-${i}`);
        if (i === activeIndex) {
          tab.className = 'btn btn-primary';
          tab.style.border = 'none';
          tab.style.color = '#fff';
          page.style.display = 'block';
        } else {
          tab.className = 'btn btn-outline';
          tab.style.border = '1px solid #cbd5e1';
          tab.style.color = '#64748b';
          page.style.display = 'none';
        }
      }
    }

    // Logic sinh Tab động cho Bulk Lesson
    function generateBulkLessonTabs() {
      const count = parseInt(document.getElementById('bulk-lesson-count').value);
      if (isNaN(count) || count < 1 || count > 50) {
        alert("Vui lòng nhập số lượng từ 1 đến 50");
        return;
      }
      
      const tabsContainer = document.getElementById('bulk-tabs-container');
      const pagesContainer = document.getElementById('bulk-pages-container');
      
      tabsContainer.innerHTML = '';
      pagesContainer.innerHTML = '';
      
      for (let i = 1; i <= count; i++) {
        // Tạo Tab
        const tab = document.createElement('button');
        tab.type = 'button';
        tab.className = `btn ${i === 1 ? 'btn-primary' : 'btn-outline'}`;
        tab.style.padding = '0.4rem 1rem';
        tab.style.borderRadius = '20px';
        tab.style.whiteSpace = 'nowrap';
        if (i !== 1) {
          tab.style.border = '1px solid #cbd5e1';
          tab.style.color = '#64748b';
        }
        tab.innerText = `Bài ${i}`;
        tab.onclick = () => switchBulkTab(i, count);
        tab.id = `bulk-tab-${i}`;
        tabsContainer.appendChild(tab);
        
        // Tạo Nội dung (Page)
        const page = document.createElement('div');
        page.id = `bulk-page-${i}`;
        page.style.display = i === 1 ? 'block' : 'none';
        
        page.innerHTML = `
          <h4 style="margin-bottom: 1rem; color: var(--text-main);">Nội dung Bài ${i}</h4>
          <div class="form-group">
            <label class="form-label">Loại bài học</label>
            <select name="types[]" onchange="toggleBulkQuizFields(this.value, ${i})" class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
              <option value="theory">🎥/📄 Bài học Video hoặc Văn bản</option>
              <option value="quiz">📝 Bài kiểm tra trắc nghiệm</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Tiêu đề bài học</label>
            <input type="text" name="titles[]" placeholder="Nhập tiêu đề cho bài ${i}..." required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
          </div>

          <div id="bulk-theory-fields-${i}">
            <div class="form-group">
              <label class="form-label">Tệp Video (.mp4)</label>
              <div class="compact-upload-zone" id="bulk-video-zone-${i}" onclick="triggerFileUpload('bulk-video-${i}', 'video')">
                <div class="compact-upload-info">
                  <i class="fa-solid fa-film compact-upload-icon" style="color: #06b6d4;"></i>
                  <span class="compact-upload-text" id="bulk-video-${i}-text">Kéo thả tệp video hoặc click để chọn</span>
                </div>
                <input type="hidden" id="bulk-video-${i}" name="video_urls[]">
              </div>
              <small id="bulk-video-${i}-status" style="display: block; margin-top: 0.25rem; font-size: 0.75rem;"></small>
            </div>

            <div class="form-group">
              <label class="form-label">Tài liệu đính kèm (.pdf)</label>
              <div class="compact-upload-zone" id="bulk-attachment-zone-${i}" onclick="triggerFileUpload('bulk-attachment-${i}', 'attachment')">
                <div class="compact-upload-info">
                  <i class="fa-solid fa-file-pdf compact-upload-icon" style="color: #ef4444;"></i>
                  <span class="compact-upload-text" id="bulk-attachment-${i}-text">Kéo thả tài liệu hoặc click để chọn</span>
                </div>
                <input type="hidden" id="bulk-attachment-${i}" name="attachment_urls[]">
              </div>
              <small id="bulk-attachment-${i}-status" style="display: block; margin-top: 0.25rem; font-size: 0.75rem;"></small>
            </div>
          </div>
          
          <div id="bulk-quiz-fields-${i}" style="display: none; border-top: 1px dashed var(--border-light); margin-top: 1.5rem; padding-top: 1.5rem;">
            <div class="form-group">
              <label class="form-label">Số lượng câu hỏi trắc nghiệm</label>
              <div style="display: flex; gap: 1rem;">
                <input type="number" id="bulk-quiz-count-${i}" min="1" max="50" value="5" class="form-control" style="width: 150px; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
                <button type="button" class="btn btn-outline" onclick="generateBulkQuizTabs(${i})" style="padding: 0.5rem 1.25rem; border-radius: 8px;">Tạo bộ câu hỏi</button>
              </div>
            </div>
            <div id="bulk-quiz-tabs-container-${i}" style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; overflow-x: auto; padding-bottom: 0.5rem;"></div>
            <div id="bulk-quiz-pages-container-${i}"></div>
          </div>
        `;
        pagesContainer.appendChild(page);
        
        // Đăng ký sự kiện kéo thả cho các ô Upload mới sinh ra
        setTimeout(() => {
          setupDragAndDrop(`bulk-video-zone-${i}`, `bulk-video-${i}`, 'video');
          setupDragAndDrop(`bulk-attachment-zone-${i}`, `bulk-attachment-${i}`, 'attachment');
        }, 100);
      }
      
      document.getElementById('bulk-wizard-form').style.display = 'block';
    }

    function switchBulkTab(activeIndex, total) {
      for (let i = 1; i <= total; i++) {
        const tab = document.getElementById(`bulk-tab-${i}`);
        const page = document.getElementById(`bulk-page-${i}`);
        if (i === activeIndex) {
          tab.className = 'btn btn-primary';
          tab.style.border = 'none';
          tab.style.color = '#fff';
          page.style.display = 'block';
        } else {
          tab.className = 'btn btn-outline';
          tab.style.border = '1px solid #cbd5e1';
          tab.style.color = '#64748b';
          page.style.display = 'none';
        }
      }
    }

    function toggleBulkQuizFields(val, index) {
      const isQuiz = (val === 'quiz');
      document.getElementById(`bulk-theory-fields-${index}`).style.display = isQuiz ? 'none' : 'block';
      const quizFields = document.getElementById(`bulk-quiz-fields-${index}`);
      if (quizFields) {
        quizFields.style.display = isQuiz ? 'block' : 'none';
      }
    }

    function generateBulkQuizTabs(lessonIndex) {
      const count = parseInt(document.getElementById(`bulk-quiz-count-${lessonIndex}`).value);
      if (isNaN(count) || count < 1 || count > 50) {
        alert("Vui lòng nhập số lượng câu từ 1 đến 50");
        return;
      }
      
      const tabsContainer = document.getElementById(`bulk-quiz-tabs-container-${lessonIndex}`);
      const pagesContainer = document.getElementById(`bulk-quiz-pages-container-${lessonIndex}`);
      
      tabsContainer.innerHTML = '';
      pagesContainer.innerHTML = '';
      
      for (let j = 1; j <= count; j++) {
        // Tab con
        const tab = document.createElement('button');
        tab.type = 'button';
        tab.className = `btn ${j === 1 ? 'btn-primary' : 'btn-outline'}`;
        tab.style.padding = '0.25rem 0.65rem';
        tab.style.borderRadius = '20px';
        tab.style.fontSize = '0.85rem';
        if (j !== 1) {
          tab.style.border = '1px solid #cbd5e1';
          tab.style.color = '#64748b';
        }
        tab.innerText = `Câu ${j}`;
        tab.onclick = () => switchNestedQuizTab(lessonIndex, j, count);
        tab.id = `nested-quiz-tab-${lessonIndex}-${j}`;
        tabsContainer.appendChild(tab);
        
        // Page con
        const page = document.createElement('div');
        page.id = `nested-quiz-page-${lessonIndex}-${j}`;
        page.style.display = j === 1 ? 'block' : 'none';
        page.style.background = '#f8fafc';
        page.style.border = '1px solid #e2e8f0';
        page.style.borderRadius = '8px';
        page.style.padding = '1rem';
        
        page.innerHTML = `
          <h6 style="margin-top: 0; margin-bottom: 0.75rem; color: #475569;">Nội dung Câu ${j}</h6>
          <div class="form-group" style="margin-bottom: 0.75rem;">
            <textarea name="q_text_${lessonIndex}[]" placeholder="Nhập câu hỏi..." required rows="2" class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;"></textarea>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
            <input type="text" name="q_optA_${lessonIndex}[]" placeholder="A" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            <input type="text" name="q_optB_${lessonIndex}[]" placeholder="B" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            <input type="text" name="q_optC_${lessonIndex}[]" placeholder="C" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
            <input type="text" name="q_optD_${lessonIndex}[]" placeholder="D" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem;">
          </div>
          <div class="form-group" style="margin-top: 0.75rem; margin-bottom: 0;">
            <select name="q_correct_${lessonIndex}[]" required class="form-control" style="width: 100%; border: 1px solid var(--border-light); border-radius: 8px; padding: 0.5rem; background: #ecfdf5; color: #059669; font-weight: 600;">
              <option value="A">Đáp án đúng là A</option>
              <option value="B">Đáp án đúng là B</option>
              <option value="C">Đáp án đúng là C</option>
              <option value="D">Đáp án đúng là D</option>
            </select>
          </div>
        `;
        pagesContainer.appendChild(page);
      }
    }

    function switchNestedQuizTab(lessonIndex, activeJ, totalJ) {
      for (let j = 1; j <= totalJ; j++) {
        const tab = document.getElementById(`nested-quiz-tab-${lessonIndex}-${j}`);
        const page = document.getElementById(`nested-quiz-page-${lessonIndex}-${j}`);
        if (j === activeJ) {
          tab.className = 'btn btn-primary';
          tab.style.border = 'none';
          tab.style.color = '#fff';
          page.style.display = 'block';
        } else {
          tab.className = 'btn btn-outline';
          tab.style.border = '1px solid #cbd5e1';
          tab.style.color = '#64748b';
          page.style.display = 'none';
        }
      }
    }

    function switchChapterMode(mode) {
      const formSingle = document.getElementById('form-chapter-single');
      const formBulk = document.getElementById('form-chapter-bulk');
      const tabSingle = document.getElementById('tab-chapter-single');
      const tabBulk = document.getElementById('tab-chapter-bulk');
      
      if (mode === 'single') {
        formSingle.style.display = 'block';
        formBulk.style.display = 'none';
        tabSingle.style.color = '#4f46e5';
        tabSingle.style.borderBottom = '2px solid #4f46e5';
        tabBulk.style.color = 'var(--text-muted)';
        tabBulk.style.borderBottom = 'none';
      } else {
        formSingle.style.display = 'none';
        formBulk.style.display = 'block';
        tabBulk.style.color = '#4f46e5';
        tabBulk.style.borderBottom = '2px solid #4f46e5';
        tabSingle.style.color = 'var(--text-muted)';
        tabSingle.style.borderBottom = 'none';
      }
    }

    function switchLessonMode(mode) {
      const formSingle = document.getElementById('form-lesson-single');
      const formBulk = document.getElementById('form-lesson-bulk');
      const tabSingle = document.getElementById('tab-lesson-single');
      const tabBulk = document.getElementById('tab-lesson-bulk');
      
      if (mode === 'single') {
        formSingle.style.display = 'block';
        formBulk.style.display = 'none';
        tabSingle.style.color = '#4f46e5';
        tabSingle.style.borderBottom = '2px solid #4f46e5';
        tabBulk.style.color = 'var(--text-muted)';
        tabBulk.style.borderBottom = 'none';
      } else {
        formSingle.style.display = 'none';
        formBulk.style.display = 'block';
        tabBulk.style.color = '#4f46e5';
        tabBulk.style.borderBottom = '2px solid #4f46e5';
        tabSingle.style.color = 'var(--text-muted)';
        tabSingle.style.borderBottom = 'none';
      }
    }

    // Các hàm điều khiển Modal - Chương
    function openAddChapterModal() {
      document.getElementById('add-chapter-modal').style.display = 'block';
      document.getElementById('modal-overlay').style.display = 'block';
    }
    function closeAddChapterModal() {
      document.getElementById('add-chapter-modal').style.display = 'none';
      document.getElementById('modal-overlay').style.display = 'none';
    }
    function openEditChapterModal(id, title, desc, order) {
      document.getElementById('edit-chapter-form').action = `/course-management/<%= course.id %>/chapters/${id}/update`;
      document.getElementById('edit-chapter-title').value = title;
      document.getElementById('edit-chapter-desc').value = desc;
      document.getElementById('edit-chapter-order').value = order;
      document.getElementById('edit-chapter-modal').style.display = 'block';
      document.getElementById('modal-overlay').style.display = 'block';
    }
    function closeEditChapterModal() {
      document.getElementById('edit-chapter-modal').style.display = 'none';
      document.getElementById('modal-overlay').style.display = 'none';
    }

    // Các hàm điều khiển Modal - Bài học
    function openAddLessonModal(chapterId) {
      document.getElementById('add-lesson-chapter-id').value = chapterId;
      document.getElementById('add-lesson-chapter-id-bulk').value = chapterId;
      document.getElementById('add-lesson-modal').style.display = 'block';
      document.getElementById('modal-overlay').style.display = 'block';
    }

    function closeAddLessonModal() {
      document.getElementById('add-lesson-modal').style.display = 'none';
      document.getElementById('modal-overlay').style.display = 'none';
    }

    function openEditLessonModal(chapterId, id, title, content, video, attachment, order, isQuiz) {
      document.getElementById('edit-lesson-chapter-id').value = chapterId;
      document.getElementById('edit-lesson-form').action = `/course-management/<%= course.id %>/lessons/${id}/update`;
      document.getElementById('edit-lesson-title').value = title || '';
      document.getElementById('edit-lesson-content').value = content || '';
      
      // Gán giá trị vào các thẻ input ẩn
      document.getElementById('edit-lesson-video').value = video || '';
      document.getElementById('edit-lesson-attachment').value = attachment || '';
      
      // Cập nhật thông báo văn bản hiển thị
      document.getElementById('edit-lesson-video-text').innerHTML = video 
        ? `Đã chọn: <strong style="color: #10b981;">${video.split('/').pop()}</strong>` 
        : 'Kéo thả tệp video (.mp4) hoặc click để thay đổi';
      document.getElementById('edit-lesson-attachment-text').innerHTML = attachment 
        ? `Đã chọn: <strong style="color: #10b981;">${attachment.split('/').pop()}</strong>` 
        : 'Kéo thả tài liệu (.pdf, .zip) hoặc click để thay đổi';
        
      document.getElementById('edit-lesson-order').value = order || '';

      const isQuizVal = isQuiz === 'true' || isQuiz === true;
      document.getElementById('edit-lesson-type').value = isQuizVal ? 'quiz' : 'theory';
      toggleQuizFields(isQuizVal ? 'quiz' : 'theory', 'edit');

      document.getElementById('edit-lesson-modal').style.display = 'block';
      document.getElementById('modal-overlay').style.display = 'block';
    }

    function closeEditLessonModal() {
      document.getElementById('edit-lesson-modal').style.display = 'none';
      document.getElementById('modal-overlay').style.display = 'none';
    }

    function closeAllModals() {
      closeAddLessonModal();
      closeEditLessonModal();
      closeAddChapterModal();
      closeEditChapterModal();
    }

    // Khởi động sự kiện kéo thả tệp và giá trị ban đầu
    document.addEventListener('DOMContentLoaded', () => {
      toggleQuizFields('false', 'add');
      setupDragAndDrop('add-lesson-video-zone', 'add-lesson-video', 'video');
      setupDragAndDrop('add-lesson-attachment-zone', 'add-lesson-attachment', 'attachment');
      setupDragAndDrop('edit-lesson-video-zone', 'edit-lesson-video', 'video');
      setupDragAndDrop('edit-lesson-attachment-zone', 'edit-lesson-attachment', 'attachment');
    });

    async function uploadFile(file, inputId, fileType) {
      if (fileType === 'video' && !file.type.startsWith('video/')) {
        alert('Vui lòng chỉ kéo thả tệp tin Video vào ô này.');
        return;
      }
      
      const statusEl = document.getElementById(inputId + '-status');
      const textEl = document.getElementById(inputId + '-text');
      
      if (statusEl) {
        statusEl.style.color = '#4f46e5';
        statusEl.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang tải tệp "${file.name}" lên máy chủ...`;
      }
      
      const formData = new FormData();
      formData.append('file', file);
      
      try {
        const response = await fetch('/course-management/upload', {
          method: 'POST',
          body: formData
        });
        const data = await response.json();
        
        if (data.success && data.filePath) {
          document.getElementById(inputId).value = data.filePath;
          
          if (textEl) {
            textEl.innerHTML = `Đã chọn: <strong style="color: #10b981;">${data.fileName}</strong>`;
          }
          
          if (statusEl) {
            statusEl.style.color = '#10b981';
            statusEl.innerHTML = `<i class="fa-solid fa-circle-check"></i> Tải lên thành công!`;
          }
        } else {
          throw new Error(data.error || 'Có lỗi xảy ra khi tải lên.');
        }
      } catch (error) {
        console.error('Lỗi tải tệp:', error);
        if (statusEl) {
          statusEl.style.color = '#ef4444';
          statusEl.innerHTML = `❌ Lỗi: ${error.message}`;
        }
        alert('Tải tệp thất bại: ' + error.message);
      }
    }

    function triggerFileUpload(inputId, fileType) {
      const fileInput = document.createElement('input');
      fileInput.type = 'file';
      if (fileType === 'video') {
        fileInput.accept = 'video/*';
      } else {
        fileInput.accept = '.pdf,.ppt,.pptx,.doc,.docx,.xls,.xlsx,.zip,.rar,image/*';
      }

      fileInput.onchange = () => {
        if (fileInput.files.length === 0) return;
        uploadFile(fileInput.files[0], inputId, fileType);
      };

      fileInput.click();
    }

    function setupDragAndDrop(zoneId, inputId, fileType) {
      const zoneEl = document.getElementById(zoneId);
      const inputEl = document.getElementById(inputId);
      if (!zoneEl || !inputEl) return;

      const originalBorder = zoneEl.style.borderColor || '';
      const originalBg = zoneEl.style.backgroundColor || '';

      ['dragenter', 'dragover'].forEach(eventName => {
        zoneEl.addEventListener(eventName, (e) => {
          e.preventDefault();
          e.stopPropagation();
          zoneEl.style.borderColor = '#4f46e5';
          zoneEl.style.borderStyle = 'dashed';
          zoneEl.style.backgroundColor = 'rgba(79, 70, 229, 0.04)';
        }, false);
      });

      ['dragleave', 'drop'].forEach(eventName => {
        zoneEl.addEventListener(eventName, (e) => {
          e.preventDefault();
          e.stopPropagation();
          zoneEl.style.borderColor = originalBorder;
          zoneEl.style.borderStyle = 'dashed';
          zoneEl.style.backgroundColor = originalBg;
        }, false);
      });

      zoneEl.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const files = dt.files;
        if (files.length > 0) {
          uploadFile(files[0], inputId, fileType);
        }
      }, false);
    }
  </script>

