<%- include('partials/header') %>

<div style="display: flex; justify-content: center; align-items: center; min-height: 50vh; padding: 2rem;">
  <div class="glass-card" style="max-width: 500px; text-align: center; border-color: rgba(239, 68, 68, 0.3); box-shadow: 0 4px 30px rgba(239, 68, 68, 0.1);">
    <i class="fa-solid fa-circle-exclamation fa-4x" style="color: #ef4444; margin-bottom: 1.5rem; animation: pulse 2s infinite;"></i>
    <h2 style="font-size: 1.6rem; font-weight: 800; margin-bottom: 1rem; color: #fca5a5;">Gặp Sự Cố Hệ Thống</h2>
    <p style="color: var(--text-muted); margin-bottom: 2rem; font-size: 0.95rem; line-height: 1.6;">
      <%= message %>
    </p>
    <div style="display: flex; gap: 1rem; justify-content: center;">
      <a href="/dashboard" class="btn btn-primary" style="padding: 0.6rem 1.5rem; font-size: 0.9rem;">
        <i class="fa-solid fa-house"></i> Quay lại trang chủ
      </a>
      <button class="btn btn-secondary" onclick="window.history.back()" style="padding: 0.6rem 1.5rem; font-size: 0.9rem;">
        <i class="fa-solid fa-arrow-left"></i> Quay lại
      </button>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
