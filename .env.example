# Tên dự án Docker Compose
COMPOSE_PROJECT_NAME=lms-course

# Cấu hình Cổng máy chủ
PORT=3000

# Cấu hình Kết nối PostgreSQL
# Khi chạy trong Docker Compose, địa chỉ máy chủ db sẽ là tên service 'db'.
DATABASE_URL=postgresql://postgres:123456@db:5432/postgres

# Cấu hình Kết nối Redis
# Khi chạy trong Docker Compose, địa chỉ máy chủ redis sẽ là tên service 'redis'.
REDIS_URL=redis://redis:6379

# Khóa bảo mật Session (Nên đổi thành một chuỗi ngẫu nhiên bảo mật trên production)
SESSION_SECRET=thay_the_bang_khoa_bao_mat_cua_ban_12345

# Cấu hình SMTP gửi Email OTP (Sử dụng Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM="Hệ thống LMS <your_email@gmail.com>"
